########################################
# Global / OS / Editor
########################################
.env
.DS_Store
Thumbs.db
System Volume Information/
*.swp
*.swo
*.tmp

########################################
# Invidious: ignore entire folder
########################################
invidious/

########################################
# Home Assistant: keep YAML config, ignore secrets + runtime
########################################
# Secrets / tokens / keys
homeassistant/config/home-assistant/secrets.yaml
homeassistant/config/home-assistant/secrets.yaml.example
homeassistant/config/home-assistant/*.key
homeassistant/config/home-assistant/*.pem
homeassistant/config/home-assistant/*.crt

# Logs / runtime
homeassistant/config/home-assistant/home-assistant.log*
homeassistant/config/home-assistant/*.log
homeassistant/config/home-assistant/.storage/
homeassistant/config/home-assistant/.cloud/
homeassistant/config/home-assistant/tts/
homeassistant/config/home-assistant/backup/
homeassistant/config/home-assistant/backups/

# Python cache (you already hit this via HACS)
__pycache__/
*.pyc

# Zigbee2MQTT: keep config yaml, ignore DB + logs + temp
homeassistant/config/zigbee2mqtt/database.db
homeassistant/config/zigbee2mqtt/log/
homeassistant/config/zigbee2mqtt/configuration.yaml.tmp

########################################
# Node-RED: keep flows/settings, ignore runtime & dependencies
########################################
**/node_modules/
**/.npm/
**/.node-red/
homeassistant/nodered/.config.runtime.json
homeassistant/nodered/.sessions.json
monitoring/nodered/.config.runtime.json

# If you export flows to JSON files, keep them.
# (No ignore rule needed; just make sure they exist as files you commit.)

########################################
# Monitoring stack
########################################
# Prometheus: keep prometheus.yml, ignore tokens and data
monitoring/prometheus/*.token
monitoring/prom-data/
monitoring/prometheus/data/
monitoring/prometheus/wal/
monitoring/prometheus/lock

# Grafana: keep dashboard exports, ignore db/plugins/cache
monitoring/grafana/grafana.db
monitoring/grafana/plugins/
monitoring/grafana/png/
monitoring/grafana/pdf/
# Keep JSON exports:
!monitoring/grafana/**/*.json

# Uptime Kuma: ignore db + uploads + runtime
monitoring/uptime-kuma/
monitoring/uptime-kuma/*.db*
monitoring/uptime-kuma/upload/
monitoring/uptime-kuma/screenshots/
monitoring/uptime-kuma/error.log

# AdGuard: ignore runtime working data
monitoring/adguard/work/

########################################
# Jellyfin: keep compose, ignore media + logs + cache
########################################
jellyfin/config/log/
jellyfin/config/.cache/
jellyfin/movies/
jellyfin/tvseries/

########################################
# Qbittorrent: ignore app state + downloads + logs
########################################
qbittorrent/appdata/
qbittorrent/downloads/
**/qbittorrent.log

########################################
# PhotoPrism: ignore media + DB storage
########################################
photoprism/database/
photoprism/media/
photoprism/storage/cache/
photoprism/storage/sidecar/
photoprism/storage/backup/
photoprism/storage/users/
photoprism/storage/serial/

########################################
# CouchDB livesync: keep config, ignore data
########################################
couchdb-livesync/data/

########################################
# Generic database / state directories (safety net)
########################################
**/*.db
**/*.db-shm
**/*.db-wal
**/wal/
**/chunks_head/
**/lock
**/queries.active
**/*-journal

########################################
# Backups / exports / large binaries
########################################
**/*.bak
**/*.zip
**/*.tar
**/*.tar.gz
**/*.7z
**/*.iso
