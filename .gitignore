invidious/

# Jellyfin
jellyfin/config/.cache/
jellyfin/config/cache/
jellyfin/config/data/
jellyfin/config/log/
jellyfin/movies/
jellyfin/tvseries/

# PhotoPrism
photoprism/database/
photoprism/media/
photoprism/storage/

# qBittorrent
qbittorrent/appdata/
