############################################
# Secrets / env
############################################
.env
**/*.token
**/*.key
**/*.pem

############################################
# OS / editor junk
############################################
.DS_Store
Thumbs.db
System Volume Information/

############################################
# Home Assistant (keep YAML, ignore state)
############################################
homeassistant/config/home-assistant/.storage/
homeassistant/config/home-assistant/secrets.yaml
homeassistant/config/home-assistant/secrets.yaml.example
homeassistant/config/home-assistant/home-assistant.log*
homeassistant/config/home-assistant/home-assistant_v2.db*
homeassistant/config/home-assistant/custom_components/
homeassistant/store/

# Mosquitto
homeassistant/config/mosquitto/passwd

# Zigbee2MQTT (state + DB + temp)
homeassistant/config/zigbee2mqtt/configuration.yaml.tmp
homeassistant/config/zigbee2mqtt/database.db
homeassistant/config/zigbee2mqtt/log/
homeassistant/config/zigbee2mqtt/state.json
homeassistant/config/zigbee2mqtt/coordinator_backup.json

# Node-RED (HA stack)
homeassistant/nodered/.npm/
homeassistant/nodered/node_modules/
homeassistant/nodered/.sessions.json
homeassistant/nodered/.config.runtime.json
homeassistant/nodered/.config.nodes.json
homeassistant/nodered/settings.js.bak

############################################
# Monitoring stack
############################################
monitoring/prom-data/
monitoring/grafana/
monitoring/uptime-kuma/
monitoring/prometheus/*.token
monitoring/prometheus/hass.token
monitoring/prometheus/kuma.token

# Node-RED (monitoring stack)
monitoring/nodered/.npm/
monitoring/nodered/node_modules/
monitoring/nodered/.config.runtime.json
monitoring/nodered/.config.nodes.json

# AdGuard
monitoring/adguard/work/

############################################
# Media services (big data / caches)
############################################
