#################################################################
# Global OS / Editor / Temp
#################################################################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~
*.tmp
*.bak
*.orig
*.log

#################################################################
# Secrets / Environment
#################################################################
.env
.env.*
!.env.example
**/*.token
**/hass.token
**/kuma.token
**/*secret*
**/*secrets*
**/*apikey*
**/*api_key*
**/*password*
**/*passwd*
**/*key*
**/*private*

#################################################################
# Docker / Compose misc
#################################################################
**/.docker/
**/docker-tls/
**/*-tls/
**/*cert*
**/*certs*

#################################################################
# Monitoring stack (Prometheus / Grafana / Uptime Kuma)
#################################################################
# Prometheus TSDB data (huge)
monitoring/prom-data/
monitoring/prom-data/**

# Grafana local state
monitoring/grafana/grafana.db
monitoring/grafana/plugins/
monitoring/grafana/plugins/**
monitoring/grafana/png/
monitoring/grafana/png/**
monitoring/grafana/pdf/
monitoring/grafana/pdf/**
monitoring/grafana/csv/
monitoring/grafana/csv/**

# Uptime Kuma DB + uploads
monitoring/uptime-kuma/kuma.db
monitoring/uptime-kuma/kuma.db-shm
monitoring/uptime-kuma/kuma.db-wal
monitoring/uptime-kuma/upload/
monitoring/uptime-kuma/upload/**
monitoring/uptime-kuma/screenshots/
monitoring/uptime-kuma/screenshots/**
monitoring/uptime-kuma/error.log
monitoring/uptime-kuma/error.log.*

#################################################################
# Node-RED (both homeassistant/ and monitoring/)
#################################################################
**/node_modules/
**/node_modules/**
**/.npm/
**/.cache/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Optional: ignore Node-RED runtime state if it appears
**/.node-red/
**/.node-red/**

#################################################################
# Home Assistant / Zigbee2MQTT / Mosquitto
#################################################################
# Keep your YAML + configs, but ignore runtime DBs, backups, and caches
homeassistant/config/**/.storage/
homeassistant/config/**/.storage/**
homeassistant/config/**/.cloud/
homeassistant/config/**/.cloud/**
homeassistant/config/**/backup/
homeassistant/config/**/backup/**
homeassistant/config/**/backups/
homeassistant/config/**/backups/**
homeassistant/config/**/home-assistant.log*
homeassistant/config/**/home-assistant_v2.db*
homeassistant/config/**/home-assistant_v2.db-shm
homeassistant/config/**/home-assistant_v2.db-wal

# Zigbee2MQTT runtime artifacts (keep configuration.yaml)
homeassistant/config/zigbee2mqtt/data/database.db
homeassistant/config/zigbee2mqtt/data/database.db-shm
homeassistant/config/zigbee2mqtt/data/database.db-wal
homeassistant/config/zigbee2mqtt/data/log/
homeassistant/config/zigbee2mqtt/data/log/**
homeassistant/config/zigbee2mqtt/data/state.json

# Mosquitto persistence/logs if you use them
homeassistant/config/mosquitto/data/
homeassistant/config/mosquitto/data/**
homeassistant/config/mosquitto/log/
homeassistant/config/mosquitto/log/**

#################################################################
# Databases / App data (do NOT commit)
#################################################################
# MariaDB data stores
homeassistant/store/mariadb/
homeassistant/store/mariadb/**
photoprism/database/
photoprism/database/**
couchdb-livesync/data/
couchdb-livesync/data/**
couchdb-livesync/data/**

# CouchDB node/metadata files (if they appear)
**/couchdb*.db
**/*.couch
**/*.couchdb

#################################################################
# Media libraries / Downloads (very large)
#################################################################
jellyfin/movies/
jellyfin/movies/**
jellyfin/tvseries/
jellyfin/tvseries/**
photoprism/media/
photoprism/media/**
photoprism/storage/
photoprism/storage/**
qbittorrent/downloads/
qbittorrent/downloads/**
invidious/

#################################################################
# Jellyfin runtime (cache/log/data are huge + host-specific)
#################################################################
jellyfin/config/cache/
jellyfin/config/cache/**
jellyfin/config/log/
jellyfin/config/log/**
jellyfin/config/data/
jellyfin/config/data/**

#################################################################
# System / external drive artifacts
#################################################################
System Volume Information/
System Volume Information/**
$RECYCLE.BIN/
$RECYCLE.BIN/**
