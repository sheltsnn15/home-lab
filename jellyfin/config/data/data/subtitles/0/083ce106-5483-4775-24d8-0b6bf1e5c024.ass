Dialogue: 0,0:00:00.00,0:00:02.95,Default,,0,0,0,,TẬP 48: THI HÀNH
Dialogue: 0,0:03:38.08,0:03:43.98,Default,,0,0,0,,CHÚ THUẬT HỒI CHIẾN TỬ DIỆT HỒI DU
Dialogue: 0,0:04:18.55,0:04:22.60,Default,,0,0,0,,CHÚ THUẬT HỒI CHIẾN TỬ DIỆT HỒI DU PHẦN 1
Dialogue: 0,0:05:15.74,0:05:17.50,Default,,0,0,0,,Vậy là con bé Mai đó...
Dialogue: 0,0:05:18.49,0:05:19.21,Default,,0,0,0,,chết rồi à?
Dialogue: 0,0:05:20.88,0:05:23.00,Default,,0,0,0,,Giờ nên lo cho tộc trưởng thì hơn.
Dialogue: 0,0:05:23.29,0:05:25.51,Default,,0,0,0,,Và người sắp chết là Maki.
Dialogue: 0,0:05:25.77,0:05:28.35,Default,,0,0,0,,Thế à. Mà cũng chẳng sao.
Dialogue: 0,0:05:28.69,0:05:31.31,Default,,0,0,0,,Maki tuy xinh đẹp nhưng không ổn chút nào.
Dialogue: 0,0:05:31.56,0:05:33.48,Default,,0,0,0,,Không biết cách hỗ trợ đàn ông.
Dialogue: 0,0:05:33.68,0:05:37.82,Default,,0,0,0,,Loại đàn bà không nép sau đàn ông ba bước\Nthì bị đâm sau lưng mà chết đi.
Dialogue: 0,0:05:38.67,0:05:41.24,Default,,0,0,0,,Về khoản đó thì Mai lại làm rất tốt.
Dialogue: 0,0:05:41.24,0:05:43.82,Default,,0,0,0,,CHÚ THUẬT SƯ ĐẶC CẤP 1 ZEN'IN NAOYA
Dialogue: 0,0:05:44.24,0:05:47.52,Default,,0,0,0,,Cùng một khuôn mặt,\Ncùng một bộ ngực với Maki.
Dialogue: 0,0:05:47.65,0:05:51.58,Default,,0,0,0,,Dù luôn tỏ ra mạnh mẽ nhưng\Ntrong thâm tâm vẫn biết mình là phụ nữ.
Dialogue: 0,0:05:52.46,0:05:53.75,Default,,0,0,0,,Trễ quá đấy.
Dialogue: 0,0:05:54.08,0:05:55.72,Default,,0,0,0,,Làm gì mà lâu thế?
Dialogue: 0,0:05:55.72,0:05:59.21,Default,,0,0,0,,Cha đẻ mày đang hấp hối đấy.
Dialogue: 0,0:05:59.46,0:06:00.76,Default,,0,0,0,,Xin lỗi.
Dialogue: 0,0:06:01.00,0:06:03.97,Default,,0,0,0,,Nhưng tôi đến hay không\Ncũng đâu quan trọng.
Dialogue: 0,0:06:04.47,0:06:07.51,Default,,0,0,0,,Đằng nào tộc trưởng nhà Zen'in tiếp theo\Ncũng là tôi mà.
Dialogue: 0,0:06:08.66,0:06:11.64,Default,,0,0,0,,Đám anh trai thì toàn một lũ vô tích sự.
Dialogue: 0,0:06:12.34,0:06:13.44,Default,,0,0,0,,Còn chú...
Dialogue: 0,0:06:13.68,0:06:15.98,Default,,0,0,0,,phận làm em mà chẳng tài cán gì.
Dialogue: 0,0:06:16.15,0:06:18.02,Default,,0,0,0,,Con gái chú thì thôi khỏi bàn.
Dialogue: 0,0:06:18.57,0:06:20.44,Default,,0,0,0,,Còn Jinichi thì...
Dialogue: 0,0:06:22.70,0:06:24.50,Default,,0,0,0,,nhìn mặt thấy gớm.
Dialogue: 0,0:06:24.91,0:06:27.37,Default,,0,0,0,,Giá mà đổi được cho Toji thì tốt.
Dialogue: 0,0:06:31.12,0:06:33.87,Default,,0,0,0,,CHÚ THUẬT SƯ ĐẶC CẤP 1 ZEN'IN OGI
Dialogue: 0,0:06:33.87,0:06:35.50,Default,,0,0,0,,CHÚ THUẬT SƯ ĐẶC CẤP 1 ZEN'IN JINICHI
Dialogue: 0,0:06:35.50,0:06:37.88,Default,,0,0,0,,Bố tôi đang hấp hối đấy.
Dialogue: 0,0:06:38.25,0:06:40.00,Default,,0,0,0,,Nhẫn nhịn một chút đi.
Dialogue: 0,0:06:40.92,0:06:42.84,Default,,0,0,0,,Mọi người đông đủ cả rồi chứ?
Dialogue: 0,0:06:45.26,0:06:51.56,Default,,0,0,0,,Cách đây vài phút, tộc trưởng nhà Zeni'in,\Nngài Zen'in Naobito đã qua đời.
Dialogue: 0,0:06:55.64,0:07:00.02,Default,,0,0,0,,Tôi, Furudate, đang giữ di chúc của ngài ấy.
Dialogue: 0,0:07:00.02,0:07:03.65,Default,,0,0,0,,Theo nguyện vọng của ngài,
Dialogue: 0,0:07:04.15,0:07:06.07,Default,,0,0,0,,Zen'in Ogi,
Dialogue: 0,0:07:06.36,0:07:08.37,Default,,0,0,0,,Zen'in Jinichi,
Dialogue: 0,0:07:08.82,0:07:10.70,Default,,0,0,0,,Zen'in Naoya,
Dialogue: 0,0:07:11.23,0:07:16.62,Default,,0,0,0,,khi ba vị có mặt đông đủ,\Ntôi sẽ công bố di chúc.
Dialogue: 0,0:07:17.79,0:07:21.84,Default,,0,0,0,,Nếu không ai phản đối, tôi xin phép đọc.
Dialogue: 0,0:07:28.43,0:07:29.50,Default,,0,0,0,,Thứ nhất,
Dialogue: 0,0:07:29.67,0:07:34.22,Default,,0,0,0,,Zen'in Naoya\Nsẽ là tộc trưởng đời thứ 27 của nhà Zen'in.
Dialogue: 0,0:07:34.89,0:07:36.31,Default,,0,0,0,,Thứ hai,
Dialogue: 0,0:07:36.44,0:07:41.64,Default,,0,0,0,,toàn bộ tài sản, gồm cả chú cụ trong\Nkho cấm Trường Chú Thuật và nhà Zen'in...
Dialogue: 0,0:07:41.64,0:07:44.57,Default,,0,0,0,,sẽ được Naoya kế thừa.
Dialogue: 0,0:07:45.20,0:07:50.66,Default,,0,0,0,,Chỉ khi có sự chấp thuận\Ncủa Zen'in Ogi hoặc Zen'in Jinichi,
Dialogue: 0,0:07:51.20,0:07:54.24,Default,,0,0,0,,Naoya mới có thể sử dụng chúng.
Dialogue: 0,0:07:55.87,0:07:57.37,Default,,0,0,0,,Thôi cũng được.
Dialogue: 0,0:07:57.46,0:07:58.42,Default,,0,0,0,,Tuy nhiên...
Dialogue: 0,0:07:59.21,0:08:02.46,Default,,0,0,0,,nếu vì bất cứ lý do gì\Nmà Gojo Satoru tử vong...
Dialogue: 0,0:08:02.61,0:08:06.11,Default,,0,0,0,,hoặc là mất khả năng nhận thức...
Dialogue: 0,0:08:06.34,0:08:09.89,Default,,0,0,0,,thì phải thực hiện lời thề\Nvới Fushiguro Toji...
Dialogue: 0,0:08:10.14,0:08:13.26,Default,,0,0,0,,là đón Fushiguro Megumi về nhà Zen'in...
Dialogue: 0,0:08:13.26,0:08:15.97,Default,,0,0,0,,với tư cách là trưởng tộc.
Dialogue: 0,0:08:16.43,0:08:19.81,Default,,0,0,0,,Toàn bộ tài sản\Ncũng sẽ chuyển giao cho cậu ta.
Dialogue: 0,0:08:21.66,0:08:22.52,Default,,0,0,0,,Hả?
Dialogue: 0,0:08:22.65,0:08:24.50,Default,,0,0,0,,Đúng là không ổn.
Dialogue: 0,0:08:24.50,0:08:26.19,Default,,0,0,0,,Hai cái tên hèn nhát đó...
Dialogue: 0,0:08:26.36,0:08:30.95,Default,,0,0,0,,Chúng thà để một thằng nhóc lạ hoắc\Nlên làm tộc trưởng thay vì tôi.
Dialogue: 0,0:08:32.34,0:08:35.04,Default,,0,0,0,,Megumi đang ở đâu và làm gì?
Dialogue: 0,0:08:35.33,0:08:36.71,Default,,0,0,0,,Tôi không rõ chi tiết.
Dialogue: 0,0:08:36.71,0:08:40.83,Default,,0,0,0,,Nhưng nghe nói cậu ta đang\Nnhận nhiệm vụ tìm Itadori Yuji ở Tokyo.
Dialogue: 0,0:08:40.83,0:08:41.88,Default,,0,0,0,,Là thằng nào?
Dialogue: 0,0:08:42.33,0:08:44.46,Default,,0,0,0,,Là vật chứa của Sukuna.
Dialogue: 0,0:08:44.46,0:08:46.50,Default,,0,0,0,,Vậy hãy báo với đám bên trên là...
Dialogue: 0,0:08:46.69,0:08:49.88,Default,,0,0,0,,Zen'in Naoya sẽ\Nđi giết vật chứa của Sukuna.
Dialogue: 0,0:08:50.34,0:08:53.35,Default,,0,0,0,,Megumi chắc cũng đang ở cùng nó đúng không?
Dialogue: 0,0:08:53.63,0:08:55.60,Default,,0,0,0,,Tôi giết cả hai cùng lúc luôn.
Dialogue: 0,0:08:56.37,0:08:58.48,Default,,0,0,0,,Giờ Tokyo đang là địa ngục trần gian.
Dialogue: 0,0:08:58.93,0:09:01.85,Default,,0,0,0,,Ai chết lúc nào\Nvà ra sao cũng chẳng quan trọng
Dialogue: 0,0:09:02.44,0:09:05.61,Default,,0,0,0,,Chỉ cần giết chúng xong,\Nchuyện sau đó sẽ đâu vào đấy.
Dialogue: 0,0:09:09.28,0:09:11.53,Default,,0,0,0,,Tộc trưởng nhà Zen'in sẽ là tôi!
Dialogue: 0,0:09:21.23,0:09:22.43,Default,,0,0,0,,Đáng chết...
Dialogue: 0,0:09:22.71,0:09:24.50,Default,,0,0,0,,- Kugisaki.\N- Chỉ có mình đáng chết!
Dialogue: 0,0:09:24.50,0:09:26.04,Default,,0,0,0,,- Nhờ cậu phần còn lại.\N- Chết đi! - Itadori.
Dialogue: 0,0:09:26.06,0:09:27.50,Default,,0,0,0,,Itadori.
Dialogue: 0,0:09:27.50,0:09:28.55,Default,,0,0,0,,Cậu tính làm gì?
Dialogue: 0,0:09:53.49,0:09:54.32,Default,,0,0,0,,Yuji.
Dialogue: 0,0:09:56.06,0:09:57.58,Default,,0,0,0,,Vết thương thế nào?
Dialogue: 0,0:09:59.09,0:10:02.50,Default,,0,0,0,,Ngoài chỗ bị Hắc Thiểm đánh trúng\Nthì tạm ổn.
Dialogue: 0,0:10:04.12,0:10:06.09,Default,,0,0,0,,Có lẽ do ảnh hưởng của Sukuna.
Dialogue: 0,0:10:06.62,0:10:09.42,Default,,0,0,0,,Tôi có thể cảm thấy\Nsức mạnh của hắn đang lớn dần.
Dialogue: 0,0:10:10.83,0:10:11.68,Default,,0,0,0,,Yuji,
Dialogue: 0,0:10:11.84,0:10:13.50,Default,,0,0,0,,đừng lo cho anh.
Dialogue: 0,0:10:13.68,0:10:15.72,Default,,0,0,0,,Cứ trở về Trường Chú Thuật đi.
Dialogue: 0,0:10:16.56,0:10:19.68,Default,,0,0,0,,Anh cũng muốn đi thu hồi\Nthi thể của đám Shoso.
Dialogue: 0,0:10:21.10,0:10:22.52,Default,,0,0,0,,Ai lo cho anh chứ.
Dialogue: 0,0:10:23.10,0:10:25.69,Default,,0,0,0,,Không phải vấn đề tôi muốn về hay không.
Dialogue: 0,0:10:26.64,0:10:29.65,Default,,0,0,0,,Sukuna đang muốn lợi dụng Fushiguro\Nlàm gì đó.
Dialogue: 0,0:10:30.32,0:10:33.90,Default,,0,0,0,,Và tôi đã giết quá nhiều người.
Dialogue: 0,0:10:34.82,0:10:38.66,Default,,0,0,0,,Nếu người mà cậu cứu\Ngiết người trong tương lai thì sao?
Dialogue: 0,0:10:40.04,0:10:43.00,Default,,0,0,0,,Tôi không thể ở bên mọi người nữa.
Dialogue: 0,0:10:44.04,0:10:48.00,Default,,0,0,0,,Còn anh, không thấy bận tâm sao?\NTôi đã giết em trai anh đấy.
Dialogue: 0,0:10:48.13,0:10:50.42,Default,,0,0,0,,Không sao. Đó là chuyện ngoài ý muốn.
Dialogue: 0,0:10:50.63,0:10:54.55,Default,,0,0,0,,Nếu đứng ở vị trí của anh,\NEso và Kechizu cũng sẽ làm như vậy.
Dialogue: 0,0:10:55.13,0:10:57.18,Default,,0,0,0,,Không phải vấn đề tha thứ\Nhay không tha thứ.
Dialogue: 0,0:10:57.59,0:10:59.81,Default,,0,0,0,,Anh em là như vậy.
Dialogue: 0,0:11:03.10,0:11:04.23,Default,,0,0,0,,Đi thôi.
Dialogue: 0,0:11:04.64,0:11:06.98,Default,,0,0,0,,Trước hết phải\Nlàm giảm số lượng chú linh đã.
Dialogue: 0,0:12:59.38,0:13:00.13,Default,,0,0,0,,Choso!
Dialogue: 0,0:13:07.85,0:13:08.81,Default,,0,0,0,,Yuji.
Dialogue: 0,0:13:21.03,0:13:22.99,Default,,0,0,0,,Đáng sợ thật.
Dialogue: 0,0:13:23.24,0:13:26.33,Default,,0,0,0,,Lúc chiến đấu với Yuji,\Nmình đã thấy nó rất mạnh mẽ.
Dialogue: 0,0:13:26.66,0:13:29.00,Default,,0,0,0,,Giờ còn thêm cả độ tinh vi nữa.
Dialogue: 0,0:13:29.53,0:13:33.08,Default,,0,0,0,,Điều khiển chú thuật điêu luyện,\Nlực tay phi phàm.
Dialogue: 0,0:13:35.84,0:13:37.50,Default,,0,0,0,,Thật sự là quỷ thần.
Dialogue: 0,0:13:37.80,0:13:40.76,Default,,0,0,0,,Chưa hồi phục hoàn toàn mà đã thế này.
Dialogue: 0,0:13:42.53,0:13:45.05,Default,,0,0,0,,Đúng là em trai anh.
Dialogue: 0,0:13:45.26,0:13:46.72,Default,,0,0,0,,Vẫn còn nói thế à?
Dialogue: 0,0:13:47.85,0:13:49.27,Default,,0,0,0,,Anh sẽ còn nói nhiều lần nữa.
Dialogue: 0,0:13:49.85,0:13:50.98,Default,,0,0,0,,Hãy nhớ lại đi.
Dialogue: 0,0:13:50.98,0:13:52.60,Default,,0,0,0,,Chắc chắn cha em...
Dialogue: 0,0:13:55.98,0:13:59.32,Default,,0,0,0,,cũng có một vết khâu trên trán đúng không?
Dialogue: 0,0:14:01.78,0:14:03.49,Default,,0,0,0,,Không thấy Megumi.
Dialogue: 0,0:14:03.95,0:14:05.53,Default,,0,0,0,,Mình đến đầu tiên à?
Dialogue: 0,0:14:05.53,0:14:06.83,Default,,0,0,0,,Vậy mà cũng được sao?
Dialogue: 0,0:14:06.83,0:14:07.95,Default,,0,0,0,,Chậm thật.
Dialogue: 0,0:14:08.66,0:14:10.04,Default,,0,0,0,,Tên nào thế kia?
Dialogue: 0,0:14:10.33,0:14:12.37,Default,,0,0,0,,Vừa nhắc đến Fushiguro sao?
Dialogue: 0,0:14:12.75,0:14:14.54,Default,,0,0,0,,Các ngươi làm gì thế?
Dialogue: 0,0:14:14.54,0:14:17.21,Default,,0,0,0,,Lộ liễu quá đấy. Không định chạy trốn sao?
Dialogue: 0,0:14:17.84,0:14:18.92,Default,,0,0,0,,Chạy trốn?
Dialogue: 0,0:14:19.30,0:14:20.63,Default,,0,0,0,,Ủa, không biết à?
Dialogue: 0,0:14:21.21,0:14:23.05,Default,,0,0,0,,Ngươi đã bị kết án tử hình.
Dialogue: 0,0:14:23.47,0:14:26.14,Default,,0,0,0,,Đã không còn sự hậu thuẫn của Satoru rồi.
Dialogue: 0,0:14:29.01,0:14:30.77,Default,,0,0,0,,Vì sự tùy hứng và tùy tiện của Gojo
Dialogue: 0,0:14:30.85,0:14:34.31,Default,,0,0,0,,mà rất nhiều thuật sư đã được cứu đấy.
Dialogue: 0,0:14:34.48,0:14:37.15,Default,,0,0,0,,Người ta cần tìm là Megumi.
Dialogue: 0,0:14:37.15,0:14:40.07,Default,,0,0,0,,Nói thật, các ngươi sống chết\Nkhông quan trọng.
Dialogue: 0,0:14:40.07,0:14:42.36,Default,,0,0,0,,Nhưng cũng không muốn bị ngáng đường...
Dialogue: 0,0:14:42.36,0:14:44.95,Default,,0,0,0,,nên chắc cứ đánh gãy chân ngươi trước vậy.
Dialogue: 0,0:14:45.36,0:14:47.37,Default,,0,0,0,,Tìm Fushiguro có việc gì?
Dialogue: 0,0:14:47.37,0:14:49.50,Default,,0,0,0,,Ta cần hắn phải chết.
Dialogue: 0,0:14:49.78,0:14:53.08,Default,,0,0,0,,Nhưng nếu nó chịu viết vài dòng\Ntrước khi chết thì tốt.
Dialogue: 0,0:14:53.46,0:14:55.87,Default,,0,0,0,,Nghe nói Megumi đang tìm ngươi.
Dialogue: 0,0:15:16.52,0:15:19.48,Default,,0,0,0,,Nhanh thì nhanh thật,\Nnhưng có gì đó lạ lắm.
Dialogue: 0,0:15:19.81,0:15:21.32,Default,,0,0,0,,Chắc là thuật thức.
Dialogue: 0,0:15:21.52,0:15:23.86,Default,,0,0,0,,Khá hơn ta nghĩ đấy.
Dialogue: 0,0:15:24.24,0:15:25.95,Default,,0,0,0,,Đã đánh giá thấp các ngươi rồi.
Dialogue: 0,0:15:26.54,0:15:28.82,Default,,0,0,0,,Nó là vật chứa nên cũng dễ hiểu.
Dialogue: 0,0:15:28.82,0:15:30.53,Default,,0,0,0,,Còn thứ đứng bên cạnh là ai?
Dialogue: 0,0:15:30.87,0:15:33.24,Default,,0,0,0,,Tăng tốc thêm một chút xem vậy.
Dialogue: 0,0:15:39.38,0:15:40.84,Default,,0,0,0,,Thầy Gojo?
Dialogue: 0,0:15:41.13,0:15:43.76,Default,,0,0,0,,Không, là cái gì đó kỳ lạ hơn.
Dialogue: 0,0:15:50.85,0:15:51.89,Default,,0,0,0,,Ủa...
Dialogue: 0,0:15:52.18,0:15:53.60,Default,,0,0,0,,không phải một mình à?
Dialogue: 0,0:15:56.14,0:15:58.94,Default,,0,0,0,,CHÚ THUẬT HỒI CHIẾN - TỬ DIỆT HỒI DU\NPHẦN ĐẦU
Dialogue: 0,0:15:59.96,0:16:00.52,Default,,0,0,0,,Ai vậy?
Dialogue: 0,0:16:00.69,0:16:02.82,Default,,0,0,0,,Dù là ai, mục đích cũng là...
Dialogue: 0,0:16:02.82,0:16:05.82,Default,,0,0,0,,Ngươi là gì của Itadori?
Dialogue: 0,0:16:06.50,0:16:09.28,Default,,0,0,0,,Quả nhiên là kẻ đến\Nthi hành án tử với Yuji à?
Dialogue: 0,0:16:17.80,0:16:19.17,Default,,0,0,0,,Gượm đã.
Dialogue: 0,0:16:19.17,0:16:20.21,Default,,0,0,0,,Tôi là đồng minh nhé.
Dialogue: 0,0:16:20.73,0:16:22.59,Default,,0,0,0,,Cậu là Okkotsu đúng không?
Dialogue: 0,0:16:22.71,0:16:23.92,Default,,0,0,0,,Okkotsu?
Dialogue: 0,0:16:24.05,0:16:25.96,Default,,0,0,0,,Là đàn anh năm hai mà Fushiguro nhắc đến.
Dialogue: 0,0:16:26.38,0:16:29.18,Default,,0,0,0,,Một thuật sư đặc cấp giống thầy Gojo.
Dialogue: 0,0:16:29.72,0:16:30.76,Default,,0,0,0,,Anh là ai?
Dialogue: 0,0:16:30.84,0:16:33.89,Default,,0,0,0,,Zen'in Naoya, anh họ của Maki.
Dialogue: 0,0:16:34.31,0:16:37.06,Default,,0,0,0,,Giống cậu, tôi đến để giết Itadori.
Dialogue: 0,0:16:37.06,0:16:38.18,Default,,0,0,0,,Chuồn thôi, Yuji.
Dialogue: 0,0:16:38.18,0:16:38.98,Default,,0,0,0,,Yên tâm.
Dialogue: 0,0:16:38.98,0:16:39.72,Default,,0,0,0,,Hả?
Dialogue: 0,0:16:39.72,0:16:41.23,Default,,0,0,0,,Tôi sẽ không cản trở cậu đâu.
Dialogue: 0,0:16:41.23,0:16:43.57,Default,,0,0,0,,Tên tóc vàng là dạng tốc độ ngầm.
Dialogue: 0,0:16:43.99,0:16:45.94,Default,,0,0,0,,Không chơi đuổi bắt với hắn được đâu.
Dialogue: 0,0:16:46.40,0:16:47.90,Default,,0,0,0,,Anh sẽ cầm chân hắn.
Dialogue: 0,0:16:48.11,0:16:49.24,Default,,0,0,0,,Ổn không vậy?
Dialogue: 0,0:16:49.57,0:16:50.82,Default,,0,0,0,,Đổi lại,
Dialogue: 0,0:16:50.82,0:16:52.20,Default,,0,0,0,,sau khi giết Itadori,
Dialogue: 0,0:16:52.24,0:16:55.16,Default,,0,0,0,,cậu có thể tạm thời\Nkhông báo với đám cấp trên không?
Dialogue: 0,0:16:55.16,0:16:57.37,Default,,0,0,0,,Tôi muốn dùng nó làm mồi nhử một người.
Dialogue: 0,0:16:57.70,0:16:58.98,Default,,0,0,0,,Khỏi lo cho anh.
Dialogue: 0,0:16:58.98,0:17:01.46,Default,,0,0,0,,Người chúng nhắm vào là em đấy, Yuji.
Dialogue: 0,0:17:01.88,0:17:05.63,Default,,0,0,0,,Em tập trung nghĩ cách\Nthoát khỏi tên Okkotsu tóc đen đó đi.
Dialogue: 0,0:17:06.25,0:17:08.67,Default,,0,0,0,,Có vẻ là cùng loại với Gojo Satoru.
Dialogue: 0,0:17:08.94,0:17:10.30,Default,,0,0,0,,Giao đấu với hắn là chết đấy.
Dialogue: 0,0:17:10.59,0:17:13.51,Default,,0,0,0,,May mà mình chưa đả động gì đến Megumi.
Dialogue: 0,0:17:13.51,0:17:14.76,Default,,0,0,0,,Hú hồn thật.
Dialogue: 0,0:17:14.76,0:17:17.27,Default,,0,0,0,,Cách này sẽ giúp Yuji\Nđỡ phải giao đấu với con người,
Dialogue: 0,0:17:17.27,0:17:20.35,Default,,0,0,0,,cũng khiến thằng bé\Nkhông thấy mang nợ mình.
Dialogue: 0,0:17:21.31,0:17:22.81,Default,,0,0,0,,Làm anh là phải thế.
Dialogue: 0,0:17:23.19,0:17:25.02,Default,,0,0,0,,Gặp nhau ở chỗ hôm qua nhé.
Dialogue: 0,0:17:25.52,0:17:26.61,Default,,0,0,0,,Cũng được.
Dialogue: 0,0:17:26.82,0:17:28.53,Default,,0,0,0,,Vậy nhờ anh xử lý tên đó.
Dialogue: 0,0:17:28.57,0:17:29.28,Default,,0,0,0,,Được.
Dialogue: 0,0:17:32.11,0:17:32.91,Default,,0,0,0,,Nhanh quá!
Dialogue: 0,0:17:32.91,0:17:34.66,Default,,0,0,0,,Đang cầm kiếm mà vẫn nhanh vậy sao?
Dialogue: 0,0:17:36.62,0:17:37.83,Default,,0,0,0,,Nhanh thật đấy.
Dialogue: 0,0:17:37.83,0:17:39.87,Default,,0,0,0,,Cứ tưởng lao đến là giết được ngay chứ.
Dialogue: 0,0:17:41.33,0:17:44.50,Default,,0,0,0,,Chúng nhận ra mình định cản trở Okkotsu ư?
Dialogue: 0,0:17:44.79,0:17:46.75,Default,,0,0,0,,Vừa nãy ta thấy rồi nhé.
Dialogue: 0,0:17:46.75,0:17:48.71,Default,,0,0,0,,Xích Huyết Thao Thuật đúng không?
Dialogue: 0,0:17:49.21,0:17:52.09,Default,,0,0,0,,Không biết tại sao ngươi lại\Ndùng được nó...
Dialogue: 0,0:17:52.30,0:17:54.97,Default,,0,0,0,,nhưng ngoài Xuyên Huyết\Nthì chẳng có gì đáng sợ.
Dialogue: 0,0:17:54.97,0:17:57.76,Default,,0,0,0,,Và để dùng Xuyên Huyết\Nthì phải dùng Bách Liễm trước,
Dialogue: 0,0:17:57.76,0:17:59.35,Default,,0,0,0,,khiến ngươi mất một lượng máu lớn.
Dialogue: 0,0:17:59.56,0:18:01.48,Default,,0,0,0,,Kết quả thì khỏi cần nói nhỉ.
Dialogue: 0,0:18:01.60,0:18:03.98,Default,,0,0,0,,Chiếu tướng hết cờ. Ngươi sẽ chết.
Dialogue: 0,0:18:04.23,0:18:05.81,Default,,0,0,0,,Ngươi cũng vậy.
Dialogue: 0,0:18:06.06,0:18:11.19,Default,,0,0,0,,Tưởng động tay vào em trai ta\Nmà có thể toàn mạng sao?
Dialogue: 0,0:18:32.67,0:18:34.55,Default,,0,0,0,,Cứ tưởng là trúng rồi chứ.
Dialogue: 0,0:18:34.84,0:18:36.47,Default,,0,0,0,,Giống Maki ghê.
Dialogue: 0,0:18:58.28,0:18:59.58,Default,,0,0,0,,Bị bất ngờ đúng không?
Dialogue: 0,0:18:59.95,0:19:01.95,Default,,0,0,0,,Vì tôi trông không giống dạng sức mạnh nhỉ.
Dialogue: 0,0:19:02.41,0:19:04.04,Default,,0,0,0,,Dù không có sức mạnh...
Dialogue: 0,0:19:04.58,0:19:06.62,Default,,0,0,0,,thì lượng chú lực cũng to khủng khiếp.
Dialogue: 0,0:19:06.62,0:19:08.71,Default,,0,0,0,,Thật ra tôi thuộc dạng yếu đấy.
Dialogue: 0,0:19:09.00,0:19:11.75,Default,,0,0,0,,Tăng cường chú lực để bù đắp sức mạnh...
Dialogue: 0,0:19:11.99,0:19:13.59,Default,,0,0,0,,Dù ai cũng làm được,
Dialogue: 0,0:19:13.63,0:19:15.30,Default,,0,0,0,,nhưng tên này thì đẳng cấp khác hẳn.
Dialogue: 0,0:19:15.30,0:19:16.93,Default,,0,0,0,,Hoàn toàn trái ngược với tôi nhỉ.
Dialogue: 0,0:19:19.47,0:19:20.81,Default,,0,0,0,,Nhận ra rồi nhỉ?
Dialogue: 0,0:19:21.18,0:19:24.10,Default,,0,0,0,,Tôi còn nhiều chú lực hơn cả thầy Gojo đấy.
Dialogue: 0,0:19:25.44,0:19:27.77,Default,,0,0,0,,Nhưng vì thầy có Lục Nhãn...
Dialogue: 0,0:19:28.00,0:19:32.61,Default,,0,0,0,,nên khi phát động thuật thức,\Nnăng lượng bị phân tán gần như bằng không.
Dialogue: 0,0:19:33.57,0:19:36.11,Default,,0,0,0,,Về hiệu quả thì thầy vẫn là mạnh nhất.
Dialogue: 0,0:19:37.03,0:19:39.03,Default,,0,0,0,,Chú lực của tôi có thể cạn...
Dialogue: 0,0:19:39.03,0:19:40.58,Default,,0,0,0,,nhưng thầy ấy thì không.
Dialogue: 0,0:19:42.04,0:19:43.83,Default,,0,0,0,,Chỉ vậy thôi.
Dialogue: 0,0:19:49.17,0:19:50.38,Default,,0,0,0,,Chết tiệt.
Dialogue: 0,0:19:50.38,0:19:51.96,Default,,0,0,0,,Chú thuật sư càng giỏi
Dialogue: 0,0:19:51.96,0:19:54.21,Default,,0,0,0,,thì càng khó thấy dòng chảy chú lực của họ.
Dialogue: 0,0:19:54.21,0:19:56.17,Default,,0,0,0,,Nhưng với lý do khác của cậu.
Dialogue: 0,0:19:56.17,0:19:59.92,Default,,0,0,0,,CHÚ LỰC DÙNG CHƯA THÀNH THẠO SẼ LỆCH\NThuật sư giỏi kiểm soát chú lực thì...
Dialogue: 0,0:19:59.92,0:20:02.93,Default,,0,0,0,,SANG MỘT BÊN VÀ CÀNG DỄ BỊ ĐỌC VỊ\Nkhông thể đọc vị cho đến sát lúc trúng đòn.
Dialogue: 0,0:20:04.68,0:20:06.02,Default,,0,0,0,,Nhưng người này...
Dialogue: 0,0:20:06.23,0:20:10.10,Default,,0,0,0,,bao gồm cả thanh kiếm,\Ntoàn cơ thể luôn tràn ngập chú lực.
Dialogue: 0,0:20:10.52,0:20:12.90,Default,,0,0,0,,Không còn là đọc chuyển động nữa.
Dialogue: 0,0:20:13.40,0:20:15.90,Default,,0,0,0,,Mọi đòn tấn công đều trở thành tất sát...
Dialogue: 0,0:20:16.19,0:20:18.74,Default,,0,0,0,,trong khi giảm thiểu mọi thiệt hại.
Dialogue: 0,0:20:19.74,0:20:21.20,Default,,0,0,0,,Nhờ cậu phần còn lại.
Dialogue: 0,0:20:21.73,0:20:25.29,Default,,0,0,0,,Xin lỗi, nhưng tôi chưa thể chết được.
Dialogue: 0,0:20:33.34,0:20:34.71,Default,,0,0,0,,Với một số học sinh,
Dialogue: 0,0:20:34.71,0:20:37.55,Default,,0,0,0,,thầy sẽ khuyến khích họ\Ntập trung học cách dùng vũ khí.
Dialogue: 0,0:20:38.59,0:20:42.76,Default,,0,0,0,,Nhưng quá phụ thuộc vào chú cụ mà\Nlơ là việc kiểm soát chú lực thì không nên.
Dialogue: 0,0:20:43.39,0:20:45.27,Default,,0,0,0,,Tạm thời Yuji chưa cần học cái này.
Dialogue: 0,0:20:46.98,0:20:48.60,Default,,0,0,0,,Chỉ dùng Đồ Tọa Ma khi khẩn cấp thôi.
Dialogue: 0,0:20:49.94,0:20:51.77,Default,,0,0,0,,Đã học bao giờ đâu!
Dialogue: 0,0:20:53.52,0:20:56.11,Default,,0,0,0,,Cậu... quá tập trung vào thanh kiếm rồi.
Dialogue: 0,0:21:03.66,0:21:04.95,Default,,0,0,0,,Gãy rồi ư?
Dialogue: 0,0:21:05.41,0:21:06.79,Default,,0,0,0,,Mà cũng phải thôi.
Dialogue: 0,0:21:06.87,0:21:08.83,Default,,0,0,0,,Là học trò của thầy Gojo mà.
Dialogue: 0,0:21:09.12,0:21:10.79,Default,,0,0,0,,Đâu dễ gì đối phó.
Dialogue: 0,0:21:11.62,0:21:14.09,Default,,0,0,0,,Vết thương sâu quá\Nnhưng chưa vào nội tạng.
Dialogue: 0,0:21:14.34,0:21:16.13,Default,,0,0,0,,Tranh thủ hắn đang mất vũ khí,
Dialogue: 0,0:21:16.13,0:21:17.05,Default,,0,0,0,,chuồn thôi!
Dialogue: 0,0:21:22.51,0:21:25.43,Default,,0,0,0,,Đang làm gì thế?
Dialogue: 0,0:21:28.56,0:21:31.31,Default,,0,0,0,,Chơi đùa một chút thôi, Rika.
Dialogue: 0,0:21:32.65,0:21:33.56,Default,,0,0,0,,Rika?
Dialogue: 0,0:21:33.56,0:21:34.81,Default,,0,0,0,,Con này là sao?
Dialogue: 0,0:21:34.81,0:21:35.77,Default,,0,0,0,,Thức thần?
Dialogue: 0,0:21:35.94,0:21:37.15,Default,,0,0,0,,Chui ra từ đâu vậy?
Dialogue: 0,0:21:38.94,0:21:40.32,Default,,0,0,0,,Giữ chặt cậu ta nhé.
Dialogue: 0,0:21:41.07,0:21:42.28,Default,,0,0,0,,Không nhúc nhích nổi.
Dialogue: 0,0:21:44.53,0:21:46.49,Default,,0,0,0,,Nó khỏe quá!
Dialogue: 0,0:21:53.62,0:21:54.83,Default,,0,0,0,,Xin lỗi nhé,
Dialogue: 0,0:22:01.67,0:22:03.05,Default,,0,0,0,,Itadori.
Dialogue: 0,0:23:40.31,0:23:42.94,Default,,0,0,0,,Làm anh mà kém cỏi hơn em thì sống làm gì.
Dialogue: 0,0:23:42.94,0:23:45.82,Default,,0,0,0,,Không thể hiểu nổi\Nkẻ không biết yêu thương anh em.
Dialogue: 0,0:23:45.82,0:23:46.74,Default,,0,0,0,,Cái chết của Itadori là...
Dialogue: 0,0:23:46.74,0:23:49.70,Default,,0,0,0,,Mọi sai lầm đều là từ lúc đó.
Dialogue: 0,0:23:49.70,0:23:50.45,Default,,0,0,0,,Đừng coi thường ta.
Dialogue: 0,0:23:50.45,0:23:51.53,Default,,0,0,0,,Trước mắt hãy giúp tôi đã.
Dialogue: 0,0:23:51.53,0:23:52.08,Default,,0,0,0,,Chiếu tướng.
Dialogue: 0,0:23:52.08,0:23:54.50,Default,,0,0,0,,TẬP TỚI: MỘT LẦN NỮA\Nsumiki cũng bị kéo vào Tử Diệt Hồi Du rồi.

