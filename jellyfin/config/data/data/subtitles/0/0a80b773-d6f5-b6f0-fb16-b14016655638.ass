Dialogue: 0,0:00:00.00,0:00:02.96,Default,,0,0,0,,(EPISODE 48 EKSEKUSI)
Dialogue: 0,0:03:38.05,0:03:43.97,Default,,0,0,0,,JUJUTSU KAISEN THE CULLING GAME
Dialogue: 0,0:04:18.55,0:04:22.60,Default,,0,0,0,,JUJUTSU KAISEN THE CULLING GAME PART 1
Dialogue: 0,0:05:15.90,0:05:17.94,Default,,0,0,0,,Jadi, dia sudah mati?
Dialogue: 0,0:05:18.57,0:05:19.57,Default,,0,0,0,,Maksudku, Mai.
Dialogue: 0,0:05:21.03,0:05:23.28,Default,,0,0,0,,Khawatirkan kepala keluarga dahulu.
Dialogue: 0,0:05:23.37,0:05:25.83,Default,,0,0,0,,Lagi pula, Maki yang sekarat.
Dialogue: 0,0:05:25.91,0:05:28.79,Default,,0,0,0,,Begitukah?\NKalau begitu, itu tidak penting.
Dialogue: 0,0:05:28.87,0:05:31.58,Default,,0,0,0,,Maki mungkin cantik,\Ntapi kepribadiannya buruk.
Dialogue: 0,0:05:31.67,0:05:33.79,Default,,0,0,0,,Dia tidak tahu\Ncara membiarkan pria memimpin.
Dialogue: 0,0:05:33.88,0:05:35.75,Default,,0,0,0,,Wanita yang tidak mau dipimpin pria
Dialogue: 0,0:05:35.84,0:05:38.05,Default,,0,0,0,,pantas ditikam dari belakang dan mati.
Dialogue: 0,0:05:38.88,0:05:41.63,Default,,0,0,0,,Mai jauh lebih baik dalam hal itu.
Dialogue: 0,0:05:41.72,0:05:43.80,Default,,0,0,0,,(PENYIHIR TINGKAT SATU, NAOYA ZEN'IN)
Dialogue: 0,0:05:44.30,0:05:47.64,Default,,0,0,0,,Wajah dan dadanya seperti Maki.
Dialogue: 0,0:05:47.72,0:05:48.81,Default,,0,0,0,,Meski dia suka berlagak tangguh,
Dialogue: 0,0:05:48.89,0:05:52.44,Default,,0,0,0,,dia tahu di lubuk hatinya\Nbahwa dia seorang wanita.
Dialogue: 0,0:05:52.73,0:05:54.27,Default,,0,0,0,,Kau terlambat.
Dialogue: 0,0:05:54.35,0:05:55.98,Default,,0,0,0,,Apa yang kau lakukan?
Dialogue: 0,0:05:56.06,0:05:59.53,Default,,0,0,0,,Saat ayahmu sendiri di ambang kematian…
Dialogue: 0,0:05:59.61,0:06:01.07,Default,,0,0,0,,Maafkan aku.
Dialogue: 0,0:06:01.15,0:06:04.66,Default,,0,0,0,,Tapi tidak masalah aku datang atau tidak.
Dialogue: 0,0:06:04.74,0:06:07.74,Default,,0,0,0,,Lagi pula,\Naku calon kepala keluarga Zen'in.
Dialogue: 0,0:06:08.79,0:06:12.08,Default,,0,0,0,,Para saudaraku tidak berguna.
Dialogue: 0,0:06:12.75,0:06:13.83,Default,,0,0,0,,Paman…
Dialogue: 0,0:06:13.92,0:06:16.21,Default,,0,0,0,,Sebagai adik, kau tidak lebih baik.
Dialogue: 0,0:06:16.29,0:06:18.71,Default,,0,0,0,,Belum lagi putrimu.
Dialogue: 0,0:06:18.80,0:06:20.51,Default,,0,0,0,,Sedangkan Jinichi,
Dialogue: 0,0:06:22.93,0:06:25.01,Default,,0,0,0,,dia terlalu jelek.
Dialogue: 0,0:06:25.09,0:06:27.76,Default,,0,0,0,,Andai saja kau kebalikan dari Toji.
Dialogue: 0,0:06:31.14,0:06:33.77,Default,,0,0,0,,(PENYIHIR TINGKAT SATU KHUSUS, OGI ZEN'IN)
Dialogue: 0,0:06:33.85,0:06:35.48,Default,,0,0,0,,(PENYIHIR TINGKAT SATU KHUSUS,\NJINICHI ZEN'IN)
Dialogue: 0,0:06:35.56,0:06:38.36,Default,,0,0,0,,Ayah hampir mati.
Dialogue: 0,0:06:38.44,0:06:40.40,Default,,0,0,0,,Tidak bisakah kau bersabar?
Dialogue: 0,0:06:41.07,0:06:43.36,Default,,0,0,0,,Semuanya sudah datang?
Dialogue: 0,0:06:45.41,0:06:48.03,Default,,0,0,0,,Baru saja, kepala keluarga Zen'in,
Dialogue: 0,0:06:48.12,0:06:52.08,Default,,0,0,0,,Naobito Zen'in, meninggal.
Dialogue: 0,0:06:55.75,0:07:00.09,Default,,0,0,0,,Wasiatnya ada padaku.
Dialogue: 0,0:07:00.17,0:07:03.67,Default,,0,0,0,,Sesuai keinginan Naobito Zen'in…
Dialogue: 0,0:07:04.30,0:07:06.34,Default,,0,0,0,,Tuan Ogi Zen'in.
Dialogue: 0,0:07:06.43,0:07:08.97,Default,,0,0,0,,Tuan Jinichi Zen'in.
Dialogue: 0,0:07:09.05,0:07:10.97,Default,,0,0,0,,Tuan Naoya Zen'in.
Dialogue: 0,0:07:11.47,0:07:17.10,Default,,0,0,0,,Aku akan membacakan wasiatnya\Nsaat kalian bertiga hadir.
Dialogue: 0,0:07:18.06,0:07:21.98,Default,,0,0,0,,Jika tidak ada yang keberatan,\Naku akan mulai membacakan wasiatnya.
Dialogue: 0,0:07:28.53,0:07:29.87,Default,,0,0,0,,Pertama,
Dialogue: 0,0:07:29.95,0:07:34.37,Default,,0,0,0,,Naoya Zen'in akan menjadi\Nkepala keluarga Zen'in ke-27.
Dialogue: 0,0:07:35.08,0:07:36.42,Default,,0,0,0,,Berikutnya,
Dialogue: 0,0:07:36.50,0:07:41.84,Default,,0,0,0,,semua alat terkutuk di SMA Jujutsu\Ndan gudang terkutuk keluarga Zen'in,
Dialogue: 0,0:07:41.92,0:07:44.84,Default,,0,0,0,,bersama semua aset,\Nakan diwarisi oleh Naoya.
Dialogue: 0,0:07:45.47,0:07:51.39,Default,,0,0,0,,Naoya hanya bisa menggunakannya\Ndengan persetujuan Ogi Zen'in
Dialogue: 0,0:07:51.47,0:07:54.93,Default,,0,0,0,,atau Jinichi Zen'in.
Dialogue: 0,0:07:56.10,0:07:57.64,Default,,0,0,0,,Terserah.
Dialogue: 0,0:07:57.73,0:07:59.23,Default,,0,0,0,,Namun…
Dialogue: 0,0:07:59.31,0:08:02.61,Default,,0,0,0,,Jika Satoru Gojo mati\Nkarena alasan apa pun,
Dialogue: 0,0:08:02.69,0:08:06.45,Default,,0,0,0,,atau kehilangan kesadarannya,
Dialogue: 0,0:08:06.53,0:08:10.12,Default,,0,0,0,,maka sumpah dengan Toji Fushiguro\Nakan terpenuhi.
Dialogue: 0,0:08:10.20,0:08:13.24,Default,,0,0,0,,Megumi Fushiguro akan diterima\Ndi keluarga Zen'in.
Dialogue: 0,0:08:13.33,0:08:16.62,Default,,0,0,0,,Dia akan menjadi kepala keluarga Zen'in
Dialogue: 0,0:08:16.71,0:08:20.17,Default,,0,0,0,,dan semua aset akan dialihkan kepadanya.
Dialogue: 0,0:08:21.92,0:08:22.75,Default,,0,0,0,,Apa?
Dialogue: 0,0:08:22.84,0:08:24.55,Default,,0,0,0,,Sudah kuduga itu tidak akan berhasil.
Dialogue: 0,0:08:24.63,0:08:26.55,Default,,0,0,0,,Dua pengecut itu.
Dialogue: 0,0:08:26.63,0:08:28.84,Default,,0,0,0,,Mereka lebih suka berandal asing
Dialogue: 0,0:08:28.93,0:08:31.35,Default,,0,0,0,,sebagai kepala daripada aku.\NMereka tidak mau bertindak.
Dialogue: 0,0:08:32.68,0:08:35.47,Default,,0,0,0,,Di mana Megumi sekarang?\NApa yang dia lakukan?
Dialogue: 0,0:08:35.56,0:08:37.02,Default,,0,0,0,,Aku tak tahu detailnya.
Dialogue: 0,0:08:37.10,0:08:40.90,Default,,0,0,0,,Aku hanya tahu dia di Tokyo\Nmencari Yuji Itadori.
Dialogue: 0,0:08:40.98,0:08:42.40,Default,,0,0,0,,Siapa itu?
Dialogue: 0,0:08:42.48,0:08:44.69,Default,,0,0,0,,Wadah Sukuna.
Dialogue: 0,0:08:44.78,0:08:46.99,Default,,0,0,0,,Kalau begitu, beri tahu petinggi
Dialogue: 0,0:08:47.07,0:08:50.45,Default,,0,0,0,,bahwa Naoya Zen'in\Nakan membunuh wadah Sukuna.
Dialogue: 0,0:08:50.53,0:08:53.78,Default,,0,0,0,,Megumi bersama wadah Sukuna, bukan?
Dialogue: 0,0:08:53.87,0:08:55.83,Default,,0,0,0,,Aku akan membunuh mereka berdua sekaligus.
Dialogue: 0,0:08:56.70,0:08:59.12,Default,,0,0,0,,Tokyo sekarang adalah Makyo Non-Manusia.
Dialogue: 0,0:08:59.21,0:09:01.88,Default,,0,0,0,,Tidak penting waktu\Natau cara seseorang mati.
Dialogue: 0,0:09:02.88,0:09:04.04,Default,,0,0,0,,Selama kubunuh dia,
Dialogue: 0,0:09:04.13,0:09:06.26,Default,,0,0,0,,aku bisa mengurus sisanya.
Dialogue: 0,0:09:09.42,0:09:11.80,Default,,0,0,0,,Aku kepala keluarga Zen'in.
Dialogue: 0,0:09:21.77,0:09:23.02,Default,,0,0,0,,Matilah.
Dialogue: 0,0:09:23.11,0:09:24.27,Default,,0,0,0,,- Kugisaki!\N- Hanya aku yang harus mati.
Dialogue: 0,0:09:24.36,0:09:25.19,Default,,0,0,0,,Kuserahkan sisanya kepadamu.
Dialogue: 0,0:09:25.27,0:09:26.15,Default,,0,0,0,,- Matilah!\N- Itadori.
Dialogue: 0,0:09:26.23,0:09:27.44,Default,,0,0,0,,Itadori.
Dialogue: 0,0:09:27.53,0:09:28.61,Default,,0,0,0,,Apa yang akan kau lakukan?
Dialogue: 0,0:09:53.68,0:09:54.68,Default,,0,0,0,,Yuji.
Dialogue: 0,0:09:56.22,0:09:58.06,Default,,0,0,0,,Bagaimana lukamu?
Dialogue: 0,0:09:59.18,0:10:03.10,Default,,0,0,0,,Selain bagian yang terkena Kilatan Hitam,\Naku baik-baik saja.
Dialogue: 0,0:10:04.31,0:10:06.86,Default,,0,0,0,,Mungkin itu pengaruh Sukuna.
Dialogue: 0,0:10:06.94,0:10:09.74,Default,,0,0,0,,Aku bisa merasakan\Nkekuatannya bertambah kuat.
Dialogue: 0,0:10:10.94,0:10:12.07,Default,,0,0,0,,Yuji.
Dialogue: 0,0:10:12.15,0:10:14.07,Default,,0,0,0,,Kau tidak perlu mencemaskanku.
Dialogue: 0,0:10:14.16,0:10:16.66,Default,,0,0,0,,Kau bisa kembali ke SMA Jujutsu.
Dialogue: 0,0:10:16.74,0:10:19.87,Default,,0,0,0,,Aku juga ingin mengambil\Njasad Shoso dan yang lainnya.
Dialogue: 0,0:10:21.33,0:10:23.25,Default,,0,0,0,,Aku tidak mencemaskanmu.
Dialogue: 0,0:10:23.33,0:10:26.17,Default,,0,0,0,,Ini bukan soal aku ingin kembali\Natau tidak.
Dialogue: 0,0:10:26.96,0:10:30.51,Default,,0,0,0,,Sukuna ingin memanfaatkan Megumi\Nuntuk sesuatu.
Dialogue: 0,0:10:30.59,0:10:34.76,Default,,0,0,0,,Dan aku sudah membunuh banyak orang.
Dialogue: 0,0:10:34.84,0:10:39.18,Default,,0,0,0,,Tapi bagaimana jika yang kau selamatkan\Nmembunuh orang lain di masa depan?
Dialogue: 0,0:10:40.18,0:10:44.10,Default,,0,0,0,,Aku tidak bisa bersama semua orang lagi.
Dialogue: 0,0:10:44.19,0:10:45.73,Default,,0,0,0,,Bagaimana denganmu, Choso?
Dialogue: 0,0:10:45.81,0:10:48.23,Default,,0,0,0,,Aku membunuh para saudaramu.
Dialogue: 0,0:10:48.32,0:10:50.82,Default,,0,0,0,,Tidak apa-apa. Itu kecelakaan.
Dialogue: 0,0:10:50.90,0:10:52.28,Default,,0,0,0,,Eso dan Kechizu.
Dialogue: 0,0:10:52.36,0:10:55.24,Default,,0,0,0,,Akan kulakukan hal yang sama\Njika menjadi kalian.
Dialogue: 0,0:10:55.32,0:10:57.70,Default,,0,0,0,,Ini bukan masalah memaafkan atau tidak.
Dialogue: 0,0:10:57.78,0:11:00.24,Default,,0,0,0,,Begitulah saudara.
Dialogue: 0,0:11:03.33,0:11:04.67,Default,,0,0,0,,Ayo.
Dialogue: 0,0:11:04.79,0:11:07.17,Default,,0,0,0,,Kita harus mengurangi\Njumlah roh terkutuk dahulu.
Dialogue: 0,0:12:59.53,0:13:00.53,Default,,0,0,0,,Choso!
Dialogue: 0,0:13:07.96,0:13:08.83,Default,,0,0,0,,Yuji.
Dialogue: 0,0:13:21.30,0:13:23.30,Default,,0,0,0,,Luar biasa.
Dialogue: 0,0:13:23.39,0:13:24.76,Default,,0,0,0,,Saat kali pertama dia melawanku,
Dialogue: 0,0:13:24.85,0:13:26.64,Default,,0,0,0,,dia terasa kuat dan tangguh.
Dialogue: 0,0:13:26.72,0:13:29.64,Default,,0,0,0,,Tapi sekarang, dia bahkan lebih terasah.
Dialogue: 0,0:13:29.73,0:13:31.40,Default,,0,0,0,,Kendali energi terkutuk\Nyang bersih dan tepat.
Dialogue: 0,0:13:31.48,0:13:33.52,Default,,0,0,0,,Kekuatan lengan manusia super.
Dialogue: 0,0:13:36.07,0:13:37.99,Default,,0,0,0,,Dia seperti iblis.
Dialogue: 0,0:13:38.07,0:13:41.41,Default,,0,0,0,,Apalagi, dia belum sepenuhnya pulih.
Dialogue: 0,0:13:42.70,0:13:45.41,Default,,0,0,0,,Itu adikku.
Dialogue: 0,0:13:45.49,0:13:46.99,Default,,0,0,0,,Kau masih mengatakan itu?
Dialogue: 0,0:13:47.95,0:13:49.91,Default,,0,0,0,,Akan kukatakan sebanyak yang kau mau.
Dialogue: 0,0:13:50.00,0:13:51.16,Default,,0,0,0,,Cobalah ingat.
Dialogue: 0,0:13:51.25,0:13:52.88,Default,,0,0,0,,Seharusnya ada satu juga.
Dialogue: 0,0:13:56.04,0:13:58.13,Default,,0,0,0,,Seharusnya ada jahitan
Dialogue: 0,0:13:58.21,0:13:59.80,Default,,0,0,0,,di dahi ayahmu juga.
Dialogue: 0,0:14:01.88,0:14:04.05,Default,,0,0,0,,Megumi tidak ada di sini?
Dialogue: 0,0:14:04.14,0:14:05.51,Default,,0,0,0,,Apa aku yang pertama datang?
Dialogue: 0,0:14:05.60,0:14:06.64,Default,,0,0,0,,Bagaimana ini bisa terjadi?
Dialogue: 0,0:14:06.72,0:14:08.27,Default,,0,0,0,,Bukankah mereka terlalu lambat?
Dialogue: 0,0:14:08.85,0:14:10.48,Default,,0,0,0,,Siapa pria itu?
Dialogue: 0,0:14:10.56,0:14:12.48,Default,,0,0,0,,Dia menyebutkan Fushiguro?
Dialogue: 0,0:14:12.94,0:14:14.65,Default,,0,0,0,,Kau juga. Sedang apa di sana?
Dialogue: 0,0:14:14.73,0:14:18.03,Default,,0,0,0,,Kau terlalu menarik perhatian.\NKau tidak akan lari?
Dialogue: 0,0:14:18.11,0:14:19.44,Default,,0,0,0,,Lari?
Dialogue: 0,0:14:19.53,0:14:21.40,Default,,0,0,0,,Apa? Kau tidak tahu?
Dialogue: 0,0:14:21.49,0:14:23.66,Default,,0,0,0,,Kau dihukum mati.
Dialogue: 0,0:14:23.74,0:14:26.49,Default,,0,0,0,,Karena dukungan Satoru hilang.
Dialogue: 0,0:14:29.24,0:14:30.79,Default,,0,0,0,,Gojo melanggar peraturan.
Dialogue: 0,0:14:30.87,0:14:34.50,Default,,0,0,0,,Artinya, tekadnya menyelamatkan\Nbanyak Penyihir Jujutsu.
Dialogue: 0,0:14:34.75,0:14:37.04,Default,,0,0,0,,Aku mencari Megumi.
Dialogue: 0,0:14:37.13,0:14:40.21,Default,,0,0,0,,Sejujurnya,\Naku tidak peduli kau hidup atau mati.
Dialogue: 0,0:14:40.30,0:14:42.38,Default,,0,0,0,,Tapi aku tidak ingin kau menghalangiku.
Dialogue: 0,0:14:42.47,0:14:45.05,Default,,0,0,0,,Mari patahkan kakimu dahulu.
Dialogue: 0,0:14:45.51,0:14:47.55,Default,,0,0,0,,Kenapa kau mencari Fushiguro?
Dialogue: 0,0:14:47.64,0:14:49.85,Default,,0,0,0,,Aku ingin membunuhnya.
Dialogue: 0,0:14:49.93,0:14:53.44,Default,,0,0,0,,Akan lebih baik jika dia bisa\Nmenulis surat untukku sebelum mati.
Dialogue: 0,0:14:53.52,0:14:56.06,Default,,0,0,0,,Kudengar Megumi mencarimu.
Dialogue: 0,0:15:16.71,0:15:19.55,Default,,0,0,0,,Cepat sekali, tapi ada yang aneh.
Dialogue: 0,0:15:20.09,0:15:21.71,Default,,0,0,0,,Mungkin itu teknik terkutuk?
Dialogue: 0,0:15:21.80,0:15:24.05,Default,,0,0,0,,Kau lebih tangguh daripada dugaanku.
Dialogue: 0,0:15:24.38,0:15:26.22,Default,,0,0,0,,Sejujurnya, aku meremehkanmu.
Dialogue: 0,0:15:26.89,0:15:28.97,Default,,0,0,0,,Tidak mengejutkan wadahnya kuat.
Dialogue: 0,0:15:29.05,0:15:30.43,Default,,0,0,0,,Tapi siapa yang ada di sampingnya?
Dialogue: 0,0:15:31.01,0:15:33.60,Default,,0,0,0,,Aku akan mempercepat sedikit lagi.
Dialogue: 0,0:15:39.57,0:15:41.19,Default,,0,0,0,,Pak Gojo?
Dialogue: 0,0:15:41.28,0:15:43.99,Default,,0,0,0,,Tidak, itu sesuatu yang lebih aneh…
Dialogue: 0,0:15:51.08,0:15:52.24,Default,,0,0,0,,Apa?
Dialogue: 0,0:15:52.33,0:15:53.91,Default,,0,0,0,,Ada lebih dari satu.
Dialogue: 0,0:15:56.12,0:15:58.92,Default,,0,0,0,,JUJUTSU KAISEN
Dialogue: 0,0:16:00.04,0:16:00.96,Default,,0,0,0,,Siapa itu?
Dialogue: 0,0:16:01.04,0:16:02.88,Default,,0,0,0,,Siapa pun itu, tujuan mereka pasti…
Dialogue: 0,0:16:03.34,0:16:05.97,Default,,0,0,0,,Apa hubunganmu dengan Itadori?
Dialogue: 0,0:16:06.93,0:16:09.68,Default,,0,0,0,,Jadi, kau memang algojo Yuji?
Dialogue: 0,0:16:18.06,0:16:19.27,Default,,0,0,0,,Tunggu sebentar.
Dialogue: 0,0:16:19.35,0:16:20.94,Default,,0,0,0,,Aku ada di pihakmu.
Dialogue: 0,0:16:21.02,0:16:22.86,Default,,0,0,0,,Kau Okkotsu, bukan?
Dialogue: 0,0:16:22.94,0:16:24.28,Default,,0,0,0,,Okkotsu…
Dialogue: 0,0:16:24.36,0:16:26.57,Default,,0,0,0,,Dia murid kelas dua\Nyang disebutkan Fushiguro.
Dialogue: 0,0:16:26.65,0:16:29.66,Default,,0,0,0,,Dia Penyihir Tingkat Khusus\Nseperti Pak Gojo.
Dialogue: 0,0:16:29.95,0:16:30.87,Default,,0,0,0,,Siapa kau?
Dialogue: 0,0:16:30.95,0:16:32.49,Default,,0,0,0,,Aku Naoya Zen'in.
Dialogue: 0,0:16:32.58,0:16:34.33,Default,,0,0,0,,Aku sepupu Maki.
Dialogue: 0,0:16:34.41,0:16:36.96,Default,,0,0,0,,Sama sepertimu, aku di sini
Dialogue: 0,0:16:37.04,0:16:38.25,Default,,0,0,0,,- Lari, Yuji.\N- untuk membunuh Itadori.
Dialogue: 0,0:16:38.33,0:16:39.83,Default,,0,0,0,,- Jangan khawatir.\N- Apa?
Dialogue: 0,0:16:39.92,0:16:41.54,Default,,0,0,0,,Aku tidak akan menghalangimu.
Dialogue: 0,0:16:41.63,0:16:44.17,Default,,0,0,0,,Pria pirang itu unggul dalam kecepatan\Ndan trik tersembunyi.
Dialogue: 0,0:16:44.25,0:16:46.67,Default,,0,0,0,,Bermain kejar-kejaran dengannya\Ntidak akan berakhir baik.
Dialogue: 0,0:16:46.76,0:16:48.38,Default,,0,0,0,,Aku akan menghentikannya.
Dialogue: 0,0:16:48.47,0:16:49.43,Default,,0,0,0,,Kau yakin?
Dialogue: 0,0:16:49.72,0:16:50.89,Default,,0,0,0,,Sebagai gantinya,
Dialogue: 0,0:16:50.97,0:16:52.35,Default,,0,0,0,,setelah kita membunuh Itadori,
Dialogue: 0,0:16:52.43,0:16:55.39,Default,,0,0,0,,bisakah kau tidak segera melaporkan ini\Nkepada petinggi?
Dialogue: 0,0:16:55.47,0:16:57.94,Default,,0,0,0,,Aku ingin menggunakannya sebagai umpan\Nuntuk memancing seseorang.
Dialogue: 0,0:16:58.02,0:16:59.19,Default,,0,0,0,,Aku tidak keberatan.
Dialogue: 0,0:16:59.27,0:17:02.06,Default,,0,0,0,,Target mereka adalah kau, Yuji.
Dialogue: 0,0:17:02.15,0:17:03.48,Default,,0,0,0,,Si rambut hitam itu…
Dialogue: 0,0:17:03.57,0:17:06.57,Default,,0,0,0,,Kau hanya perlu memikirkan\Ncara kabur dari Okkotsu.
Dialogue: 0,0:17:06.65,0:17:09.03,Default,,0,0,0,,Sepertinya dia tipe yang sama\Ndengan Satoru Gojo.
Dialogue: 0,0:17:09.11,0:17:10.78,Default,,0,0,0,,Kita pasti akan mati jika melawannya.
Dialogue: 0,0:17:10.86,0:17:13.70,Default,,0,0,0,,Syukurlah aku tidak memberitahunya\Ntentang Megumi.
Dialogue: 0,0:17:13.78,0:17:15.08,Default,,0,0,0,,Aku sangat khawatir.
Dialogue: 0,0:17:15.16,0:17:17.37,Default,,0,0,0,,Usulan ini bisa mencegah\NYuji melawan manusia.
Dialogue: 0,0:17:17.45,0:17:20.87,Default,,0,0,0,,Pada saat yang sama,\Ndia tidak akan merasa berutang kepadaku.
Dialogue: 0,0:17:21.58,0:17:23.42,Default,,0,0,0,,Dia harus diurus.
Dialogue: 0,0:17:23.50,0:17:25.67,Default,,0,0,0,,Mari bertemu di tempat yang sama kemarin.
Dialogue: 0,0:17:25.75,0:17:27.01,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:17:27.09,0:17:28.72,Default,,0,0,0,,Kalau begitu, kuserahkan kepadamu.
Dialogue: 0,0:17:28.80,0:17:29.80,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:17:32.30,0:17:33.14,Default,,0,0,0,,Dia cepat sekali.
Dialogue: 0,0:17:33.22,0:17:34.81,Default,,0,0,0,,Berlari dengan pedang tersarung,\Ndia masih sangat cepat.
Dialogue: 0,0:17:36.81,0:17:37.98,Default,,0,0,0,,Dia cepat.
Dialogue: 0,0:17:38.06,0:17:40.35,Default,,0,0,0,,Aku berniat menghabisinya\Nbegitu aku menyerang.
Dialogue: 0,0:17:41.35,0:17:44.65,Default,,0,0,0,,Apa dia berharap aku menghalangi Okkotsu?
Dialogue: 0,0:17:45.07,0:17:46.94,Default,,0,0,0,,Aku baru saja melihatnya.
Dialogue: 0,0:17:47.07,0:17:49.15,Default,,0,0,0,,Itu "Manipulasi Darah", bukan?
Dialogue: 0,0:17:49.44,0:17:52.49,Default,,0,0,0,,Entah kenapa kau bisa menggunakannya,
Dialogue: 0,0:17:52.57,0:17:55.20,Default,,0,0,0,,tapi selain "Darah Menusuk",\Ntidak ada yang perlu ditakutkan.
Dialogue: 0,0:17:55.28,0:17:58.00,Default,,0,0,0,,Untuk menggunakan "Darah Menusuk",\Nkau harus menggunakan "Konvergensi".
Dialogue: 0,0:17:58.08,0:17:59.75,Default,,0,0,0,,Itu akan menghasilkan jeda panjang.
Dialogue: 0,0:17:59.83,0:18:01.96,Default,,0,0,0,,Aku tidak perlu\Nmemberitahumu hasilnya, bukan?
Dialogue: 0,0:18:02.04,0:18:04.29,Default,,0,0,0,,Kau akan tersudut. Tamat riwayatmu.
Dialogue: 0,0:18:04.71,0:18:06.25,Default,,0,0,0,,Tidak, kau yang tamat.
Dialogue: 0,0:18:06.34,0:18:08.51,Default,,0,0,0,,Beraninya kau menyentuh saudaraku?
Dialogue: 0,0:18:08.59,0:18:11.55,Default,,0,0,0,,Kau pikir bisa lolos hidup-hidup?
Dialogue: 0,0:18:32.86,0:18:35.12,Default,,0,0,0,,Kukira aku pasti akan menebasnya.
Dialogue: 0,0:18:35.20,0:18:36.66,Default,,0,0,0,,Dia seperti Maki.
Dialogue: 0,0:18:58.47,0:19:00.22,Default,,0,0,0,,Apa aku menakutimu?
Dialogue: 0,0:19:00.31,0:19:02.39,Default,,0,0,0,,Lagi pula, aku tidak terlihat\Nseperti tipe yang kuat.
Dialogue: 0,0:19:02.60,0:19:04.77,Default,,0,0,0,,Bahkan tanpa kekuatan,
Dialogue: 0,0:19:04.85,0:19:06.81,Default,,0,0,0,,jumlah energi terkutuknya sangat besar.
Dialogue: 0,0:19:06.90,0:19:08.98,Default,,0,0,0,,Sebenarnya, aku juga tipe yang lemah.
Dialogue: 0,0:19:09.32,0:19:12.44,Default,,0,0,0,,Aku menebus kurangnya kekuatanku\Ndengan meningkatkan energi terkutukku.
Dialogue: 0,0:19:12.53,0:19:13.86,Default,,0,0,0,,Semua orang melakukan itu.
Dialogue: 0,0:19:13.95,0:19:15.66,Default,,0,0,0,,Tapi saat dia melakukannya…
Dialogue: 0,0:19:15.74,0:19:17.20,Default,,0,0,0,,Dia kebalikan dariku.
Dialogue: 0,0:19:19.95,0:19:21.37,Default,,0,0,0,,Kau menyadarinya?
Dialogue: 0,0:19:21.45,0:19:24.62,Default,,0,0,0,,Aku punya lebih banyak energi terkutuk\Ndaripada Pak Gojo.
Dialogue: 0,0:19:25.79,0:19:28.34,Default,,0,0,0,,Tapi karena Pak Gojo punya Enam Mata,
Dialogue: 0,0:19:28.42,0:19:29.75,Default,,0,0,0,,saat dia mengaktifkan teknik terkutuknya,
Dialogue: 0,0:19:29.84,0:19:33.72,Default,,0,0,0,,energi yang tersebar mendekati "nol".
Dialogue: 0,0:19:33.80,0:19:36.84,Default,,0,0,0,,Dalam hal efisiensi,\Ndia memang yang terkuat.
Dialogue: 0,0:19:37.30,0:19:39.26,Default,,0,0,0,,Energi terkutukku mungkin akan habis.
Dialogue: 0,0:19:39.35,0:19:40.89,Default,,0,0,0,,Tapi tidak dengan Pak Gojo.
Dialogue: 0,0:19:42.18,0:19:43.85,Default,,0,0,0,,Aku sudah selesai bicara.
Dialogue: 0,0:19:49.57,0:19:50.40,Default,,0,0,0,,Sial.
Dialogue: 0,0:19:50.48,0:19:52.07,Default,,0,0,0,,Makin baik seorang Penyihir Jujutsu,
Dialogue: 0,0:19:52.15,0:19:54.44,Default,,0,0,0,,makin sulit melihat\Naliran energi terkutuk mereka.
Dialogue: 0,0:19:54.53,0:19:56.32,Default,,0,0,0,,Tapi untuk alasan yang berbeda darimu.
Dialogue: 0,0:19:56.41,0:19:57.70,Default,,0,0,0,,(Untuk penyihir dengan kendali buruk,)\NAku mengatakannya karena
Dialogue: 0,0:19:57.78,0:19:58.62,Default,,0,0,0,,(energi terkutuk mereka miring di posisi\Nsiap dan membocorkan gerakan mereka.)
Dialogue: 0,0:19:58.70,0:19:59.95,Default,,0,0,0,,teknik penyihir kelas satu untuk\Nmengendalikan energi terkutuk lebih tepat.
Dialogue: 0,0:20:00.03,0:20:00.87,Default,,0,0,0,,(Jika kau pandai mengendalikan\Nenergi terkutuk, itu terbagi merata.)
Dialogue: 0,0:20:00.95,0:20:02.95,Default,,0,0,0,,Membuatnya sulit memprediksi serangan\Nsampai saat terakhir.
Dialogue: 0,0:20:04.96,0:20:06.46,Default,,0,0,0,,Tapi orang ini…
Dialogue: 0,0:20:06.54,0:20:07.67,Default,,0,0,0,,termasuk bilahnya,
Dialogue: 0,0:20:07.75,0:20:10.71,Default,,0,0,0,,seluruh tubuhnya\Nterus dipenuhi energi terkutuk.
Dialogue: 0,0:20:10.79,0:20:13.59,Default,,0,0,0,,Ini bukan hanya masalah\Nmemprediksi gerakannya.
Dialogue: 0,0:20:13.67,0:20:16.26,Default,,0,0,0,,Semua serangannya fatal.
Dialogue: 0,0:20:16.34,0:20:19.47,Default,,0,0,0,,Pada saat yang sama,\Ndia meminimalkan semua kerusakan.
Dialogue: 0,0:20:19.97,0:20:21.31,Default,,0,0,0,,Kuserahkan sisanya padamu.
Dialogue: 0,0:20:22.01,0:20:25.77,Default,,0,0,0,,Maaf, tapi aku belum boleh mati.
Dialogue: 0,0:20:33.53,0:20:34.86,Default,,0,0,0,,Ada tipe murid tertentu.
Dialogue: 0,0:20:34.94,0:20:37.61,Default,,0,0,0,,Aku akan melatih mereka\Ncara menggunakan senjata.
Dialogue: 0,0:20:39.07,0:20:40.41,Default,,0,0,0,,Tapi karena itu,\Nmereka terlalu mengandalkan alat terkutuk.
Dialogue: 0,0:20:40.49,0:20:43.41,Default,,0,0,0,,Mengabaikan kendali energi terkutuk\Njuga tidak baik.
Dialogue: 0,0:20:43.49,0:20:46.00,Default,,0,0,0,,Kurasa Yuji tidak perlu\Nmempelajari ini untuk saat ini.
Dialogue: 0,0:20:47.00,0:20:48.79,Default,,0,0,0,,Iblis Pembantai\Nhanya untuk keadaan darurat.
Dialogue: 0,0:20:50.21,0:20:52.00,Default,,0,0,0,,Aku tidak pernah mempelajarinya!
Dialogue: 0,0:20:53.84,0:20:55.01,Default,,0,0,0,,Kesadaranmu…
Dialogue: 0,0:20:55.09,0:20:56.30,Default,,0,0,0,,terlalu fokus pada pedangku.
Dialogue: 0,0:21:04.10,0:21:05.18,Default,,0,0,0,,Dia mematahkannya.
Dialogue: 0,0:21:05.68,0:21:06.98,Default,,0,0,0,,Sudah kuduga.
Dialogue: 0,0:21:07.06,0:21:09.23,Default,,0,0,0,,Lagi pula, dia murid Pak Gojo.
Dialogue: 0,0:21:09.31,0:21:11.19,Default,,0,0,0,,Dia benar-benar sulit ditangani.
Dialogue: 0,0:21:11.81,0:21:12.86,Default,,0,0,0,,Lukanya dalam.
Dialogue: 0,0:21:12.94,0:21:14.57,Default,,0,0,0,,Tapi organ dalamnya belum mencuat.
Dialogue: 0,0:21:14.65,0:21:16.24,Default,,0,0,0,,Kalau begitu,\Ndia dan aku tidak bersenjata.
Dialogue: 0,0:21:16.32,0:21:17.44,Default,,0,0,0,,Aku mungkin masih bisa menang.
Dialogue: 0,0:21:22.78,0:21:25.91,Default,,0,0,0,,Apa yang kau lakukan?
Dialogue: 0,0:21:28.87,0:21:31.71,Default,,0,0,0,,Kami hanya bermain-main, Rika.
Dialogue: 0,0:21:32.84,0:21:33.88,Default,,0,0,0,,Rika?
Dialogue: 0,0:21:33.96,0:21:35.05,Default,,0,0,0,,Benda apa ini?
Dialogue: 0,0:21:35.13,0:21:36.05,Default,,0,0,0,,Shikigami?
Dialogue: 0,0:21:36.13,0:21:37.67,Default,,0,0,0,,Dari mana asalnya?
Dialogue: 0,0:21:39.26,0:21:40.76,Default,,0,0,0,,Tahan dia.
Dialogue: 0,0:21:41.43,0:21:42.72,Default,,0,0,0,,Aku tidak bisa bergerak.
Dialogue: 0,0:21:44.76,0:21:46.72,Default,,0,0,0,,Kekuatan yang luar biasa.
Dialogue: 0,0:21:53.98,0:21:55.23,Default,,0,0,0,,Maafkan aku.
Dialogue: 0,0:22:01.99,0:22:03.37,Default,,0,0,0,,Itadori.
Dialogue: 0,0:23:40.46,0:23:42.88,Default,,0,0,0,,Kakak yang lebih lemah\Ntidak punya alasan untuk hidup, bukan?
Dialogue: 0,0:23:42.97,0:23:45.51,Default,,0,0,0,,Aku tidak bisa memahamimu\Nyang tidak menyayangi kerabatnya.
Dialogue: 0,0:23:45.59,0:23:47.97,Default,,0,0,0,,- Itadori sudah mati.\N- Mungkin semua distorsi
Dialogue: 0,0:23:48.05,0:23:49.51,Default,,0,0,0,,dimulai dari momen itu.
Dialogue: 0,0:23:49.60,0:23:50.47,Default,,0,0,0,,Jangan meremehkanku.
Dialogue: 0,0:23:50.56,0:23:52.02,Default,,0,0,0,,- Jadi, tolong aku dahulu.\N- Kau tersudut.
Dialogue: 0,0:23:52.10,0:23:54.85,Default,,0,0,0,,(EPISODE BERIKUTNYA, SEKALI LAGI)\NTsumiki juga ada di Permainan Membasmi.

