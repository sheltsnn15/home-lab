Dialogue: 0,0:01:56.47,0:01:57.88,Sottotitoli,Narratore,0000,0000,0000,,Incidilo...
Dialogue: 0,0:02:03.76,0:02:06.14,Sottotitoli,Narratore,0000,0000,0000,,Incidilo nella carne...
Dialogue: 0,0:02:13.19,0:02:15.44,Sottotitoli,Narratore,0000,0000,0000,,Incidilo nella terra...
Dialogue: 0,0:02:21.45,0:02:23.74,Sottotitoli,Narratore,0000,0000,0000,,Incidilo nel mare...
Dialogue: 0,0:02:28.62,0:02:31.25,Sottotitoli,Narratore,0000,0000,0000,,Incidilo nel nemico...
Dialogue: 0,0:02:31.67,0:02:33.75,Sottotitoli,Narratore,0000,0000,0000,,Incidilo nella preda...
Dialogue: 0,0:02:36.17,0:02:38.13,Sottotitoli,Narratore,0000,0000,0000,,Incidilo...
Dialogue: 0,0:02:38.88,0:02:40.76,Sottotitoli,Narratore,0000,0000,0000,,Incidi...
Dialogue: 0,0:02:57.07,0:02:58.82,Sottotitoli,Narratore,0000,0000,0000,,Quel calore...
Dialogue: 0,0:02:58.82,0:03:01.24,Sottotitoli,Narratore,0000,0000,0000,,Dentro di me...
Dialogue: 0,0:03:16.00,0:03:22.26,Cartelli Times,Sign,0000,0000,0000,,{\fad(350,550)\shad1\an1\bord0\fs23\b0\blur5\t(362,1280,\blur0)\t(5075,5492,\blur5)\c&HD5DCDB&\pos(41.434,314.121)}#01\h\h\hSchiavo
Dialogue: 0,0:03:23.33,0:03:24.18,Dialogue,Emma,0000,0000,0000,,Einar!
Dialogue: 0,0:03:29.04,0:03:30.43,Dialogue,Einar,0000,0000,0000,,Che cavolo fai?!
Dialogue: 0,0:03:30.43,0:03:32.43,Dialogue,Emma,0000,0000,0000,,Questo dovrei essere io a dirlo!
Dialogue: 0,0:03:32.85,0:03:35.94,Dialogue,Emma,0000,0000,0000,,Hai intenzione di distruggere la casa\Ntagliando quell'albero?
Dialogue: 0,0:03:37.45,0:03:39.76,Dialogue,Lotta,0000,0000,0000,,Einar, vuoi diventare un taglialegna?
Dialogue: 0,0:03:39.76,0:03:41.45,Dialogue,Einar,0000,0000,0000,,Ti sbagli!
Dialogue: 0,0:03:41.45,0:03:43.83,Dialogue,Einar,0000,0000,0000,,Mi sto esercitando per combattere!
Dialogue: 0,0:03:43.83,0:03:45.20,Dialogue,Einar,0000,0000,0000,,Guarda che forza!
Dialogue: 0,0:03:46.11,0:03:50.01,Dialogue,Emma,0000,0000,0000,,Essere grandi e grossi\Nnon è utile in battaglia!
Dialogue: 0,0:03:50.01,0:03:51.54,Dialogue,Emma,0000,0000,0000,,Va' a preparare per mangiare!
Dialogue: 0,0:03:51.54,0:03:54.08,Dialogue,Lotta,0000,0000,0000,,Che fame!
Dialogue: 0,0:03:57.99,0:04:00.25,Dialogue,Einar,0000,0000,0000,,Comunque, non lanciarmi contro coltelli!
Dialogue: 0,0:04:00.25,0:04:02.70,Dialogue,Einar,0000,0000,0000,,Esistono anche piatti e cucchiai, no?!
Dialogue: 0,0:04:02.70,0:04:04.39,Dialogue,Emma,0000,0000,0000,,Ah, quindi i piatti vanno bene?
Dialogue: 0,0:04:09.57,0:04:10.35,Dialogue,Lotta,0000,0000,0000,,Te l'ho detto,
Dialogue: 0,0:04:10.61,0:04:14.44,Dialogue,Lotta,0000,0000,0000,,prima che arrivi l'inverno,\Ngli orsi devono riempirsi per bene la pancia.
Dialogue: 0,0:04:14.44,0:04:15.63,Dialogue,Emma,0000,0000,0000,,Davvero?
Dialogue: 0,0:04:19.93,0:04:23.78,Dialogue,Emma,0000,0000,0000,,E quindi? Come mai all'improvviso\Nti sei messo di nuovo ad esercitarti?
Dialogue: 0,0:04:20.53,0:04:21.73,Dialogue Top,Lotta,0000,0000,0000,,Grazie.
Dialogue: 0,0:04:25.27,0:04:26.70,Dialogue,Einar,0000,0000,0000,,Perché
Dialogue: 0,0:04:26.70,0:04:28.78,Dialogue,Einar,0000,0000,0000,,devo proteggere questo posto, no?
Dialogue: 0,0:04:31.96,0:04:34.01,Dialogue,Einar,0000,0000,0000,,Dopo essere stato messo a ferro e fuoco,
Dialogue: 0,0:04:34.32,0:04:36.56,Dialogue,Einar,0000,0000,0000,,il villaggio si è finalmente risollevato.
Dialogue: 0,0:04:38.35,0:04:40.91,Dialogue,Einar,0000,0000,0000,,Non vuoi che succeda ancora, no?
Dialogue: 0,0:04:43.17,0:04:44.34,Dialogue,Einar,0000,0000,0000,,Anche nostro padre...
Dialogue: 0,0:04:46.38,0:04:49.14,Dialogue,Lotta,0000,0000,0000,,Il latte del signor Guthrum è buonissimo!
Dialogue: 0,0:04:49.38,0:04:51.90,Dialogue,Emma,0000,0000,0000,,Vero?! Ci sa fare parecchio!
Dialogue: 0,0:04:51.90,0:04:54.20,Dialogue,Emma,0000,0000,0000,,Quando si tratta di mammelle,\Nsa bene dove mettere le mani!
Dialogue: 0,0:04:54.20,0:04:56.36,Dialogue,Lotta,0000,0000,0000,,Basta con quei gesti! Sei disgustosa!
Dialogue: 0,0:04:56.36,0:04:58.26,Dialogue,Einar,0000,0000,0000,,Volete ascoltarmi?!
Dialogue: 0,0:04:58.06,0:04:59.11,Dialogue Top,Lotta,0000,0000,0000,,Davvero!
Dialogue: 0,0:04:58.26,0:05:00.02,Dialogue,Emma,0000,0000,0000,,Lascia perdere.
Dialogue: 0,0:05:00.02,0:05:01.86,Dialogue,Emma,0000,0000,0000,,Meglio non averci a che fare con i guerrieri.
Dialogue: 0,0:05:04.28,0:05:07.32,Dialogue,Einar,0000,0000,0000,,Non è umiliante essere sempre quelli che perdono?
Dialogue: 0,0:05:07.63,0:05:10.92,Dialogue,Einar,0000,0000,0000,,Nostro padre è morto per proteggerci.
Dialogue: 0,0:05:10.92,0:05:11.87,Dialogue,Emma,0000,0000,0000,,Sì, è così.
Dialogue: 0,0:05:12.16,0:05:13.91,Dialogue,Emma,0000,0000,0000,,E tu sei vivo.
Dialogue: 0,0:05:13.91,0:05:15.52,Dialogue,Emma,0000,0000,0000,,Hai contribuito a risollevare il villaggio
Dialogue: 0,0:05:15.52,0:05:18.54,Dialogue,Emma,0000,0000,0000,,e ora sei qui a mangiare insieme a due belle donne.
Dialogue: 0,0:05:22.85,0:05:24.28,Dialogue,Emma,0000,0000,0000,,Non hai assolutamente perso.
Dialogue: 0,0:06:13.36,0:06:14.37,Dialogue,Emma,0000,0000,0000,,Ascoltatemi bene.
Dialogue: 0,0:06:14.37,0:06:16.35,Dialogue,Emma,0000,0000,0000,,Una volta nella foresta dobbiamo correre.
Dialogue: 0,0:06:16.35,0:06:17.39,Dialogue,Emma,0000,0000,0000,,Da lì, seguiremo il fiume...
Dialogue: 0,0:06:18.43,0:06:19.31,Dialogue,Einar,0000,0000,0000,,Lotta...
Dialogue: 0,0:06:20.58,0:06:21.73,Dialogue,Einar,0000,0000,0000,,Madre...
Dialogue: 0,0:06:31.81,0:06:34.62,Dialogue,Emma,0000,0000,0000,,Corri sempre dritta, senza pensare a niente.
Dialogue: 0,0:06:35.68,0:06:37.58,Dialogue,Emma,0000,0000,0000,,Io e tuo fratello saremo con te.
Dialogue: 0,0:07:13.68,0:07:14.77,Dialogue,Einar,0000,0000,0000,,Madre!
Dialogue: 0,0:07:24.15,0:07:25.82,Dialogue,Einar,0000,0000,0000,,Resisti, ti tiro su.
Dialogue: 0,0:07:29.03,0:07:30.10,Dialogue,Einar,0000,0000,0000,,Madre!
Dialogue: 0,0:07:39.35,0:07:40.40,Dialogue,Emma,0000,0000,0000,,Einar...
Dialogue: 0,0:07:40.86,0:07:41.78,Dialogue,Emma,0000,0000,0000,,Scappa...
Dialogue: 0,0:07:42.58,0:07:43.59,Dialogue,Emma,0000,0000,0000,,Lasciami
Dialogue: 0,0:07:43.95,0:07:44.97,Dialogue,Emma,0000,0000,0000,,qui.
Dialogue: 0,0:07:44.97,0:07:45.91,Dialogue,Einar,0000,0000,0000,,Non dire idiozie!
Dialogue: 0,0:07:47.26,0:07:49.89,Dialogue,Einar,0000,0000,0000,,Non preoccuparti!\NCerca di alzarti!
Dialogue: 0,0:07:49.89,0:07:51.06,Dialogue,Lotta,0000,0000,0000,,Madre!
Dialogue: 0,0:07:51.76,0:07:52.95,Dialogue,Lotta,0000,0000,0000,,Madre!
Dialogue: 0,0:08:00.76,0:08:03.04,Dialogue,Lotta,0000,0000,0000,,Madre!
Dialogue: 0,0:08:05.34,0:08:06.75,Dialogue,Emma,0000,0000,0000,,Sciocca...
Dialogue: 0,0:08:09.28,0:08:10.61,Dialogue,Vichingo B,0000,0000,0000,,Ehi, laggiù!
Dialogue: 0,0:08:10.61,0:08:12.55,Dialogue,Vichingo B,0000,0000,0000,,C'è ancora gente!
Dialogue: 0,0:08:12.92,0:08:15.04,Dialogue,Vichingo C,0000,0000,0000,,Ah, c'è anche una donna!
Dialogue: 0,0:08:15.04,0:08:16.55,Dialogue,Vichingo B,0000,0000,0000,,Stiamo arrivando!
Dialogue: 0,0:08:29.16,0:08:30.75,Dialogue,Emma,0000,0000,0000,,Alzati, Einar!
Dialogue: 0,0:08:32.49,0:08:34.57,Dialogue,Emma,0000,0000,0000,,Presto, prendi Lotta e...
Dialogue: 0,0:08:36.53,0:08:37.53,Dialogue,Einar,0000,0000,0000,,Madre...
Dialogue: 0,0:08:40.69,0:08:42.75,Dialogue,Emma,0000,0000,0000,,Una vecchia mezza morta come me...
Dialogue: 0,0:08:43.37,0:08:44.62,Dialogue,Emma,0000,0000,0000,,Può benissimo...
Dialogue: 0,0:08:46.78,0:08:48.29,Dialogue,Emma,0000,0000,0000,,Vivi!
Dialogue: 0,0:08:51.26,0:08:53.28,Dialogue,Emma,0000,0000,0000,,Se sopravvivrai...
Dialogue: 0,0:08:54.27,0:08:55.16,Dialogue,Emma,0000,0000,0000,,Un giorno...
Dialogue: 0,0:09:04.94,0:09:07.19,Dialogue,Emma,0000,0000,0000,,Ei... nar...
Dialogue: 0,0:09:08.73,0:09:10.14,Dialogue,Emma,0000,0000,0000,,Lot... te...
Dialogue: 0,0:09:30.68,0:09:32.77,Dialogue,Vichingo B,0000,0000,0000,,Perché questi qua non scappano?
Dialogue: 0,0:09:32.77,0:09:35.47,Dialogue,Vichingo C,0000,0000,0000,,Ah! Questa ragazza è parecchio carina.
Dialogue: 0,0:09:36.28,0:09:38.68,Dialogue,Vichingo D,0000,0000,0000,,La tua mammina è morta, no?
Dialogue: 0,0:09:40.28,0:09:41.10,Dialogue,Einar,0000,0000,0000,,Lotta!
Dialogue: 0,0:09:41.10,0:09:42.34,Dialogue,Lotta,0000,0000,0000,,Lasciami!
Dialogue: 0,0:09:42.34,0:09:43.29,Dialogue,Lotta,0000,0000,0000,,Einar!
Dialogue: 0,0:09:43.29,0:09:44.10,Dialogue,Einar,0000,0000,0000,,Lotta!
Dialogue: 0,0:09:44.45,0:09:45.73,Dialogue,Einar,0000,0000,0000,,Lascia immediatamente Lotta!
Dialogue: 0,0:09:47.41,0:09:48.53,Dialogue,Lotta,0000,0000,0000,,Einar!
Dialogue: 0,0:09:50.20,0:09:51.54,Dialogue,Lotta,0000,0000,0000,,Non vi perdonerò mai!
Dialogue: 0,0:09:51.54,0:09:52.65,Dialogue,Lotta,0000,0000,0000,,Maledetti!
Dialogue: 0,0:09:53.21,0:09:54.16,Dialogue,Lotta,0000,0000,0000,,Einar!
Dialogue: 0,0:09:55.02,0:09:56.24,Dialogue,Lotta,0000,0000,0000,,Einar!
Dialogue: 0,0:10:05.78,0:10:06.58,Dialogue,Lotta,0000,0000,0000,,Mio fratello non si toc—
Dialogue: 0,0:10:17.72,0:10:20.23,Dialogue,Vichingo C,0000,0000,0000,,Ehi, che diavolo fai?
Dialogue: 0,0:10:20.23,0:10:23.35,Dialogue,Vichingo B,0000,0000,0000,,Mi ha infilzato con qualcosa!
Dialogue: 0,0:10:23.35,0:10:25.43,Dialogue,Vichingo C,0000,0000,0000,,Ah, che spreco!
Dialogue: 0,0:10:25.43,0:10:26.69,Dialogue,Vichingo D,0000,0000,0000,,Ormai è fatta.
Dialogue: 0,0:10:26.69,0:10:29.47,Dialogue,Vichingo D,0000,0000,0000,,Vendiamo questo qua\Ne andiamo a bere coi soldi che ci frutterà.
Dialogue: 0,0:10:30.13,0:10:31.55,Dialogue,Vichingo C,0000,0000,0000,,Sei proprio un idiota.
Dialogue: 0,0:10:31.55,0:10:33.33,Dialogue,Vichingo B,0000,0000,0000,,Eddai, mi dispiace.
Dialogue: 0,0:10:33.33,0:10:36.00,Dialogue,Vichingo D,0000,0000,0000,,Forza, andiamocene.
Dialogue: 0,0:11:33.29,0:11:45.26,Cartelli Times,Sign,0000,0000,0000,,{\an7\fad(1125,0)\bord1\b0\blur2\3c&H000000&\3a&H46&\pos(382,32)\fs18}S'inaridisce l'albero\Nche s'erge su un brullo colle,\Nné foglie né scorza lo proteggono.\NCosì è l'uomo che nessuno ama:\Na che scopo dovrebbe vivere a lungo?\N\NTratto da "Hávamál"
Dialogue: 0,0:12:23.24,0:12:24.05,Dialogue,Mercante A,0000,0000,0000,,Allora?
Dialogue: 0,0:12:27.56,0:12:29.43,Dialogue,Mercante B,0000,0000,0000,,Niente, è inutile.
Dialogue: 0,0:12:29.43,0:12:31.22,Dialogue,Mercante A,0000,0000,0000,,Dannazione.
Dialogue: 0,0:12:31.22,0:12:33.25,Dialogue,Mercante A,0000,0000,0000,,C'è poco da fare, prendiamola.
Dialogue: 0,0:12:45.72,0:12:47.37,Dialogue,Mercante A - Mercante B,0000,0000,0000,,Oh issa!
Dialogue: 0,0:12:49.94,0:12:50.70,Dialogue,Einar,0000,0000,0000,,Ehi!
Dialogue: 0,0:13:01.88,0:13:02.97,Dialogue,Einar,0000,0000,0000,,Ehi!
Dialogue: 0,0:13:02.97,0:13:04.26,Dialogue,Einar,0000,0000,0000,,Che diavolo fai?!
Dialogue: 0,0:13:04.26,0:13:05.93,Dialogue,Einar,0000,0000,0000,,Che bisogno c'era di gettarla in mare?!
Dialogue: 0,0:13:10.79,0:13:12.87,Dialogue,Mercante A,0000,0000,0000,,Bene, non vedo nessun gonfiore.
Dialogue: 0,0:13:15.41,0:13:16.96,Dialogue,Mercante B,0000,0000,0000,,Vi porto delle coperte.
Dialogue: 0,0:13:16.96,0:13:19.65,Dialogue,Mercante B,0000,0000,0000,,Copritevi e non prendete freddo!
Dialogue: 0,0:13:20.05,0:13:22.58,Dialogue,Mercante B,0000,0000,0000,,Siete costati un sacco di soldi!
Dialogue: 0,0:13:22.58,0:13:25.65,Dialogue,Mercante B,0000,0000,0000,,Non avete il diritto di ammalarvi!
Dialogue: 0,0:13:26.35,0:13:29.41,Dialogue,Mercante B,0000,0000,0000,,Cercate di rimanere in salute\Nfino a quando non avremo trovato degli acquirenti.
Dialogue: 0,0:13:29.41,0:13:30.57,Dialogue,Mercante B,0000,0000,0000,,Intesi?
Dialogue: 0,0:13:33.54,0:13:35.15,Dialogue,Mercante B,0000,0000,0000,,Avanti, non state lì impalati!
Dialogue: 0,0:13:35.15,0:13:36.60,Dialogue,Mercante B,0000,0000,0000,,Ammainate la vela!
Dialogue: 0,0:14:04.45,0:14:05.51,Dialogue,Einar,0000,0000,0000,,Sì...
Dialogue: 0,0:14:06.72,0:14:07.92,Dialogue,Einar,0000,0000,0000,,Devo vivere...
Dialogue: 0,0:14:18.92,0:14:22.54,Dialogue,Mercante D,0000,0000,0000,,Bevete alcolici, vi daranno un bel colorito.
Dialogue: 0,0:14:23.30,0:14:26.59,Dialogue,Mercante C,0000,0000,0000,,Lavatevi bene, soprattutto i capelli.
Dialogue: 0,0:14:27.12,0:14:29.17,Dialogue,Mercante C,0000,0000,0000,,Mettetevi in coppia e toglietevi i pidocchi!
Dialogue: 0,0:14:33.69,0:14:36.14,Dialogue,Donna B,0000,0000,0000,,Che te ne pare?
Dialogue: 0,0:14:37.22,0:14:38.86,Dialogue,Mercante A,0000,0000,0000,,I capelli vanno bene.
Dialogue: 0,0:14:38.86,0:14:41.48,Dialogue,Mercante A,0000,0000,0000,,Truccala in modo da farla sembrare più giovane.
Dialogue: 0,0:14:56.41,0:14:57.80,Dialogue,Mercante A,0000,0000,0000,,Allora?
Dialogue: 0,0:14:57.80,0:14:59.75,Dialogue,Mercante A,0000,0000,0000,,Anche stavolta abbiamo degli schiavi bellissimi.
Dialogue: 0,0:15:00.27,0:15:02.29,Dialogue,Cliente A,0000,0000,0000,,Ma se sono tutti di seconda categoria...
Dialogue: 0,0:15:02.29,0:15:03.79,Dialogue,Mercante A,0000,0000,0000,,Ma che dice!
Dialogue: 0,0:15:03.79,0:15:05.81,Dialogue,Mercante A,0000,0000,0000,,Nessuno ne ha di più belli dei nostri.
Dialogue: 0,0:15:09.18,0:15:10.38,Internal,Einar,0000,0000,0000,,Ma certo!
Dialogue: 0,0:15:10.38,0:15:12.23,Internal,Einar,0000,0000,0000,,Chi è che vuole restare in un posto del genere?
Dialogue: 0,0:15:13.01,0:15:14.12,Internal,Einar,0000,0000,0000,,Se scappo
Dialogue: 0,0:15:14.12,0:15:15.06,Internal,Einar,0000,0000,0000,,e riesco a sopravvivere...
Dialogue: 0,0:15:15.79,0:15:16.75,Internal,Einar,0000,0000,0000,,Allora...
Dialogue: 0,0:15:39.45,0:15:41.04,Dialogue,Donna C,0000,0000,0000,,Oplà.
Dialogue: 0,0:15:43.79,0:15:45.22,Dialogue,Donna C,0000,0000,0000,,Al ladro!
Dialogue: 0,0:15:46.26,0:15:47.39,Dialogue,Einar,0000,0000,0000,,Scusa!
Dialogue: 0,0:15:54.30,0:15:55.76,Dialogue,Mercante A,0000,0000,0000,,Ehi, Einar.
Dialogue: 0,0:15:56.60,0:15:59.33,Dialogue,Mercante A,0000,0000,0000,,Sembra che tu non abbia ancora capito.
Dialogue: 0,0:16:06.97,0:16:09.28,Dialogue,Mercante A,0000,0000,0000,,Ascoltate, schiavi!
Dialogue: 0,0:16:09.28,0:16:10.82,Dialogue,Mercante A,0000,0000,0000,,Aprite bene le orecchie!
Dialogue: 0,0:16:11.73,0:16:14.63,Dialogue,Mercante A,0000,0000,0000,,Le vostre case sono al di là del mare!
Dialogue: 0,0:16:14.63,0:16:17.13,Dialogue,Mercante A,0000,0000,0000,,Non riuscirete mai a tornarci con le vostre forze!
Dialogue: 0,0:16:17.13,0:16:18.81,Dialogue,Mercante A,0000,0000,0000,,E naturalmente,
Dialogue: 0,0:16:18.81,0:16:22.00,Dialogue,Mercante A,0000,0000,0000,,qui non c'è nessuno\Ndisposto ad aiutarvi nella vostra fuga!
Dialogue: 0,0:16:22.36,0:16:23.71,Dialogue,Mercante A,0000,0000,0000,,Questo perché
Dialogue: 0,0:16:23.71,0:16:26.92,Dialogue,Mercante A,0000,0000,0000,,voialtri non siete altro che dei semplici
Dialogue: 0,0:16:27.26,0:16:28.78,Dialogue,Mercante A,0000,0000,0000,,schiavi!
Dialogue: 0,0:16:29.39,0:16:32.92,Dialogue,Mercante A,0000,0000,0000,,Vi farete comprare da un buon padrone\N e lavorerete sodo!
Dialogue: 0,0:16:33.50,0:16:37.69,Dialogue,Mercante A,0000,0000,0000,,Così mangerete meglio rispetto a fuggire\Ne fare una vita da mendicanti!
Dialogue: 0,0:16:38.00,0:16:41.93,Dialogue,Mercante A,0000,0000,0000,,Prima di buttarvi all'avventura,\Npensate bene a cosa vi conviene di più!
Dialogue: 0,0:16:42.97,0:16:45.26,Dialogue,Mercante A,0000,0000,0000,,Hai capito, Einar?
Dialogue: 0,0:17:00.36,0:17:01.22,Dialogue,Einar,0000,0000,0000,,Vi...
Dialogue: 0,0:17:03.03,0:17:04.01,Dialogue,Einar,0000,0000,0000,,Vivere...
Dialogue: 0,0:17:12.55,0:17:16.16,Dialogue,Cliente B,0000,0000,0000,,Uhm, sì...
Dialogue: 0,0:17:16.16,0:17:20.77,Dialogue,Cliente B,0000,0000,0000,,Non è niente male, ma non ne avrebbe uno più carino?
Dialogue: 0,0:17:20.77,0:17:22.47,Dialogue,Mercante D,0000,0000,0000,,D'accordo.
Dialogue: 0,0:17:22.47,0:17:26.16,Dialogue,Mercante D,0000,0000,0000,,Ne ho qui uno speciale solo per lei.
Dialogue: 0,0:17:26.16,0:17:29.21,Dialogue,Cliente B,0000,0000,0000,,Ah, davvero? Vediamo un po'!
Dialogue: 0,0:17:29.21,0:17:32.19,Dialogue,Mercante D,0000,0000,0000,,Sono sicuro che le piacerà.
Dialogue: 0,0:17:37.73,0:17:39.31,Internal,Einar,0000,0000,0000,,È proprio come dicono loro.
Dialogue: 0,0:17:40.44,0:17:42.06,Internal,Einar,0000,0000,0000,,Anche se provassi a scappare,
Dialogue: 0,0:17:42.51,0:17:44.20,Internal,Einar,0000,0000,0000,,non avrei via di scampo.
Dialogue: 0,0:17:45.90,0:17:46.89,Internal,Einar,0000,0000,0000,,E poi...
Dialogue: 0,0:17:50.34,0:17:51.17,Internal,Einar,0000,0000,0000,,Ormai...
Dialogue: 0,0:17:52.54,0:17:55.33,Internal,Einar,0000,0000,0000,,Non ho più un posto dove andare...
Dialogue: 0,0:17:57.51,0:17:58.60,Internal,Einar,0000,0000,0000,,Forse è meglio
Dialogue: 0,0:17:59.87,0:18:02.35,Internal,Einar,0000,0000,0000,,che mi rassegni a farmi comprare.
Dialogue: 0,0:18:04.55,0:18:08.22,Dialogue,Mercante A,0000,0000,0000,,Lei è davvero un uomo fortunato.
Dialogue: 0,0:18:08.22,0:18:10.45,Dialogue,Mercante A,0000,0000,0000,,Ne sono arrivati molti proprio adesso.
Dialogue: 0,0:18:10.45,0:18:11.94,Dialogue,Mercante A,0000,0000,0000,,Ecco, guardi.
Dialogue: 0,0:18:14.23,0:18:16.49,Dialogue,Mercante A,0000,0000,0000,,È lui quello che va cercando, no?
Dialogue: 0,0:18:42.93,0:18:45.48,Dialogue,Leif,0000,0000,0000,,Ma è completamente diverso!
Dialogue: 0,0:18:45.48,0:18:47.75,Dialogue,Leif,0000,0000,0000,,Non è né biondo né piccoletto!
Dialogue: 0,0:18:47.75,0:18:49.17,Dialogue,Mercante A,0000,0000,0000,,Eh?
Dialogue: 0,0:18:49.17,0:18:51.06,Dialogue,Mercante A,0000,0000,0000,,Ora che lo guardo bene, devo dire che ha ragione.
Dialogue: 0,0:18:51.45,0:18:54.00,Dialogue,Mercante A,0000,0000,0000,,Comunque, che ne pensa di lui?
Dialogue: 0,0:18:54.00,0:18:56.57,Dialogue,Mercante A,0000,0000,0000,,È forte ed è in salute.\NSe lo compra adesso...
Dialogue: 0,0:18:56.57,0:19:00.95,Dialogue,Leif,0000,0000,0000,,Gliel'ho già detto!\NNon sono venuto a comprare un bracciante!
Dialogue: 0,0:19:01.29,0:19:04.01,Dialogue,Leif,0000,0000,0000,,Sono qui per liberare un mio parente!
Dialogue: 0,0:19:04.01,0:19:07.48,Dialogue,Leif,0000,0000,0000,,Sono sicuro che sia stato venduto in questa città!
Dialogue: 0,0:19:07.83,0:19:11.25,Dialogue,Leif,0000,0000,0000,,È biondo e piccolo di statura, si chiama Thorfinn!
Dialogue: 0,0:19:11.25,0:19:14.34,Dialogue,Leif,0000,0000,0000,,È proprio sicuro di non saperne niente?
Dialogue: 0,0:19:21.89,0:19:23.38,Dialogue,Leif,0000,0000,0000,,Mi dispiace.
Dialogue: 0,0:19:26.10,0:19:27.41,Dialogue,Leif,0000,0000,0000,,Scusi il disturbo.
Dialogue: 0,0:19:27.41,0:19:30.40,Dialogue,Mercante A,0000,0000,0000,,Si ricordi di noi la prossima volta!
Dialogue: 0,0:19:32.78,0:19:34.67,Dialogue,Mercante A,0000,0000,0000,,Non lo troverà mai.
Dialogue: 0,0:19:37.70,0:19:39.27,Internal,Einar,0000,0000,0000,,Se ne va in giro
Dialogue: 0,0:19:39.27,0:19:42.24,Internal,Einar,0000,0000,0000,,a cercare un parente...
Dialogue: 0,0:19:45.89,0:19:48.47,Internal,Einar,0000,0000,0000,,Il tizio che cerca
Dialogue: 0,0:19:48.83,0:19:50.29,Internal,Einar,0000,0000,0000,,dev'essere veramente fortunato.
Dialogue: 0,0:19:55.15,0:19:56.49,Dialogue,Ketil,0000,0000,0000,,Ehi, tu!
Dialogue: 0,0:20:01.22,0:20:03.14,Dialogue,Ketil,0000,0000,0000,,Capisci la mia lingua?
Dialogue: 0,0:20:03.14,0:20:04.77,Dialogue,Ketil,0000,0000,0000,,Fammi vedere i denti.
Dialogue: 0,0:20:18.27,0:20:19.51,Dialogue,Ketil,0000,0000,0000,,Come ti chiami?
Dialogue: 0,0:20:19.91,0:20:21.74,Dialogue,Einar,0000,0000,0000,,Einar.
Dialogue: 0,0:20:21.74,0:20:24.13,Dialogue,Ketil,0000,0000,0000,,Che tipo di lavoro hai fatto in passato e dove?
Dialogue: 0,0:20:24.56,0:20:27.16,Dialogue,Einar,0000,0000,0000,,Ho coltivato campi nell'Inghilterra del nord.
Dialogue: 0,0:20:27.16,0:20:28.58,Dialogue,Ketil,0000,0000,0000,,Oh.
Dialogue: 0,0:20:37.24,0:20:38.65,Dialogue,Ketil,0000,0000,0000,,Che ne dici, Einar?
Dialogue: 0,0:20:38.99,0:20:41.43,Dialogue,Ketil,0000,0000,0000,,Ti andrebbe di lavorare nei miei campi?
Dialogue: 0,0:20:49.45,0:20:50.84,Dialogue,Einar,0000,0000,0000,,Campi?
Dialogue: 0,0:21:14.21,0:21:16.34,Dialogue,Ketil,0000,0000,0000,,Einar, da questa parte.
Dialogue: 0,0:21:20.64,0:21:22.92,Dialogue,Ketil,0000,0000,0000,,La mia famiglia è al lavoro.
Dialogue: 0,0:21:22.92,0:21:25.87,Dialogue,Ketil,0000,0000,0000,,Ti presenterò a tutti durante la cena.
Dialogue: 0,0:21:25.87,0:21:26.89,Dialogue,Einar,0000,0000,0000,,Grazie.
Dialogue: 0,0:21:28.37,0:21:30.89,Dialogue,Ketil,0000,0000,0000,,Per cominciare, dai un'occhiata alla mia fattoria.
Dialogue: 0,0:22:02.60,0:22:03.42,Internal,Einar,0000,0000,0000,,Ah,
Dialogue: 0,0:22:04.05,0:22:05.15,Internal,Einar,0000,0000,0000,,madre.
Dialogue: 0,0:22:05.88,0:22:07.12,Internal,Einar,0000,0000,0000,,È tutto vero?
Dialogue: 0,0:22:09.48,0:22:10.44,Internal,Einar,0000,0000,0000,,Ormai,
Dialogue: 0,0:22:11.05,0:22:14.75,Internal,Einar,0000,0000,0000,,non ho più la libertà \Ndi decidere se vivere o morire.
Dialogue: 0,0:22:16.43,0:22:17.85,Internal,Einar,0000,0000,0000,,Nonostante ciò,
Dialogue: 0,0:22:19.18,0:22:21.23,Internal,Einar,0000,0000,0000,,dici ancora che non ho perso?
Dialogue: 0,0:22:45.28,0:22:46.99,Flashback Internal,Einar,0000,0000,0000,,Mi venne portata via la famiglia...
Dialogue: 0,0:22:47.46,0:22:48.54,Flashback Internal,Einar,0000,0000,0000,,Il mio paese natio...
Dialogue: 0,0:22:49.01,0:22:51.01,Flashback Internal,Einar,0000,0000,0000,,Avevo perso tutto...
Dialogue: 0,0:22:52.76,0:22:54.40,Flashback Internal,Einar,0000,0000,0000,,Non riuscivo nemmeno più a capire
Dialogue: 0,0:22:55.13,0:22:56.88,Flashback Internal,Einar,0000,0000,0000,,quale fosse il significato di vivere.
Dialogue: 0,0:23:05.94,0:23:07.47,Dialogue,Ketil,0000,0000,0000,,Thorfinn!
Dialogue: 0,0:23:07.47,0:23:09.32,Dialogue,Ketil,0000,0000,0000,,Sono io! Vieni qua!
Dialogue: 0,0:23:25.44,0:23:27.45,Flashback Internal,Einar,0000,0000,0000,,Mi sarei fatto comprare \Nda un bravo padrone
Dialogue: 0,0:23:28.71,0:23:30.82,Flashback Internal,Einar,0000,0000,0000,,e avrei lavorato sodo.
Dialogue: 0,0:23:32.40,0:23:34.28,Flashback Internal,Einar,0000,0000,0000,,Se me ne fossi stato buono,
Dialogue: 0,0:23:34.28,0:23:36.47,Flashback Internal,Einar,0000,0000,0000,,avrei sempre avuto la pancia piena.
Dialogue: 0,0:23:37.64,0:23:40.71,Flashback Internal,Einar,0000,0000,0000,,Pian piano, iniziai a pensarla così.
Dialogue: 0,0:23:41.20,0:23:42.76,Dialogue,Einar,0000,0000,0000,,Thor... finn?
Dialogue: 0,0:23:54.81,0:23:55.99,Flashback Internal,Einar,0000,0000,0000,,Ad ogni modo,
Dialogue: 0,0:23:58.16,0:23:59.15,Flashback Internal,Einar,0000,0000,0000,,quello fu
Dialogue: 0,0:23:59.72,0:24:00.91,Flashback Internal,Einar,0000,0000,0000,,il giorno in cui
Dialogue: 0,0:24:01.79,0:24:03.13,Flashback Internal,Einar,0000,0000,0000,,conobbi Thorfinn.
Dialogue: 0,0:25:51.94,0:25:54.99,Cartelli Times,Sign,0000,0000,0000,,{\fad(675,0)\shad1\an1\bord0\fsp2\fs38\b0\blur5\t(694,1153,\blur0)\c&HD7E4D9&\pos(41.434,297.841)}#02\h\h\hLa fattoria di Ketil
