Dialogue: 0,0:18:12.59,0:18:13.68,Default,Mahito,0000,0000,0000,,Das war knapp!
Dialogue: 0,0:18:14.28,0:18:17.12,Internal,Mahito,0000,0000,0000,,Wenn ich’s riskiere und\Ndann vermassle, sterbe ich.
Dialogue: 0,0:18:17.12,0:18:20.32,Internal,Mahito,0000,0000,0000,,Dann greife ich eben vorerst\Nmit umgestalteten Menschen an.
Dialogue: 0,0:18:20.32,0:18:21.79,Default,Mahito,0000,0000,0000,,Da kriegt man ja Angst.
Dialogue: 0,0:18:22.14,0:18:24.29,Internal,Itadori,0000,0000,0000,,Er hat noch mehr Tricks drauf\Nals letztes Mal.
Dialogue: 0,0:18:33.47,0:18:34.51,Default,Junger Mann A,0000,0000,0000,,Ein Junge?
Dialogue: 0,0:18:34.51,0:18:36.48,Default,Junger Mann B,0000,0000,0000,,Hey, komm zu uns!
Dialogue: 0,0:18:36.48,0:18:39.06,Default,Junger Mann B,0000,0000,0000,,Da vorne ist alles voller Monster!
Dialogue: 0,0:18:39.44,0:18:41.06,Internal,Itadori,0000,0000,0000,,Dann ist er …
Dialogue: 0,0:18:41.28,0:18:42.45,Internal,Itadori,0000,0000,0000,,oben?
Dialogue: 0,0:18:44.08,0:18:45.48,Default,Itadori,0000,0000,0000,,Sorry.
Dialogue: 0,0:18:45.69,0:18:49.07,Default,Itadori,0000,0000,0000,,In Shibuya ist es grad nirgends sicher,\Nalso lauft so weit wie …
Dialogue: 0,0:18:51.87,0:18:54.07,Internal,Itadori,0000,0000,0000,,Dieser verdammte Wichser!
Dialogue: 0,0:19:03.21,0:19:04.96,Default,Mahito,0000,0000,0000,,Sag mal …
Dialogue: 0,0:19:07.29,0:19:09.75,Default,Mahito,0000,0000,0000,,Bist du nicht etwas fantasielos?
Dialogue: 0,0:19:10.11,0:19:10.75,Default,Itadori,0000,0000,0000,,Aufhören!
Dialogue: 0,0:19:11.21,0:19:14.39,Default,Mahito,0000,0000,0000,,Trottel. Du hast es doch\Nselbst in der Hand.
Dialogue: 0,0:19:15.18,0:19:18.93,Top Internal,Mahito,0000,0000,0000,,Diese Taktik belastet Itadori\Npsychisch stärker.
Dialogue: 0,0:19:18.93,0:19:20.45,Top Internal,Mahito,0000,0000,0000,,Außerdem …
Dialogue: 0,0:19:20.45,0:19:25.14,Top Internal,Mahito,0000,0000,0000,,kommen wir so an noch\Neine Karte zur Versicherung.
Dialogue: 0,0:19:26.46,0:19:27.30,Default,Leute,0000,0000,0000,,Was?
Dialogue: 0,0:19:27.30,0:19:28.52,Default,Leute,0000,0000,0000,,Hey!
Dialogue: 0,0:19:29.00,0:19:33.79,Flashback,Mahito,0000,0000,0000,,Los, schluck, schluck, schluck, schluck!
Dialogue: 0,0:19:33.79,0:19:34.95,Flashback,Mahito,0000,0000,0000,,Runter damit!
Dialogue: 0,0:19:35.78,0:19:40.83,TypePlaceholder,,0000,0000,0000,,{\fnVerdana bold\c&HFDFEFE&\bord0\an1\fad(0,943)\fs+1\pos(32.5,306.5)}21:30\h\h\h\h\h\h\hBahnhof Shibuya 4. UG
Dialogue: 0,0:19:36.94,0:19:38.26,Flashback Top,Mahito,0000,0000,0000,,Supi!
Dialogue: 0,0:19:38.26,0:19:40.24,Flashback Top,Mahito,0000,0000,0000,,Ich habe genug eingespeichert,
Dialogue: 0,0:19:40.24,0:19:42.74,Flashback Top,Mahito,0000,0000,0000,,also tut mit den Menschen im 5. UG,\Nwas ihr wollt.
Dialogue: 0,0:19:43.10,0:19:46.18,Flashback Top,Mahito,0000,0000,0000,,Dann möge die Jagd\Nauf Itadori weitergehen!
Dialogue: 0,0:19:46.18,0:19:47.62,Flashback Top,Dagon,0000,0000,0000,,Örks!
Dialogue: 0,0:19:47.79,0:19:48.63,Flashback,Jōgo,0000,0000,0000,,Nichts da!
Dialogue: 0,0:19:48.63,0:19:49.63,Flashback,Mahito,0000,0000,0000,,Jōgo.
Dialogue: 0,0:19:50.72,0:19:52.35,Flashback,Mahito,0000,0000,0000,,Fang mich doch!
Dialogue: 0,0:19:55.52,0:19:59.15,Flashback,Mahito,0000,0000,0000,,Ich übernehm den Untergrund,\Ndu die Oberfläche.
Dialogue: 0,0:19:59.15,0:20:01.28,Flashback,Mahito,0000,0000,0000,,Aber komm zurück,\Nwenn ich dich rufe.
Dialogue: 0,0:20:01.28,0:20:03.87,Flashback,Mahito,0000,0000,0000,,Jaja, weiß ich doch.
Dialogue: 0,0:20:03.87,0:20:05.14,Flashback,Mahito,0000,0000,0000,,Recht hast du.
Dialogue: 1,0:20:07.14,0:20:07.77,TypePlaceholder,,0000,0000,0000,,{\fnComic Sans MS Bold\bord2.3\c&H787E85&\3c&H454549&\frz20.1\pos(401,279.5)}Sie teilen\Nsich auf!!
