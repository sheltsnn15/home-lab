Dialogue: 0,0:00:34.54,0:00:38.37,Default,,0,0,0,,(มหาเวทผนึกมาร จรดลล้างบาง พาร์ต 1)
Dialogue: 0,0:01:56.88,0:01:59.89,Default,,0,0,0,,(ตอนที่ 49 อีกหนึ่งครั้ง)
Dialogue: 0,0:02:00.46,0:02:01.44,Default,,0,0,0,,ขอโทษนะ
Dialogue: 0,0:02:03.31,0:02:04.38,Default,,0,0,0,,อิตาโดริคุง
Dialogue: 0,0:02:42.05,0:02:43.05,Default,,0,0,0,,เร็วมาก
Dialogue: 0,0:02:43.23,0:02:45.36,Default,,0,0,0,,เดาไม่ออกเลยว่าเป็นอาคมประเภทไหน
Dialogue: 0,0:02:45.76,0:02:49.83,Default,,0,0,0,,เห็นเราเสียเปรียบถึงขนาดนี้\Nอีกฝ่ายคงไม่เผยอาคมของตัวเองแน่
Dialogue: 0,0:02:50.06,0:02:52.11,Default,,0,0,0,,ไม่ใช่เวลามาคิดเรื่อง "ร้อยรวม" แล้ว
Dialogue: 0,0:02:53.06,0:02:56.57,Default,,0,0,0,,ขนาดเลือดที่อยู่นอกร่างกาย\Nยังควบคุมไม่ได้เลยด้วยซ้ำ
Dialogue: 0,0:03:06.44,0:03:09.76,Default,,0,0,0,,ทนทายาดชะมัด\Nถามจริงนายเป็นใครกันแน่เนี่ย
Dialogue: 0,0:03:10.54,0:03:13.90,Default,,0,0,0,,พี่คนโตในหมู่พี่น้อง 10 คนไง
Dialogue: 0,0:03:14.88,0:03:17.37,Default,,0,0,0,,"เกล็ดสีชาดไหลหลั่ง ซ้อน"
Dialogue: 0,0:03:17.79,0:03:19.82,Default,,0,0,0,,ตอบบ่ตรงคำถามนี่หว่า
Dialogue: 0,0:03:20.09,0:03:24.81,Default,,0,0,0,,ฉันถามเรื่องอาคม\Nกับความทนมือทนเท้าอยู่เหอะ
Dialogue: 0,0:03:42.99,0:03:44.41,Default,,0,0,0,,ตามการเคลื่อนไหวทันแล้วเรอะ
Dialogue: 0,0:03:52.25,0:03:53.88,Default,,0,0,0,,อย่างนี้นี่เอง
Dialogue: 0,0:03:54.08,0:03:56.23,Default,,0,0,0,,"เกล็ดสีชาดไหลหลั่ง" เรอะ
Dialogue: 0,0:03:56.23,0:04:01.19,Default,,0,0,0,,เอาพลังนั้นไปเพ่งรวมกันที่กล้ามเนื้อตา\Nเพื่อเพิ่มความสามารถในการจับการเคลื่อนไหว
Dialogue: 0,0:04:02.10,0:04:06.40,Default,,0,0,0,,เสียใจด้วย ทางนี้เคลื่อนไหวโดย\Nคาดการณ์แผนสวนกลับไว้แล้วจ้า
Dialogue: 0,0:04:07.53,0:04:10.66,Default,,0,0,0,,นายมันขี้ตื๊อฉันถึงต้องงัดมาใช้ไง
Dialogue: 0,0:04:10.66,0:04:11.56,Default,,0,0,0,,อาวุธน่ะ
Dialogue: 0,0:04:11.85,0:04:14.84,Default,,0,0,0,,นายใช้วิชาควบคุมโลหิตนี่\Nห้ามเลือดคงง่ายเหมือนเกาตูดแหละมั้ง
Dialogue: 0,0:04:15.10,0:04:19.82,Default,,0,0,0,,มาลองกันหน่อยไหมว่าระหว่างที่ง่วนอยู่กับ\Nการห้ามเลือดจะรับมือฉันได้สักกี่น้ำเชียว
Dialogue: 0,0:04:20.41,0:04:21.70,Default,,0,0,0,,เตรียมตัวมาดีจังนะ
Dialogue: 0,0:04:21.94,0:04:27.44,Default,,0,0,0,,อย่าไปบอกใครเด้อ เว่ากันซื่อ ๆ เลย\Nฉันว่าผู้ใช้คุณไสยที่พกอาวุธมันเห่ยบรมน่ะ
Dialogue: 0,0:04:27.77,0:04:30.28,Default,,0,0,0,,เหมือนห้อยป้ายประจาน\Nตัวเองว่าถ้าไม่มีก็สู้ไม่ชนะ
Dialogue: 0,0:04:30.48,0:04:33.40,Default,,0,0,0,,แล้วคนที่คิดเหมือนฉันมีเยอะผิดคาดเลยละ
Dialogue: 0,0:04:33.87,0:04:37.14,Default,,0,0,0,,พวกพี่ชายฉันก็หิ้วไปหิ้วมาเหมือนกัน\Nทุเรศไม่มีใครเกิน
Dialogue: 0,0:04:37.14,0:04:40.58,Default,,0,0,0,,ทำงั้นแล้วยังกล้ามาแดกดัน\Nโทจิคุงอีก ไม่อายปากกันเลย
Dialogue: 0,0:04:40.92,0:04:43.25,Default,,0,0,0,,แกเกลียดพี่น้องตัวเองสินะ
Dialogue: 0,0:04:43.74,0:04:44.97,Default,,0,0,0,,เกลียดอยู่แล้วสิ
Dialogue: 0,0:04:45.24,0:04:48.78,Default,,0,0,0,,พี่ที่ห่วยแตกกว่าน้อง\Nจะอยู่ให้หนักแผ่นดินไปทำไม
Dialogue: 0,0:04:48.78,0:04:50.76,Default,,0,0,0,,ไปผูกคอตายยังมีประโยชน์กว่าอีก
Dialogue: 0,0:04:51.06,0:04:56.11,Default,,0,0,0,,แต่อาจเป็นเพราะพี่น้องเหล่านั้น\Nถึงได้มีแกในวันนี้ก็ได้นะ
Dialogue: 0,0:04:56.75,0:04:57.44,Default,,0,0,0,,หา
Dialogue: 0,0:04:57.68,0:05:01.07,Default,,0,0,0,,เมื่อกี้พล่ามอะไรชวนอ้วกออกมาปะเนี่ย
Dialogue: 0,0:05:01.29,0:05:02.95,Default,,0,0,0,,จะอ้วกเลยว่ะ
Dialogue: 0,0:05:04.07,0:05:08.41,Default,,0,0,0,,จะทำได้ดีกว่าหรือห่วยกว่า\Nคนเป็นพี่ก็คือแบบอย่างของน้อง ๆ
Dialogue: 0,0:05:09.20,0:05:13.55,Default,,0,0,0,,ถ้าฉันเลือกเดินทางที่ผิด\Nน้อง ๆ ก็หลีกเลี่ยงไม่เดินซ้ำรอยก็พอ
Dialogue: 0,0:05:14.08,0:05:18.36,Default,,0,0,0,,ถ้าฉันเลือกเดินทางที่ถูกต้อง\Nน้อง ๆ ก็แค่เดินตามรอยมาก็เท่านั้น
Dialogue: 0,0:05:19.08,0:05:23.50,Default,,0,0,0,,ถ้าความแข็งแกร่งของแกมาจาก\Nความอ่อนแอของพี่ชายแกจะว่ายังไง
Dialogue: 0,0:05:24.22,0:05:26.49,Default,,0,0,0,,แกถามฉันสินะว่าทำไมทนทายาดจัง
Dialogue: 0,0:05:27.21,0:05:28.30,Default,,0,0,0,,ฉันจะบอกให้เอาบุญ
Dialogue: 0,0:05:28.68,0:05:32.49,Default,,0,0,0,,ฉันไม่มีใครให้เป็นแบบอย่าง\Nฉันถึงได้ผิดพลาดซ้ำแล้วซ้ำเล่า
Dialogue: 0,0:05:32.49,0:05:33.67,Default,,0,0,0,,แต่ถึงอย่างนั้น...
Dialogue: 0,0:05:33.85,0:05:36.51,Default,,0,0,0,,ฉันก็ต้องเดินนำหน้าน้อง ๆ ต่อไป
Dialogue: 0,0:05:36.89,0:05:39.06,Default,,0,0,0,,เพราะงั้นฉันถึงได้แข็งแกร่งไงล่ะ
Dialogue: 0,0:05:43.34,0:05:44.92,Default,,0,0,0,,นี่มันบ้าอะไรเนี่ย
Dialogue: 0,0:05:44.92,0:05:47.05,Default,,0,0,0,,เลือดออกขนาดนี้ยังมีชีวิตอยู่ได้ยังไง
Dialogue: 0,0:05:54.99,0:05:58.73,Default,,0,0,0,,อสุภนพรูปคือเลือดผสม\Nระหว่างวิญญาณคำสาปกับมนุษย์
Dialogue: 0,0:05:58.73,0:06:02.89,Default,,0,0,0,,มีร่างกายพิเศษที่เปลี่ยน\Nพลังไสยเวทเป็นเลือดได้
Dialogue: 0,0:06:03.24,0:06:07.98,Default,,0,0,0,,ตราบใดที่พลังไสยเวทไม่หมดเกลี้ยง\Nก็ไม่มีวันตายจากการเสียเลือด
Dialogue: 0,0:06:33.98,0:06:35.20,Default,,0,0,0,,ขาหนักอึ้งเลย
Dialogue: 0,0:06:35.95,0:06:38.80,Default,,0,0,0,,ทำให้เลือดที่ซึมมาตามผ้าแข็งตัวงั้นเหรอ
Dialogue: 0,0:06:40.09,0:06:41.58,Default,,0,0,0,,ที่เหลือก็น่าจะรู้ดีนะ
Dialogue: 0,0:06:42.74,0:06:43.81,Default,,0,0,0,,รุกจนแล้ว
Dialogue: 0,0:06:50.40,0:06:52.05,Default,,0,0,0,,ก็ไม่รู้สินะ
Dialogue: 0,0:06:53.56,0:06:58.43,Default,,0,0,0,,อาคมของเราคือการแกะรอยตาม\Nการเคลื่อนไหว 24fps ที่เราสร้างขึ้น
Dialogue: 0,0:06:58.91,0:07:01.78,Default,,0,0,0,,ตัวถ่วงขาแค่นี้ไม่คณาเท้าเราหรอก
Dialogue: 0,0:07:02.86,0:07:04.42,Default,,0,0,0,,จัดมาเน้น ๆ เลยสิ
Dialogue: 0,0:07:07.90,0:07:10.38,Default,,0,0,0,,ทำไมถึงไม่ยอมยิงล่ะ
Dialogue: 0,0:07:11.07,0:07:12.97,Default,,0,0,0,,นี่ท่าต้นฉบับของโจโซ
Dialogue: 0,0:07:12.97,0:07:15.64,Default,,0,0,0,,ที่ได้จากการเผชิญหน้ากับอาคมของตัวเอง...
Dialogue: 0,0:07:15.64,0:07:17.68,Default,,0,0,0,,มาตลอด 150 ปี\N(มหานวดารา)
Dialogue: 0,0:07:42.94,0:07:47.60,Default,,0,0,0,,โทษทีนะ ฉันไม่เข้าใจความรู้สึก\Nของไอ้คนไม่รักพี่น้องอย่างแกหรอก
Dialogue: 0,0:08:03.08,0:08:03.49,Default,,0,0,0,,อะไร...
Dialogue: 0,0:08:10.29,0:08:11.86,Default,,0,0,0,,ดูไม่จืดเลยนะครับ
Dialogue: 0,0:08:13.37,0:08:14.47,Default,,0,0,0,,คุณนาโอยะ
Dialogue: 0,0:08:18.84,0:08:20.48,Default,,0,0,0,,อย่ามามองเหยียดกันนะเว้ย
Dialogue: 0,0:08:26.32,0:08:28.84,Default,,0,0,0,,นี่มันอะไร พิษเรอะ
Dialogue: 0,0:08:29.56,0:08:32.43,Default,,0,0,0,,วิชาควบคุมโลหิตมีผลแบบนี้ได้ไง...
Dialogue: 0,0:08:32.83,0:08:35.42,Default,,0,0,0,,ไม่ใช่ มันไม่ใช่ผลจากอาคม
Dialogue: 0,0:08:35.68,0:08:39.31,Default,,0,0,0,,ปริมาณเลือดขนาดนั้น\Nหมอนั่นมันไม่ใช่มนุษย์ต่างหาก
Dialogue: 0,0:08:39.48,0:08:44.66,Default,,0,0,0,,ร่างอวตารเรอะ เลือดอมนุษย์\Nมันปนเข้ามาร่างกายก็เลยต่อต้าน
Dialogue: 0,0:08:44.66,0:08:46.15,Default,,0,0,0,,ผมรักษาให้เอาไหมครับ
Dialogue: 0,0:08:47.66,0:08:51.04,Default,,0,0,0,,อาคมย้อนกลับของผม\Nใช้รักษาคนอื่นได้นะครับ
Dialogue: 0,0:08:51.72,0:08:52.91,Default,,0,0,0,,เพื่อเป็นการแลกเปลี่ยน...
Dialogue: 0,0:08:53.77,0:08:58.80,Default,,0,0,0,,ช่วยรายงานเรื่องการตายของอิตาโดริคุง\Nให้เบื้องบนจากปากของคุณเองทีนะครับ
Dialogue: 0,0:09:01.76,0:09:02.99,Default,,0,0,0,,จิน...
Dialogue: 0,0:09:09.06,0:09:10.59,Default,,0,0,0,,อะไรเหรอครับ คุณพ่อ
Dialogue: 0,0:09:11.50,0:09:13.95,Default,,0,0,0,,ถ้าจะพูดเรื่องเธอคนนั้น\Nผมขอกลับก่อนนะครับ
Dialogue: 0,0:09:15.07,0:09:16.07,Default,,0,0,0,,จิน
Dialogue: 0,0:09:16.41,0:09:19.42,Default,,0,0,0,,แกจะใช้ชีวิตยังไงมันก็เรื่องของแก
Dialogue: 0,0:09:20.11,0:09:23.70,Default,,0,0,0,,แต่เลิกไปยุ่งกับผู้หญิงคนนั้นได้แล้ว
Dialogue: 0,0:09:23.70,0:09:24.68,Default,,0,0,0,,เดี๋ยวก็ตายหรอก
Dialogue: 0,0:09:25.71,0:09:29.00,Default,,0,0,0,,อย่าพูดอะไรแปลก ๆ ต่อหน้ายูจิสิครับ
Dialogue: 0,0:09:29.36,0:09:32.49,Default,,0,0,0,,เขาว่ากันว่าเด็กทารก\Nความจำดีเกินคาดเลยนะครับ
Dialogue: 0,0:09:33.09,0:09:39.18,Default,,0,0,0,,ฉันรู้ดีว่าแกอยากมีลูกขนาดไหน\Nและฉันก็รู้ด้วยว่าคาโอริทำให้แกสมหวังไม่ได้
Dialogue: 0,0:09:40.05,0:09:41.90,Default,,0,0,0,,แต่คาโอริน่ะตาย...
Dialogue: 0,0:09:42.64,0:09:45.32,Default,,0,0,0,,คุณพ่อ พูดเรื่องอะไรอยู่เหรอคะ
Dialogue: 0,0:09:59.68,0:10:02.06,Default,,0,0,0,,เดี๋ยวนะ นี่เรา...
Dialogue: 0,0:10:18.98,0:10:20.46,Default,,0,0,0,,ค่อย...
Dialogue: 0,0:10:20.46,0:10:23.47,Default,,0,0,0,,ค่อยยังชั่ว...
Dialogue: 0,0:10:30.60,0:10:32.41,Default,,0,0,0,,น่าจะประมาณเดือนกันยายนมั้ง
Dialogue: 0,0:10:33.12,0:10:35.36,Default,,0,0,0,,อาจารย์โกโจเขาถ่อมาหาผมเลยนะ
Dialogue: 0,0:10:36.20,0:10:38.51,Default,,0,0,0,,เพื่อฝากฝังนายโดยเฉพาะเลยละ
Dialogue: 0,0:10:39.36,0:10:42.88,Default,,0,0,0,,ผมก็เลยต้องเล่นละครอย่างเลี่ยงไม่ได้
Dialogue: 0,0:10:43.39,0:10:44.52,Default,,0,0,0,,เล่นละครเหรอ
Dialogue: 0,0:10:45.42,0:10:48.08,Default,,0,0,0,,เผอิญสังหรณ์ใจไม่ดีนี๊ดหน่อยน่ะ
Dialogue: 0,0:10:48.70,0:10:53.12,Default,,0,0,0,,ถ้ามีอะไรเกิดขึ้นกับผมก็อยากฝากยูตะ\Nดูแลเด็กปีหนึ่งกับปีสองแทนผมหน่อย
Dialogue: 0,0:10:53.58,0:10:55.56,Default,,0,0,0,,ส่วนฮาคาริก็คงไหวชิลแหละมั้ง
Dialogue: 0,0:10:56.48,0:10:59.47,Default,,0,0,0,,"มีอะไรเกิดขึ้น" เนี่ย เรื่องชู้สาวเหรอครับ
Dialogue: 0,0:11:00.89,0:11:04.05,Default,,0,0,0,,ยูตะก็เริ่มยิงมุกเป็นเหมือนกันแล้วสินะ
Dialogue: 0,0:11:04.24,0:11:08.33,Default,,0,0,0,,เปล่าสักหน่อย ผมแค่นึกภาพไม่ออกว่า\Nจะมีอะไรเกิดขึ้นกับอาจารย์โกโจได้ต่างหาก
Dialogue: 0,0:11:09.77,0:11:12.12,Default,,0,0,0,,โดยเฉพาะเด็กปีหนึ่งที่ชื่ออิตาโดริ ยูจิ
Dialogue: 0,0:11:12.12,0:11:16.10,Default,,0,0,0,,เด็กคนนั้นเหมือนกับยูตะตรงที่เคย\Nต้องโทษประหารลับสุดยอดเหมือนกัน
Dialogue: 0,0:11:16.48,0:11:18.75,Default,,0,0,0,,ถ้าจับตาดูเขาให้หน่อยจะขอบคุณมากเลย
Dialogue: 0,0:11:20.36,0:11:21.29,Default,,0,0,0,,มิเกลล่ะ
Dialogue: 0,0:11:21.47,0:11:23.45,Default,,0,0,0,,เขาไม่ค่อยอยากเจอหน้าอาจารย์น่ะครับ
Dialogue: 0,0:11:26.09,0:11:31.10,Default,,0,0,0,,แทนที่จะให้คนอื่นมาเป็นเพชฌฆาตแล้วต้อง\Nถูกตัดขาดจากการรู้ข่าวคราวของอิตาโดริคุง
Dialogue: 0,0:11:31.10,0:11:33.54,Default,,0,0,0,,สู้เสนอตัวเป็น\Nเพชฌฆาตเองเลยน่าจะดีที่สุดน่ะ
Dialogue: 0,0:11:34.52,0:11:36.06,Default,,0,0,0,,อีกฝ่ายเองก็ไม่ใช่คนโง่
Dialogue: 0,0:11:36.35,0:11:39.55,Default,,0,0,0,,เพื่อแลกเปลี่ยนกับการเป็นเพชฌฆาต
Dialogue: 0,0:11:39.82,0:11:43.36,Default,,0,0,0,,ทางกองบัญชาการให้ผมทำข้อผูกมัด\Nซึ่งก็คือการฆ่าอิตาโดริคุง
Dialogue: 0,0:11:43.82,0:11:45.46,Default,,0,0,0,,ผมก็เลยต้องฆ่านายครั้งนึงก่อน
Dialogue: 0,0:11:45.46,0:11:46.65,Default,,0,0,0,,ขอโทษจริง ๆ นะ
Dialogue: 0,0:11:49.47,0:11:50.36,Default,,0,0,0,,เดี๋ยวสิ...
Dialogue: 0,0:11:51.28,0:11:53.04,Default,,0,0,0,,ถ้างั้นแล้วทำไมผมถึงยังมีชีวิตอยู่ล่ะ
Dialogue: 0,0:11:54.22,0:11:55.80,Default,,0,0,0,,อาคมย้อนกลับน่ะ
Dialogue: 0,0:11:57.21,0:12:02.33,Default,,0,0,0,,ในจังหวะที่หัวใจของนายหยุดเต้น\Nผมก็ใช้อาคมย้อนกลับรักษาในทันที
Dialogue: 0,0:12:03.13,0:12:06.70,Default,,0,0,0,,ผมเคยได้ยินเรื่องของนายตอนสมัยก่อน\Nมาบ้างก็เลยคิดว่าน่าจะได้ผลน่ะ
Dialogue: 0,0:12:07.16,0:12:11.82,Default,,0,0,0,,คนที่รู้ว่าผมส่งพลังงานบวกออกมาได้เลย\Nก็มีอยู่แค่หยิบมือเดียวด้วยแหละนะ
Dialogue: 0,0:12:12.56,0:12:13.58,Default,,0,0,0,,ใช่...
Dialogue: 0,0:12:13.85,0:12:17.09,Default,,0,0,0,,นี่เป็นครั้งที่สองแล้ว\Nที่จัดฉากการตายของนาย
Dialogue: 0,0:12:17.80,0:12:21.60,Default,,0,0,0,,จริงอยู่ที่อาจจะความแตกก็ได้\Nแต่สถานการณ์มันบีบบังคับละนะ
Dialogue: 0,0:12:21.96,0:12:26.20,Default,,0,0,0,,โทษประหารของอิตาโดริคุงน่าจะถูก\Nพิจารณาว่าดำเนินการเสร็จสิ้นไปแล้วล่ะ
Dialogue: 0,0:12:28.70,0:12:31.50,Default,,0,0,0,,ทำไมต้องทำถึงขนาดนั้นด้วย...
Dialogue: 0,0:12:32.08,0:12:34.78,Default,,0,0,0,,เพราะเหล่าคนที่ผมให้ความสำคัญ...
Dialogue: 0,0:12:35.31,0:12:37.28,Default,,0,0,0,,เขาให้ความสำคัญกับนายมากไงล่ะ
Dialogue: 0,0:12:40.30,0:12:41.94,Default,,0,0,0,,ผมก็เคยแบกรับ...
Dialogue: 0,0:12:41.94,0:12:44.35,Default,,0,0,0,,พลังที่ยิ่งใหญ่เกินตัวมาก่อนเหมือนกัน
Dialogue: 0,0:12:44.91,0:12:50.49,Default,,0,0,0,,แต่พลังที่ผมคิดว่าถูกบังคับให้แบกรับ\Nเป็นสิ่งที่ผมเชื้อเชิญเข้ามาเอง
Dialogue: 0,0:12:50.49,0:12:51.80,Default,,0,0,0,,แต่นายไม่ใช่แบบนั้น
Dialogue: 0,0:12:52.35,0:12:55.04,Default,,0,0,0,,พลังที่นายต้องแบกรับไม่ใช่พลังของนาย
Dialogue: 0,0:12:58.61,0:13:00.16,Default,,0,0,0,,นายไม่ได้ทำอะไรผิดหรอกนะ
Dialogue: 0,0:13:06.15,0:13:07.24,Default,,0,0,0,,ไม่ใช่หรอก
Dialogue: 0,0:13:07.82,0:13:10.24,Default,,0,0,0,,ปัญหามันไม่ได้อยู่ที่ว่าผมผิดหรือไม่ผิด
Dialogue: 0,0:13:10.75,0:13:12.48,Default,,0,0,0,,เพราะว่าผมฆ่าคน...
Dialogue: 0,0:13:12.48,0:13:13.20,Default,,0,0,0,,อิตาโดริ
Dialogue: 0,0:13:18.56,0:13:20.35,Default,,0,0,0,,- ฟุชิงุโระ...\N- มัวทำบ้าอะไรอยู่เนี่ย
Dialogue: 0,0:13:21.16,0:13:22.83,Default,,0,0,0,,รีบกลับไปที่โรงเรียนได้แล้ว
Dialogue: 0,0:13:23.32,0:13:25.49,Default,,0,0,0,,ตอนนี้เขตแดนของโรงเรียนกำลังอ่อนลง
Dialogue: 0,0:13:25.93,0:13:29.85,Default,,0,0,0,,ตราบใดที่ไม่มีใครเห็นหน้านายตรง ๆ\Nต่อให้กลับไปก็ไม่มีปัญหาอะไรหรอก
Dialogue: 0,0:13:30.51,0:13:32.17,Default,,0,0,0,,ไปสมทบกับพวกรุ่นพี่กันก่อน...
Dialogue: 0,0:13:32.17,0:13:32.89,Default,,0,0,0,,พอเถอะน่า
Dialogue: 0,0:13:34.56,0:13:36.62,Default,,0,0,0,,อย่ามาอ้าแขนยอมรับฉัน\Nเหมือนเป็นเรื่องปกตินะ
Dialogue: 0,0:13:37.87,0:13:39.63,Default,,0,0,0,,อย่าทำเหมือนมันไม่เคยเกิดขึ้นด้วย
Dialogue: 0,0:13:41.53,0:13:44.25,Default,,0,0,0,,ฉันมันเป็น... ไอ้ฆาตกร...
Dialogue: 0,0:13:46.16,0:13:49.12,Default,,0,0,0,,- มีคนมากมายต้องตายเพราะฉัน...\N- เป็นเพราะพวกเราต่างหาก
Dialogue: 0,0:13:50.84,0:13:53.42,Default,,0,0,0,,กะแล้ว... ว่านายต้องพูดแบบนั้น...
Dialogue: 0,0:13:53.42,0:13:54.57,Default,,0,0,0,,นายอย่าเพิ่งยอมแพ้...
Dialogue: 0,0:13:55.83,0:13:57.20,Default,,0,0,0,,แบบคิดเองเออเองคนเดียวเชียวนะ
Dialogue: 0,0:14:10.72,0:14:12.75,Default,,0,0,0,,พวกเราไม่ใช่ฮีโร่
Dialogue: 0,0:14:13.47,0:14:14.54,Default,,0,0,0,,เป็นผู้ใช้คุณไสยต่างหาก
Dialogue: 0,0:14:15.16,0:14:18.20,Default,,0,0,0,,ไม่มีมนุษย์คนไหนมาพิพากษา\Nพวกเราตามครรลองคลองธรรมได้
Dialogue: 0,0:14:19.34,0:14:20.54,Default,,0,0,0,,เพราะอย่างนั้น...
Dialogue: 0,0:14:20.96,0:14:23.87,Default,,0,0,0,,พวกเราถึงต้องแสดงความหมาย\Nในการมีตัวตนอยู่ต่อไปเรื่อย ๆ
Dialogue: 0,0:14:24.92,0:14:27.03,Default,,0,0,0,,ผิดแล้วละ ฟุชิงุโระ...
Dialogue: 0,0:14:27.03,0:14:29.91,Default,,0,0,0,,ตอนนี้เราไม่ว่างมาคิดเรื่องตัวเองแล้วนะ
Dialogue: 0,0:14:29.91,0:14:31.08,Default,,0,0,0,,แบบนั้นมันก็หมายความว่า...
Dialogue: 0,0:14:31.08,0:14:33.21,Default,,0,0,0,,เราต้องทุ่มสุดตัวเพื่อช่วยเหลือคนอื่น
Dialogue: 0,0:14:33.21,0:14:34.64,Default,,0,0,0,,ตราบใดที่นายยังอยู่ข้างฉัน...
Dialogue: 0,0:14:34.64,0:14:35.82,Default,,0,0,0,,เดิมทีแล้วเรื่องนี้...
Dialogue: 0,0:14:35.82,0:14:37.03,Default,,0,0,0,,มันคือหลักการของนายใช่ไหมล่ะ
Dialogue: 0,0:14:37.03,0:14:38.95,Default,,0,0,0,,นายต้องทุกข์ทรมานไปตลอดนะ
Dialogue: 0,0:14:38.95,0:14:40.18,Default,,0,0,0,,เริ่มจากมาช่วยฉันก่อนเลย
Dialogue: 0,0:14:40.97,0:14:41.72,Default,,0,0,0,,อิตาโดริ
Dialogue: 0,0:14:46.38,0:14:47.90,Default,,0,0,0,,คาโมะ โนริโทชิวางแผนเอาไว้...
Dialogue: 0,0:14:48.75,0:14:51.38,Default,,0,0,0,,โดยให้เหล่าผู้ที่ได้รับ\Nวิชาคุณไสยฆ่าฟันกันเอง
Dialogue: 0,0:14:52.22,0:14:53.35,Default,,0,0,0,,"จรดลล้างบาง"
Dialogue: 0,0:14:54.91,0:14:57.47,Default,,0,0,0,,สึมิกิก็ถูกลากไปพัวพัน\Nในจรดลล้างบางเหมือนกัน
Dialogue: 0,0:15:00.00,0:15:01.03,Default,,0,0,0,,ขอร้องล่ะ...
Dialogue: 0,0:15:01.65,0:15:02.30,Default,,0,0,0,,อิตาโดริ
Dialogue: 0,0:15:08.49,0:15:10.35,Default,,0,0,0,,ฉันต้องพึ่งพลังของนาย
Dialogue: 0,0:15:17.95,0:15:23.54,Default,,0,0,0,,(จรดลล้างบาง "กติกา")
Dialogue: 0,0:15:23.54,0:15:26.92,Default,,0,0,0,,(ภายใน 19 วัน หากผู้เข้าร่วมคนใด)\N(ละเมิดกฎกติกา อาคมจะถูกริบคืนในทันที)
Dialogue: 0,0:15:26.92,0:15:28.88,Default,,0,0,0,,(ผู้ที่บุกรุกเข้าเขตแดนจะถูกนับว่า)\N(เป็นผู้เข้าร่วมโดยอัตโนมัติ)
Dialogue: 0,0:15:28.88,0:15:30.51,Default,,0,0,0,,(การสังหารชีวิต)\N(ของผู้เข้าร่วมคนอื่น)
Dialogue: 0,0:15:30.51,0:15:32.11,Default,,0,0,0,,(หากสังหารผู้ใช้คุณไสยจะได้รับ 5 คะแนน)\N(หากสังหารผู้ไร้วิชาจะได้รับ 1 คะแนน)
Dialogue: 0,0:15:32.11,0:15:37.99,Default,,0,0,0,,(จรดลล้างบาง "กติกา")
Dialogue: 0,0:15:41.41,0:15:43.00,Default,,0,0,0,,(มหาเวทผนึกมาร)
Dialogue: 0,0:15:43.16,0:15:44.08,Default,,0,0,0,,ขอร้องล่ะ...
Dialogue: 0,0:15:44.50,0:15:45.31,Default,,0,0,0,,อิตาโดริ
Dialogue: 0,0:15:46.35,0:15:48.16,Default,,0,0,0,,ฉันต้องพึ่งพลังของนาย
Dialogue: 0,0:15:50.34,0:15:51.52,Default,,0,0,0,,รุ่นพี่อคคตสึ
Dialogue: 0,0:15:52.61,0:15:54.66,Default,,0,0,0,,สุคุนะกำลังวางแผนจะ\Nทำอะไรบางอย่างกับฟุชิงุโระอยู่
Dialogue: 0,0:15:56.35,0:15:58.62,Default,,0,0,0,,ที่หมอนั่นยึดร่างผมตอนอยู่ที่ชิบูย่าได้...
Dialogue: 0,0:15:59.08,0:16:01.74,Default,,0,0,0,,คงเป็นเพราะผมถูกบังคับ\Nให้กินนิ้ว 10 นิ้วพร้อมกัน
Dialogue: 0,0:16:02.31,0:16:05.01,Default,,0,0,0,,ตอนนี้ในตัวผมมีอยู่ 15 นิ้ว
Dialogue: 0,0:16:05.38,0:16:07.55,Default,,0,0,0,,ถึงจะถูกบังคับให้กิน\Nอีกห้านิ้วที่เหลือรวดเดียว...
Dialogue: 0,0:16:07.99,0:16:09.54,Default,,0,0,0,,ผมว่าหมอนั่นก็ยึดร่างผมไม่ได้หรอก
Dialogue: 0,0:16:10.26,0:16:11.32,Default,,0,0,0,,แต่ถึงอย่างนั้น...
Dialogue: 0,0:16:12.02,0:16:15.62,Default,,0,0,0,,ถ้าคราวหน้าสุคุนะเปลี่ยนตัวกับผมอีก\Nให้ฆ่าผมได้เลยไม่ต้องลังเล
Dialogue: 0,0:16:16.86,0:16:18.24,Default,,0,0,0,,ผมคิดว่ารุ่นพี่ต้องทำได้แน่
Dialogue: 0,0:16:20.46,0:16:21.20,Default,,0,0,0,,เข้าใจแล้ว
Dialogue: 0,0:16:22.33,0:16:23.62,Default,,0,0,0,,ผมจะทำให้ดีที่สุดนะ
Dialogue: 0,0:16:25.04,0:16:25.78,Default,,0,0,0,,ฟุชิงุโระ
Dialogue: 0,0:16:26.54,0:16:27.72,Default,,0,0,0,,ฉันต้องทำอะไรต่อ
Dialogue: 0,0:16:29.09,0:16:32.58,Default,,0,0,0,,ก่อนอื่นก็กลับไปที่โรงเรียน\Nแล้วติดต่อกับท่านเท็นเก็น
Dialogue: 0,0:16:36.00,0:16:37.93,Default,,0,0,0,,วิธีปลดผนึกขอบเขตประตูคุก
Dialogue: 0,0:16:38.92,0:16:42.32,Default,,0,0,0,,เป้าหมายที่เป็นรูปธรรมของคาโมะ โนริโทชิ\Nและแนวทางของมันหลังจากนี้
Dialogue: 0,0:16:43.19,0:16:45.61,Default,,0,0,0,,จรดลล้างบางเป็นการก่อการร้าย\Nด้วยคุณไสยที่ไม่เคยมีมาก่อน
Dialogue: 0,0:16:46.15,0:16:49.22,Default,,0,0,0,,การควบคุมสถานการณ์ให้อยู่หมัด\Nต้องรู้คำตอบสองข้อนั้นให้ได้
Dialogue: 0,0:16:50.12,0:16:53.12,Default,,0,0,0,,และคนที่จะตอบคำถามให้เราได้\Nมีแค่ท่านเท็นเก็นเท่านั้น
Dialogue: 0,0:16:54.10,0:16:55.36,Default,,0,0,0,,แล้วคนคนนั้น...
Dialogue: 0,0:16:55.63,0:16:57.24,Default,,0,0,0,,คุณสึคุโมะรู้เรื่องไหมเนี่ย
Dialogue: 0,0:16:57.98,0:16:59.71,Default,,0,0,0,,ฉันคุยกับคุณสึคุโมะแล้ว
Dialogue: 0,0:17:00.26,0:17:01.84,Default,,0,0,0,,นี่ก็เป็นการตัดสินใจของหล่อน
Dialogue: 0,0:17:02.56,0:17:05.33,Default,,0,0,0,,ตอนนี้คนคนนั้นก็กบดาน\Nอยู่ในโรงเรียนเหมือนกัน
Dialogue: 0,0:17:06.80,0:17:07.74,Default,,0,0,0,,กบดานเหรอ
Dialogue: 0,0:17:08.27,0:17:10.72,Default,,0,0,0,,เห็นว่าไม่อยากไปมีเอี่ยวกับพวกเบื้องบนน่ะ
Dialogue: 0,0:17:11.34,0:17:14.72,Default,,0,0,0,,ปัญหาคือเขตแดน "ซ่อนเร้นกาย"\Nของท่านเท็นเก็นต่างหาก
Dialogue: 0,0:17:16.12,0:17:19.38,Default,,0,0,0,,ในบรรดาประตูมากกว่าพันบาน\Nที่สลับสับเปลี่ยนไปมา
Dialogue: 0,0:17:19.90,0:17:23.72,Default,,0,0,0,,มีแค่บานเดียวเท่านั้นที่เชื่อมไปยัง\Nตำหนักดาราอาสัญที่ท่านเท็นเก็นพำนักอยู่
Dialogue: 0,0:17:25.74,0:17:27.67,Default,,0,0,0,,ถ้าเราหาประตูบานนั้นไม่เจอ...
Dialogue: 0,0:17:28.18,0:17:30.15,Default,,0,0,0,,ก็ไม่มีทางได้เจอท่านเท็นเก็นสินะ
Dialogue: 0,0:17:34.62,0:17:35.94,Default,,0,0,0,,โทษทีนะ ฟุชิงุโระ
Dialogue: 0,0:17:45.33,0:17:46.66,Default,,0,0,0,,ฉันว่าถามตอนนี้เลยดีกว่า
Dialogue: 0,0:17:50.94,0:17:52.28,Default,,0,0,0,,คุกิซากิเป็นยังไง...
Dialogue: 0,0:17:59.89,0:18:00.91,Default,,0,0,0,,งั้นเหรอ...
Dialogue: 0,0:18:04.62,0:18:05.52,Default,,0,0,0,,เข้าใจแล้ว...
Dialogue: 0,0:18:13.80,0:18:14.62,Default,,0,0,0,,เข้าใจแล้ว...
Dialogue: 0,0:18:16.66,0:18:18.54,Default,,0,0,0,,ไอ้เขตแดนซ่อนเร้นกายอะไรนั่น...
Dialogue: 0,0:18:19.05,0:18:20.84,Default,,0,0,0,,ฉันอาจจะพอทำอะไรได้บ้างนะ
Dialogue: 0,0:18:22.39,0:18:24.27,Default,,0,0,0,,ฟังอยู่ด้วยสินะครับ
Dialogue: 0,0:18:25.42,0:18:27.06,Default,,0,0,0,,หมายความว่าไงอะ โจโซ
Dialogue: 0,0:18:28.18,0:18:31.80,Default,,0,0,0,,ก่อนหน้านี้ มาฮิโตะขโมยนิ้วสุคุนะ\Nกับพวกฉันออกมาใช่ไหมล่ะ
Dialogue: 0,0:18:33.34,0:18:35.34,Default,,0,0,0,,เราจะใช้วิธีการแบบเดียวกัน
Dialogue: 0,0:18:44.62,0:18:47.08,Default,,0,0,0,,ไม่เจอกันนาน... ก็ไม่ได้นานเท่าไหร่หรอก
Dialogue: 0,0:18:47.43,0:18:48.63,Default,,0,0,0,,รุ่นพี่มากิ
Dialogue: 0,0:18:49.86,0:18:51.06,Default,,0,0,0,,อ้าว หวัดดีครับ
Dialogue: 0,0:18:51.81,0:18:54.26,Default,,0,0,0,,คุณมากิ ขยับตัวได้แล้วเหรอ
Dialogue: 0,0:18:54.88,0:18:56.52,Default,,0,0,0,,โอ้ ไม่มีปัญหา
Dialogue: 0,0:18:57.32,0:18:59.07,Default,,0,0,0,,แผลไฟไหม้นี่จนปัญญาแล้วละ
Dialogue: 0,0:18:59.32,0:19:01.54,Default,,0,0,0,,ถึงจะใช้อาคมย้อนกลับ\Nก็ยังเหลือรอยแผลเป็นอยู่ดี
Dialogue: 0,0:19:02.11,0:19:05.35,Default,,0,0,0,,แต่ก็สมกับเป็นกายเนื้อฟ้าประทาน\Nจากคำสาปผูกมัดสวรรค์จริง ๆ
Dialogue: 0,0:19:05.98,0:19:08.88,Default,,0,0,0,,เพราะสุดท้ายสิ่งที่จะวัดว่าจะอยู่หรือตาย\Nไม่ใช่ความทนทานต่อคำสาป
Dialogue: 0,0:19:08.88,0:19:11.69,Default,,0,0,0,,แต่เป็นความแข็งแกร่งของ\Nร่างกายที่มีมาแต่กำเนิด
Dialogue: 0,0:19:12.46,0:19:14.34,Default,,0,0,0,,ฉันเสียใจเรื่องเจ้าบ้านด้วยนะ
Dialogue: 0,0:19:14.88,0:19:17.14,Default,,0,0,0,,ฉันก็ไม่ได้จะไปแก่งแย่ง\Nอะไรกับเขาหรอกค่ะ
Dialogue: 0,0:19:18.42,0:19:19.33,Default,,0,0,0,,เมงุมิ
Dialogue: 0,0:19:19.66,0:19:21.53,Default,,0,0,0,,เรื่องเขตแดนของท่านเท็นเก็นล่ะ
Dialogue: 0,0:19:22.54,0:19:23.37,Default,,0,0,0,,เรื่องนั้น...
Dialogue: 0,0:19:23.79,0:19:24.99,Default,,0,0,0,,เดี๋ยวฉันอธิบายเอง
Dialogue: 0,0:19:25.99,0:19:28.46,Default,,0,0,0,,ระหว่างทางจากประตู\Nไปยังตำหนักดาราอาสัญ
Dialogue: 0,0:19:28.46,0:19:32.04,Default,,0,0,0,,มีคลังสมบัติของโรงเรียนที่เก็บเครื่องมือ\Nไสยเวทและวัตถุต้องสาปอยู่ใช่ไหม
Dialogue: 0,0:19:32.57,0:19:35.11,Default,,0,0,0,,ในคลังนั้นมีร่างของบรรดาน้องชายฉัน...
Dialogue: 0,0:19:35.11,0:19:41.11,Default,,0,0,0,,ประกอบด้วยโนรันโซ โชโอโซ\Nทันโซ ซันโซ คตสึโซ และโชโซอยู่
Dialogue: 0,0:19:41.55,0:19:43.40,Default,,0,0,0,,ถึงจะเป็นร่างไร้วิญญาณ\Nแต่ถ้ายังอยู่ครบหกคน...
Dialogue: 0,0:19:43.80,0:19:45.99,Default,,0,0,0,,ด้วยผลพลอยได้จากอาคมของฉัน...
Dialogue: 0,0:19:45.99,0:19:47.82,Default,,0,0,0,,ทำให้รู้กลิ่นอายของพวกเขาได้
Dialogue: 0,0:19:48.82,0:19:49.60,Default,,0,0,0,,กู๊ด
Dialogue: 0,0:19:50.23,0:19:51.70,Default,,0,0,0,,ก็ฟังดูเข้าท่าอยู่
Dialogue: 0,0:19:52.24,0:19:53.65,Default,,0,0,0,,ว่าแต่หมอนี่ใครเนี่ย
Dialogue: 0,0:19:57.34,0:19:58.34,Default,,0,0,0,,เอาเป็นว่า...
Dialogue: 0,0:19:59.59,0:20:01.59,Default,,0,0,0,,ให้คิดซะว่าเป็นพี่ชายผมละกัน
Dialogue: 0,0:20:01.97,0:20:04.94,Default,,0,0,0,,ยูจิ
Dialogue: 0,0:20:05.42,0:20:06.16,Default,,0,0,0,,ไปเห๊อะ
Dialogue: 0,0:20:09.47,0:20:10.43,Default,,0,0,0,,ตรงนั้นไง
Dialogue: 0,0:20:11.54,0:20:12.55,Default,,0,0,0,,ไม่ผิดแน่
Dialogue: 0,0:20:13.06,0:20:15.40,Default,,0,0,0,,ทางข้างหน้านี้มี\Nพวกน้องชายของฉันหลับใหลอยู่
Dialogue: 0,0:20:15.79,0:20:16.46,Default,,0,0,0,,จะเปิดแล้วนะ
Dialogue: 0,0:20:27.44,0:20:28.33,Default,,0,0,0,,ลงไปกันเถอะ
Dialogue: 0,0:20:30.33,0:20:33.50,Default,,0,0,0,,ข้างในสุดจะมีลิฟต์ที่\Nพาเราไปยังตำหนักดาราอาสัญอยู่
Dialogue: 0,0:20:35.17,0:20:35.86,Default,,0,0,0,,โจโซ
Dialogue: 0,0:20:37.12,0:20:38.13,Default,,0,0,0,,เข้าใจแล้ว
Dialogue: 0,0:20:39.34,0:20:40.99,Default,,0,0,0,,เดี๋ยวพี่มารับทีหลัง
Dialogue: 0,0:20:40.99,0:20:42.76,Default,,0,0,0,,ช่วยรอพี่อีกหน่อยนะ
Dialogue: 0,0:20:48.89,0:20:49.76,Default,,0,0,0,,คราบเลือดเหรอ
Dialogue: 0,0:20:50.24,0:20:51.40,Default,,0,0,0,,เกิดอะไรขึ้นรึเปล่านะ
Dialogue: 0,0:20:51.97,0:20:54.09,Default,,0,0,0,,เป็นเรื่องเมื่อ 12 ปีก่อนน่ะ
Dialogue: 0,0:20:54.48,0:20:55.46,Default,,0,0,0,,พอมาคิด ๆ ดูแล้ว...
Dialogue: 0,0:20:55.89,0:20:59.52,Default,,0,0,0,,ความบิดเบี้ยวของทุกสิ่งทุกอย่าง\Nอาจจะเริ่มต้นมาจากตอนนั้นก็ได้
Dialogue: 0,0:21:00.58,0:21:03.50,Default,,0,0,0,,เอาละทุกคน  ตำหนักหลักอยู่ข้างหน้านี้แล้ว
Dialogue: 0,0:21:20.34,0:21:21.56,Default,,0,0,0,,ไม่มีอะไรเลยแฮะ
Dialogue: 0,0:21:21.56,0:21:22.92,Default,,0,0,0,,นี่คือตำหนักหลักเหรอ
Dialogue: 0,0:21:23.34,0:21:26.50,Default,,0,0,0,,ไม่ล่ะ เป็นเพราะพวกเราถูกปฏิเสธน่ะ
Dialogue: 0,0:21:27.34,0:21:29.87,Default,,0,0,0,,แม้เท็นเก็นจะไม่ยุ่งเกี่ยวกับโลกภายนอก
Dialogue: 0,0:21:30.10,0:21:34.24,Default,,0,0,0,,แต่ตอนนี้ที่เนตรทิพย์ถูกผนึกไปแล้ว\Nก็อาจจะติดต่อได้สำเร็จ...
Dialogue: 0,0:21:34.66,0:21:36.36,Default,,0,0,0,,ฉันประเมินสถานการณ์ต่ำเกินไป
Dialogue: 0,0:21:38.31,0:21:40.94,Default,,0,0,0,,คนที่ถูกปฏิเสธไม่ใช่พวกเรา
Dialogue: 0,0:21:41.50,0:21:42.99,Default,,0,0,0,,แต่เป็นฉันงั้นเหรอ
Dialogue: 0,0:21:45.10,0:21:46.27,Default,,0,0,0,,กลับกันเถอะครับ
Dialogue: 0,0:21:46.54,0:21:48.08,Default,,0,0,0,,คุณสึมิกิเหลือเวลาไม่มากแล้ว
Dialogue: 0,0:21:51.15,0:21:52.54,Default,,0,0,0,,จะกลับกันเลยรึ
Dialogue: 0,0:21:54.10,0:21:55.47,Default,,0,0,0,,ยินดีที่ได้รู้จัก
Dialogue: 0,0:21:55.47,0:22:01.20,Default,,0,0,0,,บุตรแห่งเซ็นอิง สายเลือดมิจิซาเนะ\Nครรภ์คำสาปอสุภนพรูป แล้วก็...
Dialogue: 0,0:22:03.70,0:22:05.62,Default,,0,0,0,,ภาชนะของสุคุนะ
Dialogue: 0,0:23:40.43,0:23:42.67,Default,,0,0,0,,ขอตั้งเงื่อนไขหนึ่งข้อ
Dialogue: 0,0:23:42.68,0:23:44.47,Default,,0,0,0,,พวกเรามาถามวิธีปลดผนึก\Nขอบเขตประตูคุกครับ
Dialogue: 0,0:23:44.47,0:23:45.92,Default,,0,0,0,,จะไม่ทักทายฉันหน่อยเหรอ
Dialogue: 0,0:23:45.92,0:23:47.10,Default,,0,0,0,,งั้นจรดลล้างบาง...
Dialogue: 0,0:23:47.10,0:23:49.02,Default,,0,0,0,,การบังคับให้มนุษยชาติวิวัฒนาการ
Dialogue: 0,0:23:49.02,0:23:50.95,Default,,0,0,0,,ฉันว่าตามกฎแล้วถ้าถูกริบก็เท่ากับตายนะ
Dialogue: 0,0:23:50.95,0:23:52.01,Default,,0,0,0,,ถ้าคราวหน้าสุคุนะเปลี่ยนตัวกับผมอีก
Dialogue: 0,0:23:52.01,0:23:53.12,Default,,0,0,0,,ให้ฆ่าผมได้เลยไม่ต้องลังเล\N(ตอนต่อไป ว่าด้วยเรื่องของจรดลล้างบาง)
Dialogue: 0,0:23:53.12,0:23:53.98,Default,,0,0,0,,ห้ามตายเชียวนะ\N(ตอนต่อไป ว่าด้วยเรื่องของจรดลล้างบาง)
Dialogue: 0,0:23:53.98,0:23:55.06,Default,,0,0,0,,(ตอนต่อไป ว่าด้วยเรื่องของจรดลล้างบาง)

