Dialogue: 0,0:00:34.54,0:00:38.37,Default,,0,0,0,,(JUJUTSU KAISEN THE CULLING GAME PART 1)
Dialogue: 0,0:01:56.87,0:01:59.87,Default,,0,0,0,,(EPISOD 49: SEKALI LAGI)
Dialogue: 0,0:02:00.54,0:02:01.54,Default,,0,0,0,,Maafkan saya.
Dialogue: 0,0:02:03.42,0:02:04.37,Default,,0,0,0,,Itadori.
Dialogue: 0,0:02:42.12,0:02:43.04,Default,,0,0,0,,Lajunya dia.
Dialogue: 0,0:02:43.33,0:02:45.37,Default,,0,0,0,,Saya langsung tak faham\Nteknik sumpahannya.
Dialogue: 0,0:02:45.79,0:02:47.46,Default,,0,0,0,,Saya ditekan seteruk ini,
Dialogue: 0,0:02:47.75,0:02:49.84,Default,,0,0,0,,jadi dia mungkin takkan dedahkannya.
Dialogue: 0,0:02:50.13,0:02:52.21,Default,,0,0,0,,Lupakan tentang Pertumpuan.
Dialogue: 0,0:02:53.42,0:02:56.43,Default,,0,0,0,,Saya tak boleh kawal darah\Ndi luar badan saya pun.
Dialogue: 0,0:03:06.65,0:03:07.94,Default,,0,0,0,,Awak tahan lasak.
Dialogue: 0,0:03:08.02,0:03:09.82,Default,,0,0,0,,Siapa awak sebenarnya?
Dialogue: 0,0:03:10.73,0:03:11.69,Default,,0,0,0,,Saya abang.
Dialogue: 0,0:03:12.11,0:03:13.94,Default,,0,0,0,,Abang sulung daripada sepuluh beradik.
Dialogue: 0,0:03:14.95,0:03:17.45,Default,,0,0,0,,(ALIRAN SISIK MERAH: TIMBUNAN)\NAliran Sisik Merah: Timbunan.
Dialogue: 0,0:03:17.74,0:03:19.83,Default,,0,0,0,,Awak tak jawab soalan saya.
Dialogue: 0,0:03:20.24,0:03:24.66,Default,,0,0,0,,Saya tanya tentang teknik sumpahan awak\Ndan ketahanan awak.
Dialogue: 0,0:03:42.97,0:03:44.47,Default,,0,0,0,,Dia boleh ikut pergerakan saya?
Dialogue: 0,0:03:52.52,0:03:53.78,Default,,0,0,0,,Begitu rupanya.
Dialogue: 0,0:03:54.28,0:03:55.99,Default,,0,0,0,,Aliran Sisik Merah, ya?
Dialogue: 0,0:03:56.28,0:03:58.91,Default,,0,0,0,,Dia fokuskan teknik itu\Npada otot luar okularnya
Dialogue: 0,0:03:58.99,0:04:01.07,Default,,0,0,0,,untuk meningkatkan penglihatan dinamiknya.
Dialogue: 0,0:04:02.20,0:04:03.37,Default,,0,0,0,,Malang sekali.
Dialogue: 0,0:04:03.45,0:04:06.41,Default,,0,0,0,,Saya memang bertindak dengan andaian\Nawak akan menyerang balas.
Dialogue: 0,0:04:07.66,0:04:10.33,Default,,0,0,0,,Awak degil, jadi saya gunakan ini.
Dialogue: 0,0:04:10.67,0:04:11.67,Default,,0,0,0,,Senjata.
Dialogue: 0,0:04:11.88,0:04:13.17,Default,,0,0,0,,Awak guna Manipulasi Darah.
Dialogue: 0,0:04:13.25,0:04:14.96,Default,,0,0,0,,Menghentikan pendarahan\Ntentu mudah bagi awak.
Dialogue: 0,0:04:15.30,0:04:19.89,Default,,0,0,0,,Namun berapa lama awak boleh lawan saya\Nsambil menghentikan pendarahan?
Dialogue: 0,0:04:20.43,0:04:21.68,Default,,0,0,0,,Awak sangat bersedia.
Dialogue: 0,0:04:21.97,0:04:23.14,Default,,0,0,0,,Rahsiakan hal ini.
Dialogue: 0,0:04:23.22,0:04:27.56,Default,,0,0,0,,Sejujurnya, saya rasa ia memalukan\Nkalau penyihir bawa senjata.
Dialogue: 0,0:04:27.85,0:04:30.23,Default,,0,0,0,,Namun kita tak boleh menang tanpanya.
Dialogue: 0,0:04:30.52,0:04:33.57,Default,,0,0,0,,Sebenarnya ada ramai orang\Nyang berfikir seperti saya.
Dialogue: 0,0:04:33.98,0:04:37.11,Default,,0,0,0,,Abang-abang saya juga bawa senjata.\NMenyedihkan betul.
Dialogue: 0,0:04:37.28,0:04:40.57,Default,,0,0,0,,Walaupun begitu, mereka berani\Npandang rendah kepada Toji.
Dialogue: 0,0:04:40.99,0:04:43.37,Default,,0,0,0,,Awak benci abang-abang awak?
Dialogue: 0,0:04:43.91,0:04:45.04,Default,,0,0,0,,Ya.
Dialogue: 0,0:04:45.29,0:04:48.46,Default,,0,0,0,,Tiada sebab untuk abang yang lebih lemah\Ndaripada adik mereka wujud, bukan?
Dialogue: 0,0:04:48.91,0:04:50.79,Default,,0,0,0,,Lebih baik mereka mati menggantung diri.
Dialogue: 0,0:04:51.29,0:04:53.54,Default,,0,0,0,,Mungkin disebabkan abang-abang itulah
Dialogue: 0,0:04:53.92,0:04:56.17,Default,,0,0,0,,awak jadi diri awak yang sekarang.
Dialogue: 0,0:04:56.80,0:04:57.63,Default,,0,0,0,,Apa?
Dialogue: 0,0:04:57.71,0:05:00.97,Default,,0,0,0,,Kata-kata awak tadi menjijikkan.
Dialogue: 0,0:05:01.43,0:05:02.76,Default,,0,0,0,,Mengarut betul.
Dialogue: 0,0:05:04.22,0:05:06.47,Default,,0,0,0,,Tak kira kuat atau lemah,
Dialogue: 0,0:05:06.56,0:05:08.52,Default,,0,0,0,,si abang ialah contoh bagi si adik.
Dialogue: 0,0:05:09.43,0:05:11.31,Default,,0,0,0,,Kalau saya ambil jalan yang salah,
Dialogue: 0,0:05:11.40,0:05:13.61,Default,,0,0,0,,adik saya hanya perlu mengelak jalan itu.
Dialogue: 0,0:05:14.19,0:05:16.15,Default,,0,0,0,,Kalau saya ambil jalan yang betul,
Dialogue: 0,0:05:16.36,0:05:18.53,Default,,0,0,0,,adik saya hanya perlu ikut saya.
Dialogue: 0,0:05:19.15,0:05:20.53,Default,,0,0,0,,Kalau kekuatan awak berasal
Dialogue: 0,0:05:20.82,0:05:23.57,Default,,0,0,0,,daripada kelemahan abang awak,\Napa yang awak akan buat?
Dialogue: 0,0:05:24.37,0:05:26.49,Default,,0,0,0,,Awak tanya saya kenapa saya\Nbegitu tahan lasak, bukan?
Dialogue: 0,0:05:27.29,0:05:28.20,Default,,0,0,0,,Saya akan beritahu awak.
Dialogue: 0,0:05:28.75,0:05:30.25,Default,,0,0,0,,Sebab saya tiada pembimbing jalan.
Dialogue: 0,0:05:30.54,0:05:32.50,Default,,0,0,0,,Saya buat silap berulang kali.
Dialogue: 0,0:05:32.83,0:05:33.83,Default,,0,0,0,,Walaupun begitu,
Dialogue: 0,0:05:34.00,0:05:36.50,Default,,0,0,0,,saya sentiasa perlu berjalan\Nmendahului adik-adik saya.
Dialogue: 0,0:05:37.13,0:05:38.88,Default,,0,0,0,,Sebab itulah saya kuat.
Dialogue: 0,0:05:43.34,0:05:44.68,Default,,0,0,0,,Apa yang berlaku?
Dialogue: 0,0:05:44.97,0:05:47.06,Default,,0,0,0,,Kenapa dia masih hidup selepas\Nkehilangan banyak darah?
Dialogue: 0,0:05:55.15,0:05:58.82,Default,,0,0,0,,Rahim Lukisan Kematian ialah kacukan\Nsemangat sumpahan dan manusia.
Dialogue: 0,0:05:58.90,0:06:02.82,Default,,0,0,0,,Mereka ada tubuh khas yang menukar\Ntenaga sumpahan kepada darah.
Dialogue: 0,0:06:03.36,0:06:07.83,Default,,0,0,0,,Selagi tenaga sumpahan mereka tak habis,\Nmereka takkan mati.
Dialogue: 0,0:06:34.10,0:06:35.23,Default,,0,0,0,,Kaki saya terasa berat.
Dialogue: 0,0:06:36.02,0:06:38.77,Default,,0,0,0,,Adakah dia mengeraskan darah\Nyang meresap pada kain saya?
Dialogue: 0,0:06:40.23,0:06:41.57,Default,,0,0,0,,Saya tak perlu beritahu awak\Nyang selebihnya, bukan?
Dialogue: 0,0:06:42.82,0:06:43.95,Default,,0,0,0,,Awak dah terkepung.
Dialogue: 0,0:06:50.54,0:06:52.04,Default,,0,0,0,,Saya tak pasti tentang itu.
Dialogue: 0,0:06:53.54,0:06:54.92,Default,,0,0,0,,Teknik sumpahan saya
Dialogue: 0,0:06:55.08,0:06:58.46,Default,,0,0,0,,boleh menyalin pergerakan\Npada kadar 24fps.
Dialogue: 0,0:06:59.00,0:07:01.84,Default,,0,0,0,,Dengan kekangan sekuat ini saja,\Nsaya masih boleh bergerak bebas.
Dialogue: 0,0:07:02.97,0:07:04.30,Default,,0,0,0,,Cubalah kalau boleh.
Dialogue: 0,0:07:08.05,0:07:08.97,Default,,0,0,0,,Kenapa dia…
Dialogue: 0,0:07:09.05,0:07:10.43,Default,,0,0,0,,tak lancarkan serangannya?
Dialogue: 0,0:07:11.10,0:07:15.64,Default,,0,0,0,,Ini teknik yang Choso cipta\Nselepas 150 tahun
Dialogue: 0,0:07:15.73,0:07:17.65,Default,,0,0,0,,(SUPERNOVA)\Ndia mengasah teknik sumpahannya.
Dialogue: 0,0:07:43.01,0:07:43.92,Default,,0,0,0,,Maaflah.
Dialogue: 0,0:07:44.17,0:07:47.22,Default,,0,0,0,,Saya tak boleh faham perasaan seseorang\Nyang tak sayang adik-beradiknya.
Dialogue: 0,0:08:03.15,0:08:03.98,Default,,0,0,0,,Apa…
Dialogue: 0,0:08:10.41,0:08:11.74,Default,,0,0,0,,Awak nampak macam dalam kesakitan.
Dialogue: 0,0:08:13.49,0:08:14.41,Default,,0,0,0,,En. Naoya.
Dialogue: 0,0:08:19.00,0:08:20.38,Default,,0,0,0,,Jangan pandang rendah pada saya.
Dialogue: 0,0:08:26.67,0:08:27.88,Default,,0,0,0,,Apa yang berlaku?
Dialogue: 0,0:08:28.13,0:08:28.97,Default,,0,0,0,,Racun?
Dialogue: 0,0:08:29.68,0:08:32.10,Default,,0,0,0,,Adakah Manipulasi Darah\Nmempunyai kesan sebegitu?
Dialogue: 0,0:08:32.89,0:08:35.43,Default,,0,0,0,,Tak, ia bukan kesan teknik sumpahan.
Dialogue: 0,0:08:35.81,0:08:37.10,Default,,0,0,0,,Darah sebanyak itu…
Dialogue: 0,0:08:37.18,0:08:39.06,Default,,0,0,0,,Dia bukan manusia.
Dialogue: 0,0:08:39.52,0:08:40.98,Default,,0,0,0,,Adakah itu darah dan daging?
Dialogue: 0,0:08:41.15,0:08:44.65,Default,,0,0,0,,Badan saya menolak darah bukan manusia\Nyang memasukinya.
Dialogue: 0,0:08:44.78,0:08:46.03,Default,,0,0,0,,Nak saya sembuhkan awak?
Dialogue: 0,0:08:47.78,0:08:49.49,Default,,0,0,0,,Teknik sumpahan balikan saya
Dialogue: 0,0:08:49.78,0:08:51.07,Default,,0,0,0,,boleh menyembuhkan orang juga.
Dialogue: 0,0:08:51.78,0:08:52.99,Default,,0,0,0,,Sebagai balasan…
Dialogue: 0,0:08:53.95,0:08:58.87,Default,,0,0,0,,Tolong laporkan kepada pihak atasan\Ntentang kematian Itadori.
Dialogue: 0,0:09:01.96,0:09:05.42,Default,,0,0,0,,Jin…
Dialogue: 0,0:09:09.13,0:09:10.84,Default,,0,0,0,,Ada apa, ayah?
Dialogue: 0,0:09:11.64,0:09:14.01,Default,,0,0,0,,Kalau ayah nak cakap tentang dia,\Nsaya nak balik.
Dialogue: 0,0:09:15.10,0:09:16.10,Default,,0,0,0,,Jin.
Dialogue: 0,0:09:16.56,0:09:19.39,Default,,0,0,0,,Kamu boleh hidup sesuka hati kamu.
Dialogue: 0,0:09:20.31,0:09:23.52,Default,,0,0,0,,Namun kamu tak boleh terlibat\Ndengan perempuan itu.
Dialogue: 0,0:09:23.81,0:09:24.73,Default,,0,0,0,,Kamu akan mati.
Dialogue: 0,0:09:25.90,0:09:28.78,Default,,0,0,0,,Tolong jangan cakap perkara pelik\Ndi depan Yuji.
Dialogue: 0,0:09:29.44,0:09:32.53,Default,,0,0,0,,Orang kata bayi boleh ingat lebih banyak\Ndaripada yang kita sangka.
Dialogue: 0,0:09:33.12,0:09:35.83,Default,,0,0,0,,Ayah tahu kamu dah lama mahukan anak.
Dialogue: 0,0:09:35.91,0:09:39.29,Default,,0,0,0,,Ayah juga tahu kamu dan Kaori\Ntak boleh dapat anak.
Dialogue: 0,0:09:40.25,0:09:41.92,Default,,0,0,0,,Namun Kaori mati kerana…
Dialogue: 0,0:09:42.75,0:09:45.38,Default,,0,0,0,,Ayah bercakap tentang apa?
Dialogue: 0,0:09:59.81,0:10:00.68,Default,,0,0,0,,Apa?
Dialogue: 0,0:10:00.93,0:10:01.85,Default,,0,0,0,,Saya…
Dialogue: 0,0:10:18.95,0:10:19.79,Default,,0,0,0,,Syu…
Dialogue: 0,0:10:20.50,0:10:22.92,Default,,0,0,0,,Syukurlah.
Dialogue: 0,0:10:30.63,0:10:32.22,Default,,0,0,0,,Mungkin pada bulan September?
Dialogue: 0,0:10:33.22,0:10:35.43,Default,,0,0,0,,Cikgu Gojo datang jumpa saya.
Dialogue: 0,0:10:36.51,0:10:38.26,Default,,0,0,0,,Dia minta saya tengok-tengokkan awak.
Dialogue: 0,0:10:39.43,0:10:42.85,Default,,0,0,0,,Sebab itulah saya terpaksa berlakon.
Dialogue: 0,0:10:43.60,0:10:44.65,Default,,0,0,0,,Berlakon?
Dialogue: 0,0:10:45.52,0:10:48.27,Default,,0,0,0,,Saya rasa tak sedap hati.
Dialogue: 0,0:10:48.77,0:10:50.11,Default,,0,0,0,,Kalau ada apa-apa berlaku kepada saya,
Dialogue: 0,0:10:50.40,0:10:53.11,Default,,0,0,0,,saya harapkan awak untuk jaga\Npara pelajar tahun satu dan dua.
Dialogue: 0,0:10:53.74,0:10:55.53,Default,,0,0,0,,Hakari pula tentu takkan apa-apa.
Dialogue: 0,0:10:56.57,0:10:57.70,Default,,0,0,0,,Kalau ada apa-apa berlaku?
Dialogue: 0,0:10:58.24,0:10:59.49,Default,,0,0,0,,Contohnya awak dapat teman wanita?
Dialogue: 0,0:11:01.04,0:11:03.83,Default,,0,0,0,,Yuta, awak dah pandai buat lawak sekarang.
Dialogue: 0,0:11:04.41,0:11:05.25,Default,,0,0,0,,Tak.
Dialogue: 0,0:11:05.54,0:11:08.34,Default,,0,0,0,,Saya cuma tak boleh bayangkan perkara\Nyang akan berlaku kepada awak, Cikgu Gojo.
Dialogue: 0,0:11:09.84,0:11:11.88,Default,,0,0,0,,Terutamanya pelajar tahun satu,\NYuji Itadori.
Dialogue: 0,0:11:12.26,0:11:13.88,Default,,0,0,0,,Budak itu, sama seperti awak,
Dialogue: 0,0:11:14.13,0:11:16.13,Default,,0,0,0,,pernah dijatuhkan\Nhukuman mati secara rahsia.
Dialogue: 0,0:11:16.64,0:11:18.68,Default,,0,0,0,,Saya hargainya kalau awak\Nboleh tengok-tengokkan dia.
Dialogue: 0,0:11:20.56,0:11:21.39,Default,,0,0,0,,Mana Miguel?
Dialogue: 0,0:11:21.60,0:11:23.43,Default,,0,0,0,,Dia tak nak jumpa awak.
Dialogue: 0,0:11:26.14,0:11:28.31,Default,,0,0,0,,Berbanding ada orang lain\Nsebagai penghapus awak
Dialogue: 0,0:11:28.73,0:11:30.86,Default,,0,0,0,,atau menyembunyikan\Nsemua maklumat tentang awak,
Dialogue: 0,0:11:31.32,0:11:33.49,Default,,0,0,0,,saya putuskan bahawa inilah cara terbaik.
Dialogue: 0,0:11:34.53,0:11:35.99,Default,,0,0,0,,Namun mereka juga bukannya dungu.
Dialogue: 0,0:11:36.45,0:11:39.58,Default,,0,0,0,,Pihak atasan bersetuju dengan satu syarat.
Dialogue: 0,0:11:39.83,0:11:43.37,Default,,0,0,0,,Saya mesti angkat Ikrar Mengikat\Nuntuk "bunuh" awak.
Dialogue: 0,0:11:43.95,0:11:45.29,Default,,0,0,0,,Sebab itulah saya bunuh awak sekali.
Dialogue: 0,0:11:45.62,0:11:46.75,Default,,0,0,0,,Saya benar-benar minta maaf.
Dialogue: 0,0:11:49.75,0:11:50.59,Default,,0,0,0,,Namun…
Dialogue: 0,0:11:51.50,0:11:53.13,Default,,0,0,0,,Kalau begitu, kenapa saya masih hidup?
Dialogue: 0,0:11:54.21,0:11:55.67,Default,,0,0,0,,Disebabkan teknik sumpahan balikan.
Dialogue: 0,0:11:57.30,0:11:59.80,Default,,0,0,0,,Pada masa yang sama jantung awak terhenti,
Dialogue: 0,0:11:59.97,0:12:02.35,Default,,0,0,0,,saya guna teknik sumpahan balikan\Nuntuk sembuhkan awak.
Dialogue: 0,0:12:03.18,0:12:06.52,Default,,0,0,0,,Saya dah dengar tentang keadaan awak,\Njadi saya fikir ia mungkin berhasil.
Dialogue: 0,0:12:07.31,0:12:11.86,Default,,0,0,0,,Lagipun, tak ramai orang tahu saya boleh\Nkeluarkan tenaga positif secara langsung.
Dialogue: 0,0:12:12.48,0:12:13.32,Default,,0,0,0,,Betul.
Dialogue: 0,0:12:13.94,0:12:17.11,Default,,0,0,0,,Ini kali kedua saya\Npalsukan kematian awak.
Dialogue: 0,0:12:17.91,0:12:19.74,Default,,0,0,0,,Ia mungkin akan terbongkar tak lama lagi,
Dialogue: 0,0:12:19.99,0:12:21.45,Default,,0,0,0,,tapi ini situasi istimewa.
Dialogue: 0,0:12:22.08,0:12:23.49,Default,,0,0,0,,Buat masa ini,
Dialogue: 0,0:12:23.58,0:12:26.29,Default,,0,0,0,,hukuman mati awak sepatutnya\Ndianggap telah dilaksanakan.
Dialogue: 0,0:12:28.79,0:12:31.42,Default,,0,0,0,,Kenapa awak tolong saya\Nsampai begitu sekali?
Dialogue: 0,0:12:32.29,0:12:37.42,Default,,0,0,0,,Sebab awak penting bagi mereka\Nyang penting bagi saya.
Dialogue: 0,0:12:40.30,0:12:41.47,Default,,0,0,0,,Saya juga pernah dibebani
Dialogue: 0,0:12:42.14,0:12:44.35,Default,,0,0,0,,dengan kuasa yang terlalu besar\Nuntuk saya tangani.
Dialogue: 0,0:12:45.02,0:12:47.98,Default,,0,0,0,,Saya ingatkan kuasa itu\Ndipaksa kepada saya,
Dialogue: 0,0:12:48.31,0:12:50.31,Default,,0,0,0,,tapi sebenarnya saya sendiri\Nyang menjemputnya.
Dialogue: 0,0:12:50.90,0:12:51.81,Default,,0,0,0,,Awak berbeza.
Dialogue: 0,0:12:52.61,0:12:54.94,Default,,0,0,0,,Kuasa yang awak pikul itu\Nbukan milik awak.
Dialogue: 0,0:12:58.74,0:13:00.07,Default,,0,0,0,,Ia bukan salah awak.
Dialogue: 0,0:13:06.25,0:13:07.25,Default,,0,0,0,,Tak.
Dialogue: 0,0:13:07.87,0:13:10.17,Default,,0,0,0,,Ini bukan tentang salah saya atau tak.
Dialogue: 0,0:13:10.87,0:13:12.38,Default,,0,0,0,,Sebab saya…
Dialogue: 0,0:13:12.50,0:13:13.34,Default,,0,0,0,,Itadori.
Dialogue: 0,0:13:18.55,0:13:20.18,Default,,0,0,0,,- Fushiguro…\N- Apa yang awak buat?
Dialogue: 0,0:13:21.22,0:13:22.89,Default,,0,0,0,,Mari balik ke Sekolah Tinggi Jujutsu.
Dialogue: 0,0:13:23.43,0:13:25.43,Default,,0,0,0,,Benteng Sekolah Tinggi Jujutsu\Nsedang melonggar.
Dialogue: 0,0:13:26.01,0:13:27.85,Default,,0,0,0,,Asalkan tiada sesiapa nampak muka awak,
Dialogue: 0,0:13:28.14,0:13:29.77,Default,,0,0,0,,tiada masalah untuk awak balik.
Dialogue: 0,0:13:30.56,0:13:32.10,Default,,0,0,0,,Mari jumpa senior-senior kita dulu…
Dialogue: 0,0:13:32.19,0:13:33.06,Default,,0,0,0,,Berhenti.
Dialogue: 0,0:13:34.69,0:13:36.61,Default,,0,0,0,,Jangan terima saya\Nseolah-olah semuanya normal.
Dialogue: 0,0:13:37.99,0:13:39.65,Default,,0,0,0,,Jangan pura-pura\Nmacam tiada apa-apa berlaku.
Dialogue: 0,0:13:41.78,0:13:44.32,Default,,0,0,0,,Saya dah bunuh orang.
Dialogue: 0,0:13:46.33,0:13:47.83,Default,,0,0,0,,Ramai orang mati disebabkan saya…
Dialogue: 0,0:13:47.91,0:13:49.04,Default,,0,0,0,,Ia salah kita semua.
Dialogue: 0,0:13:50.91,0:13:53.25,Default,,0,0,0,,Ya, dah tentu awak akan cakap begitu.
Dialogue: 0,0:13:53.38,0:13:54.42,Default,,0,0,0,,Jangan pentingkan diri…
Dialogue: 0,0:13:55.96,0:13:57.21,Default,,0,0,0,,dan putus asa sendiri.
Dialogue: 0,0:14:10.81,0:14:12.52,Default,,0,0,0,,Kita bukan wira.
Dialogue: 0,0:14:13.52,0:14:14.56,Default,,0,0,0,,Kita penyihir jujutsu.
Dialogue: 0,0:14:15.48,0:14:18.11,Default,,0,0,0,,Tiada sesiapa yang boleh\Nbetul-betul menghukum kita.
Dialogue: 0,0:14:19.48,0:14:20.44,Default,,0,0,0,,Sebab itulah
Dialogue: 0,0:14:21.20,0:14:23.82,Default,,0,0,0,,kita perlu sentiasa membuktikan\Nnilai kewujudan kita.
Dialogue: 0,0:14:25.07,0:14:26.95,Default,,0,0,0,,Tak, Fushiguro.
Dialogue: 0,0:14:27.03,0:14:29.83,Default,,0,0,0,,Kita tiada masa untuk berfikir\Ntentang diri sendiri sekarang.
Dialogue: 0,0:14:29.91,0:14:31.04,Default,,0,0,0,,Kalau begitu, awak…
Dialogue: 0,0:14:31.12,0:14:33.17,Default,,0,0,0,,Kita hanya boleh terus membantu yang lain.
Dialogue: 0,0:14:33.25,0:14:34.67,Default,,0,0,0,,Selagi saya ada di sisi kamu semua…
Dialogue: 0,0:14:34.75,0:14:37.09,Default,,0,0,0,,Itu prinsip awak dari dulu lagi, bukan?
Dialogue: 0,0:14:37.17,0:14:38.96,Default,,0,0,0,,…kamu akan terus menderita.
Dialogue: 0,0:14:39.05,0:14:41.63,Default,,0,0,0,,Mulakan dengan membantu saya, Itadori.
Dialogue: 0,0:14:46.47,0:14:48.01,Default,,0,0,0,,Noritoshi Kamo telah membuat rancangan
Dialogue: 0,0:14:48.93,0:14:51.23,Default,,0,0,0,,bagi mereka yang terlibat dengan jujutsu\Nuntuk saling membunuh.
Dialogue: 0,0:14:52.23,0:14:53.39,Default,,0,0,0,,Dalam Culling Game.
Dialogue: 0,0:14:54.94,0:14:57.61,Default,,0,0,0,,Tsumiki juga telah diheret\Nuntuk menyertai Culling Game.
Dialogue: 0,0:15:00.11,0:15:02.36,Default,,0,0,0,,Tolonglah, Itadori.
Dialogue: 0,0:15:08.49,0:15:10.29,Default,,0,0,0,,Saya perlukan kekuatan awak.
Dialogue: 0,0:15:18.00,0:15:22.51,Default,,0,0,0,,(CULLING GAME, PERATURAN AM)
Dialogue: 0,0:15:22.59,0:15:23.47,Default,,0,0,0,,(CULLING GAME, PERATURAN AM)
Dialogue: 0,0:15:23.55,0:15:24.38,Default,,0,0,0,,(DALAM 19 HARI PENYERTAAN)
Dialogue: 0,0:15:25.26,0:15:26.22,Default,,0,0,0,,(PELANGGAR PERATURAN AKAN DILUCUTKAN\NTEKNIK SUMPAHAN MEREKA)
Dialogue: 0,0:15:26.93,0:15:27.76,Default,,0,0,0,,(MEMASUKI BENTENG DIANGGAP PENYERTAAN)
Dialogue: 0,0:15:28.93,0:15:29.76,Default,,0,0,0,,(HAPUSKAN NYAWA ORANG)
Dialogue: 0,0:15:30.43,0:15:31.27,Default,,0,0,0,,(PENYIHIR BERNILAI LIMA MATA)
Dialogue: 0,0:15:31.60,0:15:32.43,Default,,0,0,0,,(BUKAN PENYIHIR BERNILAI SATU MATA)
Dialogue: 0,0:15:40.73,0:15:42.99,Default,,0,0,0,,(JUJUTSU KAISEN)
Dialogue: 0,0:15:43.24,0:15:45.32,Default,,0,0,0,,Tolonglah, Itadori.
Dialogue: 0,0:15:46.24,0:15:48.12,Default,,0,0,0,,Saya perlukan kekuatan awak.
Dialogue: 0,0:15:50.33,0:15:51.41,Default,,0,0,0,,Senior Okkotsu.
Dialogue: 0,0:15:52.54,0:15:54.71,Default,,0,0,0,,Nampaknya Sukuna merancang sesuatu\Nyang melibatkan Fushiguro.
Dialogue: 0,0:15:56.37,0:15:58.63,Default,,0,0,0,,Dia mungkin dapat ambil alih\Nbadan saya di Shibuya
Dialogue: 0,0:15:58.96,0:16:01.63,Default,,0,0,0,,kerana saya telan sepuluh jari sekali gus.
Dialogue: 0,0:16:02.38,0:16:04.84,Default,,0,0,0,,Ada 15 jari dalam badan saya sekarang.
Dialogue: 0,0:16:05.47,0:16:07.59,Default,,0,0,0,,Walaupun saya makan lima jari\Nyang selebihnya sekali gus,
Dialogue: 0,0:16:08.01,0:16:09.68,Default,,0,0,0,,saya tak rasa dia\Nakan ambil alih badan saya lagi.
Dialogue: 0,0:16:10.22,0:16:11.14,Default,,0,0,0,,Walaupun begitu,
Dialogue: 0,0:16:11.97,0:16:14.31,Default,,0,0,0,,kalau Sukuna ambil alih badan saya lagi,
Dialogue: 0,0:16:14.39,0:16:15.77,Default,,0,0,0,,jangan teragak-agak untuk bunuh saya.
Dialogue: 0,0:16:16.85,0:16:18.27,Default,,0,0,0,,Saya rasa awak boleh lakukannya, senior.
Dialogue: 0,0:16:20.44,0:16:21.32,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:16:22.32,0:16:23.69,Default,,0,0,0,,Saya akan buat yang terbaik.
Dialogue: 0,0:16:24.94,0:16:25.90,Default,,0,0,0,,Fushiguro.
Dialogue: 0,0:16:26.61,0:16:27.86,Default,,0,0,0,,Apa patut saya buat?
Dialogue: 0,0:16:29.03,0:16:30.57,Default,,0,0,0,,Mula-mula, kita balik\Nke Sekolah Tinggi Jujutsu
Dialogue: 0,0:16:30.99,0:16:32.45,Default,,0,0,0,,dan hubungi Mahaguru Tengen.
Dialogue: 0,0:16:35.87,0:16:37.92,Default,,0,0,0,,Kita perlu cari jalan untuk buka\Nkurungan Alam Penjara.
Dialogue: 0,0:16:38.92,0:16:41.08,Default,,0,0,0,,Kita juga perlu memahami\Nobjektif sebenar Noritoshi Kamo
Dialogue: 0,0:16:41.38,0:16:42.50,Default,,0,0,0,,dan tindakan masa depannya.
Dialogue: 0,0:16:43.38,0:16:45.67,Default,,0,0,0,,Culling Game ialah keganasan jujutsu\Nyang tak pernah berlaku sebelum ini.
Dialogue: 0,0:16:46.22,0:16:47.42,Default,,0,0,0,,Untuk selesaikan masalah ini,
Dialogue: 0,0:16:47.51,0:16:50.01,Default,,0,0,0,,kita perlukan jawapan\Nuntuk dua soalan ini.
Dialogue: 0,0:16:50.09,0:16:53.06,Default,,0,0,0,,Saya rasa cuma Mahaguru Tengen\Nada jawapan untuk soalan-soalan itu.
Dialogue: 0,0:16:54.06,0:16:55.06,Default,,0,0,0,,Adakah orang itu…
Dialogue: 0,0:16:55.64,0:16:57.23,Default,,0,0,0,,Cik Tsukumo tak tahu tentang ini?
Dialogue: 0,0:16:57.94,0:16:59.60,Default,,0,0,0,,Saya dah tanya dia.
Dialogue: 0,0:17:00.27,0:17:01.69,Default,,0,0,0,,Ini cadangan dia.
Dialogue: 0,0:17:02.52,0:17:05.07,Default,,0,0,0,,Dia juga sedang bersembunyi\Ndi Sekolah Tinggi Jujutsu.
Dialogue: 0,0:17:06.69,0:17:07.78,Default,,0,0,0,,Bersembunyi?
Dialogue: 0,0:17:08.20,0:17:10.49,Default,,0,0,0,,Saya rasa dia tak nak terlibat\Ndengan pihak atasan.
Dialogue: 0,0:17:11.24,0:17:14.70,Default,,0,0,0,,Masalahnya ialah benteng\Nyang menyembunyikan Mahaguru Tengen.
Dialogue: 0,0:17:16.12,0:17:19.50,Default,,0,0,0,,Ada lebih seribu pintu\Nyang sentiasa berubah lokasi.
Dialogue: 0,0:17:19.75,0:17:20.87,Default,,0,0,0,,Hanya satu daripadanya
Dialogue: 0,0:17:20.96,0:17:23.79,Default,,0,0,0,,bersambung dengan\NMakam Koridor Bintang Mahaguru Tengen.
Dialogue: 0,0:17:25.67,0:17:29.93,Default,,0,0,0,,Jadi kalau kita tak jumpa pintu itu,\Nkita takkan dapat jumpa Tengen.
Dialogue: 0,0:17:34.64,0:17:35.60,Default,,0,0,0,,Maaf, Fushiguro.
Dialogue: 0,0:17:45.32,0:17:46.61,Default,,0,0,0,,Saya terpaksa tanya sekarang.
Dialogue: 0,0:17:50.90,0:17:52.41,Default,,0,0,0,,Apa yang berlaku kepada Kugisaki?
Dialogue: 0,0:17:59.83,0:18:00.87,Default,,0,0,0,,Begitu rupanya.
Dialogue: 0,0:18:04.59,0:18:05.50,Default,,0,0,0,,Saya faham.
Dialogue: 0,0:18:13.84,0:18:14.76,Default,,0,0,0,,Saya faham.
Dialogue: 0,0:18:16.64,0:18:18.64,Default,,0,0,0,,Benteng yang menyembunyikan dia itu…
Dialogue: 0,0:18:19.14,0:18:20.98,Default,,0,0,0,,Saya mungkin boleh pecahkannya.
Dialogue: 0,0:18:22.44,0:18:23.98,Default,,0,0,0,,Jadi awak juga mendengar.
Dialogue: 0,0:18:25.48,0:18:27.15,Default,,0,0,0,,Apa maksud awak, Choso?
Dialogue: 0,0:18:28.15,0:18:31.82,Default,,0,0,0,,Bukankah Mahito pernah curi jari Sukuna\Ndan kami, Rahim Lukisan Kematian?
Dialogue: 0,0:18:33.36,0:18:35.37,Default,,0,0,0,,Kita boleh guna cara yang sama.
Dialogue: 0,0:18:44.50,0:18:47.09,Default,,0,0,0,,Lama tak jumpa. Namun tak begitu lama.
Dialogue: 0,0:18:47.46,0:18:48.59,Default,,0,0,0,,Senior Maki?
Dialogue: 0,0:18:49.88,0:18:50.88,Default,,0,0,0,,Helo.
Dialogue: 0,0:18:51.67,0:18:52.63,Default,,0,0,0,,Maki!
Dialogue: 0,0:18:53.05,0:18:54.34,Default,,0,0,0,,Awak dah boleh bergerak?
Dialogue: 0,0:18:54.84,0:18:56.60,Default,,0,0,0,,Ya. Tiada masalah.
Dialogue: 0,0:18:57.22,0:18:58.89,Default,,0,0,0,,Saya tak boleh buat apa-apa\Ntentang kesan lecur dia.
Dialogue: 0,0:18:59.26,0:19:01.52,Default,,0,0,0,,Walaupun dengan teknik sumpahan balikan,\Nparut tetap akan tinggal.
Dialogue: 0,0:19:02.10,0:19:05.35,Default,,0,0,0,,Kebolehan fizikal semula jadi\NSekatan Syurga memang hebat.
Dialogue: 0,0:19:05.90,0:19:08.73,Default,,0,0,0,,Nyawa dia diselamatkan bukan\Ndengan ketahanan terhadap sumpahan,
Dialogue: 0,0:19:08.82,0:19:11.86,Default,,0,0,0,,tapi dengan kekuatan fizikal semula jadi.
Dialogue: 0,0:19:12.40,0:19:14.28,Default,,0,0,0,,Sayang sekali tentang\Nhal ketua keluarga awak itu.
Dialogue: 0,0:19:14.86,0:19:17.16,Default,,0,0,0,,Saya bukannya nak kedudukan itu.
Dialogue: 0,0:19:18.49,0:19:21.54,Default,,0,0,0,,Megumi, tentang benteng Mahaguru Tengen…
Dialogue: 0,0:19:22.58,0:19:23.46,Default,,0,0,0,,Tentang itu…
Dialogue: 0,0:19:23.91,0:19:25.17,Default,,0,0,0,,Biar saya yang jelaskan.
Dialogue: 0,0:19:26.00,0:19:28.38,Default,,0,0,0,,Di antara pintu-pintu itu\Ndan Makam Koridor Bintang,
Dialogue: 0,0:19:28.46,0:19:30.84,Default,,0,0,0,,ada gudang sumpahan yang\NSekolah Tinggi Jujutsu menyimpan alat
Dialogue: 0,0:19:30.92,0:19:32.01,Default,,0,0,0,,dan objek sumpahan.
Dialogue: 0,0:19:32.59,0:19:34.97,Default,,0,0,0,,Di dalam gudang sumpahan itu,\Nada jasad adik-adik saya…
Dialogue: 0,0:19:35.05,0:19:35.88,Default,,0,0,0,,Noranso,
Dialogue: 0,0:19:35.97,0:19:36.80,Default,,0,0,0,,Sho-oso,
Dialogue: 0,0:19:36.89,0:19:39.22,Default,,0,0,0,,Tanso, Sanso, Kotsuso,
Dialogue: 0,0:19:39.30,0:19:41.01,Default,,0,0,0,,dan Shoso.
Dialogue: 0,0:19:41.56,0:19:43.56,Default,,0,0,0,,Walaupun cuma jasad,\Nselagi keenam-enamnya ada,
Dialogue: 0,0:19:43.85,0:19:45.89,Default,,0,0,0,,kesan sampingan teknik sumpahan saya
Dialogue: 0,0:19:45.98,0:19:47.81,Default,,0,0,0,,sepatutnya membolehkan saya\Nmengesan mereka.
Dialogue: 0,0:19:48.77,0:19:49.77,Default,,0,0,0,,Bagus.
Dialogue: 0,0:19:50.15,0:19:51.69,Default,,0,0,0,,Lupakan dulu tentang itu.
Dialogue: 0,0:19:52.19,0:19:53.44,Default,,0,0,0,,Siapa dia?
Dialogue: 0,0:19:57.24,0:19:58.37,Default,,0,0,0,,Buat masa ini…
Dialogue: 0,0:19:59.62,0:20:01.49,Default,,0,0,0,,anggap dia abang saya.
Dialogue: 0,0:20:02.04,0:20:05.04,Default,,0,0,0,,Yuji!
Dialogue: 0,0:20:05.50,0:20:06.37,Default,,0,0,0,,Mari.
Dialogue: 0,0:20:09.46,0:20:10.38,Default,,0,0,0,,Itu pintunya.
Dialogue: 0,0:20:11.59,0:20:12.71,Default,,0,0,0,,Tak syak lagi.
Dialogue: 0,0:20:13.05,0:20:15.42,Default,,0,0,0,,Adik-adik saya tidur di depan sana.
Dialogue: 0,0:20:15.72,0:20:16.72,Default,,0,0,0,,Saya akan buka pintu.
Dialogue: 0,0:20:27.60,0:20:28.44,Default,,0,0,0,,Mari turun.
Dialogue: 0,0:20:30.27,0:20:33.36,Default,,0,0,0,,Jauh di dalam sini,\Nada lif ke Makam Koridor Bintang.
Dialogue: 0,0:20:35.15,0:20:36.03,Default,,0,0,0,,Choso.
Dialogue: 0,0:20:37.03,0:20:38.03,Default,,0,0,0,,Saya tahu.
Dialogue: 0,0:20:39.24,0:20:40.70,Default,,0,0,0,,Saya akan datang semula.
Dialogue: 0,0:20:40.99,0:20:42.70,Default,,0,0,0,,Tunggu sekejap saja lagi.
Dialogue: 0,0:20:48.79,0:20:49.88,Default,,0,0,0,,Kesan darah?
Dialogue: 0,0:20:50.17,0:20:51.50,Default,,0,0,0,,Ada apa-apa yang berlaku?
Dialogue: 0,0:20:51.96,0:20:53.92,Default,,0,0,0,,Itu cerita 12 tahun lalu.
Dialogue: 0,0:20:54.51,0:20:55.63,Default,,0,0,0,,Apabila difikirkan semula,
Dialogue: 0,0:20:56.01,0:20:57.30,Default,,0,0,0,,semua herotan itu
Dialogue: 0,0:20:57.55,0:20:59.59,Default,,0,0,0,,mungkin bermula ketika itu.
Dialogue: 0,0:21:00.64,0:21:01.47,Default,,0,0,0,,Ayuh, semua.
Dialogue: 0,0:21:01.76,0:21:03.56,Default,,0,0,0,,Dewan utama ada di depan sana.
Dialogue: 0,0:21:20.41,0:21:21.45,Default,,0,0,0,,Tiada apa-apa di sini.
Dialogue: 0,0:21:21.53,0:21:22.82,Default,,0,0,0,,Ini dewan utama?
Dialogue: 0,0:21:23.37,0:21:26.41,Default,,0,0,0,,Tak, Tengen menolak kita.
Dialogue: 0,0:21:27.20,0:21:29.92,Default,,0,0,0,,Tengen tak masuk campur\Ndengan dunia sebenar.
Dialogue: 0,0:21:30.00,0:21:31.96,Default,,0,0,0,,Namun saya fikir memandangkan\NEnam Mata dah dikurung,
Dialogue: 0,0:21:32.04,0:21:34.38,Default,,0,0,0,,mungkin ada peluang\Nuntuk kita hubungi Tengen.
Dialogue: 0,0:21:34.71,0:21:36.26,Default,,0,0,0,,Saya terlalu naif.
Dialogue: 0,0:21:38.30,0:21:40.97,Default,,0,0,0,,Bukan kami yang ditolak,
Dialogue: 0,0:21:41.55,0:21:42.76,Default,,0,0,0,,tapi saya?
Dialogue: 0,0:21:45.14,0:21:46.14,Default,,0,0,0,,Mari kita balik.
Dialogue: 0,0:21:46.56,0:21:48.10,Default,,0,0,0,,Tsumiki dah kesuntukan masa.
Dialogue: 0,0:21:51.14,0:21:52.69,Default,,0,0,0,,Kamu nak balik?
Dialogue: 0,0:21:54.02,0:21:55.40,Default,,0,0,0,,Selamat berkenalan.
Dialogue: 0,0:21:55.48,0:21:56.69,Default,,0,0,0,,Anak Zen'in,
Dialogue: 0,0:21:56.78,0:21:58.03,Default,,0,0,0,,keturunan Michizane,
Dialogue: 0,0:21:58.11,0:21:59.78,Default,,0,0,0,,Rahim Lukisan Kematian,
Dialogue: 0,0:21:59.86,0:22:00.99,Default,,0,0,0,,dan…
Dialogue: 0,0:22:03.70,0:22:05.78,Default,,0,0,0,,vesel Sukuna.
Dialogue: 0,0:23:40.46,0:23:42.55,Default,,0,0,0,,Biar saya cadangkan satu syarat dulu.
Dialogue: 0,0:23:42.63,0:23:44.55,Default,,0,0,0,,Kami datang nak tanya cara\Nuntuk buka Alam Penjara.
Dialogue: 0,0:23:44.63,0:23:46.01,Default,,0,0,0,,Awak tak nak sapa saya?
Dialogue: 0,0:23:46.09,0:23:47.09,Default,,0,0,0,,Jadi Culling Game…
Dialogue: 0,0:23:47.18,0:23:48.93,Default,,0,0,0,,Evolusi Manusia Secara Paksa.
Dialogue: 0,0:23:49.01,0:23:51.01,Default,,0,0,0,,Menurut peraturan,\Nawak akan mati jika ia dirampas.
Dialogue: 0,0:23:51.10,0:23:52.31,Default,,0,0,0,,Jika Sukuna ambil alih badan saya,
Dialogue: 0,0:23:52.39,0:23:53.23,Default,,0,0,0,,(EPISOD SETERUSNYA, TENTANG CULLING GAME)\Njangan teragak-agak untuk bunuh saya.
Dialogue: 0,0:23:53.31,0:23:55.02,Default,,0,0,0,,(EPISOD SETERUSNYA, TENTANG CULLING GAME)\NJangan mati.

