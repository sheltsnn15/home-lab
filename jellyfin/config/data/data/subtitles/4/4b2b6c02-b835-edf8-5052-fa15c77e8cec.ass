Dialogue: 0,0:00:34.54,0:00:38.37,Default,,0,0,0,,JUJUTSU KAISEN THE CULLING GAME PART 1
Dialogue: 0,0:01:56.87,0:01:59.87,Default,,0,0,0,,(EPISODE 49 SEKALI LAGI)
Dialogue: 0,0:02:00.54,0:02:01.54,Default,,0,0,0,,Maafkan aku.
Dialogue: 0,0:02:03.42,0:02:04.71,Default,,0,0,0,,Itadori.
Dialogue: 0,0:02:42.12,0:02:43.25,Default,,0,0,0,,Dia cepat.
Dialogue: 0,0:02:43.33,0:02:45.71,Default,,0,0,0,,Aku sama sekali tidak mengerti\Nteknik terkutuknya.
Dialogue: 0,0:02:45.79,0:02:47.67,Default,,0,0,0,,Karena dia menekanku sampai sejauh ini,
Dialogue: 0,0:02:47.75,0:02:50.05,Default,,0,0,0,,dia mungkin tidak akan\Nmengungkap teknik terkutuknya?
Dialogue: 0,0:02:50.13,0:02:52.59,Default,,0,0,0,,Lupakan soal "Konvergensi".
Dialogue: 0,0:02:53.42,0:02:56.76,Default,,0,0,0,,Aku bahkan tak bisa mengendalikan\Ndarah di luar tubuhku.
Dialogue: 0,0:03:06.65,0:03:07.94,Default,,0,0,0,,Kau cukup tangguh.
Dialogue: 0,0:03:08.02,0:03:10.65,Default,,0,0,0,,Sebenarnya kau ini apa?
Dialogue: 0,0:03:10.73,0:03:12.03,Default,,0,0,0,,Aku Kakak.
Dialogue: 0,0:03:12.11,0:03:14.19,Default,,0,0,0,,Aku kakak tertua\Ndi antara sepuluh bersaudara.
Dialogue: 0,0:03:14.95,0:03:16.20,Default,,0,0,0,,"Sisik Merah Mengalir: Tumpuk."
Dialogue: 0,0:03:16.28,0:03:17.61,Default,,0,0,0,,(Sisik Merah Mengalir: Tumpuk)\N"Sisik Merah Mengalir: Tumpuk."
Dialogue: 0,0:03:17.74,0:03:20.16,Default,,0,0,0,,Kau tidak menjawab pertanyaanku.
Dialogue: 0,0:03:20.24,0:03:24.83,Default,,0,0,0,,Aku menanyakan teknik terkutukmu\Ndan seberapa tangguhnya dirimu.
Dialogue: 0,0:03:42.97,0:03:44.56,Default,,0,0,0,,Dia bisa mengimbangi gerakanku?
Dialogue: 0,0:03:52.48,0:03:54.15,Default,,0,0,0,,Begitu rupanya.
Dialogue: 0,0:03:54.23,0:03:56.20,Default,,0,0,0,,Itu "Sisik Merah Mengalir"?
Dialogue: 0,0:03:56.28,0:03:58.91,Default,,0,0,0,,Dia memfokuskan kemampuan itu\Npada otot ekstraokular
Dialogue: 0,0:03:58.99,0:04:01.24,Default,,0,0,0,,untuk meningkatkan penglihatan dinamisnya.
Dialogue: 0,0:04:02.20,0:04:03.37,Default,,0,0,0,,Sayang sekali.
Dialogue: 0,0:04:03.45,0:04:06.54,Default,,0,0,0,,Gerakanku berdasarkan serangan balik.
Dialogue: 0,0:04:07.66,0:04:10.58,Default,,0,0,0,,Kau terlalu gigih,\Njadi, aku menggunakan ini.
Dialogue: 0,0:04:10.67,0:04:11.79,Default,,0,0,0,,Senjata.
Dialogue: 0,0:04:11.88,0:04:13.17,Default,,0,0,0,,Lagi pula,\Nkau menggunakan Manipulasi Darah.
Dialogue: 0,0:04:13.25,0:04:15.21,Default,,0,0,0,,Menghentikan pendarahan\Nseharusnya mudah bagimu.
Dialogue: 0,0:04:15.30,0:04:16.76,Default,,0,0,0,,Kau mau mencobanya?
Dialogue: 0,0:04:16.84,0:04:20.01,Default,,0,0,0,,Seberapa jauh kau bisa melawanku\Nsambil menghentikan pendarahan?
Dialogue: 0,0:04:20.43,0:04:21.89,Default,,0,0,0,,Persiapanmu bagus.
Dialogue: 0,0:04:21.97,0:04:23.14,Default,,0,0,0,,Rahasiakan ini.
Dialogue: 0,0:04:23.22,0:04:27.77,Default,,0,0,0,,Sejujurnya, menurutku payah\Njika penyihir membawa senjata.
Dialogue: 0,0:04:27.85,0:04:30.44,Default,,0,0,0,,Tapi kau tak bisa menang tanpanya.
Dialogue: 0,0:04:30.52,0:04:33.90,Default,,0,0,0,,Mengejutkannya, ada banyak orang\Nyang berpikir sepertiku.
Dialogue: 0,0:04:33.98,0:04:37.19,Default,,0,0,0,,Para kakakku juga membawa senjata.\NItu sangat tidak sedap dipandang.
Dialogue: 0,0:04:37.28,0:04:40.91,Default,,0,0,0,,Tapi mereka berani meremehkan Toji.
Dialogue: 0,0:04:40.99,0:04:43.83,Default,,0,0,0,,Kau membenci kakak-kakakmu?
Dialogue: 0,0:04:43.91,0:04:45.20,Default,,0,0,0,,Ya.
Dialogue: 0,0:04:45.29,0:04:47.12,Default,,0,0,0,,Kakak yang lebih buruk\Ndaripada adik mereka
Dialogue: 0,0:04:47.20,0:04:48.83,Default,,0,0,0,,tidak pantas hidup, bukan?
Dialogue: 0,0:04:48.91,0:04:51.21,Default,,0,0,0,,Lebih baik mereka gantung diri.
Dialogue: 0,0:04:51.29,0:04:53.84,Default,,0,0,0,,Mungkin karena kakak-kakak itu
Dialogue: 0,0:04:53.92,0:04:56.30,Default,,0,0,0,,kau menjadi dirimu yang sekarang.
Dialogue: 0,0:04:56.80,0:04:57.63,Default,,0,0,0,,Apa?
Dialogue: 0,0:04:57.71,0:05:01.39,Default,,0,0,0,,Ucapanmu menjijikkan.
Dialogue: 0,0:05:01.47,0:05:03.01,Default,,0,0,0,,Aku tidak tahan.
Dialogue: 0,0:05:04.18,0:05:06.47,Default,,0,0,0,,Cakap atau tidak,
Dialogue: 0,0:05:06.56,0:05:09.39,Default,,0,0,0,,kakak adalah panutan adiknya.
Dialogue: 0,0:05:09.48,0:05:11.31,Default,,0,0,0,,Jika kuambil jalan yang salah,
Dialogue: 0,0:05:11.40,0:05:14.11,Default,,0,0,0,,sang adik hanya perlu menghindari jejakku.
Dialogue: 0,0:05:14.19,0:05:16.28,Default,,0,0,0,,Jika kuambil jalan yang benar,
Dialogue: 0,0:05:16.36,0:05:19.11,Default,,0,0,0,,sang adik hanya perlu mengikuti.
Dialogue: 0,0:05:19.19,0:05:20.78,Default,,0,0,0,,Jika kekuatanmu berasal
Dialogue: 0,0:05:20.86,0:05:24.28,Default,,0,0,0,,dari kelemahan kakakmu,\Napa yang akan kau lakukan?
Dialogue: 0,0:05:24.37,0:05:26.83,Default,,0,0,0,,Kau bertanya\Nkenapa aku sangat tangguh, bukan?
Dialogue: 0,0:05:27.29,0:05:28.20,Default,,0,0,0,,Kuberi tahu.
Dialogue: 0,0:05:28.75,0:05:30.46,Default,,0,0,0,,Karena aku tak punya panutan.
Dialogue: 0,0:05:30.54,0:05:32.75,Default,,0,0,0,,Aku membuat kesalahan berulang kali.
Dialogue: 0,0:05:32.83,0:05:33.92,Default,,0,0,0,,Meski begitu,
Dialogue: 0,0:05:34.00,0:05:37.05,Default,,0,0,0,,aku harus selalu mengungguli adik-adikku.
Dialogue: 0,0:05:37.13,0:05:39.72,Default,,0,0,0,,Itu sebabnya aku sangat kuat.
Dialogue: 0,0:05:43.34,0:05:44.89,Default,,0,0,0,,Apa yang terjadi?
Dialogue: 0,0:05:44.97,0:05:47.22,Default,,0,0,0,,Kenapa dia masih hidup\Nsetelah kehilangan banyak darah?
Dialogue: 0,0:05:55.15,0:05:58.82,Default,,0,0,0,,Rahim Lukisan Maut adalah\Nperpaduan roh terkutuk dan manusia.
Dialogue: 0,0:05:58.90,0:06:03.32,Default,,0,0,0,,Mereka punya tubuh khusus yang mengubah\Nenergi terkutuk menjadi darah.
Dialogue: 0,0:06:03.41,0:06:08.12,Default,,0,0,0,,Selama energi terkutuk mereka tak habis,\Nmereka tak akan mati kehabisan darah.
Dialogue: 0,0:06:34.10,0:06:35.60,Default,,0,0,0,,Kakiku berat sekali.
Dialogue: 0,0:06:35.94,0:06:39.19,Default,,0,0,0,,Apa dia memadatkan darah\Nyang meresap ke dalam kain?
Dialogue: 0,0:06:40.19,0:06:41.69,Default,,0,0,0,,Aku tidak perlu\Nmemberitahumu hasilnya, bukan?
Dialogue: 0,0:06:42.69,0:06:44.24,Default,,0,0,0,,Kau tersudut.
Dialogue: 0,0:06:50.54,0:06:52.08,Default,,0,0,0,,Aku tidak yakin soal itu.
Dialogue: 0,0:06:53.54,0:06:55.00,Default,,0,0,0,,Teknik terkutukku bisa
Dialogue: 0,0:06:55.08,0:06:58.92,Default,,0,0,0,,mensimulasikan dan meniru\Ngerakan 24 fps sebelumnya.
Dialogue: 0,0:06:59.00,0:07:00.55,Default,,0,0,0,,Dengan tingkat pengekangan ini,
Dialogue: 0,0:07:00.63,0:07:01.92,Default,,0,0,0,,aku masih bisa bergerak bebas.
Dialogue: 0,0:07:02.88,0:07:04.76,Default,,0,0,0,,Coba saja.
Dialogue: 0,0:07:08.05,0:07:08.97,Default,,0,0,0,,Kenapa…
Dialogue: 0,0:07:09.05,0:07:10.60,Default,,0,0,0,,dia tidak menembakku?
Dialogue: 0,0:07:11.10,0:07:15.64,Default,,0,0,0,,Ini teknik yang dikembangkan Choso\Nsetelah menghabiskan 150 tahun
Dialogue: 0,0:07:15.73,0:07:17.65,Default,,0,0,0,,(SUPERNOVA)\Ndengan teknik terkutuknya.
Dialogue: 0,0:07:42.96,0:07:44.09,Default,,0,0,0,,Maafkan aku.
Dialogue: 0,0:07:44.17,0:07:47.51,Default,,0,0,0,,Aku tidak paham perasaan seseorang\Nyang tidak menyayangi saudara-saudaranya.
Dialogue: 0,0:08:03.11,0:08:04.44,Default,,0,0,0,,Apa?
Dialogue: 0,0:08:10.37,0:08:12.08,Default,,0,0,0,,Sepertinya kau kesakitan.
Dialogue: 0,0:08:13.49,0:08:14.79,Default,,0,0,0,,Pak Naoya.
Dialogue: 0,0:08:18.96,0:08:20.71,Default,,0,0,0,,Jangan meremehkanku.
Dialogue: 0,0:08:26.67,0:08:28.05,Default,,0,0,0,,Apa yang terjadi?
Dialogue: 0,0:08:28.13,0:08:29.13,Default,,0,0,0,,Apa itu racun?
Dialogue: 0,0:08:29.72,0:08:32.68,Default,,0,0,0,,Apa Manipulasi Darah memiliki efek itu?
Dialogue: 0,0:08:32.76,0:08:35.68,Default,,0,0,0,,Tidak, itu bukan efek teknik terkutuk.
Dialogue: 0,0:08:35.77,0:08:37.10,Default,,0,0,0,,Darah sebanyak itu…
Dialogue: 0,0:08:37.18,0:08:39.44,Default,,0,0,0,,Dia bukan manusia.
Dialogue: 0,0:08:39.52,0:08:40.98,Default,,0,0,0,,Itu daging dan darah?
Dialogue: 0,0:08:41.06,0:08:42.65,Default,,0,0,0,,Darah non-manusia memasukiku,
Dialogue: 0,0:08:42.73,0:08:44.65,Default,,0,0,0,,menyebabkan tubuhku menolaknya.
Dialogue: 0,0:08:44.73,0:08:46.44,Default,,0,0,0,,Haruskah aku menyembuhkanmu?
Dialogue: 0,0:08:47.69,0:08:49.70,Default,,0,0,0,,Teknik terkutuk kebalikanku
Dialogue: 0,0:08:49.78,0:08:51.70,Default,,0,0,0,,juga bisa sembuhkan orang lain.
Dialogue: 0,0:08:51.78,0:08:53.83,Default,,0,0,0,,Sebagai balasannya…
Dialogue: 0,0:08:53.91,0:08:59.21,Default,,0,0,0,,Tolong laporkan sendiri kepada petinggi\Nbahwa Itadori sudah mati.
Dialogue: 0,0:09:01.96,0:09:05.50,Default,,0,0,0,,Jin…
Dialogue: 0,0:09:09.13,0:09:10.93,Default,,0,0,0,,Ada apa, Ayah?
Dialogue: 0,0:09:11.64,0:09:14.60,Default,,0,0,0,,Jika kau datang untuk membicarakannya,\Naku akan pergi.
Dialogue: 0,0:09:15.10,0:09:16.47,Default,,0,0,0,,Jin.
Dialogue: 0,0:09:16.56,0:09:20.23,Default,,0,0,0,,Kau bebas menjalani hidupmu sesukamu.
Dialogue: 0,0:09:20.31,0:09:23.73,Default,,0,0,0,,Tapi kau tidak boleh terlibat\Ndengan wanita itu.
Dialogue: 0,0:09:23.81,0:09:24.73,Default,,0,0,0,,Kau akan mati.
Dialogue: 0,0:09:25.86,0:09:29.36,Default,,0,0,0,,Tolong jangan mengatakan\Nhal-hal aneh di depan Yuji.
Dialogue: 0,0:09:29.44,0:09:33.03,Default,,0,0,0,,Konon kita ingat hal-hal sejak masih bayi.
Dialogue: 0,0:09:33.12,0:09:35.83,Default,,0,0,0,,Aku tahu kau selalu menginginkan anak.
Dialogue: 0,0:09:35.91,0:09:40.16,Default,,0,0,0,,Aku tahu kau dan Kaori\Ntidak bisa memilikinya.
Dialogue: 0,0:09:40.25,0:09:41.92,Default,,0,0,0,,Tapi alasan Kaori meninggal…
Dialogue: 0,0:09:42.75,0:09:46.34,Default,,0,0,0,,Apa maksud Ayah?
Dialogue: 0,0:09:59.81,0:10:00.85,Default,,0,0,0,,Apa?
Dialogue: 0,0:10:00.93,0:10:02.35,Default,,0,0,0,,Aku…
Dialogue: 0,0:10:18.95,0:10:23.08,Default,,0,0,0,,Aku senang sekali.
Dialogue: 0,0:10:30.63,0:10:33.09,Default,,0,0,0,,Mungkin bulan September?
Dialogue: 0,0:10:33.18,0:10:36.39,Default,,0,0,0,,Pak Gojo secara khusus datang menemuiku.
Dialogue: 0,0:10:36.51,0:10:38.72,Default,,0,0,0,,Dia memintaku untuk menjagamu.
Dialogue: 0,0:10:39.43,0:10:43.19,Default,,0,0,0,,Itu sebabnya aku tak punya pilihan\Nselain berpura-pura.
Dialogue: 0,0:10:43.60,0:10:44.90,Default,,0,0,0,,Berpura-pura?
Dialogue: 0,0:10:45.52,0:10:48.65,Default,,0,0,0,,Aku punya firasat buruk tentang ini.
Dialogue: 0,0:10:48.73,0:10:50.32,Default,,0,0,0,,Jika terjadi sesuatu padaku,
Dialogue: 0,0:10:50.40,0:10:53.65,Default,,0,0,0,,aku harus mengurus\Nanak kelas satu dan dua saat ini.
Dialogue: 0,0:10:53.74,0:10:56.37,Default,,0,0,0,,Soal Hakari,\Ndia akan baik-baik saja, bukan?
Dialogue: 0,0:10:56.45,0:10:58.16,Default,,0,0,0,,Sesuatu terjadi kepadamu…
Dialogue: 0,0:10:58.24,0:11:00.29,Default,,0,0,0,,Apa ini soal hubungan?
Dialogue: 0,0:11:01.04,0:11:04.33,Default,,0,0,0,,Yuta, kau bisa membuat lelucon sekarang.
Dialogue: 0,0:11:04.41,0:11:05.46,Default,,0,0,0,,Tidak.
Dialogue: 0,0:11:05.54,0:11:08.84,Default,,0,0,0,,Aku tidak bisa membayangkan\Napa yang mungkin terjadi pada Pak Gojo.
Dialogue: 0,0:11:09.84,0:11:12.17,Default,,0,0,0,,Terutama anak kelas satu, Yuji Itadori.
Dialogue: 0,0:11:12.26,0:11:14.05,Default,,0,0,0,,Anak itu, sama sepertimu,
Dialogue: 0,0:11:14.13,0:11:16.55,Default,,0,0,0,,dia pernah dihukum mati diam-diam.
Dialogue: 0,0:11:16.64,0:11:19.22,Default,,0,0,0,,Akan bagus\Njika kau bisa mengawasi situasinya.
Dialogue: 0,0:11:20.51,0:11:21.52,Default,,0,0,0,,Miguel bagaimana?
Dialogue: 0,0:11:21.60,0:11:23.85,Default,,0,0,0,,Sepertinya dia tidak mau bertemu kau.
Dialogue: 0,0:11:26.14,0:11:28.65,Default,,0,0,0,,Aku yakin memiliki orang lain\Nsebagai algojomu
Dialogue: 0,0:11:28.73,0:11:31.23,Default,,0,0,0,,akan mencegahku\Nmendapatkan informasi tentangmu,
Dialogue: 0,0:11:31.32,0:11:33.90,Default,,0,0,0,,jadi, metode ini yang terbaik.
Dialogue: 0,0:11:34.49,0:11:36.36,Default,,0,0,0,,Orang-orang itu juga tak bodoh.
Dialogue: 0,0:11:36.45,0:11:39.74,Default,,0,0,0,,Para petinggi setuju dengan satu syarat.
Dialogue: 0,0:11:39.83,0:11:43.87,Default,,0,0,0,,Yaitu, aku harus membentuk\NSumpah Pengikat untuk "membunuhmu".
Dialogue: 0,0:11:43.95,0:11:45.54,Default,,0,0,0,,Itu sebabnya aku pernah membunuhmu.
Dialogue: 0,0:11:45.62,0:11:47.21,Default,,0,0,0,,Aku sungguh minta maaf.
Dialogue: 0,0:11:49.75,0:11:50.92,Default,,0,0,0,,Tapi…
Dialogue: 0,0:11:51.50,0:11:53.42,Default,,0,0,0,,Lalu kenapa aku masih hidup?
Dialogue: 0,0:11:54.21,0:11:55.92,Default,,0,0,0,,Ini teknik terkutuk kebalikan.
Dialogue: 0,0:11:57.30,0:11:59.89,Default,,0,0,0,,Saat jantungmu berhenti,
Dialogue: 0,0:11:59.97,0:12:02.35,Default,,0,0,0,,aku memakai teknik kutukan kebalikan\Nuntuk menyembuhkanmu.
Dialogue: 0,0:12:03.18,0:12:05.31,Default,,0,0,0,,Aku sudah mendengar kondisimu.
Dialogue: 0,0:12:05.39,0:12:07.19,Default,,0,0,0,,Kupikir itu mungkin berhasil.
Dialogue: 0,0:12:07.27,0:12:12.40,Default,,0,0,0,,Lagi pula, tak banyak orang tahu aku bisa\Nkeluarkan energi positif langsung.
Dialogue: 0,0:12:12.48,0:12:13.78,Default,,0,0,0,,Benar.
Dialogue: 0,0:12:13.86,0:12:17.82,Default,,0,0,0,,Ini kali kedua aku memalsukan kematianmu.
Dialogue: 0,0:12:17.91,0:12:19.91,Default,,0,0,0,,Mungkin ini akan segera terungkap.
Dialogue: 0,0:12:19.99,0:12:21.99,Default,,0,0,0,,Tapi ini situasi khusus.
Dialogue: 0,0:12:22.08,0:12:23.49,Default,,0,0,0,,Untuk saat ini, eksekusimu
Dialogue: 0,0:12:23.58,0:12:26.75,Default,,0,0,0,,harus dianggap selesai.
Dialogue: 0,0:12:28.79,0:12:31.88,Default,,0,0,0,,Kenapa kau banyak membantuku?
Dialogue: 0,0:12:32.29,0:12:37.88,Default,,0,0,0,,Karena kau sangat berarti\Nbagi orang-orang yang kusayangi.
Dialogue: 0,0:12:40.30,0:12:42.10,Default,,0,0,0,,Aku terbebani
Dialogue: 0,0:12:42.18,0:12:44.93,Default,,0,0,0,,dengan kekuatan yang terlalu besar\Nuntuk ditangani.
Dialogue: 0,0:12:45.02,0:12:48.23,Default,,0,0,0,,Kukira seseorang memaksakannya kepadaku.
Dialogue: 0,0:12:48.31,0:12:50.81,Default,,0,0,0,,Tapi aku sadar akulah penyebabnya.
Dialogue: 0,0:12:50.90,0:12:52.52,Default,,0,0,0,,Kau berbeda.
Dialogue: 0,0:12:52.61,0:12:55.57,Default,,0,0,0,,Kekuatan yang membebanimu bukan milikmu.
Dialogue: 0,0:12:58.65,0:13:00.66,Default,,0,0,0,,Ini bukan salahmu.
Dialogue: 0,0:13:06.25,0:13:07.75,Default,,0,0,0,,Tidak.
Dialogue: 0,0:13:07.83,0:13:10.79,Default,,0,0,0,,Ini bukan soal itu salahku atau bukan.
Dialogue: 0,0:13:10.87,0:13:12.38,Default,,0,0,0,,Itu karena aku…
Dialogue: 0,0:13:12.50,0:13:13.75,Default,,0,0,0,,Itadori.
Dialogue: 0,0:13:18.55,0:13:20.51,Default,,0,0,0,,- Fushiguro…\N- Kau sedang apa?
Dialogue: 0,0:13:21.22,0:13:22.89,Default,,0,0,0,,Ayo kembali ke SMA Jujutsu.
Dialogue: 0,0:13:23.43,0:13:25.93,Default,,0,0,0,,Penghalang SMA Jujutsu\Nsudah longgar sekarang.
Dialogue: 0,0:13:26.01,0:13:28.06,Default,,0,0,0,,Selama tak ada yang lihat wajahmu,
Dialogue: 0,0:13:28.14,0:13:30.48,Default,,0,0,0,,kau bisa kembali.
Dialogue: 0,0:13:30.56,0:13:32.10,Default,,0,0,0,,Mari temui para senior dahulu…
Dialogue: 0,0:13:32.19,0:13:33.06,Default,,0,0,0,,Hentikan.
Dialogue: 0,0:13:34.65,0:13:37.07,Default,,0,0,0,,Jangan menerimaku seolah tak ada apa-apa.
Dialogue: 0,0:13:37.99,0:13:40.07,Default,,0,0,0,,Jangan pura-pura itu tak terjadi.
Dialogue: 0,0:13:41.78,0:13:44.70,Default,,0,0,0,,Aku membunuh orang.
Dialogue: 0,0:13:46.33,0:13:47.83,Default,,0,0,0,,Banyak orang mati karena aku…
Dialogue: 0,0:13:47.91,0:13:49.37,Default,,0,0,0,,Ini salah kami.
Dialogue: 0,0:13:50.91,0:13:53.25,Default,,0,0,0,,Ya, tentu saja kau akan bilang begitu.
Dialogue: 0,0:13:53.38,0:13:55.88,Default,,0,0,0,,Jangan bertindak sendirian.
Dialogue: 0,0:13:55.96,0:13:57.63,Default,,0,0,0,,Jangan menyerah begitu saja.
Dialogue: 0,0:14:10.77,0:14:13.40,Default,,0,0,0,,Kita bukan pahlawan.
Dialogue: 0,0:14:13.48,0:14:15.36,Default,,0,0,0,,Kita Penyihir Jujutsu.
Dialogue: 0,0:14:15.44,0:14:19.28,Default,,0,0,0,,Tidak ada yang bisa menghukum kita.
Dialogue: 0,0:14:19.36,0:14:21.03,Default,,0,0,0,,Itu sebabnya
Dialogue: 0,0:14:21.11,0:14:24.28,Default,,0,0,0,,kita harus terus menunjukkan\Narti keberadaan kita.
Dialogue: 0,0:14:25.07,0:14:26.95,Default,,0,0,0,,Tidak, Fushiguro.
Dialogue: 0,0:14:27.03,0:14:29.83,Default,,0,0,0,,Tak ada waktu\Nmemikirkan diri sendiri sekarang.
Dialogue: 0,0:14:29.91,0:14:31.04,Default,,0,0,0,,Kalau begitu, kau…
Dialogue: 0,0:14:31.12,0:14:33.12,Default,,0,0,0,,Kau hanya bisa terus membantu orang lain.
Dialogue: 0,0:14:33.21,0:14:34.67,Default,,0,0,0,,Selama kau di sisiku,
Dialogue: 0,0:14:34.75,0:14:35.75,Default,,0,0,0,,Lagi pula,
Dialogue: 0,0:14:35.83,0:14:37.09,Default,,0,0,0,,itu selalu prinsipmu, kan?
Dialogue: 0,0:14:37.17,0:14:38.96,Default,,0,0,0,,kau akan terus menderita.
Dialogue: 0,0:14:39.05,0:14:42.09,Default,,0,0,0,,Jadi, tolong aku, Itadori.
Dialogue: 0,0:14:46.47,0:14:48.85,Default,,0,0,0,,Noritoshi Kamo membiarkan\Nsekelompok orang mendapatkan jujutsu
Dialogue: 0,0:14:48.93,0:14:52.23,Default,,0,0,0,,dan merancang permainan\Ndi mana mereka saling membunuh.
Dialogue: 0,0:14:52.31,0:14:53.77,Default,,0,0,0,,"Permainan Membasmi".
Dialogue: 0,0:14:54.94,0:14:58.11,Default,,0,0,0,,Tsumiki juga terjebak\Ndalam Permainan Membasmi.
Dialogue: 0,0:15:00.11,0:15:02.57,Default,,0,0,0,,Kumohon, Itadori.
Dialogue: 0,0:15:08.49,0:15:10.70,Default,,0,0,0,,Aku butuh kekuatanmu.
Dialogue: 0,0:15:18.00,0:15:22.51,Default,,0,0,0,,(PERMAINAN MEMBASMI, PERATURAN UMUM)
Dialogue: 0,0:15:22.59,0:15:23.47,Default,,0,0,0,,(PERMAINAN MEMBASMI, PERATURAN UMUM)
Dialogue: 0,0:15:23.55,0:15:24.38,Default,,0,0,0,,(DALAM 19 HARI PARTISIPASI)
Dialogue: 0,0:15:25.26,0:15:26.22,Default,,0,0,0,,(PELANGGAR ATURAN\NAKAN DIAMBIL TEKNIK KUTUKANNYA)
Dialogue: 0,0:15:26.93,0:15:27.76,Default,,0,0,0,,(MEMASUKI PENGHALANG DIANGGAP PARTISIPASI)
Dialogue: 0,0:15:28.93,0:15:29.76,Default,,0,0,0,,(BUNUH NYAWA)
Dialogue: 0,0:15:30.43,0:15:31.27,Default,,0,0,0,,(PENYIHIR BERNILAI LIMA POIN)
Dialogue: 0,0:15:31.60,0:15:32.43,Default,,0,0,0,,(NON-PENYIHIR, SATU POIN)
Dialogue: 0,0:15:40.73,0:15:42.99,Default,,0,0,0,,JUJUTSU KAISEN
Dialogue: 0,0:15:43.24,0:15:45.70,Default,,0,0,0,,Kumohon, Itadori.
Dialogue: 0,0:15:46.24,0:15:48.57,Default,,0,0,0,,Aku butuh kekuatanmu.
Dialogue: 0,0:15:50.33,0:15:51.66,Default,,0,0,0,,Okkotsu.
Dialogue: 0,0:15:52.54,0:15:55.16,Default,,0,0,0,,Sukuna sepertinya ingin\Nmemanfaatkan Fushiguro untuk sesuatu.
Dialogue: 0,0:15:56.37,0:15:58.88,Default,,0,0,0,,Tubuhku diambil alih olehnya di Shibuya.
Dialogue: 0,0:15:58.96,0:16:02.30,Default,,0,0,0,,Mungkin karena aku dipaksa\Ntelan sepuluh jari sekaligus.
Dialogue: 0,0:16:02.38,0:16:05.38,Default,,0,0,0,,Ada 15 jari di tubuhku sekarang.
Dialogue: 0,0:16:05.47,0:16:07.97,Default,,0,0,0,,Bahkan jika aku makan\Nlima jari sisanya sekaligus,
Dialogue: 0,0:16:08.05,0:16:10.14,Default,,0,0,0,,dia tidak akan\Nmengambil alih tubuhku lagi.
Dialogue: 0,0:16:10.22,0:16:11.22,Default,,0,0,0,,Meski begitu,
Dialogue: 0,0:16:11.93,0:16:14.31,Default,,0,0,0,,jika Sukuna mengambil alih tubuhku lagi,
Dialogue: 0,0:16:14.39,0:16:16.73,Default,,0,0,0,,jangan ragu untuk membunuhku.
Dialogue: 0,0:16:16.81,0:16:18.85,Default,,0,0,0,,Kurasa kau bisa, Okkotsu.
Dialogue: 0,0:16:20.44,0:16:23.94,Default,,0,0,0,,Aku mengerti.\NAku akan melakukan yang terbaik.
Dialogue: 0,0:16:24.99,0:16:26.53,Default,,0,0,0,,Fushiguro.
Dialogue: 0,0:16:26.61,0:16:28.24,Default,,0,0,0,,Apa yang harus kulakukan?
Dialogue: 0,0:16:29.03,0:16:32.95,Default,,0,0,0,,Pertama, ayo kembali ke SMA Jujutsu\Ndan hubungi Master Tengen.
Dialogue: 0,0:16:35.87,0:16:38.83,Default,,0,0,0,,Pertama, kita harus cari cara\Nuntuk membuka segel Alam Penjara.
Dialogue: 0,0:16:38.92,0:16:41.25,Default,,0,0,0,,Kedua, kita harus memahami\Ntujuan Noritoshi Kamo yang sebenarnya
Dialogue: 0,0:16:41.34,0:16:42.71,Default,,0,0,0,,dan tindakannya di masa depan.
Dialogue: 0,0:16:43.38,0:16:46.13,Default,,0,0,0,,Permainan Membasmi adalah serangan\Nteror Jujutsu yang belum pernah terjadi.
Dialogue: 0,0:16:46.22,0:16:47.42,Default,,0,0,0,,Untuk mengatasinya,
Dialogue: 0,0:16:47.51,0:16:50.01,Default,,0,0,0,,kita butuh jawaban\Ndari dua pertanyaan ini.
Dialogue: 0,0:16:50.09,0:16:53.39,Default,,0,0,0,,Satu-satunya yang bisa menjawabnya\Nadalah Master Tengen.
Dialogue: 0,0:16:54.06,0:16:57.85,Default,,0,0,0,,Apa orang itu… Nona Tsukumo tahu soal ini?
Dialogue: 0,0:16:57.94,0:17:00.19,Default,,0,0,0,,Aku sudah bertanya kepadanya.
Dialogue: 0,0:17:00.27,0:17:02.48,Default,,0,0,0,,Ini sarannya.
Dialogue: 0,0:17:02.56,0:17:05.90,Default,,0,0,0,,Dia juga bersembunyi di SMA Jujutsu.
Dialogue: 0,0:17:06.69,0:17:08.11,Default,,0,0,0,,Bersembunyi?
Dialogue: 0,0:17:08.20,0:17:11.16,Default,,0,0,0,,Kurasa dia tidak ingin terlibat\Ndengan para petinggi.
Dialogue: 0,0:17:11.24,0:17:14.99,Default,,0,0,0,,Masalahnya penghalang\Nyang "menyembunyikan" Master Tengen.
Dialogue: 0,0:17:16.12,0:17:19.67,Default,,0,0,0,,Lebih dari seribu pintu\Nterus berubah lokasi.
Dialogue: 0,0:17:19.75,0:17:20.87,Default,,0,0,0,,Hanya satu
Dialogue: 0,0:17:20.96,0:17:24.21,Default,,0,0,0,,yang mengarah ke Makam Koridor Bintang\NMaster Tengen.
Dialogue: 0,0:17:25.67,0:17:30.13,Default,,0,0,0,,Jika tak bisa temukan pintunya,\Nkita takkan bisa bertemu Master Tengen.
Dialogue: 0,0:17:34.64,0:17:35.97,Default,,0,0,0,,Maaf, Fushiguro.
Dialogue: 0,0:17:45.32,0:17:46.90,Default,,0,0,0,,Sebaiknya kutanya sekarang.
Dialogue: 0,0:17:50.90,0:17:52.99,Default,,0,0,0,,Bagaimana keadaan Kugisaki?
Dialogue: 0,0:17:59.83,0:18:01.42,Default,,0,0,0,,Begitu rupanya.
Dialogue: 0,0:18:04.54,0:18:05.88,Default,,0,0,0,,Aku mengerti.
Dialogue: 0,0:18:13.84,0:18:15.05,Default,,0,0,0,,Aku mengerti.
Dialogue: 0,0:18:16.60,0:18:19.06,Default,,0,0,0,,Penghalang untuk "menyembunyikannya"…
Dialogue: 0,0:18:19.14,0:18:21.31,Default,,0,0,0,,Mungkin aku bisa menghancurkannya.
Dialogue: 0,0:18:22.44,0:18:24.31,Default,,0,0,0,,Rupanya kau juga mendengarkan.
Dialogue: 0,0:18:25.48,0:18:27.36,Default,,0,0,0,,Choso, apa maksudmu?
Dialogue: 0,0:18:28.15,0:18:32.78,Default,,0,0,0,,Bukankah Mahito mencuri jari Sukuna\Ndan kita, Rahim Lukisan Maut?
Dialogue: 0,0:18:33.36,0:18:35.70,Default,,0,0,0,,Kita lakukan dengan cara yang sama.
Dialogue: 0,0:18:44.50,0:18:47.09,Default,,0,0,0,,Sudah lama tidak bertemu.\NBelum selama itu.
Dialogue: 0,0:18:47.46,0:18:49.05,Default,,0,0,0,,Maki?
Dialogue: 0,0:18:49.88,0:18:50.88,Default,,0,0,0,,Halo.
Dialogue: 0,0:18:51.67,0:18:54.76,Default,,0,0,0,,Maki, kau bisa berjalan?
Dialogue: 0,0:18:54.84,0:18:57.14,Default,,0,0,0,,Ya, aku bisa. Tidak masalah.
Dialogue: 0,0:18:57.22,0:18:59.18,Default,,0,0,0,,Aku tak bisa apa-apa soal luka bakarnya.
Dialogue: 0,0:18:59.26,0:19:02.02,Default,,0,0,0,,Dengan teknik terkutuk kebalikan pun\Nmasih ada bekas luka.
Dialogue: 0,0:19:02.10,0:19:05.81,Default,,0,0,0,,Kemampuan fisik alami\Ndari Pembatasan Surgawi.
Dialogue: 0,0:19:05.90,0:19:08.73,Default,,0,0,0,,Ketahanan terhadap kutukan\Ntidak menentukan kau hidup atau mati,
Dialogue: 0,0:19:08.82,0:19:12.32,Default,,0,0,0,,melainkan kekuatan fisik bawaanmu.
Dialogue: 0,0:19:12.40,0:19:14.78,Default,,0,0,0,,Aku minta maaf atas kejadian\Nyang menimpa kepala keluarga.
Dialogue: 0,0:19:14.86,0:19:17.45,Default,,0,0,0,,Ini bukan soal siapa yang lebih kuat.
Dialogue: 0,0:19:18.45,0:19:21.79,Default,,0,0,0,,Megumi, soal penghalang Master Tengen…
Dialogue: 0,0:19:22.58,0:19:23.79,Default,,0,0,0,,Soal itu…
Dialogue: 0,0:19:23.91,0:19:25.37,Default,,0,0,0,,Serahkan kepadaku.
Dialogue: 0,0:19:26.00,0:19:28.38,Default,,0,0,0,,Dalam perjalanan dari gerbang\Nke Makam Koridor Bintang,
Dialogue: 0,0:19:28.46,0:19:32.51,Default,,0,0,0,,ada gudang terkutuk untuk menyimpan\Nalat dan objek terkutuk di SMA Jujutsu.
Dialogue: 0,0:19:32.59,0:19:34.97,Default,,0,0,0,,Di gudang terkutuk itu\Nada jasad para saudaraku…
Dialogue: 0,0:19:35.05,0:19:35.88,Default,,0,0,0,,Noranso,
Dialogue: 0,0:19:35.97,0:19:36.80,Default,,0,0,0,,Sho-oso,
Dialogue: 0,0:19:36.89,0:19:37.72,Default,,0,0,0,,Tanso,
Dialogue: 0,0:19:37.80,0:19:39.22,Default,,0,0,0,,Sanso, Kotsuso,
Dialogue: 0,0:19:39.30,0:19:41.47,Default,,0,0,0,,dan Shoso.
Dialogue: 0,0:19:41.56,0:19:43.73,Default,,0,0,0,,Walau hanya jasad,\Nselama keenamnya di sana,
Dialogue: 0,0:19:43.85,0:19:45.89,Default,,0,0,0,,efek tambahan teknik terkutukku
Dialogue: 0,0:19:45.98,0:19:48.15,Default,,0,0,0,,seharusnya membuatku bisa merasakannya.
Dialogue: 0,0:19:48.77,0:19:50.07,Default,,0,0,0,,Luar biasa.
Dialogue: 0,0:19:50.15,0:19:52.11,Default,,0,0,0,,Jangan bicarakan itu sekarang.
Dialogue: 0,0:19:52.19,0:19:54.03,Default,,0,0,0,,Siapa dia?
Dialogue: 0,0:19:57.24,0:19:59.53,Default,,0,0,0,,Anggap saja dia…
Dialogue: 0,0:19:59.62,0:20:01.91,Default,,0,0,0,,sebagai kakakku.
Dialogue: 0,0:20:02.04,0:20:05.41,Default,,0,0,0,,Yuji!
Dialogue: 0,0:20:05.50,0:20:06.50,Default,,0,0,0,,Ayo.
Dialogue: 0,0:20:09.46,0:20:10.46,Default,,0,0,0,,Itu pintunya.
Dialogue: 0,0:20:11.59,0:20:12.96,Default,,0,0,0,,Tidak diragukan lagi.
Dialogue: 0,0:20:13.05,0:20:15.63,Default,,0,0,0,,Para saudaraku tertidur di depan.
Dialogue: 0,0:20:15.72,0:20:16.72,Default,,0,0,0,,Akan kubuka pintunya.
Dialogue: 0,0:20:27.56,0:20:28.77,Default,,0,0,0,,Ayo turun.
Dialogue: 0,0:20:30.23,0:20:33.73,Default,,0,0,0,,Jauh di dalam sini ada lift\Nmenuju Makam Koridor Bintang.
Dialogue: 0,0:20:35.07,0:20:36.07,Default,,0,0,0,,Choso.
Dialogue: 0,0:20:37.03,0:20:38.32,Default,,0,0,0,,Aku tahu.
Dialogue: 0,0:20:39.24,0:20:40.91,Default,,0,0,0,,Aku akan kembali nanti.
Dialogue: 0,0:20:40.99,0:20:42.99,Default,,0,0,0,,Tunggulah sebentar lagi.
Dialogue: 0,0:20:48.79,0:20:50.08,Default,,0,0,0,,Noda darah?
Dialogue: 0,0:20:50.17,0:20:51.84,Default,,0,0,0,,Apa terjadi sesuatu?
Dialogue: 0,0:20:51.96,0:20:54.42,Default,,0,0,0,,Itu 12 tahun lalu.
Dialogue: 0,0:20:54.51,0:20:55.92,Default,,0,0,0,,Setelah kupikir-pikir,
Dialogue: 0,0:20:56.01,0:20:57.47,Default,,0,0,0,,semua distorsi
Dialogue: 0,0:20:57.55,0:20:59.89,Default,,0,0,0,,mungkin dimulai saat itu.
Dialogue: 0,0:21:00.64,0:21:01.68,Default,,0,0,0,,Ayo, Semuanya.
Dialogue: 0,0:21:01.76,0:21:03.89,Default,,0,0,0,,Aula utama ada di depan.
Dialogue: 0,0:21:20.41,0:21:21.45,Default,,0,0,0,,Tak ada apa-apa.
Dialogue: 0,0:21:21.53,0:21:23.28,Default,,0,0,0,,Ini aula utamanya?
Dialogue: 0,0:21:23.37,0:21:27.12,Default,,0,0,0,,Tidak, ini karena kita ditolak.
Dialogue: 0,0:21:27.20,0:21:29.92,Default,,0,0,0,,Tengen tidak mengganggu dunia nyata.
Dialogue: 0,0:21:30.00,0:21:31.96,Default,,0,0,0,,Tapi kupikir,\Ndengan disegelnya Enam Mata sekarang,
Dialogue: 0,0:21:32.04,0:21:34.63,Default,,0,0,0,,mungkin ada kesempatan\Nuntuk menghubungi Tengen.
Dialogue: 0,0:21:34.71,0:21:37.01,Default,,0,0,0,,Aku terlalu naif.
Dialogue: 0,0:21:38.30,0:21:41.39,Default,,0,0,0,,Bukan kita yang ditolak,
Dialogue: 0,0:21:41.47,0:21:43.43,Default,,0,0,0,,tapi aku?
Dialogue: 0,0:21:45.14,0:21:46.47,Default,,0,0,0,,Ayo kembali.
Dialogue: 0,0:21:46.56,0:21:48.56,Default,,0,0,0,,Tsumiki tidak punya banyak waktu lagi.
Dialogue: 0,0:21:51.10,0:21:52.98,Default,,0,0,0,,Kalian mau kembali?
Dialogue: 0,0:21:54.02,0:21:55.40,Default,,0,0,0,,Senang bertemu kalian.
Dialogue: 0,0:21:55.48,0:21:56.69,Default,,0,0,0,,Putra Zen'in,
Dialogue: 0,0:21:56.78,0:21:58.03,Default,,0,0,0,,keturunan Michizane,
Dialogue: 0,0:21:58.11,0:21:59.78,Default,,0,0,0,,Rahim Lukisan Maut,
Dialogue: 0,0:21:59.86,0:22:01.66,Default,,0,0,0,,dan…
Dialogue: 0,0:22:03.70,0:22:05.87,Default,,0,0,0,,wadah Sukuna.
Dialogue: 0,0:23:40.46,0:23:42.55,Default,,0,0,0,,Aku akan mengajukan syarat dahulu.
Dialogue: 0,0:23:42.63,0:23:44.55,Default,,0,0,0,,Kami datang untuk menanyakan\Ncara membuka Alam Penjara.
Dialogue: 0,0:23:44.63,0:23:46.01,Default,,0,0,0,,Kau tidak akan menyapaku?
Dialogue: 0,0:23:46.09,0:23:47.09,Default,,0,0,0,,Jadi, Permainan Membasmi…
Dialogue: 0,0:23:47.18,0:23:48.93,Default,,0,0,0,,Evolusi Manusia Paksa.
Dialogue: 0,0:23:49.01,0:23:51.01,Default,,0,0,0,,Menurut peraturan,\Nkau akan mati jika itu diambil.
Dialogue: 0,0:23:51.10,0:23:52.22,Default,,0,0,0,,Jika Sukuna menggantikanku,
Dialogue: 0,0:23:52.31,0:23:53.23,Default,,0,0,0,,(BERIKUTNYA, SOAL PERMAINAN MEMBASMI)\Njangan ragu untuk membunuhku.
Dialogue: 0,0:23:53.31,0:23:55.02,Default,,0,0,0,,(BERIKUTNYA, SOAL PERMAINAN MEMBASMI)\NJangan coba-coba mati.

