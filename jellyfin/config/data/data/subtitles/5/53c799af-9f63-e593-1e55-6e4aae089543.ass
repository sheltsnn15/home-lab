Dialogue: 0,0:00:28.41,0:00:31.62,Default,,0,0,0,,{\an8}PLANÈTE TERRE, PAYS S
Dialogue: 0,0:00:52.25,0:00:53.37,Default,,0,0,0,,C'est l'heure.
Dialogue: 0,0:01:02.20,0:01:03.12,Default,,0,0,0,,Il a disparu ?
Dialogue: 0,0:01:04.62,0:01:06.45,Default,,0,0,0,,Qui ça ? J'ai vu personne.
Dialogue: 0,0:01:06.62,0:01:07.66,Default,,0,0,0,,Le type sur la route !
Dialogue: 0,0:01:07.00,0:01:08.70,Default,,0,0,0,,{\an8}BIBLIOTHÈQUE
Dialogue: 0,0:01:18.45,0:01:20.12,Default,,0,0,0,,{\i1}- Allô ?\N- Tu es en danger.
Dialogue: 0,0:01:26.04,0:01:27.04,Default,,0,0,0,,Qui êtes-vous ?
Dialogue: 0,0:01:34.50,0:01:34.87,Default,,0,0,0,,{\i1}Cours !
Dialogue: 0,0:01:40.79,0:01:42.75,Default,,0,0,0,,{\i1}Prends à gauche.
Dialogue: 0,0:01:43.62,0:01:45.37,Default,,0,0,0,,{\i1}- Et après ?\N- Première porte à droite.
Dialogue: 0,0:01:47.29,0:01:47.83,Default,,0,0,0,,{\i1}Rentre.
Dialogue: 0,0:01:50.04,0:01:51.12,Default,,0,0,0,,C'est fermé !
Dialogue: 0,0:02:00.41,0:02:01.08,Default,,0,0,0,,Et maintenant ?
Dialogue: 0,0:02:07.87,0:02:08.83,Default,,0,0,0,,{\i1}Derrière toi.
Dialogue: 0,0:02:20.58,0:02:22.33,Default,,0,0,0,,NUMÉRO INCONNU
Dialogue: 0,0:02:22.50,0:02:23.91,Default,,0,0,0,,- On va voir un film ?\N- D'accord !
Dialogue: 0,0:02:24.08,0:02:25.50,Default,,0,0,0,,Il est fou, ce type !
Dialogue: 0,0:02:46.08,0:02:46.70,Default,,0,0,0,,YAO SHEN - CIBLE INCONNUE
Dialogue: 0,0:03:06.00,0:03:06.54,Default,,0,0,0,,On y va !
Dialogue: 0,0:03:23.25,0:03:24.62,Default,,0,0,0,,Où est Yao Shen ?
Dialogue: 0,0:04:02.16,0:04:03.12,Default,,0,0,0,,Très bien...
Dialogue: 0,0:04:03.95,0:04:05.66,Default,,0,0,0,,J'ai plus le choix, on dirait.
Dialogue: 0,0:04:07.83,0:04:10.04,Default,,0,0,0,,Si.\NRemets-nous Yao Shen...
Dialogue: 0,0:04:12.12,0:04:14.54,Default,,0,0,0,,et on te laissera la vie sauve !
Dialogue: 0,0:04:22.62,0:04:23.66,Default,,0,0,0,,Ça rigole pas.
Dialogue: 0,0:04:26.95,0:04:27.75,Default,,0,0,0,,Mais bon...
Dialogue: 0,0:05:02.33,0:05:03.87,Default,,0,0,0,,Tu l'as bien cherché.
Dialogue: 0,0:05:06.20,0:05:08.41,Default,,0,0,0,,J'ai dû employer les grands moyens.
Dialogue: 0,0:05:10.91,0:05:11.58,Default,,0,0,0,,Quoi ?
Dialogue: 0,0:05:19.04,0:05:20.25,Default,,0,0,0,,Tu te fous de moi ?
Dialogue: 0,0:05:25.16,0:05:26.79,Default,,0,0,0,,Ça ne marchera pas ici.
Dialogue: 0,0:05:42.45,0:05:43.54,Default,,0,0,0,,{\i1}J'espère...
Dialogue: 0,0:05:46.33,0:05:47.91,Default,,0,0,0,,{\i1}que cette fois sera la bonne.
Dialogue: 0,0:05:48.95,0:05:49.75,Default,,0,0,0,,{\i1}Yao.
Dialogue: 0,0:05:51.29,0:05:52.16,Default,,0,0,0,,{\i1}Yao.
Dialogue: 0,0:05:55.04,0:05:55.54,Default,,0,0,0,,{\i1}Xiaoxiu ?
Dialogue: 0,0:05:55.79,0:05:57.37,Default,,0,0,0,,{\i1}Arrête de tirer au flanc !
Dialogue: 0,0:05:57.66,0:06:00.16,Default,,0,0,0,,{\i1}Dis, je pige pas cet exercice.\NTu peux m'aider ?
Dialogue: 0,0:06:00.58,0:06:01.83,Default,,0,0,0,,{\i1}Bien sûr.
Dialogue: 0,0:06:02.66,0:06:04.08,Default,,0,0,0,,{\i1}Dis-moi où tu bloques.
Dialogue: 0,0:06:12.87,0:06:14.87,Default,,0,0,0,,
Dialogue: 0,0:06:15.04,0:06:17.25,Default,,0,0,0,,
Dialogue: 0,0:06:17.41,0:06:19.66,Default,,0,0,0,,
Dialogue: 0,0:06:22.54,0:06:24.75,Default,,0,0,0,,
Dialogue: 0,0:06:24.91,0:06:26.54,Default,,0,0,0,,
Dialogue: 0,0:06:27.37,0:06:29.66,Default,,0,0,0,,
Dialogue: 0,0:06:31.79,0:06:34.41,Default,,0,0,0,,SUPERCUBE
Dialogue: 0,0:06:34.66,0:06:37.62,Default,,0,0,0,,
Dialogue: 0,0:06:40.54,0:06:42.58,Default,,0,0,0,,
Dialogue: 0,0:06:42.87,0:06:46.00,Default,,0,0,0,,
Dialogue: 0,0:06:51.70,0:06:54.83,Default,,0,0,0,,
Dialogue: 0,0:07:00.54,0:07:03.50,Default,,0,0,0,,
Dialogue: 0,0:07:04.91,0:07:06.12,Default,,0,0,0,,
Dialogue: 0,0:07:08.08,0:07:11.79,Default,,0,0,0,,
Dialogue: 0,0:07:15.41,0:07:18.66,Default,,0,0,0,,
Dialogue: 0,0:07:19.41,0:07:22.50,Default,,0,0,0,,
Dialogue: 0,0:07:23.54,0:07:26.87,Default,,0,0,0,,
Dialogue: 0,0:07:28.91,0:07:32.66,Default,,0,0,0,,
Dialogue: 0,0:07:34.33,0:07:37.75,Default,,0,0,0,,
Dialogue: 0,0:07:38.08,0:07:42.79,Default,,0,0,0,,SUPERCUBE\NÉPISODE 1
Dialogue: 0,0:07:43.75,0:07:44.75,Default,,0,0,0,,Santé !
Dialogue: 0,0:07:53.79,0:07:54.62,Default,,0,0,0,,Oh non...
Dialogue: 0,0:07:55.45,0:07:57.50,Default,,0,0,0,,Encore perdu...\NC'est trop dur...
Dialogue: 0,0:07:58.20,0:08:00.75,Default,,0,0,0,,Je vais tirer ta carte, pour la peine.
Dialogue: 0,0:08:01.37,0:08:04.54,Default,,0,0,0,,Ce sera une carte "vérité", Yao.
Dialogue: 0,0:08:04.91,0:08:06.83,Default,,0,0,0,,"Dites le nom\Nde la personne que vous aimez."
Dialogue: 0,0:08:08.79,0:08:12.37,Default,,0,0,0,,T'étouffe pas, Xiaoxiu.\NElle risque pas de dire le tien...
Dialogue: 0,0:08:12.66,0:08:15.95,Default,,0,0,0,,Je sais bien ! Yao et moi,\Non se connaît depuis toujours !
Dialogue: 0,0:08:16.12,0:08:19.08,Default,,0,0,0,,Je suis un simple ami d'enfance...
Dialogue: 0,0:08:19.45,0:08:20.83,Default,,0,0,0,,{\i1}Qu'est-ce que je raconte ?
Dialogue: 0,0:08:21.04,0:08:23.50,Default,,0,0,0,,Un ami d'enfance, hein ?\NPas de bol.
Dialogue: 0,0:08:24.04,0:08:28.66,Default,,0,0,0,,De toute façon, les filles aiment pas\Nles types dans ton genre.
Dialogue: 0,0:08:29.16,0:08:31.58,Default,,0,0,0,,Elles préfèrent les beaux gosses\Ncomme moi.
Dialogue: 0,0:08:32.12,0:08:33.08,Default,,0,0,0,,Dans tes rêves !
Dialogue: 0,0:08:33.25,0:08:34.91,Default,,0,0,0,,Yao est notre petite princesse.
Dialogue: 0,0:08:36.20,0:08:38.87,Default,,0,0,0,,Elle mérite de trouver\Nson prince charmant !
Dialogue: 0,0:08:39.04,0:08:39.87,Default,,0,0,0,,Pas vrai ?
Dialogue: 0,0:08:40.62,0:08:42.25,Default,,0,0,0,,Tu as quelqu'un en tête ?
Dialogue: 0,0:08:42.75,0:08:43.83,Default,,0,0,0,,Vous voulez savoir ?
Dialogue: 0,0:08:44.37,0:08:45.83,Default,,0,0,0,,Mais ouais ! Dis-nous !
Dialogue: 0,0:08:47.25,0:08:48.50,Default,,0,0,0,,C'est un peu gênant...
Dialogue: 0,0:08:49.20,0:08:50.70,Default,,0,0,0,,{\i1}Depuis qu'on est petits,
Dialogue: 0,0:08:51.33,0:08:53.58,Default,,0,0,0,,{\i1}on a toujours évité ce sujet.
Dialogue: 0,0:09:00.79,0:09:02.12,Default,,0,0,0,,Allez, on veut savoir !
Dialogue: 0,0:09:06.91,0:09:07.62,Default,,0,0,0,,D'accord...
Dialogue: 0,0:09:08.16,0:09:10.58,Default,,0,0,0,,Le garçon que j'aime...
Dialogue: 0,0:09:11.20,0:09:12.16,Default,,0,0,0,,c'est...
Dialogue: 0,0:09:13.54,0:09:14.70,Default,,0,0,0,,Xiaoxiu...
Dialogue: 0,0:09:17.00,0:09:19.45,Default,,0,0,0,,C'est une blague ?\NEt moi, alors ?
Dialogue: 0,0:09:19.87,0:09:21.79,Default,,0,0,0,,Tu rigoles, j'espère ?
Dialogue: 0,0:09:23.83,0:09:25.04,Default,,0,0,0,,Non, c'est la vérité.
Dialogue: 0,0:09:25.66,0:09:28.91,Default,,0,0,0,,Je m'intéresse à lui\Ndepuis l'école primaire.
Dialogue: 0,0:09:30.25,0:09:32.16,Default,,0,0,0,,{\i1}Yao...\NDites-moi que je rêve !
Dialogue: 0,0:09:32.79,0:09:34.29,Default,,0,0,0,,{\i1}Je n'aurais jamais pensé
Dialogue: 0,0:09:34.83,0:09:36.37,Default,,0,0,0,,{\i1}que l'amour ferait aussi mal...
Dialogue: 0,0:09:36.70,0:09:39.29,Default,,0,0,0,,D'où tu piques la meuf du boss, ordure ?
Dialogue: 0,0:09:39.83,0:09:40.79,Default,,0,0,0,,Je vais te crever !
Dialogue: 0,0:09:41.79,0:09:43.54,Default,,0,0,0,,Elle est trop bien pour toi !
Dialogue: 0,0:09:43.70,0:09:45.70,Default,,0,0,0,,T'es à peine bon\Nà nourrir les poissons !
Dialogue: 0,0:09:46.08,0:09:48.33,Default,,0,0,0,,{\i1}- Enfoiré !\N- Qui a bien pu prévenir
Dialogue: 0,0:09:48.50,0:09:50.37,Default,,0,0,0,,{\i1}le gang du quartier nord ?
Dialogue: 0,0:09:50.75,0:09:53.70,Default,,0,0,0,,Du calme...\NLaissez-moi vous expliquer.
Dialogue: 0,0:09:53.87,0:09:56.00,Default,,0,0,0,,Expliquer quoi ?\NY a rien à expliquer !
Dialogue: 0,0:09:56.75,0:09:58.87,Default,,0,0,0,,Fallait réfléchir avant de la serrer !
Dialogue: 0,0:09:59.04,0:10:00.16,Default,,0,0,0,,{\i1}Jun Sun.
Dialogue: 0,0:10:00.54,0:10:03.25,Default,,0,0,0,,{\i1}C'est le chef du gang,\Net un admirateur de Yao.
Dialogue: 0,0:10:03.45,0:10:05.50,Default,,0,0,0,,{\i1}Ou plutôt, son harceleur !
Dialogue: 0,0:10:06.04,0:10:07.50,Default,,0,0,0,,Tu t'es pris pour qui ?
Dialogue: 0,0:10:07.91,0:10:10.54,Default,,0,0,0,,Laisse-le-nous.\NOn va s'occuper de lui.
Dialogue: 0,0:10:13.20,0:10:15.37,Default,,0,0,0,,Ça faisait un bail, Yao.
Dialogue: 0,0:10:16.50,0:10:17.62,Default,,0,0,0,,{\i1}Jun ?
Dialogue: 0,0:10:17.79,0:10:20.20,Default,,0,0,0,,{\i1}Mais c'est le portable de Xiaoxiu.\NOù est-il ?
Dialogue: 0,0:10:20.62,0:10:22.16,Default,,0,0,0,,Juste en face de moi.
Dialogue: 0,0:10:22.79,0:10:24.50,Default,,0,0,0,,Laisse-moi te le montrer.
Dialogue: 0,0:10:25.66,0:10:28.58,Default,,0,0,0,,Tu le vois ?\NJe vais te débarrasser de ce pervers.
Dialogue: 0,0:10:28.83,0:10:29.58,Default,,0,0,0,,{\i1}Xiaoxiu ?
Dialogue: 0,0:10:29.95,0:10:32.66,Default,,0,0,0,,Laisse-la en dehors de ça !\NRéglons ça entre hommes !
Dialogue: 0,0:10:32.95,0:10:34.12,Default,,0,0,0,,Fais pas le malin !
Dialogue: 0,0:10:37.54,0:10:38.33,Default,,0,0,0,,{\i1}Xiaoxiu !
Dialogue: 0,0:10:38.54,0:10:39.83,Default,,0,0,0,,Ne t'inquiète pas, Yao.
Dialogue: 0,0:10:40.29,0:10:42.04,Default,,0,0,0,,On est très persuasifs.
Dialogue: 0,0:10:43.37,0:10:48.33,Default,,0,0,0,,Alors, Xiaoxiu ? Tu promets\Nde ne plus embêter ma petite Yao ?
Dialogue: 0,0:10:48.87,0:10:50.91,Default,,0,0,0,,{\i1}Laisse-le tranquille, Jun !
Dialogue: 0,0:10:52.91,0:10:55.04,Default,,0,0,0,,Je te conseille de bien réfléchir.
Dialogue: 0,0:10:55.33,0:10:57.54,Default,,0,0,0,,Et de faire le bon choix.
Dialogue: 0,0:10:58.29,0:11:01.25,Default,,0,0,0,,De ta réponse\Ndépendra la suite des opérations.
Dialogue: 0,0:11:01.41,0:11:02.25,Default,,0,0,0,,{\i1}Non, Jun !
Dialogue: 0,0:11:02.50,0:11:03.91,Default,,0,0,0,,Voilà ma réponse...
Dialogue: 0,0:11:04.20,0:11:06.83,Default,,0,0,0,,Je ne te laisserai jamais Yao !
Dialogue: 0,0:11:07.33,0:11:08.91,Default,,0,0,0,,Tu ne la mérites pas !
Dialogue: 0,0:11:17.33,0:11:17.91,Default,,0,0,0,,{\i1}Xiaoxiu !
Dialogue: 0,0:11:20.83,0:11:23.79,Default,,0,0,0,,Mais il est suicidaire !\NPourquoi tu l'as lâché ?
Dialogue: 0,0:11:24.00,0:11:26.29,Default,,0,0,0,,Il m'a frappé !\NJe voulais pas !
Dialogue: 0,0:11:26.45,0:11:27.95,Default,,0,0,0,,Xiaoxiu ! Xiaoxiu !
Dialogue: 0,0:11:28.12,0:11:29.62,Default,,0,0,0,,Fais pas le con ! Remonte !
Dialogue: 0,0:11:30.87,0:11:33.50,Default,,0,0,0,,Il remonte pas, boss !\NQu'est-ce qu'on fait ?
Dialogue: 0,0:11:34.08,0:11:36.04,Default,,0,0,0,,{\i1}Si je ne peux pas protéger\Ncelle que j'aime,
Dialogue: 0,0:11:37.54,0:11:39.04,Default,,0,0,0,,{\i1}autant mourir.
Dialogue: 0,0:11:39.58,0:11:40.95,Default,,0,0,0,,{\i1}Le garçon que j'aime,
Dialogue: 0,0:11:41.45,0:11:42.70,Default,,0,0,0,,{\i1}c'est Xiaoxiu.
Dialogue: 0,0:11:54.20,0:11:56.25,Default,,0,0,0,,{\i1}Et dire que je le respectais...
Dialogue: 0,0:11:56.41,0:11:58.00,Default,,0,0,0,,{\i1}C'est qu'un pleurnichard.
Dialogue: 0,0:11:58.16,0:12:00.66,Default,,0,0,0,,{\i1}T'as vu comment il a pris\Nses jambes à son cou ?
Dialogue: 0,0:12:25.12,0:12:25.91,Default,,0,0,0,,{\i1}Xiaoxiu ?
Dialogue: 0,0:12:27.12,0:12:28.29,Default,,0,0,0,,{\i1}Yao ?
Dialogue: 0,0:12:28.87,0:12:31.25,Default,,0,0,0,,{\i1}- T'as pas de parapluie ?\N- Non...
Dialogue: 0,0:12:32.54,0:12:33.50,Default,,0,0,0,,{\i1}On rentre ensemble ?
Dialogue: 0,0:12:34.04,0:12:34.75,Default,,0,0,0,,{\i1}Non.
Dialogue: 0,0:12:38.33,0:12:40.41,Default,,0,0,0,,{\i1}Tu comptes te cacher ici longtemps ?
Dialogue: 0,0:12:40.79,0:12:41.95,Default,,0,0,0,,{\i1}Je me cache pas !
Dialogue: 0,0:12:43.54,0:12:44.50,Default,,0,0,0,,{\i1}Je préfère rentrer seul.
Dialogue: 0,0:12:44.83,0:12:47.41,Default,,0,0,0,,{\i1}Mais il pleut très fort...
Dialogue: 0,0:12:49.79,0:12:52.29,Default,,0,0,0,,{\i1}Ça va bien s'arrêter à un moment.
Dialogue: 0,0:12:54.50,0:12:56.87,Default,,0,0,0,,{\i1}Tu saignes, Xiaoxiu.\NFais-moi voir.
Dialogue: 0,0:12:57.62,0:12:58.95,Default,,0,0,0,,{\i1}Pas question !
Dialogue: 0,0:12:59.25,0:13:02.04,Default,,0,0,0,,{\i1}Allez, fais pas ton timide.
Dialogue: 0,0:13:02.58,0:13:03.54,Default,,0,0,0,,{\i1}Je vais te soigner !
Dialogue: 0,0:13:04.12,0:13:06.50,Default,,0,0,0,,Elle est trop gentille...
Dialogue: 0,0:13:17.41,0:13:18.29,Default,,0,0,0,,{\i1}Yao...
Dialogue: 0,0:13:19.37,0:13:20.54,Default,,0,0,0,,{\i1}Merci...
Dialogue: 0,0:13:21.66,0:13:22.50,Default,,0,0,0,,{\i1}On rentre ?
Dialogue: 0,0:13:23.25,0:13:25.29,Default,,0,0,0,,{\i1}- La pluie s'est arrêtée.\N- OK...
Dialogue: 0,0:13:34.75,0:13:36.08,Default,,0,0,0,,{\i1}Une lumière ?
Dialogue: 0,0:13:37.16,0:13:38.16,Default,,0,0,0,,{\i1}C'est quoi ?
Dialogue: 0,0:13:55.83,0:13:56.87,Default,,0,0,0,,{\i1}Ça brûle !
Dialogue: 0,0:13:57.29,0:13:58.50,Default,,0,0,0,,{\i1}Que m'arrive-t-il ?
Dialogue: 0,0:13:58.95,0:14:01.16,Default,,0,0,0,,{\i1}C'est rentré dans mon corps !
Dialogue: 0,0:14:07.37,0:14:08.62,Default,,0,0,0,,{\i1}Je suis où, là ?
Dialogue: 0,0:14:17.50,0:14:18.87,Default,,0,0,0,,{\i1}Qu'est-ce que...
Dialogue: 0,0:14:19.75,0:14:21.04,Default,,0,0,0,,Je vais me noyer !
Dialogue: 0,0:14:22.29,0:14:23.33,Default,,0,0,0,,{\i1}Je suis mort ?
Dialogue: 0,0:14:25.00,0:14:27.62,Default,,0,0,0,,{\i1}C'est quoi cet endroit ?\NL'espace ?
Dialogue: 0,0:14:28.58,0:14:31.50,Default,,0,0,0,,{\i1}Bienvenue, cher hôte.\NTu peux désormais générer
Dialogue: 0,0:14:28.87,0:14:29.37,Default,,0,0,0,,{\an8}HÔTE ADULTE
Dialogue: 0,0:14:31.66,0:14:34.12,Default,,0,0,0,,{\i1}un cercle de téléportation
Dialogue: 0,0:14:34.83,0:14:39.00,Default,,0,0,0,,{\i1}et te mouvoir à volonté\Nà l'intérieur de celui-ci.
Dialogue: 0,0:14:35.33,0:14:36.37,Default,,0,0,0,,{\an8}POSSIBILITÉ DE SE MOUVOIR
Dialogue: 0,0:14:36.83,0:14:39.12,Default,,0,0,0,,{\an8}N'IMPORTE OÙ\NDANS LE CERCLE DE TÉLÉPORTATION
Dialogue: 0,0:14:39.91,0:14:40.75,Default,,0,0,0,,Quoi ?
Dialogue: 0,0:14:47.33,0:14:49.12,Default,,0,0,0,,Je vais tomber !
Dialogue: 0,0:14:49.91,0:14:50.75,Default,,0,0,0,,Trouvez-le !
Dialogue: 0,0:14:51.50,0:14:53.20,Default,,0,0,0,,{\i1}Ils me cherchent encore ?
Dialogue: 0,0:14:54.75,0:14:55.95,Default,,0,0,0,,On rentre pas avant de l'avoir trouvé !
Dialogue: 0,0:14:59.41,0:15:01.33,Default,,0,0,0,,Hé, vous avez entendu ça ?
Dialogue: 0,0:15:02.16,0:15:04.20,Default,,0,0,0,,Vous avez dû halluciner, boss...
Dialogue: 0,0:15:05.20,0:15:07.95,Default,,0,0,0,,- Fermez-la et trouvez-le !\N- Oui, boss !
Dialogue: 0,0:15:08.20,0:15:09.33,Default,,0,0,0,,Merde...
Dialogue: 0,0:15:09.87,0:15:11.58,Default,,0,0,0,,C'était quoi, ce bruit ?
Dialogue: 0,0:15:17.70,0:15:20.33,Default,,0,0,0,,{\i1}Qu'est-ce que je fais ici ?\NJe me suis téléporté ?
Dialogue: 0,0:15:20.91,0:15:22.41,Default,,0,0,0,,{\i1}J'aurais un super-pouvoir ?
Dialogue: 0,0:15:22.58,0:15:25.83,Default,,0,0,0,,{\i1}Tu as laissé ton pouvoir\Nde téléportation activé, cher hôte.
Dialogue: 0,0:15:24.08,0:15:25.83,Default,,0,0,0,,{\an8}TÉLÉPORTATION ACTIVÉE\NDE MANIÈRE ALÉATOIRE
Dialogue: 0,0:15:26.00,0:15:28.50,Default,,0,0,0,,J'hallucine !\NIl y a une voix dans ma tête !
Dialogue: 0,0:15:28.66,0:15:29.75,Default,,0,0,0,,{\i1}Non, dans ton corps.
Dialogue: 0,0:15:30.45,0:15:32.66,Default,,0,0,0,,Dans mon corps ? Où ça ?
Dialogue: 0,0:15:32.83,0:15:33.91,Default,,0,0,0,,C'est dégueu !
Dialogue: 0,0:15:34.54,0:15:35.54,Default,,0,0,0,,Mon portable !
Dialogue: 0,0:15:37.08,0:15:38.54,Default,,0,0,0,,Qui es-tu ?
Dialogue: 0,0:15:38.79,0:15:40.45,Default,,0,0,0,,{\i1}- Quelqu'un approche.\N- Qui ça ?
Dialogue: 0,0:15:53.37,0:15:55.58,Default,,0,0,0,,Le sol est mouillé.\NQue s'est-il passé ?
Dialogue: 0,0:16:01.75,0:16:02.58,Default,,0,0,0,,{\an8}APPEL ENTRANT\NYAO
Dialogue: 0,0:16:01.79,0:16:02.58,Default,,0,0,0,,C'est Yao...
Dialogue: 0,0:16:04.70,0:16:07.25,Default,,0,0,0,,{\i1}- Allô ?\N- Tu réponds enfin ! Tu vas bien ?
Dialogue: 0,0:16:07.75,0:16:10.29,Default,,0,0,0,,Je te croyais mort !\NOù es-tu ?
Dialogue: 0,0:16:10.45,0:16:11.54,Default,,0,0,0,,{\i1}À la maison.
Dialogue: 0,0:16:12.41,0:16:15.58,Default,,0,0,0,,Tu aurais pu m'appeler...\NJ'étais très inquiète.
Dialogue: 0,0:16:16.00,0:16:17.54,Default,,0,0,0,,{\i1}Terrifiée, même !
Dialogue: 0,0:16:18.33,0:16:21.08,Default,,0,0,0,,{\i1}Ils sont allés trop loin.\NJe vais appeler la police.
Dialogue: 0,0:16:21.87,0:16:22.83,Default,,0,0,0,,Pas besoin.
Dialogue: 0,0:16:23.12,0:16:25.20,Default,,0,0,0,,Je vais bien.\NJe me suis échappé à la nage.
Dialogue: 0,0:16:26.00,0:16:28.33,Default,,0,0,0,,Ils doivent encore me chercher !
Dialogue: 0,0:16:29.58,0:16:30.70,Default,,0,0,0,,{\i1}C'est pas drôle.
Dialogue: 0,0:16:31.29,0:16:33.16,Default,,0,0,0,,Bon, il se fait tard.
Dialogue: 0,0:16:33.66,0:16:36.04,Default,,0,0,0,,Je vais me coucher.\NTu devrais faire pareil.
Dialogue: 0,0:16:36.20,0:16:37.29,Default,,0,0,0,,{\i1}Non ! Attends !
Dialogue: 0,0:16:45.16,0:16:47.37,Default,,0,0,0,,{\i1}Je ne peux pas lui dire la vérité.
Dialogue: 0,0:16:48.00,0:16:49.58,Default,,0,0,0,,{\i1}Et je ne veux pas la mêler à ça.
Dialogue: 0,0:16:52.00,0:16:54.58,Default,,0,0,0,,{\i1}T'es-tu calmé, cher hôte ?
Dialogue: 0,0:16:52.37,0:16:54.58,Default,,0,0,0,,{\an8}T'ES-TU CALMÉ, CHER HÔTE ?
Dialogue: 0,0:16:56.87,0:16:57.83,Default,,0,0,0,,Qu'est-ce que tu fais ici ?
Dialogue: 0,0:16:58.00,0:17:00.37,Default,,0,0,0,,{\i1}Je te l'ai dit.\NJe suis dans ton corps.
Dialogue: 0,0:17:05.37,0:17:06.29,Default,,0,0,0,,{\i1}Ça recommence !
Dialogue: 0,0:17:11.12,0:17:12.08,Default,,0,0,0,,{\i1}Bienvenue.
Dialogue: 0,0:17:12.83,0:17:13.95,Default,,0,0,0,,Ça fait mal !
Dialogue: 0,0:17:16.20,0:17:17.79,Default,,0,0,0,,C'est quoi, cet endroit ?
Dialogue: 0,0:17:18.50,0:17:20.45,Default,,0,0,0,,Et cette histoire d'hôte ?
Dialogue: 0,0:17:21.08,0:17:24.33,Default,,0,0,0,,{\i1}J'ai enfin pu établir entre nous\Nune connexion physique stable.
Dialogue: 0,0:17:24.50,0:17:27.50,Default,,0,0,0,,{\i1}Tu es désormais\Nl'utilisateur du cube Horadrim,
Dialogue: 0,0:17:27.66,0:17:29.37,Default,,0,0,0,,{\i1}l'interface universelle ultime.
Dialogue: 0,0:17:29.87,0:17:33.25,Default,,0,0,0,,{\i1}Selon la définition humaine,\Ntu es donc mon maître.
Dialogue: 0,0:17:29.95,0:17:31.54,Default,,0,0,0,,{\an8}SELON LA DÉFINITION HUMAINE
Dialogue: 0,0:17:32.12,0:17:33.54,Default,,0,0,0,,{\an8}TU ES DONC MON MAÎTRE
Dialogue: 0,0:17:33.66,0:17:36.37,Default,,0,0,0,,{\i1}Mais si tu n'aimes pas ce terme,\Nje peux t'appeler autrement.
Dialogue: 0,0:17:33.87,0:17:34.66,Default,,0,0,0,,{\an8}SI TU N'AIMES PAS
Dialogue: 0,0:17:35.20,0:17:36.37,Default,,0,0,0,,{\an8}JE PEUX T'APPELER AUTREMENT
Dialogue: 0,0:17:36.91,0:17:38.79,Default,,0,0,0,,Interface universelle ultime ?
Dialogue: 0,0:17:39.33,0:17:41.75,Default,,0,0,0,,C'est un peu pompeux, comme nom...
Dialogue: 0,0:17:42.08,0:17:43.50,Default,,0,0,0,,On est où, au juste ?
Dialogue: 0,0:17:43.75,0:17:47.79,Default,,0,0,0,,{\i1}Dans le monde physique macroscopique,\Nje ressemble à un cube de 3 cm³.
Dialogue: 0,0:17:48.29,0:17:50.95,Default,,0,0,0,,{\i1}Tu es actuellement en moi.
Dialogue: 0,0:17:51.20,0:17:52.33,Default,,0,0,0,,Rien que ça...
Dialogue: 0,0:17:53.75,0:17:55.95,Default,,0,0,0,,Jolie vue, dis donc !
Dialogue: 0,0:18:08.04,0:18:13.00,Default,,0,0,0,,Et je suppose que c'est grâce à toi\Nque je peux me téléporter ?
Dialogue: 0,0:18:13.41,0:18:14.33,Default,,0,0,0,,{\i1}Exact.
Dialogue: 0,0:18:16.45,0:18:18.25,Default,,0,0,0,,Pourquoi tu m'aides, cube ?
Dialogue: 0,0:18:19.33,0:18:21.50,Default,,0,0,0,,{\i1}Pour exaucer ton vœu
Dialogue: 0,0:18:22.50,0:18:24.33,Default,,0,0,0,,{\i1}de devenir le roi du monde.
Dialogue: 0,0:18:32.83,0:18:37.54,Default,,0,0,0,,Tu peux visualiser les alentours\Ngrâce aux micro-ondes.
Dialogue: 0,0:18:32.83,0:19:16.62,Default,,0,0,0,,{\an8}AU PROCHAIN ÉPISODE
Dialogue: 0,0:18:37.70,0:18:38.87,Default,,0,0,0,,{\i1}Les micro-ondes ?
Dialogue: 0,0:18:41.08,0:18:42.41,Default,,0,0,0,,{\i1}Qu'est-ce que tu fous là ?
Dialogue: 0,0:18:43.79,0:18:45.16,Default,,0,0,0,,{\i1}Xiaoxiu est là ?
Dialogue: 0,0:18:45.54,0:18:48.29,Default,,0,0,0,,{\i1}- Mais c'est... Jun Sun...\N- N'aie pas peur, Yao.
Dialogue: 0,0:18:50.20,0:18:52.70,Default,,0,0,0,,{\i1}Tu as dit que tu étais l'interface ultime.\NQui t'a créée ?
Dialogue: 0,0:18:53.04,0:18:54.95,Default,,0,0,0,,Tu ne trouveras rien ici, maître.
Dialogue: 0,0:18:56.16,0:18:58.95,Default,,0,0,0,,{\i1}Tu as réussi à t'en sortir hier.
Dialogue: 0,0:18:59.79,0:19:01.79,Default,,0,0,0,,{\i1}Tu n'auras pas cette chance aujourd'hui.
Dialogue: 0,0:19:01.95,0:19:04.12,Default,,0,0,0,,{\i1}Pourquoi tu m'as raccroché au nez ?
Dialogue: 0,0:19:05.41,0:19:07.12,Default,,0,0,0,,{\i1}Je veux devenir plus fort !
Dialogue: 0,0:19:07.66,0:19:08.87,Default,,0,0,0,,Mon système peut être amélioré.
Dialogue: 0,0:19:09.50,0:19:12.70,Default,,0,0,0,,Il suffit de me donner\Ndes gemmes énergétiques.
Dialogue: 0,0:19:14.12,0:19:16.62,Default,,0,0,0,,SUPERCUBE
Dialogue: 0,0:19:17.83,0:19:20.29,Default,,0,0,0,,
Dialogue: 0,0:19:20.66,0:19:22.87,Default,,0,0,0,,
Dialogue: 0,0:19:23.16,0:19:25.00,Default,,0,0,0,,
Dialogue: 0,0:20:51.75,0:20:56.62,Default,,0,0,0,,Traduction : Alexandre Panau\NRelecture : Thomas Guillemin

