Dialogue: 0,0:01:41.00,0:01:47.92,TypePlaceholder,TYPE,0000,0000,0000,,{\fnImpact\fsp1\c&H402D30&\fax-0.25\fs+4\frz5.491\move(355.5,280,359.5,-34,17,6899)}Schmeichelt den Monstern!!!
Dialogue: 0,0:01:44.03,0:01:47.58,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Am Zustand der Heldenvereinigung\Nwird deutlich,
Dialogue: 0,0:01:46.63,0:01:52.22,TypePlaceholder,TYPE,0000,0000,0000,,{\fnVerdana bold\c&H3E50AA&\fs-1\fax-0.1\frz12.65\move(370.5,366,370.5,134.5,18,5565)}Kapitulation
Dialogue: 0,0:01:47.58,0:01:50.10,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,dass die Menschheit keine Siegchance hat!
Dialogue: 0,0:01:50.10,0:01:52.22,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Wir sollten kapitulieren!
Dialogue: 0,0:01:52.22,0:01:56.60,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Widerstand führt nur\Nzur Tötung aller Menschen!
Dialogue: 0,0:01:52.22,0:02:00.47,TypePlaceholder,TYPE,0000,0000,0000,,{\fnComic Sans MS bold\bord3\c&H2C2022&\fs+2\fax-0.1\3c&HFEFEFE&\move(468,183.5,637.5,-40,17,8233)}Die {\c&H494EA3&}Menschheit\N{\c&H2C2022&}hat keine Chance!!
Dialogue: 0,0:01:52.22,0:02:02.02,TypePlaceholder,TYPE,0000,0000,0000,,{\fnImpact\fsp1\fs+1\c&H7C5158&\fax-0.2\frz353.9\move(-38.5,223,183,-75,17,9776)}Kooperation\Nmit den\NMonstern
Dialogue: 0,0:01:56.60,0:01:59.58,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Wir, die Partei der Monsterverehrung,
Dialogue: 0,0:01:59.58,0:02:02.02,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,haben die einzige Lösung ersonnen!
Dialogue: 0,0:02:02.02,0:02:22.00,TypePlaceholder,TYPE,0000,0000,0000,,{\fnVerdana bold\fs-2\bord3\c&HFFFFFC&\3c&H4B50A1&\pos(127,20)}Schmeichelt den Monstern!\NMonsterverehrung\N{\fnGeorgia Bold}Mit Monstern in Koexistenz\N{\fnVerdana bold\c&H424346&\3c&H7D94A6&}Monsterverehrung\N{\fnGeorgia Bold\c&H2E1E1F&\3c&H424796&}Schmeichelt den Monstern!
Dialogue: 0,0:02:02.48,0:02:05.85,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Bringt den Monstern\Nregelmäßig Menschenopfer dar.
Dialogue: 0,0:02:05.85,0:02:11.73,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Durch Regelung des Gefressenwerdens\Nwird die Ausrottung der Menschheit umgangen!
Dialogue: 0,0:02:12.32,0:02:17.12,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Reiht euch ein, wenn auch ihr\Nan der Seite der Monster stehen wollt!
Dialogue: 0,0:02:17.60,0:02:22.00,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,So überleben wir in einer Welt,\Nderen Vernunft und Ethik erneuert werden!
Dialogue: 0,0:02:22.00,0:02:23.66,Default,Bürger A,0000,0000,0000,,So ein Blödsinn!
Dialogue: 0,0:02:23.66,0:02:27.21,Default,Bürger A,0000,0000,0000,,Bevor ich mich auf die Seite\Nder Monster schlage, sterbe ich lieber!
Dialogue: 0,0:02:27.21,0:02:33.05,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTrebuchet MS bold\bord3\c&H483233&\3c&HDADAD6&\pos(331,23)\frz2.033}Monster
Dialogue: 0,0:02:28.09,0:02:29.42,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Wie passend!
Dialogue: 0,0:02:29.42,0:02:33.05,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Da haben wir ja unser\Nerstes Menschenopfer gefunden!
Dialogue: 0,0:02:33.05,0:02:34.33,Default,Anführer der Partei der Monsterverehrung,0000,0000,0000,,Ergreift ihn!
Dialogue: 0,0:02:35.76,0:02:38.22,Default,Bürger A,0000,0000,0000,,N-Nicht doch!
Dialogue: 0,0:02:40.43,0:02:41.89,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTrebuchet MS bold\bord3\c&H483233&\fs+2\3c&HDADAD6&}Monster
Dialogue: 0,0:02:42.76,0:02:46.28,Default,Garo,0000,0000,0000,,Andere opfern,\Num seine eigene Haut zu retten?
Dialogue: 0,0:02:46.64,0:02:49.36,Default,Garo,0000,0000,0000,,Ihr unterschätzt die Monster maßlos!
Dialogue: 0,0:02:49.36,0:02:52.99,Internal,Garo,0000,0000,0000,,Wie leicht die menschliche Gesellschaft\Ndoch zu erschüttern ist.
Dialogue: 0,0:02:52.99,0:02:54.61,Internal,Garo,0000,0000,0000,,Wie entmutigend.
Dialogue: 0,0:02:55.06,0:02:57.16,Internal,Garo,0000,0000,0000,,Bei diesen Verhältnissen
Dialogue: 0,0:02:57.16,0:02:59.27,Internal,Garo,0000,0000,0000,,werde ich, das stärkste aller Monster,
Dialogue: 0,0:02:59.27,0:03:02.76,Internal,Garo,0000,0000,0000,,bei meinem großartigem Auftritt\Neine geringere Wirkung hinterlassen.
Dialogue: 0,0:03:02.76,0:03:04.58,Internal,Garo,0000,0000,0000,,Das steht zu befürchten.
Dialogue: 0,0:03:04.58,0:03:09.25,TypePlaceholder,TYPE,0000,0000,0000,,{\fnGeorgia Bold\an2\fs+3\fad(0,550)\bord2\c&HFFFFFF&\3c&H000000&\pos(475.71,241.93)}Bedingung der Monster
Dialogue: 0,0:03:04.58,0:03:10.37,Top,Ansager,0000,0000,0000,,Vielerorts kommt es zu Ausschreitungen\Nwie Überfällen, Einbrüchen und Diebstählen.
Dialogue: 0,0:03:10.37,0:03:15.22,Default,Ansager,0000,0000,0000,,Polizei und Heldenvereinigung verstärken\Nihre Patrouillen und mahnen zur Vorsicht.
Dialogue: 0,0:03:15.77,0:03:17.18,Default,Ansager,0000,0000,0000,,Zudem marschieren in S-Stadt
Dialogue: 0,0:03:17.18,0:03:21.95,Default,Ansager,0000,0000,0000,,Gruppen auf, die das baldige Ende\Nder Menschheitsgeschichte skandieren,
Dialogue: 0,0:03:21.95,0:03:24.10,Default,Ansager,0000,0000,0000,,was die Unruhen weiter anfacht.
Dialogue: 0,0:03:24.52,0:03:29.37,Internal,Garo,0000,0000,0000,,Nur weil Monster wüten, werden dadurch\Ndie eigenen Sünden nicht geringer!
Dialogue: 0,0:03:30.18,0:03:33.15,Internal,Garo,0000,0000,0000,,Weil die Monster-Vereinigung\Nnur herumstümpert,
Dialogue: 0,0:03:33.15,0:03:36.00,Internal,Garo,0000,0000,0000,,werden lauter Großmäuler\Nhier noch frech!
Dialogue: 0,0:03:36.83,0:03:39.91,Default,Halbstarker,0000,0000,0000,,Was los, Alter?\NDu hast mich doch angerempelt!
Dialogue: 0,0:03:39.91,0:03:42.24,Default,Halbstarker,0000,0000,0000,,Hast du ’n Problem, oder was?
Dialogue: 0,0:03:39.91,0:03:42.24,Top,Bürger B,0000,0000,0000,,Aufhören! So darf man doch\Nmit Älteren nicht umgehen!
Dialogue: 0,0:03:42.60,0:03:45.23,Default,Halbstarker,0000,0000,0000,,Schnauze!\NDer hat mich doch angerempelt!
Dialogue: 0,0:03:45.23,0:03:47.33,Default,Bürger C,0000,0000,0000,,Der ist besoffen!\NVöllig außer Kontrolle!
Dialogue: 0,0:03:47.33,0:03:50.73,Default,Halbstarker,0000,0000,0000,,Wir werden sowieso alle\Nvon den Monstern getötet!
Dialogue: 0,0:03:50.73,0:03:52.42,Default,Halbstarker,0000,0000,0000,,Mir ist jetzt alles egal!
Dialogue: 0,0:03:52.42,0:03:55.92,Default,Garo,0000,0000,0000,,He!\NDu blockierst den Eingang zum Geschäft!
Dialogue: 0,0:03:55.92,0:03:56.63,Default,Garo,0000,0000,0000,,Verschwinde!
Dialogue: 0,0:03:56.63,0:03:57.94,Default,Halbstarker,0000,0000,0000,,Hä?
Dialogue: 0,0:03:57.94,0:04:00.76,Default,Halbstarker,0000,0000,0000,,Haste was gesagt, du Knirps?
Dialogue: 0,0:04:07.30,0:04:08.64,Default,Garo,0000,0000,0000,,Verpiss dich!
Dialogue: 0,0:04:09.76,0:04:11.86,Internal,Garo,0000,0000,0000,,Ich bin anders als jene Typen.
Dialogue: 0,0:04:12.40,0:04:16.32,Internal,Garo,0000,0000,0000,,Ich verbreite eine Furcht, die selbst\Ndieses Gesindel zum Schweigen bringt.
Dialogue: 0,0:04:17.40,0:04:20.32,Internal,Garo,0000,0000,0000,,Aber jetzt habe ich erst mal Hunger!
Dialogue: 0,0:04:21.36,0:04:26.19,Default,Bedienung A,0000,0000,0000,,Hier ist Ihr ultradickes Steak im\NVielfrass-Set mit einer Extraportion Reis!
Dialogue: 0,0:04:26.19,0:04:28.04,Default,Bedienung A,0000,0000,0000,,Guten Appetit!
Dialogue: 0,0:04:28.84,0:04:30.75,Default,Garo,0000,0000,0000,,Eine mammutiöse Mahlzeit!
Dialogue: 0,0:04:46.86,0:04:47.81,Default,Garo,0000,0000,0000,,Huch?
Dialogue: 0,0:04:48.27,0:04:50.73,Default,Garo,0000,0000,0000,,Das reicht hinten und vorne nicht!
Dialogue: 0,0:04:52.27,0:04:55.66,Default,Garo,0000,0000,0000,,Von dieser Fleischkarte nehme ich\Nvon oben beginnend alles!
Dialogue: 0,0:04:55.66,0:04:58.07,Default,Garo,0000,0000,0000,,Bring mir auch alles,\Nwas an Salat da ist.
Dialogue: 0,0:04:58.07,0:05:00.01,Default,Garo,0000,0000,0000,,Und einen großen Pott Wasser!
Dialogue: 0,0:05:06.06,0:05:07.58,Default,Garo,0000,0000,0000,,Ich bestelle noch etwas!
Dialogue: 0,0:05:07.58,0:05:11.58,TypePlaceholder,TYPE,0000,0000,0000,,{\fnImpact\fsp2\bord2\fs+5\c&H5543C1&\3c&HF6FEFF&\frz1.29\pos(259.5,58.5)}Kau {\alpha&HFF&\t(1311,1312,\alpha&H00&)}Kau
