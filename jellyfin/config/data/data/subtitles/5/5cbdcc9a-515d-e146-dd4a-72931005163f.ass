Dialogue: 0,0:20:58.65,0:21:03.07,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTimes New Roman bold\bord1.2\fad(400,0)\blur1\fs18\c&HFFFFFF&\3c&H000000&}Qualitätskontrolle:\NDaniel Wackenheim
Dialogue: 0,0:21:03.53,0:21:07.95,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTimes New Roman bold\bord1.2\fad(400,0)\blur1\fs18\c&HFFFFFF&\3c&H000000&}Projektleitung:\NTobias Philippi
Dialogue: 0,0:22:19.72,0:22:21.01,Internal,Zombieman,0000,0000,0000,,Endlich!
Dialogue: 0,0:22:21.01,0:22:23.63,Internal,Zombieman,0000,0000,0000,,Endlich habe ich sie aufgestöbert!
Dialogue: 0,0:22:23.63,0:22:28.49,Internal,Zombieman,0000,0000,0000,,Die Bande, mit der mich am meisten verbindet\Nund der ich jahrelang nachgestellt habe.
Dialogue: 0,0:22:29.05,0:22:32.44,Internal,Zombieman,0000,0000,0000,,Sie planen die Vertreibung der Menschheit\Nund wollen die Welt neu formen.
Dialogue: 0,0:22:32.44,0:22:34.46,Internal,Zombieman,0000,0000,0000,,Die schlimmste Organisation der Geschichte.
Dialogue: 0,0:22:35.17,0:22:39.87,Internal,Zombieman,0000,0000,0000,,Auch die Ereignisse der letzten Zeit\Nlassen vage ihre wahre Gestalt erahnen.
Dialogue: 0,0:22:40.43,0:22:43.34,Internal,Zombieman,0000,0000,0000,,Leider habe ich sie nie\Nganz zu fassen bekommen.
Dialogue: 0,0:22:44.47,0:22:47.42,Internal,Zombieman,0000,0000,0000,,Die Prophezeiung von Madame Shibabawa,\Ndass die Erde in Gefahr sei …
Dialogue: 0,0:22:47.81,0:22:51.42,Internal,Zombieman,0000,0000,0000,,Die Existenz, die hinter der so genannten\NMonster-Vereinigung die Fäden zieht …
Dialogue: 0,0:22:52.25,0:22:54.42,Internal,Zombieman,0000,0000,0000,,Sie sind die Wurzel allen Übels!
Dialogue: 0,0:22:55.19,0:22:56.69,Internal,Zombieman,0000,0000,0000,,Kein Zweifel!
Dialogue: 0,0:22:56.69,0:23:01.11,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTimes New Roman bold\c&H141922&\frx20\fs+5\fry2\t(0,3689,\fscx70\fscy70)\move(426.5,-35,426.5,42,18,3689)}Haus des\NTakoyaki
Dialogue: 0,0:23:01.11,0:23:03.41,Default,Zombieman,0000,0000,0000,,Heute findet ihr euer Ende!
Dialogue: 0,0:23:03.41,0:23:04.61,Default,Zombieman,0000,0000,0000,,Haus der Evolution!
Dialogue: 0,0:23:04.61,0:23:15.37,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTimes New Roman bold\c&H141922&\frx20\fry2\pos(426.5,41)}Haus des\NTakoyaki
Dialogue: 0,0:23:05.07,0:23:07.20,Default,Gepanzerter Gorilla,0000,0000,0000,,Huch? Ein Kunde?
Dialogue: 0,0:23:07.20,0:23:08.90,Default,Gepanzerter Gorilla,0000,0000,0000,,Ein Kunde, ja?
Dialogue: 0,0:23:09.91,0:23:13.44,Default,Zombieman,0000,0000,0000,,Habt ihr eure Basis wieder gewechselt\Nund tarnt euch nun als Takoyaki-Laden?
Dialogue: 0,0:23:13.91,0:23:15.37,Default,Zombieman,0000,0000,0000,,Wie lachhaft!
Dialogue: 0,0:23:15.37,0:23:18.22,Default,Zombieman,0000,0000,0000,,Ich habe eure Absicht\Nlängst durchschaut!
Dialogue: 0,0:23:18.22,0:23:19.25,Default,Zombieman,0000,0000,0000,,Mich legt ihr nicht rein!
Dialogue: 0,0:23:19.79,0:23:21.34,Default,Gepanzerter Gorilla,0000,0000,0000,,Einen Moment noch!
Dialogue: 0,0:23:21.34,0:23:23.26,Default,Gepanzerter Gorilla,0000,0000,0000,,Ich bereite gerade alles vor.
Dialogue: 1,0:23:23.26,0:23:35.35,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTrebuchet MS bold\fs+10\bord3\c&H7100BC&\3c&H92DC86&\pos(562,158.5)}Groll
Dialogue: 2,0:23:23.26,0:23:35.35,TypePlaceholder,TYPE,0000,0000,0000,,{\fnTrebuchet MS bold\fs+10\bord1.5\c&H7100BC&\3c&H24263A&\pos(562,158.5)}Groll
Dialogue: 0,0:23:24.85,0:23:27.93,Default,Zombieman,0000,0000,0000,,Ich bin nun ein Held: Zombieman!
Dialogue: 0,0:23:27.93,0:23:30.17,Default,Zombieman,0000,0000,0000,,Ein Wesen mit unsterblichem Körper!
Dialogue: 0,0:23:31.12,0:23:35.35,Default,Zombieman,0000,0000,0000,,Sagt dir Versuchsobjekt\NNummer 66 noch etwas?
Dialogue: 0,0:23:35.35,0:23:39.01,Default,Gepanzerter Gorilla,0000,0000,0000,,Was? Du bist ein Held, der das Haus\Nder Evolution zu Fall bringen will?
Dialogue: 0,0:23:39.01,0:23:42.61,Default,Gepanzerter Gorilla,0000,0000,0000,,Bedaure, aber das Haus der Evolution\Nwurde bereits ausgelöscht.
Dialogue: 0,0:23:46.55,0:23:50.86,Default,Gepanzerter Gorilla,0000,0000,0000,,Nun … Wollen Sie nicht\Nerst einmal etwas essen?
Dialogue: 0,0:23:50.86,0:23:52.73,Default,Gepanzerter Gorilla,0000,0000,0000,,Im Moment sind Plätze frei.
Dialogue: 0,0:23:53.37,0:23:56.00,TypePlaceholder,TYPE,0000,0000,0000,,{\fad(325,0)\fnGeorgia Bold\fs+5\bord2\c&H191717&\3c&HEEF7FC&}Wird fortgesetzt
Dialogue: 0,0:23:56.00,0:24:00.96,TypePlaceholder,TYPE,0000,0000,0000,,{\fnGeorgia Bold\c&HF9F9F9&\fs+4\an2\pos(320,116)}Grenzen des Lebewesens

