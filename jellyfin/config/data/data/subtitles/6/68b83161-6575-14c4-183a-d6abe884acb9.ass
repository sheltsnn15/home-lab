Dialogue: 0,0:12:18.96,0:12:21.29,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\fsp\fs-4\bord0\c&H151515&\pos(529.5,75.5)}Jujutsu-Akademie, 2. Jahr
Dialogue: 0,0:12:18.96,0:12:21.29,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\an2\fsp\fs-1\bord0\c&H151515&\pos(531.5,274)}Gojō Satoru
Dialogue: 0,0:12:19.88,0:12:21.29,Default,Gojō,0000,0000,0000,,Heulst du etwa?
Dialogue: 0,0:12:21.29,0:12:23.30,Default,Utahime,0000,0000,0000,,Am Arsch heul ich!
Dialogue: 0,0:12:21.29,0:12:26.51,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\fsp\fs-4\bord0\c&H151515&\pos(75.5,22)}Jujuzistin, Rang 2
Dialogue: 0,0:12:21.29,0:12:26.51,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\an2\fsp\fs-1.8\bord0\c&H151515&\pos(75,170)}Iori Utahime
Dialogue: 0,0:12:23.30,0:12:24.46,Default,Utahime,0000,0000,0000,,Unverschämtheit!
Dialogue: 0,0:12:24.46,0:12:26.51,Default,Utahime,0000,0000,0000,,Wenn ja, würdest du mich trösten?
Dialogue: 0,0:12:26.51,0:12:29.26,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\fsp\fs-2\bord0\c&H151515&\pos(557.5,15)}Jujuzistin, Rang 1
Dialogue: 0,0:12:26.51,0:12:29.26,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\an2\fsp\fs+4\bord0\c&H151515&\pos(557,226.5)}Mei Mei
Dialogue: 0,0:12:27.17,0:12:29.26,Default,Mei Mei,0000,0000,0000,,Wie lieb von dir.
Dialogue: 0,0:12:29.76,0:12:32.97,Default,Gojō,0000,0000,0000,,Eine echte Kämpferin wie du\Nwürde doch nicht heulen.
Dialogue: 0,0:12:34.43,0:12:35.35,Default,Mei Mei,0000,0000,0000,,Ach ja?
Dialogue: 0,0:12:36.47,0:12:37.60,Default,Utahime,0000,0000,0000,,Gojō!
Dialogue: 0,0:12:37.60,0:12:40.44,Default,Utahime,0000,0000,0000,,Damit das klar ist:\NIch brauchte deine Hilfe ni…
Dialogue: 0,0:12:45.23,0:12:48.40,Default,Getō,0000,0000,0000,,Nicht runterschlucken.\NIch absorbier’s später.
Dialogue: 0,0:12:49.20,0:12:51.95,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\fsp\fs-4.5\bord0\c&H151515&\pos(547.5,62.5)}Jujutsu-Akademie, 2. Jahr
Dialogue: 0,0:12:49.20,0:12:51.95,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\an2\fsp\fs-1\bord0\c&H151515&\pos(548.5,251.5)}Getō Suguru
Dialogue: 0,0:12:49.20,0:12:51.95,Default,Getō,0000,0000,0000,,Satoru, man ärgert\Nkeine Schwächeren.
Dialogue: 0,0:12:52.32,0:12:55.29,Default,Gojō,0000,0000,0000,,Wer wäre so blöd,\NStärkere zu ärgern?
Dialogue: 0,0:12:56.08,0:12:59.58,Default,Mei Mei,0000,0000,0000,,Wie beiläufig du sie auch\Nnoch anstachelst, Getō.
Dialogue: 0,0:13:01.37,0:13:03.21,Default,Shōko,0000,0000,0000,,Utahime!
Dialogue: 0,0:13:03.84,0:13:05.34,Default,Shōko,0000,0000,0000,,Geht es dir gut?
Dialogue: 0,0:13:05.34,0:13:06.67,Default,Utahime,0000,0000,0000,,Shōko!
Dialogue: 0,0:13:05.34,0:13:10.72,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\fsp\fs-4\bord0\c&H151515&\pos(479.5,80)}Jujutsu-Akademie, 2. Jahr
Dialogue: 0,0:13:05.34,0:13:10.72,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\an2\fsp\fs-1\bord0\c&H151515&\pos(482.5,297.5)}Ieiri Shōko
Dialogue: 0,0:13:06.67,0:13:08.76,Default,Shōko,0000,0000,0000,,Du hast dich zwei Tage nicht gemeldet.
Dialogue: 0,0:13:08.76,0:13:10.72,Default,Shōko,0000,0000,0000,,Ich hab mir echt Sorgen gemacht.
Dialogue: 0,0:13:10.72,0:13:14.01,Default,Utahime,0000,0000,0000,,Shōko!
Dialogue: 0,0:13:14.01,0:13:18.35,Default,Utahime,0000,0000,0000,,Shōko! Werd ja nicht\Nso wie die beiden Spinner!
Dialogue: 0,0:13:18.68,0:13:21.81,Default,Shōko,0000,0000,0000,,Doch nicht wie dieser Abschaum.
Dialogue: 0,0:13:20.23,0:13:26.52,TypePlaceholder,Type,0000,0000,0000,,{\p1\c&HF5F5F5&\3c&H2F3231&\bord15\pos(87.5,43)\clip(m 17.6 26.24 l 16.96 36.48 11.2 37.12 10.88 43.2 16.96 42.88 16.96 82.88 13.12 82.88 13.76 87.36 17.6 87.68 16.32 90.56 22.4 90.88 21.76 88 153.6 87.68 153.6 97.28 158.08 97.28 157.76 43.2 165.44 43.52 164.48 37.12 23.36 36.16 23.68 23.68)}m 0 0 l 130 0 l 130 40 l 0 40
Dialogue: 1,0:13:20.23,0:13:26.52,TypePlaceholder,Type,0000,0000,0000,,{\fnImpact\fsp3\b0\bord0\fs+2\c&H2F3231&\pos(89.5,49.5)}Abschaum
Dialogue: 0,0:13:21.81,0:13:24.81,Default,Gojō,0000,0000,0000,,Der Weg, den Utahime gegangen ist,\Nfällt auseinander.
Dialogue: 0,0:13:24.81,0:13:26.52,Default,Getō,0000,0000,0000,,Halt den Rand.
Dialogue: 0,0:13:26.52,0:13:27.53,Default,Utahime,0000,0000,0000,,Hm?
Dialogue: 0,0:13:28.23,0:13:29.44,Default,Utahime,0000,0000,0000,,Zwei Tage?
Dialogue: 0,0:13:30.07,0:13:34.41,Default,Gojō,0000,0000,0000,,Ach, die Zeit lief in\Nder Barriere also anders?
Dialogue: 0,0:13:34.41,0:13:36.83,Default,Gojō,0000,0000,0000,,Das kommt vor,\Nwenn auch nicht oft.
Dialogue: 0,0:13:36.83,0:13:39.58,Default,Gojō,0000,0000,0000,,Hab mich schon gewundert,\Nwarum Mei bei dir ist.
Dialogue: 0,0:13:40.04,0:13:42.04,Default,Mei Mei,0000,0000,0000,,Sieht ganz danach aus.
Dialogue: 0,0:13:42.04,0:13:43.79,Default,Gojō,0000,0000,0000,,Hm? Ist was?
Dialogue: 0,0:13:44.13,0:13:48.21,Default,Mei Mei,0000,0000,0000,,Soll heißen: Das waren\Neffektiv zwei Tage Arbeit.
Dialogue: 0,0:13:48.21,0:13:52.76,Default,Mei Mei,0000,0000,0000,,Das muss ich natürlich\Nentsprechend in Rechnung stellen.
Dialogue: 0,0:13:52.76,0:13:55.22,Default,Utahime,0000,0000,0000,,Du willst sie noch mehr abzocken?
Dialogue: 0,0:13:55.22,0:13:58.26,Default,Mei Mei,0000,0000,0000,,Aber zurück zum Thema:\NWas ist mit dem Schleier?
Dialogue: 0,0:14:02.27,0:14:05.65,TypePlaceholder,Type,0000,0000,0000,,{\fnTahoma\b0\fs-2\c&HE8E0CB&\3c&HBE7C69&\bord3\pos(329.5,277.5)}Explosion aufgrund veralteter Gasrohre
Dialogue: 1,0:14:02.27,0:14:05.65,TypePlaceholder,Type,0000,0000,0000,,{\fnTahoma\b0\fs-2\c&HE8E0CB&\3c&H897668&\bord1\pos(329.5,277.5)}Explosion aufgrund veralteter Gasrohre
Dialogue: 0,0:14:02.27,0:14:06.24,Top,Nachrichtensprecherin,0000,0000,0000,,Kommen wir zur Explosion,\Ndie sich kürzlich in Hamamatsu ereignete.
Dialogue: 0,0:14:06.06,0:14:09.32,Default,Yaga,0000,0000,0000,,Einer von euch wollte\Nden Schleier selbst aufspannen
Dialogue: 0,0:14:06.23,0:14:10.61,Top,Nachrichtensprecherin,0000,0000,0000,,Als Ursache werden\Nveraltete Gasrohre vermutet.
Dialogue: 0,0:14:09.32,0:14:12.57,Default,Yaga,0000,0000,0000,,und hat seinen Assistenzaufseher\Nzurückgelassen.
Dialogue: 0,0:14:12.57,0:14:15.12,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\fsp\fs-4\bord0\c&H151515&\pos(532,74.5)}Jujuzist, Rang 1
Dialogue: 0,0:14:12.57,0:14:15.12,TypePlaceholder,Type,0000,0000,0000,,{\fnTimes New Roman Bold\an2\fsp\fs-2\bord0\c&H151515&\pos(532,259)}Yaga Masamichi
Dialogue: 0,0:14:12.57,0:14:15.12,Default,Yaga,0000,0000,0000,,Und hat den Schleier dann vergessen.
Dialogue: 0,0:14:15.12,0:14:16.57,Default,Yaga,0000,0000,0000,,Wer war das?
Dialogue: 0,0:14:17.83,0:14:20.83,Default,Gojō,0000,0000,0000,,Herr Yaga, brauchen wir\Necht einen Sündenbock?
Dialogue: 0,0:14:20.83,0:14:22.00,Default,Yaga,0000,0000,0000,,Du also, Satoru.
Dialogue: 0,0:14:23.04,0:14:23.79,TypePlaceholder,Type,0000,0000,0000,,{\fnGeorgia Bold\fs+12\fsp3\c&H010403&\3c&H010403&\bord0.5\blur0.9\pos(320,296)}Disziplin
Dialogue: 0,0:14:24.71,0:14:29.13,Default,Gojō,0000,0000,0000,,Ich weiß ja nicht …\NIst ein Schleier echt so wichtig?
Dialogue: 0,0:14:29.75,0:14:32.76,Default,Gojō,0000,0000,0000,,Ist doch egal, ob uns\Ndie normalen Leute sehen.
Dialogue: 0,0:14:32.76,0:14:35.43,Default,Gojō,0000,0000,0000,,Die können doch eh keine\NFluchgeister oder Jujutsu sehen.
Dialogue: 0,0:14:38.18,0:14:40.14,Default,Getō,0000,0000,0000,,Nichts da.
Dialogue: 0,0:14:40.14,0:14:46.02,Default,Getō,0000,0000,0000,,Schließlich ist der Seelenfrieden der Leute\Ndie beste Waffe gegen Fluchgeister.
Dialogue: 0,0:14:46.02,0:14:49.19,Default,Getō,0000,0000,0000,,Deshalb müssen wir diese\Nunsichtbaren Bedrohungen
Dialogue: 0,0:14:49.19,0:14:52.40,Default,Getō,0000,0000,0000,,so gut wie möglich verborgen halten.
Dialogue: 0,0:14:52.40,0:14:53.36,Default,Getō,0000,0000,0000,,Außerdem …
Dialogue: 0,0:14:53.36,0:14:55.16,Default,Gojō,0000,0000,0000,,Ist ja gut, ist ja gut.
Dialogue: 0,0:15:01.54,0:15:05.25,Default,Gojō,0000,0000,0000,,Ist echt erschöpfend, auf die Schwachen\NRücksicht zu nehmen.
Dialogue: 0,0:15:06.25,0:15:10.84,Default,Getō,0000,0000,0000,,„Das Überleben der Schwächeren“.\NSo sollte die Gesellschaft sein.
Dialogue: 0,0:15:10.84,0:15:13.55,Default,Getō,0000,0000,0000,,Man hilft den Schwachen\Nund schwächt die Starken.
Dialogue: 0,0:15:13.84,0:15:15.47,Default,Getō,0000,0000,0000,,Ist das klar, Satoru?
Dialogue: 0,0:15:15.47,0:15:18.89,Default,Getō,0000,0000,0000,,Jujutsu existiert, um die\NNicht-Jujuzisten zu beschützen.
Dialogue: 0,0:15:19.85,0:15:21.51,Default,Gojō,0000,0000,0000,,So kommst du mir?
Dialogue: 0,0:15:21.93,0:15:24.73,Default,Gojō,0000,0000,0000,,Ich hasse dieses Moralgetue.
Dialogue: 0,0:15:25.31,0:15:26.19,Default,Getō,0000,0000,0000,,Was?
Dialogue: 0,0:15:26.77,0:15:32.53,Default,Gojō,0000,0000,0000,,Es sind immer die Schwachen, die den Starken\NPflichten und Verantwortung anhängen.
Dialogue: 0,0:15:42.45,0:15:46.62,Default,Gojō,0000,0000,0000,,Also hör auf, dich an deiner\NScheinheiligkeit aufzugeilen.
Dialogue: 0,0:15:48.37,0:15:50.21,Default,Shōko,0000,0000,0000,,Schwupp und weg.
Dialogue: 0,0:15:50.63,0:15:53.46,Default,Getō,0000,0000,0000,,Wollen wir draußen weiterreden, Satoru?
Dialogue: 0,0:15:53.76,0:15:56.88,Default,Gojō,0000,0000,0000,,Brauchst du unbedingt Gesellschaft?\NIch bleibe hier.
Dialogue: 0,0:15:59.68,0:16:02.01,Default,Yaga,0000,0000,0000,,Wie lange wollt ihr noch faulenzen?
Dialogue: 0,0:16:02.01,0:16:03.26,Default,Yaga,0000,0000,0000,,Wo ist Shōko?
Dialogue: 0,0:16:03.60,0:16:05.77,Default,Gojō,0000,0000,0000,,Gute Frage.\NBestimmt aufm Pott.
Dialogue: 0,0:16:06.73,0:16:10.61,Default,Yaga,0000,0000,0000,,Auch egal. Dann geht dieser Auftrag\Neben an euch beide.
Dialogue: 0,0:16:11.86,0:16:13.53,Default,Yaga,0000,0000,0000,,Was zieht ihr denn für Fressen?
Dialogue: 0,0:16:14.07,0:16:15.11,Default,Beide,0000,0000,0000,,Alles bestens.
Dialogue: 0,0:16:15.94,0:16:18.91,Default,Yaga,0000,0000,0000,,Ehrlich gesagt könnte das\Nzu viel für euch sein,
Dialogue: 0,0:16:18.91,0:16:21.16,Default,Yaga,0000,0000,0000,,aber Meister Tengen\Nhat nach euch verlangt.
Dialogue: 0,0:16:22.95,0:16:24.79,Default,Yaga,0000,0000,0000,,Ihr habt zwei Aufgaben.
Dialogue: 0,0:16:25.25,0:16:29.21,Default,Yaga,0000,0000,0000,,Ihr sollt die Sternplasmahülle, das Mädchen,\Ndas mit Meister Tengen kompatibel ist,
Dialogue: 0,0:16:29.21,0:16:33.25,Default,Yaga,0000,0000,0000,,eskortieren und eliminieren.
Dialogue: 0,0:16:33.71,0:16:36.26,Default,Gojō,0000,0000,0000,,Ein Blag eskortieren und eliminieren?
Dialogue: 0,0:16:37.05,0:16:38.34,Default,Yaga,0000,0000,0000,,Genau.
Dialogue: 0,0:16:38.34,0:16:40.05,Default,Gojō,0000,0000,0000,,Jetzt dreht er völlig am Rad.
Dialogue: 0,0:16:40.05,0:16:41.64,Default,Getō,0000,0000,0000,,Ist immerhin Frühling.
Dialogue: 0,0:16:41.64,0:16:44.43,Default,Getō,0000,0000,0000,,Bestimmt denkt er nur dran,\Nder nächste Rektor zu werden.
Dialogue: 0,0:16:44.89,0:16:46.18,Default,Getō,0000,0000,0000,,Aber genug gescherzt.
Dialogue: 0,0:16:46.18,0:16:49.31,Top,Yaga,0000,0000,0000,,{\i1}Ich{\i0} entscheide, ob ich diese\NScherze durchgehen lasse.
Dialogue: 0,0:16:47.64,0:16:50.40,Default,Getō,0000,0000,0000,,Sollen wir Meister Tengens\NFluchtechnik zurücksetzen?
Dialogue: 0,0:16:50.90,0:16:52.94,Default,Gojō,0000,0000,0000,,Hm? Wie meinen?
Dialogue: 0,0:16:56.44,0:16:57.53,Default,Gojō,0000,0000,0000,,Sagt schon.
Dialogue: 0,0:16:58.11,0:17:02.87,Default,Yaga,0000,0000,0000,,Meister Tengens Fluchtechnik macht ihn\Nzwar unsterblich, aber er altert dennoch.
Dialogue: 0,0:17:02.87,0:17:05.58,Default,Yaga,0000,0000,0000,,Die Alterung selbst\Nist nicht das Problem,
Dialogue: 0,0:17:05.58,0:17:07.87,Default,Yaga,0000,0000,0000,,doch ab einem bestimmten Punkt
Dialogue: 0,0:17:07.87,0:17:10.96,Default,Yaga,0000,0000,0000,,beginnt seine Fluchtechnik,\Nseinen Körper zu überschreiben.
Dialogue: 0,0:17:12.17,0:17:17.01,Default,Yaga,0000,0000,0000,,Eine Evolution. Er hört auf, Mensch zu sein,\Nund wird zu einer höheren Existenz.
Dialogue: 0,0:17:17.30,0:17:20.84,Default,Gojō,0000,0000,0000,,Und wo ist das Problem?\NKlingt doch saucool.
Dialogue: 0,0:17:20.84,0:17:24.43,Default,Getō,0000,0000,0000,,Laut Meister Tengen verlieren jene,\Ndie dieses Stadium erreichen,
Dialogue: 0,0:17:24.43,0:17:26.39,Default,Getō,0000,0000,0000,,ihr Bewusstsein.
Dialogue: 0,0:17:26.81,0:17:29.77,Default,Getō,0000,0000,0000,,Er würde also aufhören,\Ner selbst zu sein.
Dialogue: 0,0:17:29.77,0:17:31.52,TypePlaceholderBox,Type,0000,0000,0000,,{\fnGeorgia\c&H2A3839&\fs-2\4c&H3D4754&\bord0\shad0\bord3\3c&HC1EDF1&\pos(158,25.5)}\hStädtische\h\N\hJujutsu-Akademie\h\N\hTōkyō\h
Dialogue: 0,0:17:29.77,0:17:31.52,Default,Gojō,0000,0000,0000,,Alle Jujutsu-Schulen
Dialogue: 0,0:17:31.52,0:17:34.02,Default,Getō,0000,0000,0000,,und die Schutzwälle der Jujutsu-Welt,
Dialogue: 0,0:17:34.02,0:17:36.44,Default,Getō,0000,0000,0000,,die Barrierenmagie\Nder Assistenzaufseher.
Dialogue: 0,0:17:36.44,0:17:40.61,Default,Getō,0000,0000,0000,,Sie alle werden\Nvon Meister Tengen gestärkt.
Dialogue: 0,0:17:41.11,0:17:43.28,Default,Getō,0000,0000,0000,,Ohne seine Unterstützung könnten wir
Dialogue: 0,0:17:43.28,0:17:46.66,Default,Getō,0000,0000,0000,,weder Sicherheit gewährleisten\Nnoch unsere Missionen erledigen.
Dialogue: 0,0:17:46.66,0:17:48.33,Default,Getō,0000,0000,0000,,Im schlimmsten Fall
Dialogue: 0,0:17:48.33,0:17:51.62,Default,Getō,0000,0000,0000,,könnte sich Meister Tengen\Ngar gegen die Menschheit stellen.
Dialogue: 0,0:17:51.62,0:17:55.29,Default,Getō,0000,0000,0000,,Deshalb sucht er sich alle\N500 Jahre eine Sternplasmahülle.
Dialogue: 0,0:17:55.29,0:17:58.34,Default,Getō,0000,0000,0000,,Er vereinigt sich mit einem Menschen,\Nder mit ihm kompatibel ist,
Dialogue: 0,0:17:58.34,0:18:00.51,Default,Getō,0000,0000,0000,,und überschreibt seine Körperdaten.
Dialogue: 0,0:18:00.88,0:18:05.39,Default,Getō,0000,0000,0000,,Indem er seinen Körper erneuert,\Nwird auch seine Fluchtechnik zurückgesetzt
Dialogue: 0,0:18:05.39,0:18:07.01,Default,Getō,0000,0000,0000,,und die Evolution bleibt aus.
Dialogue: 0,0:18:07.01,0:18:08.51,Default,Gojō,0000,0000,0000,,Verstehe.
Dialogue: 0,0:18:08.51,0:18:11.06,Default,Gojō,0000,0000,0000,,Er darf sich also ruhig zu\NMetal Greymon entwickeln,
Dialogue: 0,0:18:11.06,0:18:13.52,Default,Gojō,0000,0000,0000,,aber ja nicht zu Skull Greymon werden.
Dialogue: 0,0:18:13.52,0:18:16.31,Default,Gojō,0000,0000,0000,,Deshalb muss er\Nvon Coromon neu starten.
Dialogue: 0,0:18:17.02,0:18:19.73,Default,Getō,0000,0000,0000,,Was? Ach, belassen wir’s dabei.
Dialogue: 0,0:18:20.03,0:18:24.20,Default,Yaga,0000,0000,0000,,Und der Aufenthaltsort der\NSternplasmahülle ist durchgesickert.
Dialogue: 0,0:18:24.20,0:18:28.33,Default,Yaga,0000,0000,0000,,Derzeit haben es primär zwei Gruppen\Nauf ihr Leben abgesehen.
Dialogue: 0,0:18:28.95,0:18:31.33,Default,Yaga,0000,0000,0000,,Einerseits die Fluchmagier-Gruppe Q,
Dialogue: 0,0:18:31.33,0:18:35.58,Default,Yaga,0000,0000,0000,,die unsere Gesellschaft stürzen will,\Nindem Meister Tengen Amok läuft.
Dialogue: 0,0:18:36.71,0:18:40.09,Default,Yaga,0000,0000,0000,,Und andererseits die Sternensekte,\Ndie sogenannte
Dialogue: 0,0:18:40.09,0:18:42.84,Default,Yaga,0000,0000,0000,,„Gesellschaft der Zeithülle“,\Ndie Meister Tengen verehrt.
Dialogue: 0,0:18:43.51,0:18:46.05,Default,Yaga,0000,0000,0000,,Meister Tengen wird sich\Nübermorgen bei Vollmond
Dialogue: 0,0:18:46.05,0:18:48.22,Default,Yaga,0000,0000,0000,,mit der Sternplasmahülle vereinigen.
Dialogue: 0,0:18:48.22,0:18:52.98,Default,Yaga,0000,0000,0000,,Bis dahin sollt ihr sie eskortieren\Nund zu Meister Tengen bringen.
Dialogue: 0,0:18:53.27,0:18:57.11,Default,Yaga,0000,0000,0000,,Solltet ihr scheitern, wird das selbst\Ndie Zivilgesellschaft zu spüren bekommen.
Dialogue: 0,0:18:57.11,0:18:58.56,Default,Yaga,0000,0000,0000,,Seid euch dessen gewahr!
Dialogue: 0,0:18:58.56,0:19:00.82,TypePlaceholderBox,Type,0000,0000,0000,,{\fnVerdana\b0\fsp2\fscx120\fax0.1\fs-2\c&HFACF99&\3c&HE6A54F&\frz350.8\pos(66,24)}\h\hKalt\h\h
