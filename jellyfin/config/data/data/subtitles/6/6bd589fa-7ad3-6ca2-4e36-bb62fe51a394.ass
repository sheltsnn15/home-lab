Dialogue: 0,0:03:23.32,0:03:24.33,main,EMMA,0000,0000,0000,,!إينار
Dialogue: 0,0:03:29.04,0:03:30.43,main,EINAR,0000,0000,0000,,ماذا تفعلين؟
Dialogue: 0,0:03:30.43,0:03:32.44,main,EMMA,0000,0000,0000,,!أنا من عليها قول ذلك لك
Dialogue: 0,0:03:32.86,0:03:35.94,main,EMMA,0000,0000,0000,,لماذا تهاجم تلك الشّجرة؟ \Nأتحاول سحق المنزل؟
Dialogue: 0,0:03:37.41,0:03:39.74,main,LOTTA,0000,0000,0000,,هل ستصير حطّابًا يا أخي؟
Dialogue: 0,0:03:39.74,0:03:41.04,main,EINAR,0000,0000,0000,,.كلاّ
Dialogue: 0,0:03:41.45,0:03:43.80,main,EINAR,0000,0000,0000,,.أنا أتدرّب للمعركة
Dialogue: 0,0:03:43.80,0:03:45.20,main,EINAR,0000,0000,0000,,.شاهدا قوّتي
Dialogue: 0,0:03:46.12,0:03:50.03,main,EMMA,0000,0000,0000,,.أنت فتى ضخم، لكنّك بلا فائدة في المعارك
Dialogue: 0,0:03:50.03,0:03:51.53,main,EMMA,0000,0000,0000,,.استعدّ للغداء
Dialogue: 0,0:03:51.53,0:03:54.08,main,LOTTA,0000,0000,0000,,...أتضوّر جوعًا
Dialogue: 0,0:03:57.99,0:04:00.22,main,EINAR,0000,0000,0000,,.لم يكن عليك رمي سكّين عليّ
Dialogue: 0,0:04:00.22,0:04:02.75,main,EINAR,0000,0000,0000,,.تحملين صحونًا وملاعق أيضًا
Dialogue: 0,0:04:02.75,0:04:04.26,main,EMMA,0000,0000,0000,,لا تمانع إن ضربتك بصحن؟
Dialogue: 0,0:04:09.43,0:04:14.49,main,LOTTA,0000,0000,0000,,.يُقال أنّ على الدّببة أكل الكثير قبل الشّتاء
Dialogue: 0,0:04:14.49,0:04:15.64,main,EMMA,0000,0000,0000,,فعلاً؟
Dialogue: 0,0:04:19.94,0:04:23.77,main,EMMA,0000,0000,0000,,أخبرني، لماذا تتدرّب ثانية فجأة؟
Dialogue: 0,0:04:20.58,0:04:21.69,top,LOTTA,0000,0000,0000,,.شكرًا لك
Dialogue: 0,0:04:25.25,0:04:28.44,main,EINAR,0000,0000,0000,,.لأنّه عليّ حماية هذا المكان
Dialogue: 0,0:04:32.00,0:04:36.58,main,EINAR,0000,0000,0000,,لقد بُني من جديد أخيرًا\N.بعد أن التهمته النّيران عن آخر
Dialogue: 0,0:04:38.42,0:04:40.82,main,EINAR,0000,0000,0000,,.لن أسمح بتكرار ذلك
Dialogue: 0,0:04:43.20,0:04:44.39,main,EINAR,0000,0000,0000,,—واثق أنّ والدي
Dialogue: 0,0:04:46.36,0:04:49.14,main,LOTTA,0000,0000,0000,,.حليب السّيّد غوثمور لذيذ جدًّا
Dialogue: 0,0:04:49.42,0:04:54.14,main,EMMA,0000,0000,0000,,.أليس كذلك؟ يعرف ذلك الرّجل كيف يعامل الضّرع
Dialogue: 0,0:04:54.14,0:04:56.40,main,LOTTA,0000,0000,0000,,.ماذا تفعلين بيديك؟ ذلك مقرف
Dialogue: 0,0:04:56.40,0:04:58.33,main,EINAR,0000,0000,0000,,.استمعا لي
Dialogue: 0,0:04:57.96,0:04:59.13,top,LOTTA,0000,0000,0000,,!توقّفي
Dialogue: 0,0:04:58.33,0:05:00.06,main,EMMA,0000,0000,0000,,.لا تبالي لذلك
Dialogue: 0,0:05:00.06,0:05:01.86,main,EMMA,0000,0000,0000,,.لا تقحم أنفك في شؤون المحاربين
Dialogue: 0,0:05:04.32,0:05:07.34,main,EINAR,0000,0000,0000,,ألا يُحبطك تواجدنا دائمًا في الجانب الخاسر؟
Dialogue: 0,0:05:07.67,0:05:10.96,main,EINAR,0000,0000,0000,,.مات والدي وهو يحمينا
Dialogue: 0,0:05:10.96,0:05:12.08,main,EMMA,0000,0000,0000,,.هذا صحيح
Dialogue: 0,0:05:12.08,0:05:14.00,main,EMMA,0000,0000,0000,,.وها أنت حيّ
Dialogue: 0,0:05:14.00,0:05:15.63,main,EMMA,0000,0000,0000,,،أعدنا بناء هذه القرية
Dialogue: 0,0:05:15.63,0:05:18.36,main,EMMA,0000,0000,0000,,.وها أنت تأكل وجبة لذيذة مع امرأتين جميلتين
Dialogue: 0,0:05:22.95,0:05:24.33,main,EMMA,0000,0000,0000,,.لن نخسر كلّ شيء
Dialogue: 0,0:05:38.61,0:05:39.15,main,OLD MAN ON CART,0000,0000,0000,,.مرحبًا
Dialogue: 0,0:05:39.16,0:05:40.61,main,OLD MAN VILLAGER,0000,0000,0000,,مرحبًا، كيف الحال؟
Dialogue: 0,0:05:42.24,0:05:43.58,main,CHILD VILLAGER,0000,0000,0000,,.بسرعة
Dialogue: 0,0:06:13.32,0:06:16.38,main,EMMA,0000,0000,0000,,.استمعي. أريدك أن تهربي بمجرّد أن ندخل الغابة
Dialogue: 0,0:06:16.38,0:06:17.39,main,EMMA,0000,0000,0000,,...اتبعي النّهر و
Dialogue: 0,0:06:18.44,0:06:19.27,main,EINAR,0000,0000,0000,,.لوتا
Dialogue: 0,0:06:20.60,0:06:21.53,main,EINAR,0000,0000,0000,,.أمّي
Dialogue: 0,0:06:31.78,0:06:34.91,main,EMMA,0000,0000,0000,,.لا تفكّري. اهربي مباشرة
Dialogue: 0,0:06:35.67,0:06:37.58,main,EMMA,0000,0000,0000,,.أخوك وأمّك سيوافيانك في الحال
Dialogue: 0,0:07:13.68,0:07:14.73,main,EINAR,0000,0000,0000,,!أمّي
Dialogue: 0,0:07:24.18,0:07:25.82,main,EINAR,0000,0000,0000,,.أأنت جاهزة؟ هيّا قفي
Dialogue: 0,0:07:28.97,0:07:30.01,main,EINAR,0000,0000,0000,,!أمّي
Dialogue: 0,0:07:39.33,0:07:44.99,main,EMMA,0000,0000,0000,,.إينار، اهرب. دعني واذهب
Dialogue: 0,0:07:44.99,0:07:45.91,main,EINAR,0000,0000,0000,,...مستحيل
Dialogue: 0,0:07:47.27,0:07:49.92,main,EINAR,0000,0000,0000,,.هيّا. قفي فحسب
Dialogue: 0,0:07:49.92,0:07:51.07,main,LOTTA,0000,0000,0000,,أمّي؟
Dialogue: 0,0:07:51.68,0:07:52.89,main,LOTTA,0000,0000,0000,,!أمّي
Dialogue: 0,0:08:00.56,0:08:02.22,main,LOTTA,0000,0000,0000,,...أمّي
Dialogue: 0,0:08:05.32,0:08:06.65,main,EMMA,0000,0000,0000,,...فتاة سخيفة
Dialogue: 0,0:08:09.25,0:08:12.16,main,VIKING B,0000,0000,0000,,.ما زال ثمّة أشخاص هناك
Dialogue: 0,0:08:12.91,0:08:15.08,main,VIKING C,0000,0000,0000,,!ومعهم نساء أيضًا
Dialogue: 0,0:08:15.08,0:08:17.10,main,VIKING B,0000,0000,0000,,!نحن قادمون يا فتيات
Dialogue: 0,0:08:29.17,0:08:30.70,main,EMMA,0000,0000,0000,,.قف يا إينار
Dialogue: 0,0:08:32.47,0:08:34.52,main,EMMA,0000,0000,0000,,!خذ لوتا واهربا بسرعة
Dialogue: 0,0:08:36.52,0:08:37.53,main,EINAR,0000,0000,0000,,...أمّي
Dialogue: 0,0:08:40.71,0:08:44.63,main,EMMA,0000,0000,0000,,.حتّى عجوز تحتضر قادرة على تولّي أمرها
Dialogue: 0,0:08:46.80,0:08:47.88,main,EMMA,0000,0000,0000,,.عيشا
Dialogue: 0,0:08:51.25,0:08:55.08,main,EMMA,0000,0000,0000,,...ما دمتما حيّين، يمكنكما
Dialogue: 0,0:09:04.96,0:09:07.56,main,EMMA,0000,0000,0000,,...إينار
Dialogue: 0,0:09:08.72,0:09:10.12,main,EMMA,0000,0000,0000,,...لوتا
Dialogue: 0,0:09:30.61,0:09:32.81,main,VIKING B,0000,0000,0000,,لماذا لا يهربان؟
Dialogue: 0,0:09:32.81,0:09:35.47,main,VIKING C,0000,0000,0000,,.مهلاً، إنّها ظريفة جدًّا
Dialogue: 0,0:09:36.28,0:09:38.63,main,VIKING D,0000,0000,0000,,ماتت أمّك، صحيح؟
Dialogue: 0,0:09:40.31,0:09:41.10,main,EINAR,0000,0000,0000,,!لوتا
Dialogue: 0,0:09:41.10,0:09:43.35,main,LOTTA,0000,0000,0000,,!اتركني! أخي
Dialogue: 0,0:09:43.35,0:09:44.10,main,EINAR,0000,0000,0000,,!لوتا
Dialogue: 0,0:09:44.56,0:09:46.12,main,EINAR,0000,0000,0000,,!أبعد يدك عن لوتا
Dialogue: 0,0:09:47.48,0:09:48.68,main,LOTTA,0000,0000,0000,,!أخي
Dialogue: 0,0:09:50.31,0:09:52.54,main,LOTTA,0000,0000,0000,,!كيف تجرؤ؟
Dialogue: 0,0:09:53.27,0:09:56.17,main,LOTTA,0000,0000,0000,,!أخي! أخي
Dialogue: 0,0:10:05.80,0:10:07.41,main,LOTTA,0000,0000,0000,,—ستدفع ثمن
Dialogue: 0,0:10:17.72,0:10:20.30,main,VIKING C,0000,0000,0000,,ما الّذي تفعله؟
Dialogue: 0,0:10:20.30,0:10:23.35,main,VIKING B,0000,0000,0000,,!لقد قامت بطعني
Dialogue: 0,0:10:23.35,0:10:25.47,main,VIKING C,0000,0000,0000,,.تبًّا. يا لها من خسارة
Dialogue: 0,0:10:25.47,0:10:26.78,main,VIKING D,0000,0000,0000,,.ما باليد حيلة
Dialogue: 0,0:10:26.78,0:10:29.48,main,VIKING D,0000,0000,0000,,.لنبع الفتى مقابل مال للجعة
Dialogue: 0,0:10:30.15,0:10:31.61,main,VIKING C,0000,0000,0000,,.يا لك من مغفّل
Dialogue: 0,0:10:31.61,0:10:33.34,main,VIKING B,0000,0000,0000,,أنا آسف، مفهوم؟
Dialogue: 0,0:10:33.34,0:10:36.01,main,VIKING C,0000,0000,0000,,.هيّا. لنذهب يا مال الجعة
Dialogue: 1,0:11:33.25,0:11:45.26,sign,SIGN,0000,0000,0000,,{\fad(1000,1)\c&HC6C6BD&\pos(250,30)\blur1}يذبل التّنّوب على أرض جدبة\Nبلا لحاء أو أوراق\Nوكذلك حال الرّجل بدون من يحبّه\Nفلِمَ قد يحيا حياة طويلة؟
Dialogue: 1,0:11:33.25,0:11:45.26,sign,SIGN,0000,0000,0000,,{\fad(1000,1)\c&HC6C6BD&\pos(160,120)\blur1}(هاومال (أقوال أودن  —
Dialogue: 0,0:12:23.22,0:12:24.26,main,MERCHANT A,0000,0000,0000,,كيف حالها؟
Dialogue: 0,0:12:27.54,0:12:29.03,main,MERCHANT B,0000,0000,0000,,.لحظاتها معدودة
Dialogue: 0,0:12:29.43,0:12:33.24,main,MERCHANT A,0000,0000,0000,,.سُحقًا. لا بأس، لننقلها
Dialogue: 0,0:12:45.73,0:12:47.37,main,MERCHANTS,0000,0000,0000,,!ها نحن أولاء
Dialogue: 0,0:12:49.96,0:12:50.70,main,EINAR,0000,0000,0000,,!مهلاً
Dialogue: 0,0:13:01.88,0:13:04.26,main,EINAR,0000,0000,0000,,أنت، ما الغاية من ذلك؟
Dialogue: 0,0:13:04.26,0:13:05.93,main,EINAR,0000,0000,0000,,!ماذا قد تجنيه من رميها هكذا؟
Dialogue: 0,0:13:10.80,0:13:13.06,main,MERCHANT A,0000,0000,0000,,.حسنًا، لا أرى أيّ تورّم
Dialogue: 0,0:13:15.50,0:13:17.02,main,MERCHANT B,0000,0000,0000,,.إنّنا نوزّع البطّانيّات
Dialogue: 0,0:13:17.02,0:13:19.34,main,MERCHANT B,0000,0000,0000,,.دفّؤوا أنفسكم جيّدًا
Dialogue: 0,0:13:20.08,0:13:22.64,main,MERCHANT B,0000,0000,0000,,.دفعنا ثروة مقابلكم
Dialogue: 0,0:13:22.64,0:13:25.65,main,MERCHANT B,0000,0000,0000,,.إيّاكم والوقوع ضحيّة للمرض
Dialogue: 0,0:13:26.36,0:13:29.45,main,MERCHANT B,0000,0000,0000,,.ابقوا أصحّاء حتّى نجد لكم مشتريًا على الأقلّ
Dialogue: 0,0:13:29.45,0:13:30.50,main,MERCHANT B,0000,0000,0000,,أهذا مفهوم؟
Dialogue: 0,0:13:33.54,0:13:35.18,main,MERCHANT B,0000,0000,0000,,!هيّا، أسرعوا
Dialogue: 0,0:13:35.18,0:13:36.66,main,MERCHANT B,0000,0000,0000,,!اجمعوا ذلك الشّراع
Dialogue: 0,0:14:04.47,0:14:07.88,italics,EINAR,0000,0000,0000,,.هذا صحيح. عليّ أن أعيش
Dialogue: 0,0:14:18.92,0:14:22.43,main,MERCHANT D,0000,0000,0000,,.لا تنسوا شرب الخمر. سيعيد لكم حيويّتكم
Dialogue: 0,0:14:23.28,0:14:26.59,main,MERCHANT C,0000,0000,0000,,.نظّفوا كلّ شبر من أجسادكم، وبالأخصّ رؤوسكم
Dialogue: 0,0:14:27.11,0:14:29.11,main,MERCHANT C,0000,0000,0000,,.تفقدّوا إن كنتم مصابين بالقمل
Dialogue: 0,0:14:33.68,0:14:36.12,main,WOMAN B,0000,0000,0000,,ما رأيك بهذا؟
Dialogue: 0,0:14:37.21,0:14:38.91,main,MERCHANT A,0000,0000,0000,,.لا بأس بالشّعر
Dialogue: 0,0:14:38.91,0:14:41.48,main,MERCHANT A,0000,0000,0000,,هلاّ قمتِ بتزيينها لتبدو أصغر سنًّا؟
Dialogue: 0,0:14:56.41,0:14:59.74,main,MERCHANT A,0000,0000,0000,,،ما قولكم؟ لدينا من خيرة البضائع\Nألا توافقوننا الرّأي؟
Dialogue: 0,0:15:00.30,0:15:02.29,main,CUSTOMER A,0000,0000,0000,,.كلّها من الدّرجة الثّانية
Dialogue: 0,0:15:02.29,0:15:03.84,main,MERCHANT A,0000,0000,0000,,.على رسلك
Dialogue: 0,0:15:03.84,0:15:05.78,main,MERCHANT A,0000,0000,0000,,!لن تجد ما هو أفضل من بضاعتنا
Dialogue: 0,0:15:09.17,0:15:12.15,italics,EINAR,0000,0000,0000,,.هذا صحيح. لا يمكنني البقاء هناك
Dialogue: 0,0:15:13.00,0:15:16.74,italics,EINAR,0000,0000,0000,,.سأهرب. أستطيع المحاولة ثانية ما دمت سأحيا
Dialogue: 0,0:15:39.46,0:15:41.06,main,WOMAN C,0000,0000,0000,,...حسنًا
Dialogue: 0,0:15:43.76,0:15:45.19,main,WOMAN C,0000,0000,0000,,!لصّ
Dialogue: 0,0:15:46.28,0:15:47.34,main,EINAR,0000,0000,0000,,!آسف
Dialogue: 0,0:15:54.34,0:15:55.76,main,MERCHANT A,0000,0000,0000,,.مرحبًا يا إينار
Dialogue: 0,0:15:56.64,0:15:59.27,main,MERCHANT A,0000,0000,0000,,.ما زلتَ لا تدرك الأمر
Dialogue: 0,0:16:07.00,0:16:10.81,main,MERCHANT A,0000,0000,0000,,.أصغوا جيّدًا أيّها العبيد
Dialogue: 0,0:16:11.77,0:16:14.62,main,MERCHANT A,0000,0000,0000,,.دياركم بعيدة كلّ البعد من هنا
Dialogue: 0,0:16:14.62,0:16:17.15,main,MERCHANT A,0000,0000,0000,,.لن تعودوا إليها أبدًا مهما قاومتم
Dialogue: 0,0:16:17.15,0:16:22.00,main,MERCHANT A,0000,0000,0000,,.ولن يساعدكم أحد على الهرب بطبيعة الحال
Dialogue: 0,0:16:22.36,0:16:28.73,main,MERCHANT A,0000,0000,0000,,.والسّبب لأنّكم عبيد غرباء ومعدمون
Dialogue: 0,0:16:29.45,0:16:32.92,main,MERCHANT A,0000,0000,0000,,.جدوا سيّدًا جيّدًا واخدموه بأفضل ما لديكم
Dialogue: 0,0:16:33.56,0:16:37.68,main,MERCHANT A,0000,0000,0000,,.ستجدون طعامًا أوفر عنده ممّا ستجدون كمتسوّل هارب
Dialogue: 0,0:16:38.03,0:16:41.93,main,MERCHANT A,0000,0000,0000,,،قبل التّفكير في الانطلاق في مغامراتكم\N.فكّروا جيّدًا ما هو الخيار الأنسب
Dialogue: 0,0:16:42.96,0:16:45.27,main,MERCHANT A,0000,0000,0000,,أفهمت يا إينار؟
Dialogue: 0,0:17:00.29,0:17:05.06,main,EINAR,0000,0000,0000,,...عليّ أن أعيش
Dialogue: 0,0:17:13.85,0:17:20.88,main,CUSTOMER B,0000,0000,0000,,حسنًا، ليس سيّئًا، لكن هل لديك \Nأيّ صِبية بملامح أظرف؟
Dialogue: 0,0:17:20.88,0:17:22.47,main,MERCHANT D,0000,0000,0000,,.فهمت
Dialogue: 0,0:17:22.47,0:17:26.19,main,MERCHANT D,0000,0000,0000,,في تلك الحالة، لدينا بضاعة \N.خاصّة لتلقي نظرة عليها
Dialogue: 0,0:17:26.19,0:17:29.23,main,CUSTOMER B,0000,0000,0000,,.فعلاً؟ كم هذا حماسيّ
Dialogue: 0,0:17:29.23,0:17:32.17,main,MERCHANT D,0000,0000,0000,,.واثق أنّهم سينالون استحسانك
Dialogue: 0,0:17:37.70,0:17:39.29,italics,EINAR,0000,0000,0000,,.معهم حقّ
Dialogue: 0,0:17:40.42,0:17:44.22,italics,EINAR,0000,0000,0000,,حتّى إن هربت بدون التّفكير \N.في العواقب، أجهل أين أذهب
Dialogue: 0,0:17:45.89,0:17:46.90,italics,EINAR,0000,0000,0000,,...إضافة لذلك
Dialogue: 0,0:17:50.40,0:17:55.32,italics,EINAR,0000,0000,0000,,.ما عاد لي مكان أعود إليه
Dialogue: 0,0:17:57.51,0:18:02.31,italics,EINAR,0000,0000,0000,,...ما دمتُ سأخدم سيّدًا ما في مكان ما بكلّ طاعة
Dialogue: 0,0:18:04.55,0:18:08.28,main,MERCHANT A,0000,0000,0000,,.إنّك محظوظ بالفعل
Dialogue: 0,0:18:08.28,0:18:10.52,main,MERCHANT A,0000,0000,0000,,.وصلتنا دفعة كبيرة للتّوّ
Dialogue: 0,0:18:10.52,0:18:11.86,main,MERCHANT A,0000,0000,0000,,.انظر، هذا هو
Dialogue: 0,0:18:14.23,0:18:16.49,main,MERCHANT A,0000,0000,0000,,أليس هذا ما تبحث عنه؟
Dialogue: 0,0:18:42.93,0:18:45.47,main,LEIF,0000,0000,0000,,!إنّه لا يبدو مثله على الإطلاق
Dialogue: 0,0:18:45.47,0:18:47.77,main,LEIF,0000,0000,0000,,!إنّه ليس أشقر ولا قصير
Dialogue: 0,0:18:47.77,0:18:51.06,main,MERCHANT A,0000,0000,0000,,،ماذا؟ بعد أن أمعنت النّظر فيه الآن\N.أفترض أنّه ليس هو
Dialogue: 0,0:18:51.48,0:18:54.08,main,MERCHANT A,0000,0000,0000,,انس ذلك، ما رأيك فيه؟
Dialogue: 0,0:18:54.08,0:18:56.56,main,MERCHANT A,0000,0000,0000,,—إنّه قويّ وشديد. إن اشتريتَه الآن
Dialogue: 0,0:18:56.56,0:19:00.95,main,LEIF,0000,0000,0000,,.أخبرتك أنّني لستُ هنا لشراء عامل
Dialogue: 0,0:19:01.36,0:19:04.03,main,LEIF,0000,0000,0000,,.كلّ ما أريده هو أن أحرّر قريبي
Dialogue: 0,0:19:04.03,0:19:07.45,main,LEIF,0000,0000,0000,,.أنا واثق أنّه أتى لهذه البلدة
Dialogue: 0,0:19:07.83,0:19:09.77,main,LEIF,0000,0000,0000,,...إنّه أشقر وقصير
Dialogue: 0,0:19:09.77,0:19:11.24,main,LEIF,0000,0000,0000,,.اسمه ثورفين
Dialogue: 0,0:19:11.24,0:19:14.34,main,LEIF,0000,0000,0000,,ألا فكرة لديك أين هو بالفعل؟
Dialogue: 0,0:19:21.89,0:19:23.31,main,LEIF,0000,0000,0000,,.أنا آسف
Dialogue: 0,0:19:26.11,0:19:27.40,main,LEIF,0000,0000,0000,,.وآسف لأنّني أزعجتك
Dialogue: 0,0:19:27.40,0:19:30.44,main,MERCHANT A,0000,0000,0000,,.لا مشكلة. تعال إلينا ثانية
Dialogue: 0,0:19:32.77,0:19:34.74,main,MERCHANT A,0000,0000,0000,,.لن يجده أبدًا
Dialogue: 0,0:19:37.68,0:19:42.25,italics,EINAR,0000,0000,0000,,.إذًا فهو يجول الأرجاء باحثًا عن قريبه
Dialogue: 0,0:19:45.83,0:19:50.34,italics,EINAR,0000,0000,0000,,.محظوظ مَن يبحث عنه كائنًا من كان
Dialogue: 0,0:19:55.12,0:19:56.49,main,KETIL,0000,0000,0000,,.أنت هناك
Dialogue: 0,0:20:01.20,0:20:04.73,main,KETIL,0000,0000,0000,,.أيمكنك الكلام؟ دعني أرى أسنانك
Dialogue: 0,0:20:18.27,0:20:19.50,main,KETIL,0000,0000,0000,,ما اسمك؟
Dialogue: 0,0:20:19.93,0:20:21.76,main,EINAR,0000,0000,0000,,.اسمي إينار
Dialogue: 0,0:20:21.76,0:20:24.14,main,KETIL,0000,0000,0000,,من أين أنت؟ وماذا كنت تعمل؟
Dialogue: 0,0:20:24.57,0:20:26.80,main,EINAR,0000,0000,0000,,.أنا مزارع من شمال إنجلترا
Dialogue: 0,0:20:27.42,0:20:28.68,main,KETIL,0000,0000,0000,,فعلاً؟
Dialogue: 0,0:20:37.32,0:20:39.00,main,KETIL,0000,0000,0000,,ما قولك يا إينار؟
Dialogue: 0,0:20:39.00,0:20:41.42,main,KETIL,0000,0000,0000,,أتودّ تقديم يد العون في مزرعتي؟
Dialogue: 0,0:20:49.48,0:20:50.90,main,EINAR,0000,0000,0000,,...مزرعة
Dialogue: 0,0:21:14.21,0:21:16.33,main,KETIL,0000,0000,0000,,.إينار، مِن هنا
Dialogue: 0,0:21:20.61,0:21:22.91,main,KETIL,0000,0000,0000,,.كلّ أفراد عائلتي يعملون الآن
Dialogue: 0,0:21:22.91,0:21:25.90,main,KETIL,0000,0000,0000,,.سأعرّفك إليهم وقت العشاء
Dialogue: 0,0:21:25.90,0:21:26.92,main,EINAR,0000,0000,0000,,.حاضر
Dialogue: 0,0:21:28.37,0:21:31.08,main,KETIL,0000,0000,0000,,.ولكن أوّلاً، أمعن النّظر لمزرعتي
Dialogue: 0,0:22:02.58,0:22:07.11,italics,EINAR,0000,0000,0000,,يا أمّي. أذلك صحيح حقًّا؟
Dialogue: 0,0:22:09.52,0:22:14.73,italics,EINAR,0000,0000,0000,,.سواء عشت أو متّ، فلن أصير حرًّا أبدًا
Dialogue: 0,0:22:16.43,0:22:21.18,italics,EINAR,0000,0000,0000,,أما زلت تظنّين أنّني لم أخسر بعد؟
Dialogue: 0,0:22:45.32,0:22:46.98,italics,EINAR,0000,0000,0000,,.سُلبت منّي عائلتي
Dialogue: 0,0:22:47.52,0:22:50.94,italics,EINAR,0000,0000,0000,,.فقدت دياري. فقدت كلّ شيء
Dialogue: 0,0:22:52.79,0:22:56.81,italics,EINAR,0000,0000,0000,,.لم أعد أعلم حتّى ما الغاية من العيش
Dialogue: 0,0:23:05.94,0:23:09.32,main,KETIL,0000,0000,0000,,.ثورفين، هذا أنا. تعال
Dialogue: 0,0:23:25.48,0:23:30.78,italics,EINAR,0000,0000,0000,,".سيشتريني سيّد جيّد وسأبذل جهدي في خدمته"
Dialogue: 0,0:23:32.40,0:23:36.04,italics,EINAR,0000,0000,0000,,".لن أجوع ما دمت عبدًا مطيعًا"
Dialogue: 0,0:23:37.64,0:23:40.70,italics,EINAR,0000,0000,0000,,.كنت قد بدأت أفكّر بتلك الطّريقة
Dialogue: 0,0:23:41.12,0:23:42.62,main,EINAR,0000,0000,0000,,...ثورفين
Dialogue: 0,0:23:54.77,0:23:55.99,italics,EINAR,0000,0000,0000,,...وهكذا
Dialogue: 0,0:23:58.21,0:24:03.10,italics,EINAR,0000,0000,0000,,.التقينا أنا وثورفين
