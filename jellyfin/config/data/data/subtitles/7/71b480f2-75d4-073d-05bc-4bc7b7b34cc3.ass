Dialogue: 0,0:00:00.00,0:00:02.98,Default,,0,0,0,,(ตอนที่ 48 โทษประหาร)
Dialogue: 0,0:03:38.07,0:03:41.95,Default,,0,0,0,,(มหาเวทผนึกมาร)
Dialogue: 0,0:03:41.95,0:03:43.99,Default,,0,0,0,,(จรดลล้างบาง)
Dialogue: 0,0:04:18.55,0:04:22.60,Default,,0,0,0,,(มหาเวทผนึกมาร จรดลล้างบาง พาร์ต 1)
Dialogue: 0,0:05:15.88,0:05:17.98,Default,,0,0,0,,แล้ว... ตายรึยังล่ะ
Dialogue: 0,0:05:18.51,0:05:19.42,Default,,0,0,0,,มาอิจังน่ะ
Dialogue: 0,0:05:20.86,0:05:23.10,Default,,0,0,0,,ตอนนี้ควรเป็นห่วงท่านเจ้าบ้านก่อน
Dialogue: 0,0:05:23.44,0:05:25.67,Default,,0,0,0,,อีกอย่างคนที่ปางตายคือมากิค่ะ
Dialogue: 0,0:05:25.88,0:05:28.33,Default,,0,0,0,,เอ้าเหรอ งั้นก็ช่างเหอะ
Dialogue: 0,0:05:28.68,0:05:31.32,Default,,0,0,0,,ถึงจะงามหยดย้อย\Nแต่มากิจังนี่บ่ไหวจะเคลียร์
Dialogue: 0,0:05:31.68,0:05:33.60,Default,,0,0,0,,แม่นั่นไม่รู้จักวิธีเชิดชูผู้ชาย
Dialogue: 0,0:05:33.87,0:05:37.63,Default,,0,0,0,,ผู้หญิงที่เป็นช้างเท้าหลังไม่ได้\Nโดนแทงหลังให้ซี้แหง๋แก๋ไปซะก็ดี
Dialogue: 0,0:05:38.69,0:05:41.45,Default,,0,0,0,,จุดนั้นมาอิจังยังดีกว่าอีก
Dialogue: 0,0:05:41.45,0:05:43.82,Default,,0,0,0,,(ผู้ใช้คุณไสยระดับ 1 พิเศษ เซ็นอิง นาโอยะ)
Dialogue: 0,0:05:44.36,0:05:47.40,Default,,0,0,0,,ถึงเบ้าหน้ากับเบ้านมจะเหมือนมากิจัง
Dialogue: 0,0:05:47.70,0:05:51.56,Default,,0,0,0,,และทำเป็นเก่งแค่ไหนแต่ในใจลึก ๆ\Nก็ยังสำเหนียกว่าตัวเองเป็นผู้หญิง
Dialogue: 0,0:05:52.70,0:05:53.70,Default,,0,0,0,,มาช้ามาก
Dialogue: 0,0:05:54.30,0:05:55.68,Default,,0,0,0,,มัวทำบ้าอะไรอยู่
Dialogue: 0,0:05:55.90,0:05:59.31,Default,,0,0,0,,พ่อบังเกิดเกล้าของแกกำลังจะสิ้นใจแล้วนะ
Dialogue: 0,0:05:59.56,0:06:00.83,Default,,0,0,0,,ขอโทษจ้า
Dialogue: 0,0:06:01.12,0:06:04.28,Default,,0,0,0,,แต่ผมจะมาหรือไม่มาก็ไม่เห็นเป็นไรนี่
Dialogue: 0,0:06:04.67,0:06:07.67,Default,,0,0,0,,ก็เจ้าบ้านตระกูลเซ็นอิงคนต่อไปคือผมนี่นา
Dialogue: 0,0:06:08.68,0:06:11.68,Default,,0,0,0,,พี่ ๆ ของผมก็มีแต่พวกซังกะบ๊วย
Dialogue: 0,0:06:12.73,0:06:13.47,Default,,0,0,0,,คุณอา...
Dialogue: 0,0:06:13.80,0:06:17.90,Default,,0,0,0,,ขนาดอาที่เป็นน้องชายยังไม่เห็นมีทีเด็ด\Nยิ่งลูกสาวนี่ไม่ต้องพูดถึงเลย
Dialogue: 0,0:06:18.69,0:06:20.69,Default,,0,0,0,,ส่วนจินอิจิคุงเนี่ย...
Dialogue: 0,0:06:22.69,0:06:24.69,Default,,0,0,0,,หน้าอย่างกับหมีควาย
Dialogue: 0,0:06:25.02,0:06:27.47,Default,,0,0,0,,ถ้าสลับหน้ากับโทจิคุง\Nก็หล่อลากไส้ไปแล้วแท้ ๆ
Dialogue: 0,0:06:31.12,0:06:33.87,Default,,0,0,0,,(ผู้ใช้คุณไสยระดับ 1 พิเศษ เซ็นอิง โองิ)
Dialogue: 0,0:06:33.87,0:06:35.47,Default,,0,0,0,,(ผู้ใช้คุณไสยระดับ 1 พิเศษ เซ็นอิง จินอิจิ)
Dialogue: 0,0:06:35.47,0:06:38.10,Default,,0,0,0,,เตี่ยแกกำลังเข้าตรีทูตแล้วนะ\N(ผู้ใช้คุณไสยระดับ 1 พิเศษ เซ็นอิง จินอิจิ)
Dialogue: 0,0:06:38.10,0:06:39.99,Default,,0,0,0,,หัดใจเย็นกันหน่อยเหอะ
Dialogue: 0,0:06:40.99,0:06:42.92,Default,,0,0,0,,ทุกท่านมาครบแล้วสินะครับ
Dialogue: 0,0:06:45.40,0:06:51.84,Default,,0,0,0,,เมื่อครู่นี้ เจ้าบ้านตระกูลเซ็นอิง\Nท่านเซ็นอิง นาโอบิโตะได้ถึงแก่กรรมแล้ว
Dialogue: 0,0:06:55.68,0:06:59.96,Default,,0,0,0,,กระผม ฟุรุดาเตะ เป็นผู้รับฝาก\Nพินัยกรรมฉบับนี้ไว้ครับ
Dialogue: 0,0:07:00.20,0:07:03.69,Default,,0,0,0,,โดยเนื้อหาของพินัยกรรม\Nตามเจตนารมณ์ของท่านเซ็นอิง นาโอบิโตะ...
Dialogue: 0,0:07:04.27,0:07:05.84,Default,,0,0,0,,ท่านเซ็นอิง โองิ
Dialogue: 0,0:07:06.44,0:07:08.27,Default,,0,0,0,,ท่านเซ็นอิง จินอิจิ
Dialogue: 0,0:07:08.69,0:07:10.70,Default,,0,0,0,,ท่านเซ็นอิง นาโอยะ
Dialogue: 0,0:07:11.50,0:07:16.70,Default,,0,0,0,,เมื่อท่านทั้งสามมาอยู่พร้อมหน้ากัน\Nกระผมจึงจะเรียนให้ทราบครับ
Dialogue: 0,0:07:17.70,0:07:21.67,Default,,0,0,0,,หากไม่มีใครโต้แย้ง กระผมจะ\Nขออ่านให้ทุกท่านฟัง ณ บัดนี้
Dialogue: 0,0:07:28.67,0:07:29.67,Default,,0,0,0,,ประการแรก
Dialogue: 0,0:07:29.67,0:07:34.20,Default,,0,0,0,,แต่งตั้งให้เซ็นอิง นาโอยะเป็น\Nเจ้าบ้านตระกูลเซ็นอิงรุ่นที่ 27
Dialogue: 0,0:07:35.00,0:07:36.09,Default,,0,0,0,,อีกหนึ่งประการ
Dialogue: 0,0:07:36.48,0:07:41.69,Default,,0,0,0,,เครื่องมือไสยเวททุกชิ้นในหอสมบัติ\Nของโรงเรียนไสยเวทและตระกูลเซ็นอิง
Dialogue: 0,0:07:41.69,0:07:44.69,Default,,0,0,0,,รวมถึงทรัพย์สินทั้งหมด\Nจะมีนาโอยะเป็นผู้รับช่วงต่อ
Dialogue: 0,0:07:45.44,0:07:50.69,Default,,0,0,0,,นาโอยะจะนำใช้ทรัพย์สินดังกล่าวไปใช้ได้\Nต่อเมื่อได้รับความเห็นชอบจากเซ็นอิง โองิ...
Dialogue: 0,0:07:51.36,0:07:54.70,Default,,0,0,0,,หรือจากเซ็นอิง จินอิจิ\Nเพียงสองท่านเท่านั้น
Dialogue: 0,0:07:55.85,0:07:57.42,Default,,0,0,0,,ช่างแม่มเหอะ
Dialogue: 0,0:07:57.74,0:07:58.70,Default,,0,0,0,,เพียงแต่ว่า...
Dialogue: 0,0:07:59.31,0:08:02.49,Default,,0,0,0,,หากโกะโจ ซาโตรุเสียชีวิต
Dialogue: 0,0:08:02.66,0:08:06.27,Default,,0,0,0,,หรือสูญเสียความสามารถในการตัดสินใจ
Dialogue: 0,0:08:06.52,0:08:09.77,Default,,0,0,0,,ให้ทำตามหนังสือสัญญาที่ทำไว้กับฟุชิงุโระ โทจิ
Dialogue: 0,0:08:10.22,0:08:13.28,Default,,0,0,0,,โดยรับตัวฟุชิงุโระ เมงุมิ\Nเข้ามาเป็นสมาชิกตระกูลเซ็นอิง
Dialogue: 0,0:08:13.34,0:08:15.90,Default,,0,0,0,,และแต่งตั้งเป็นเจ้าบ้านตระกูลเซ็นอิง
Dialogue: 0,0:08:16.68,0:08:19.71,Default,,0,0,0,,รวมถึงยกทรัพย์สินทั้งหมดให้แก่ผู้นั้น
Dialogue: 0,0:08:21.71,0:08:22.65,Default,,0,0,0,,หา
Dialogue: 0,0:08:22.84,0:08:25.98,Default,,0,0,0,,ไม่ไหวจะเคลียร์จริง ๆ ว่ะ\Nไอ้สองตัวนั้นก็ใจตุ๊ดฉิบเป๋ง
Dialogue: 0,0:08:26.51,0:08:28.64,Default,,0,0,0,,คิดว่าให้เด็กไม่รู้จักหัวนอน\Nปลายเท้ามาเป็นเจ้าบ้าน...
Dialogue: 0,0:08:28.81,0:08:31.23,Default,,0,0,0,,ยังดีกว่าฉันตั้งเยอะ\Nเลยไม่ทำห่านอะไรสักอย่าง
Dialogue: 0,0:08:32.69,0:08:35.23,Default,,0,0,0,,ตอนนี้เมงุมิคุงทำอะไรอยู่ที่ไหน
Dialogue: 0,0:08:35.70,0:08:36.70,Default,,0,0,0,,ยังไม่ทราบแน่ชัด
Dialogue: 0,0:08:37.08,0:08:40.89,Default,,0,0,0,,แต่เห็นว่ารับหน้าที่ค้นหาตัว\Nอิตาโดริ ยูจิอยู่ที่โตเกียว...
Dialogue: 0,0:08:40.99,0:08:41.70,Default,,0,0,0,,ใครอีกวะนั่น
Dialogue: 0,0:08:42.48,0:08:44.46,Default,,0,0,0,,ภาชนะของสุคุนะค่ะ
Dialogue: 0,0:08:44.72,0:08:46.67,Default,,0,0,0,,งั้นฝากไปแจ้งเบื้องบนที
Dialogue: 0,0:08:46.99,0:08:49.67,Default,,0,0,0,,ว่าเซ็นอิง นาโอยะ\Nจะฆ่าภาชนะของสุคุนะเอง
Dialogue: 0,0:08:50.49,0:08:53.23,Default,,0,0,0,,เมงุมิคุงอยู่กับภาชนะของสุคุนะใช่ไหม
Dialogue: 0,0:08:53.85,0:08:55.71,Default,,0,0,0,,พ่อจะได้เชือดนิ่ม ๆ แพ็กคู่ไปเลย
Dialogue: 0,0:08:56.65,0:08:58.60,Default,,0,0,0,,โตเกียวในตอนนี้เป็นแดนอสุราไปแล้ว
Dialogue: 0,0:08:58.73,0:09:01.68,Default,,0,0,0,,จะมีคนตายตอนไหนหรือตายยังไง\Nก็ไม่มีหมาตัวไหนมาสนหรอก
Dialogue: 0,0:09:02.68,0:09:05.82,Default,,0,0,0,,ฆ่าให้เรียบก่อน\Nแล้วอย่างอื่นค่อยมาว่ากันทีหลัง
Dialogue: 0,0:09:09.42,0:09:11.56,Default,,0,0,0,,เจ้าบ้านตระกูลเซ็นอิงคือฉัน
Dialogue: 0,0:09:21.70,0:09:22.48,Default,,0,0,0,,ไปตายซะ...
Dialogue: 0,0:09:23.48,0:09:24.66,Default,,0,0,0,,- คุกิซากิ\N- ไปตายคนเดียวเลยไป
Dialogue: 0,0:09:24.66,0:09:25.42,Default,,0,0,0,,- ไปตายซะ\N- ผมฝากที่เหลือด้วยนะครับ
Dialogue: 0,0:09:25.45,0:09:27.31,Default,,0,0,0,,- อิตาโดริ\N- อิตาโดริคุง...
Dialogue: 0,0:09:27.52,0:09:28.55,Default,,0,0,0,,แล้วนายจะเอาไงต่อ
Dialogue: 0,0:09:53.60,0:09:54.30,Default,,0,0,0,,ยูจิ
Dialogue: 0,0:09:56.00,0:09:57.70,Default,,0,0,0,,บาดแผลเป็นยังไงบ้าง
Dialogue: 0,0:09:58.91,0:10:02.80,Default,,0,0,0,,นอกจากตรงที่โดน\Nประกายทมิฬแล้ว... ก็สบายดี
Dialogue: 0,0:10:04.16,0:10:06.28,Default,,0,0,0,,คงเป็นอิทธิพลจากสุคุนะนั่นละ
Dialogue: 0,0:10:06.80,0:10:09.36,Default,,0,0,0,,รู้สึกได้เลยว่าพลังของ\Nหมอนั่นกำลังกล้าแกร่งขึ้น
Dialogue: 0,0:10:10.86,0:10:11.55,Default,,0,0,0,,ยูจิ
Dialogue: 0,0:10:11.93,0:10:13.48,Default,,0,0,0,,ไม่ต้องเกรงใจฉันก็ได้
Dialogue: 0,0:10:13.90,0:10:15.58,Default,,0,0,0,,กลับไปที่โรงเรียนไสยเวทเถอะ
Dialogue: 0,0:10:16.40,0:10:19.77,Default,,0,0,0,,ฉันเองก็อยากไปเก็บรวบรวม\Nร่างของพวกโชโซเหมือนกันด้วย
Dialogue: 0,0:10:21.21,0:10:22.68,Default,,0,0,0,,ไม่ได้เกรงใจสักหน่อย
Dialogue: 0,0:10:23.26,0:10:25.85,Default,,0,0,0,,ฉันอยากกลับหรือไม่อยาก\Nมันไม่ใช่ประเด็นหลักหรอก
Dialogue: 0,0:10:26.84,0:10:29.69,Default,,0,0,0,,สุคุนะกำลังวางแผนใช้\Nฟุชิงุโระทำอะไรบางอย่างอยู่
Dialogue: 0,0:10:30.62,0:10:32.00,Default,,0,0,0,,แล้วอีกอย่าง...
Dialogue: 0,0:10:32.36,0:10:34.28,Default,,0,0,0,,ฉันฆ่าคนไปตั้งมากมายเลยนะ
Dialogue: 0,0:10:34.69,0:10:39.02,Default,,0,0,0,,ถ้าเกิดคนที่ตัวเองช่วยกลายเป็นคนที่\Nฆ่าคนอื่นในอนาคต นายจะทำยังไง
Dialogue: 0,0:10:40.08,0:10:43.13,Default,,0,0,0,,ฉันไม่มีหน้าไปอยูู่กับทุกคนอีกแล้ว
Dialogue: 0,0:10:43.98,0:10:45.53,Default,,0,0,0,,แล้วโจโซไม่ติดใจเหรอ
Dialogue: 0,0:10:45.80,0:10:47.79,Default,,0,0,0,,ฉันฆ่าน้องชายนายเลยนะ
Dialogue: 0,0:10:48.20,0:10:50.19,Default,,0,0,0,,ไม่เป็นไร มันเป็นอุบัติเหตุ
Dialogue: 0,0:10:50.67,0:10:54.77,Default,,0,0,0,,ถ้าเอโซและเคจิซุอยู่จุดเดียวกับฉัน\Nก็คงทำไม่ต่างจากที่ฉันทำหรอก
Dialogue: 0,0:10:55.13,0:10:57.36,Default,,0,0,0,,มันไม่ใช่เรื่องของการให้หรือไม่ให้อภัย
Dialogue: 0,0:10:57.76,0:10:59.72,Default,,0,0,0,,พี่น้องมันก็เป็นแบบนั้นแหละ
Dialogue: 0,0:11:03.21,0:11:04.04,Default,,0,0,0,,ไปกันเถอะ
Dialogue: 0,0:11:04.68,0:11:06.68,Default,,0,0,0,,ตอนนี้ต้องลดจำนวนวิญญาณคำสาปให้ได้ก่อน
Dialogue: 0,0:12:59.50,0:13:00.67,Default,,0,0,0,,โจโซ
Dialogue: 0,0:13:07.93,0:13:08.64,Default,,0,0,0,,ยูจิ
Dialogue: 0,0:13:21.20,0:13:22.94,Default,,0,0,0,,น่าทึ่งจริง ๆ
Dialogue: 0,0:13:23.37,0:13:26.40,Default,,0,0,0,,ตอนสู้กับเรายังมีภาพลักษณ์\Nเป็นพวกบ้าพลังอยู่เลย
Dialogue: 0,0:13:26.70,0:13:29.23,Default,,0,0,0,,แต่ตอนนี้กลับเพิ่ม\Nความละเอียดอ่อนเข้ามาด้วย
Dialogue: 0,0:13:29.52,0:13:33.29,Default,,0,0,0,,ควบคุมพลังไสยเวทลื่นไหลไม่มีสะดุด\Nพลังทางกายภาพที่เหนือชั้นไปอีกขั้น
Dialogue: 0,0:13:35.82,0:13:37.55,Default,,0,0,0,,เป็นเทพอสูรอย่างแท้จริง
Dialogue: 0,0:13:37.93,0:13:41.02,Default,,0,0,0,,เพราะนี่ยังฟื้นตัวไม่เต็มร้อยด้วยซ้ำ
Dialogue: 0,0:13:42.57,0:13:45.02,Default,,0,0,0,,สมกับเป็นน้องชายฉันจริง ๆ
Dialogue: 0,0:13:45.32,0:13:46.73,Default,,0,0,0,,ยังพูดแบบนั้นอยู่อีกเหรอ
Dialogue: 0,0:13:47.87,0:13:49.21,Default,,0,0,0,,จะอีกกี่ครั้งฉันก็จะพูด
Dialogue: 0,0:13:49.88,0:13:51.00,Default,,0,0,0,,นึกให้ออกสิ
Dialogue: 0,0:13:51.16,0:13:52.76,Default,,0,0,0,,มันต้องมีเหมือนกันแน่
Dialogue: 0,0:13:56.00,0:13:59.21,Default,,0,0,0,,รอยเย็บบนหน้าผากพ่อนายน่ะ
Dialogue: 0,0:14:01.76,0:14:03.50,Default,,0,0,0,,เมงุมิคุงไม่อยู่นี่หว่า
Dialogue: 0,0:14:04.06,0:14:07.82,Default,,0,0,0,,นี่ฉันมาถึงคนแรกเหรอ\Nเป็นไปได้ไงเนี่ย บ่ฮีบฟ้าวกันเล๊ย
Dialogue: 0,0:14:08.70,0:14:09.84,Default,,0,0,0,,หมอนี่ใครเนี่ย
Dialogue: 0,0:14:10.59,0:14:12.32,Default,,0,0,0,,เมื่อกี้พูดถึงฟุชิงุโระงั้นเหรอ
Dialogue: 0,0:14:12.84,0:14:14.40,Default,,0,0,0,,พวกนายเฮ็ดอิหยังกันเนี่ย
Dialogue: 0,0:14:14.70,0:14:17.23,Default,,0,0,0,,มันเด่นไปนะ บ่คิดหนีกันเลยรึไง
Dialogue: 0,0:14:17.82,0:14:18.72,Default,,0,0,0,,หนีเหรอ
Dialogue: 0,0:14:19.12,0:14:20.79,Default,,0,0,0,,อิหยังเนี่ย นี่บ่ฮูู้หรอกรึ
Dialogue: 0,0:14:21.28,0:14:23.05,Default,,0,0,0,,นายโดนโทษประหารแล้วนา
Dialogue: 0,0:14:23.67,0:14:26.12,Default,,0,0,0,,เพราะซาโตรุคุงที่เป็น\Nไม้กันหมาไม่อยู่แล้วอะนะ
Dialogue: 0,0:14:29.00,0:14:34.32,Default,,0,0,0,,การแก้ปัญหาเฉพาะหน้า (ความเอาแต่ใจ)\Nของคุณโกโจช่วยผู้ใช้คุณไสยเอาไว้เพียบ
Dialogue: 0,0:14:34.68,0:14:36.94,Default,,0,0,0,,ฉันมีธุระกับเมงุมิคุงคนเดียว
Dialogue: 0,0:14:37.04,0:14:39.82,Default,,0,0,0,,เว่ากันซื่อ ๆ นายจะอยู่หรือตายฉันก็บ่สน
Dialogue: 0,0:14:40.20,0:14:44.86,Default,,0,0,0,,แต่จะให้มาเป็นก้างขวางคอก็ยังไงอยู่\Nเดี๋ยวหักขาเผื่อไว้ก่อนสักข้างแล้วกัน
Dialogue: 0,0:14:45.31,0:14:47.26,Default,,0,0,0,,มีธุระอะไรกับฟุชิงุโระมิทราบ
Dialogue: 0,0:14:47.63,0:14:49.48,Default,,0,0,0,,อยากให้ตาย ๆ ไปซะน่ะ
Dialogue: 0,0:14:49.84,0:14:52.99,Default,,0,0,0,,ถ้าเขียนอะไรไว้ให้\Nก่อนตายด้วยจะดีมากเลยละ
Dialogue: 0,0:14:53.37,0:14:55.82,Default,,0,0,0,,เมงุมิคุงหาตัวนายอยู่แม่นบ่
Dialogue: 0,0:15:16.68,0:15:19.44,Default,,0,0,0,,จะว่าเร็วก็เร็วแหละ แต่มันแปลก ๆ นะ
Dialogue: 0,0:15:19.90,0:15:21.23,Default,,0,0,0,,คงเป็นอาคมนั่นแหละ
Dialogue: 0,0:15:21.69,0:15:23.69,Default,,0,0,0,,เอาเรื่องกว่าที่คิดอีกนะเนี่ย
Dialogue: 0,0:15:24.14,0:15:26.01,Default,,0,0,0,,เอาเข้าจริงฉันคงดูถูกพวกนายไปหน่อย
Dialogue: 0,0:15:26.69,0:15:30.48,Default,,0,0,0,,ภาชนะเรายังพอเข้าใจได้\Nแต่ไอ้คนข้าง ๆ นี่ใครกัน
Dialogue: 0,0:15:30.89,0:15:33.15,Default,,0,0,0,,ลองเร่งความเร็วอีกหน่อยแล้วกัน
Dialogue: 0,0:15:39.53,0:15:41.10,Default,,0,0,0,,อาจารย์โกโจ...
Dialogue: 0,0:15:41.10,0:15:43.61,Default,,0,0,0,,ไม่ใช่ มันน่าขนลุกกว่านั้น...
Dialogue: 0,0:15:50.89,0:15:53.74,Default,,0,0,0,,อ้าว ไม่ได้อยู่คนเดียวเหรอเนี่ย
Dialogue: 0,0:15:56.97,0:15:58.93,Default,,0,0,0,,(มหาเวทผนึกมาร)
Dialogue: 0,0:16:00.02,0:16:00.76,Default,,0,0,0,,ใครน่ะ
Dialogue: 0,0:16:00.96,0:16:02.82,Default,,0,0,0,,จะเป็นใครก็ช่าง เพราะเป้าหมายคือ...
Dialogue: 0,0:16:03.02,0:16:05.92,Default,,0,0,0,,ใครเป็นอะไรกับอิตาโดริคุงบ้างเนี่ย
Dialogue: 0,0:16:06.70,0:16:09.08,Default,,0,0,0,,เป็นเพชฌฆาตประหารยูจิจริงด้วยสินะ
Dialogue: 0,0:16:17.95,0:16:20.48,Default,,0,0,0,,ช้าก่อนพวก เราพวกเดียวกันนะ
Dialogue: 0,0:16:20.96,0:16:22.57,Default,,0,0,0,,นายคืออคคตสึคุงแม่นบ่
Dialogue: 0,0:16:22.99,0:16:23.84,Default,,0,0,0,,อคคตสึ...
Dialogue: 0,0:16:24.19,0:16:26.04,Default,,0,0,0,,เด็กปีสองที่ฟุชิงุโระพูดถึง...
Dialogue: 0,0:16:26.40,0:16:29.20,Default,,0,0,0,,ผู้ใช้คุณไสยระดับพิเศษ\Nเหมือนอาจารย์โกโจ
Dialogue: 0,0:16:29.85,0:16:30.81,Default,,0,0,0,,คุณเป็นใคร
Dialogue: 0,0:16:31.01,0:16:33.88,Default,,0,0,0,,เซ็นอิง นาโอยะ ลูกพี่ลูกน้องของมากิจังน่ะ
Dialogue: 0,0:16:34.22,0:16:37.00,Default,,0,0,0,,ฉันก็โดนสั่งให้มาฆ่า\Nอิตาโดริคุงเหมือนนายนั่นแหละ
Dialogue: 0,0:16:37.00,0:16:38.18,Default,,0,0,0,,รีบหนีไป ยูจิ
Dialogue: 0,0:16:38.18,0:16:38.99,Default,,0,0,0,,สบายใจได้
Dialogue: 0,0:16:38.99,0:16:39.66,Default,,0,0,0,,หา
Dialogue: 0,0:16:39.66,0:16:41.25,Default,,0,0,0,,ฉันไม่ขวางนายหรอกน่า
Dialogue: 0,0:16:41.47,0:16:43.63,Default,,0,0,0,,ไอ้ผมมัทฉะเป็นพวกเน้นความเร็ว
Dialogue: 0,0:16:44.06,0:16:46.02,Default,,0,0,0,,เราเล่นวิ่งไล่จับกับมันไม่ไหวหรอก
Dialogue: 0,0:16:46.40,0:16:47.85,Default,,0,0,0,,ฉันจะหาทางรั้งไว้เอง
Dialogue: 0,0:16:48.17,0:16:49.13,Default,,0,0,0,,ไหวแน่ใช่ไหมเนี่ย
Dialogue: 0,0:16:49.42,0:16:55.29,Default,,0,0,0,,เพื่อเป็นการแลกเปลี่ยน ถ้าฆ่าอิตาโดริคุงได้\Nก็อย่าเพิ่งไปบอกเบื้องบนสักพักได้ไหม
Dialogue: 0,0:16:55.29,0:16:57.86,Default,,0,0,0,,พอดีอยากใช้เขาเป็นเหยื่อ\Nล่อคนที่อยากเจอออกมาน่ะ
Dialogue: 0,0:16:57.86,0:17:01.35,Default,,0,0,0,,ฉันไหวอยู่แล้ว แต่คนที่\Nโดนหมายหัวมันนายนะ ยูจิ
Dialogue: 0,0:17:02.04,0:17:03.05,Default,,0,0,0,,หนีเจ้าผมดำ...
Dialogue: 0,0:17:03.48,0:17:05.76,Default,,0,0,0,,คิดแค่เรื่องหนีจากอคคตสึให้พ้นก็พอแล้ว
Dialogue: 0,0:17:06.33,0:17:08.56,Default,,0,0,0,,หมอนั่นเป็นประเภทเดียวกับโกโจ ซาโตรุ
Dialogue: 0,0:17:08.89,0:17:10.19,Default,,0,0,0,,ขืนสู้กับเขานายตายแน่
Dialogue: 0,0:17:10.70,0:17:14.81,Default,,0,0,0,,คิดถูกจริง ๆ ที่ไม่ได้พูดเรื่องเมงุมิคุง\Nเสียวสันหลังวาบเลยว่ะ
Dialogue: 0,0:17:15.01,0:17:20.22,Default,,0,0,0,,ข้อเสนอที่ทำให้ยูจิไม่ต้องสู้กับมนุษย์\Nและไม่ทำให้เรารูู้สึกว่าตัวเองด้อยกว่า
Dialogue: 0,0:17:21.31,0:17:22.80,Default,,0,0,0,,ต้องให้ดูแลอยู่เรื่อยจริง ๆ
Dialogue: 0,0:17:23.40,0:17:25.05,Default,,0,0,0,,ไว้เจอกันตรงที่เราเจอกันเมื่อวานนะ
Dialogue: 0,0:17:25.50,0:17:28.44,Default,,0,0,0,,เอาสิครับ งั้นฝากทางนั้นด้วยนะครับ
Dialogue: 0,0:17:28.62,0:17:29.24,Default,,0,0,0,,เออ
Dialogue: 0,0:17:32.03,0:17:32.91,Default,,0,0,0,,เร็วมาก...
Dialogue: 0,0:17:33.03,0:17:34.73,Default,,0,0,0,,ขนาดถือดาบอยู่ยังเร็วขนาดนี้เลยเรอะ
Dialogue: 0,0:17:36.60,0:17:37.71,Default,,0,0,0,,เร็วเอาเรื่องแฮะ
Dialogue: 0,0:17:37.95,0:17:39.96,Default,,0,0,0,,กะจะขยี้ให้ราบตั้งแต่ตอนออกตัวแท้ ๆ
Dialogue: 0,0:17:41.03,0:17:44.54,Default,,0,0,0,,โดนอ่านออกว่าจะขวางทางอคคตสึงั้นเรอะ
Dialogue: 0,0:17:45.04,0:17:46.62,Default,,0,0,0,,เมื่อกี้ฉันเห็นนะ
Dialogue: 0,0:17:46.97,0:17:48.88,Default,,0,0,0,,"วิชาควบคุมโลหิต" แม่นบ่
Dialogue: 0,0:17:49.28,0:17:52.25,Default,,0,0,0,,ก็บ่ฮู้หรอกนะว่านายใช้มันได้จังได๋
Dialogue: 0,0:17:52.46,0:17:55.01,Default,,0,0,0,,แต่นอกจาก "โลหิตทะลวง" แล้ว\Nก็บ่มีอิหยังให้ย่าน
Dialogue: 0,0:17:55.24,0:17:59.39,Default,,0,0,0,,แถมการใช้โลหิตทะลวงมันต้องใช้\N"ร้อยรวม" ก่อนซึ่งกินเวลาสุด ๆ
Dialogue: 0,0:17:59.64,0:18:04.02,Default,,0,0,0,,ที่เหลือบ่ต้องเว่าหรอกมั้ง รุกจนแล้ว\Nนายได้ซี้แหง๋แก๋แน่ขอบอก
Dialogue: 0,0:18:04.38,0:18:05.82,Default,,0,0,0,,แกต่างหาก...
Dialogue: 0,0:18:06.17,0:18:08.19,Default,,0,0,0,,คิดว่ามาลงไม้ลงมือกับน้องชายฉัน...
Dialogue: 0,0:18:08.54,0:18:11.07,Default,,0,0,0,,แล้วฉันจะปล่อยให้รอดกลับไปรึไง
Dialogue: 0,0:18:32.65,0:18:34.76,Default,,0,0,0,,นึกว่าฟันโดนแน่นอนแล้วซะอีก
Dialogue: 0,0:18:35.00,0:18:36.33,Default,,0,0,0,,เหมือนคุณมากิเลยแฮะ
Dialogue: 0,0:18:58.16,0:18:59.42,Default,,0,0,0,,ตกใจรึเปล่า
Dialogue: 0,0:19:00.03,0:19:02.03,Default,,0,0,0,,เพราะผมดูไม่เหมือนสายพละกำลังนี่นะ
Dialogue: 0,0:19:02.41,0:19:04.11,Default,,0,0,0,,ต่อให้ไม่มีพละกำลัง...
Dialogue: 0,0:19:04.67,0:19:06.76,Default,,0,0,0,,ปริมาณพลังไสยเวทเหลือล้นเกินไปอยู่ดี
Dialogue: 0,0:19:06.76,0:19:08.75,Default,,0,0,0,,ก็ดูทรงเป็นพวกแรงน้อยจริง ๆ แหละ
Dialogue: 0,0:19:09.10,0:19:11.90,Default,,0,0,0,,ดึงพลังไสยเวทมาเสริม\Nเพื่อชดเชยพละกำลังที่ขาดไป
Dialogue: 0,0:19:12.20,0:19:14.96,Default,,0,0,0,,ทุกคนทำได้หมดก็จริง\Nแต่พอคนคนนี้ทำแล้ว...
Dialogue: 0,0:19:15.48,0:19:17.18,Default,,0,0,0,,ตรงข้ามกับเราคนละขั้วเลยแฮะ
Dialogue: 0,0:19:19.52,0:19:20.73,Default,,0,0,0,,สังเกตรึเปล่า
Dialogue: 0,0:19:21.28,0:19:24.01,Default,,0,0,0,,ผมมีพลังไสยเวท\Nเยอะกว่าอาจารย์โกโจอีกนะ
Dialogue: 0,0:19:25.61,0:19:27.85,Default,,0,0,0,,แต่อาจารย์เขามี "เนตรทิพย์" อยู่กับตัว
Dialogue: 0,0:19:28.16,0:19:32.72,Default,,0,0,0,,การสูญเสียพลังงาน\Nตอนใช้อาคมจึงแทบจะเป็นศูนย์
Dialogue: 0,0:19:33.61,0:19:36.16,Default,,0,0,0,,ถ้าพูดเรื่องประสิทธิภาพแล้ว\Nยังไงอาจารย์ก็ยืนหนึ่ง
Dialogue: 0,0:19:37.03,0:19:40.75,Default,,0,0,0,,ถึงพลังไสยเวทของผมจะมีจำกัด\Nแต่พลังไสยเวทอาจารย์ไม่มีวันหมด
Dialogue: 0,0:19:42.03,0:19:43.80,Default,,0,0,0,,หมดเวลาพักคุยเล่นแล้ว
Dialogue: 0,0:19:49.52,0:19:50.26,Default,,0,0,0,,บัดซบ...
Dialogue: 0,0:19:50.26,0:19:54.28,Default,,0,0,0,,ยิ่งเป็นผู้ใช้คุณไสยระดับสูง\Nก็ยิ่งอ่านกระแสพลังไสยเวทได้ยาก
Dialogue: 0,0:19:54.28,0:19:56.18,Default,,0,0,0,,ด้วยเหตุผลที่แตกต่างจากนายน่ะนะ
Dialogue: 0,0:19:56.18,0:19:59.69,Default,,0,0,0,,ยิ่งระดับสูงเท่าไหร่ก็ยิ่งควบคุมได้แม่นยำขึ้น\N(หากไม่ชำนาญจะถูกอ่านพลังที่ไหลเอนออกได้)
Dialogue: 0,0:19:59.69,0:20:02.92,Default,,0,0,0,,ทำให้อ่านการโจมตีไม่ออกจนกว่าจะโจมตีเข้ามา\N(หากชำนาญแล้วพลังจะไม่ไหลจึงอ่านออกยาก)
Dialogue: 0,0:20:04.84,0:20:06.08,Default,,0,0,0,,แต่ว่าคนคนนี้...
Dialogue: 0,0:20:06.43,0:20:10.25,Default,,0,0,0,,ทั้งดาบและทั่วร่างมีพลังไสยเวท\Nเอ่อล้นออกมาตลอดเวลาเลย
Dialogue: 0,0:20:10.70,0:20:13.02,Default,,0,0,0,,ปัญหาไม่ได้อยู่ที่อ่านออกหรือไม่ออกแล้ว
Dialogue: 0,0:20:13.58,0:20:16.03,Default,,0,0,0,,ทุกการโจมตีสามารถเผด็จศึกได้หมด
Dialogue: 0,0:20:16.17,0:20:18.94,Default,,0,0,0,,แถมยังลดความเสียหายทั้งหมด\Nที่ได้รับให้เหลือน้อยที่สุดด้วย
Dialogue: 0,0:20:19.74,0:20:21.16,Default,,0,0,0,,ผมขอฝากที่เหลือด้วยนะครับ
Dialogue: 0,0:20:21.71,0:20:25.36,Default,,0,0,0,,โทษทีนะ แต่ผมยังตายตอนนี้ไม่ได้หรอก
Dialogue: 0,0:20:33.39,0:20:37.52,Default,,0,0,0,,ผมจะเน้นฝึกการใช้อาวุธเป็นหลักซึ่งก็\Nขึ้นอยู่กับประเภทของนักเรียนด้วยละนะ
Dialogue: 0,0:20:38.68,0:20:43.08,Default,,0,0,0,,แต่ถ้าพึ่งแต่เครื่องมือไสยเวทจนละเลย\Nการควบคุมพลังไสยเวทก็ไม่ดีด้วยสิ
Dialogue: 0,0:20:43.34,0:20:45.31,Default,,0,0,0,,สำหรับยูจิแล้วคงจะเร็วไปหน่อยละมั้ง
Dialogue: 0,0:20:46.83,0:20:48.44,Default,,0,0,0,,สะบั้นมารเอาไว้ใช้ตอนฉุกเฉินนะ
Dialogue: 0,0:20:50.01,0:20:51.74,Default,,0,0,0,,ยังไม่ทันได้เรียนเลยเหอะ
Dialogue: 0,0:20:53.58,0:20:54.59,Default,,0,0,0,,เพ่งสมาธิ...
Dialogue: 0,0:20:54.96,0:20:56.11,Default,,0,0,0,,จดจ่อที่ดาบเกินไป
Dialogue: 0,0:21:03.80,0:21:04.92,Default,,0,0,0,,โดนหักได้เหรอ
Dialogue: 0,0:21:05.55,0:21:08.88,Default,,0,0,0,,แต่ก็เข้าใจได้อยู่\Nเป็นถึงศิษย์อาจารย์โกโจเลยนี่นา
Dialogue: 0,0:21:08.88,0:21:10.79,Default,,0,0,0,,งานนี้คงไม่หวานหมูแล้วสินะ
Dialogue: 0,0:21:11.60,0:21:14.11,Default,,0,0,0,,แผลลึกมากแต่เครื่องในยังไม่ทะลักออกมา
Dialogue: 0,0:21:14.30,0:21:16.04,Default,,0,0,0,,เท่านี้ก็มือเปล่ากันทั้งคู่แล้ว
Dialogue: 0,0:21:16.19,0:21:17.04,Default,,0,0,0,,สู้ได้แน่
Dialogue: 0,0:21:22.48,0:21:25.61,Default,,0,0,0,,ทำอะไรกันอยู่เหรอ
Dialogue: 0,0:21:28.76,0:21:31.48,Default,,0,0,0,,แค่เล่นกันเฉย ๆ น่ะ ริกะจัง
Dialogue: 0,0:21:32.75,0:21:37.16,Default,,0,0,0,,ริกะ... เจ้านี่มันตัวอะไร\Nภูตรับใช้เหรอ โผล่มาจากไหนเนี่ย
Dialogue: 0,0:21:38.96,0:21:40.30,Default,,0,0,0,,ช่วยจับไว้ให้ทีนะ
Dialogue: 0,0:21:41.15,0:21:42.78,Default,,0,0,0,,ขยับไม่ได้...
Dialogue: 0,0:21:44.54,0:21:46.54,Default,,0,0,0,,แรงบ้าอะไรวะเนี่ย
Dialogue: 0,0:21:53.81,0:21:54.92,Default,,0,0,0,,ขอโทษนะ
Dialogue: 0,0:22:01.93,0:22:02.81,Default,,0,0,0,,อิตาโดริคุง
Dialogue: 0,0:23:40.54,0:23:42.94,Default,,0,0,0,,พี่ที่ห่วยแตกกว่าน้อง\Nจะอยู่ให้หนักแผ่นดินไปทำไม
Dialogue: 0,0:23:42.94,0:23:45.64,Default,,0,0,0,,ฉันไม่เข้าใจความรู้สึกของ\Nไอ้คนไม่รักพี่น้องอย่างแกหรอก
Dialogue: 0,0:23:45.64,0:23:46.64,Default,,0,0,0,,การตายของอิตาโดริคุง...
Dialogue: 0,0:23:46.64,0:23:49.54,Default,,0,0,0,,ความบิดเบี้ยวของทุกสิ่งทุกอย่าง\Nอาจจะเริ่มต้นมาจากตอนนั้นก็ได้
Dialogue: 0,0:23:49.54,0:23:50.54,Default,,0,0,0,,อย่ามามองเหยียดกันนะเว้ย...
Dialogue: 0,0:23:50.54,0:23:51.45,Default,,0,0,0,,เริ่มจากมาช่วยฉันก่อนเลย
Dialogue: 0,0:23:51.45,0:23:52.04,Default,,0,0,0,,รุกจนแล้ว
Dialogue: 0,0:23:52.04,0:23:54.28,Default,,0,0,0,,สึมิกิก็ถูกลากไปพัวพัน\Nในจรดลล้างบางเหมือนกัน
Dialogue: 0,0:23:54.28,0:23:55.00,Default,,0,0,0,,(ตอนต่อไป อีกหนึ่งครั้ง)

