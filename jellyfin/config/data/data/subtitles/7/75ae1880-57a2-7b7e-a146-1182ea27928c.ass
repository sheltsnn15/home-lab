Dialogue: 0,0:00:34.54,0:00:38.37,Default,,0,0,0,,CHÚ THUẬT HỒI CHIẾN TỬ DIỆT HỒI DU PHẦN 1
Dialogue: 0,0:01:56.89,0:01:59.89,Default,,0,0,0,,TẬP 49: MỘT LẦN NỮA
Dialogue: 0,0:02:00.47,0:02:04.52,Default,,0,0,0,,Xin lỗi nhé, Itadori.
Dialogue: 0,0:02:07.98,0:02:08.82,Default,,0,0,0,,Chậc.
Dialogue: 0,0:02:42.02,0:02:42.85,Default,,0,0,0,,Nhanh quá.
Dialogue: 0,0:02:43.23,0:02:45.19,Default,,0,0,0,,Hoàn toàn không nhìn ra thuật thức của hắn.
Dialogue: 0,0:02:45.81,0:02:47.65,Default,,0,0,0,,Vì hắn đang áp đảo đến mức này...
Dialogue: 0,0:02:47.65,0:02:49.82,Default,,0,0,0,,nên cũng không phô diễn thuật thức đâu.
Dialogue: 0,0:02:50.15,0:02:52.07,Default,,0,0,0,,Đừng nói tới Bách Liễm,
Dialogue: 0,0:02:53.32,0:02:56.49,Default,,0,0,0,,mình thậm chí còn không thể\Nkiểm soát máu ngoài cơ thể.
Dialogue: 0,0:03:06.50,0:03:08.00,Default,,0,0,0,,Lì lợm thật.
Dialogue: 0,0:03:08.00,0:03:09.92,Default,,0,0,0,,Ngươi là cái quái gì vậy hả?
Dialogue: 0,0:03:10.58,0:03:11.59,Default,,0,0,0,,Là anh cả.
Dialogue: 0,0:03:11.88,0:03:13.84,Default,,0,0,0,,Trong mười người anh em.
Dialogue: 0,0:03:14.75,0:03:17.34,Default,,0,0,0,,Hách Lân Dược Động - Tải.
Dialogue: 0,0:03:17.68,0:03:19.80,Default,,0,0,0,,Cái đó đâu phải câu trả lời.
Dialogue: 0,0:03:20.05,0:03:24.81,Default,,0,0,0,,Đang hỏi về chú thuật\Nvà sự lì lợm của ngươi mà.
Dialogue: 0,0:03:42.83,0:03:44.66,Default,,0,0,0,,Theo kịp chuyển động của mình ư?
Dialogue: 0,0:03:52.42,0:03:53.80,Default,,0,0,0,,Ra vậy.
Dialogue: 0,0:03:54.13,0:03:55.97,Default,,0,0,0,,Hách Lân Dược Động à?
Dialogue: 0,0:03:56.17,0:03:58.97,Default,,0,0,0,,Hắn tập trung sức mạnh đó\Nvào cơ ngoại nhãn...
Dialogue: 0,0:03:58.97,0:04:00.97,Default,,0,0,0,,để tăng khả năng quan sát chuyển động.
Dialogue: 0,0:04:02.00,0:04:03.31,Default,,0,0,0,,Đáng tiếc.
Dialogue: 0,0:04:03.35,0:04:06.39,Default,,0,0,0,,Ta luôn hành động\Nvới suy tính là ngươi sẽ phản đòn.
Dialogue: 0,0:04:07.39,0:04:10.44,Default,,0,0,0,,Ngươi lì quá nên ta phải dùng đến nó đấy.
Dialogue: 0,0:04:10.56,0:04:11.36,Default,,0,0,0,,Vũ khí.
Dialogue: 0,0:04:11.61,0:04:14.94,Default,,0,0,0,,Vì đang dùng Xích Huyết Thao Thuật\Nnên chắc cầm máu dễ như bỡn nhỉ.
Dialogue: 0,0:04:15.07,0:04:19.82,Default,,0,0,0,,Để xem ngươi có thể vừa cầm máu,\Nvừa đối phó với ta được bao lâu nhé.
Dialogue: 0,0:04:20.28,0:04:21.70,Default,,0,0,0,,Chuẩn bị kỹ nhỉ.
Dialogue: 0,0:04:21.82,0:04:23.16,Default,,0,0,0,,Giữ bí mật nhé.
Dialogue: 0,0:04:23.16,0:04:27.50,Default,,0,0,0,,Thuật sư mà bị lộ là mang vũ khí\Nthì bẽ mặt lắm.
Dialogue: 0,0:04:27.71,0:04:30.21,Default,,0,0,0,,Nhưng không có chúng thì không thắng nổi.
Dialogue: 0,0:04:30.46,0:04:33.54,Default,,0,0,0,,Bất ngờ là rất nhiều người\Nđồng quan điểm với ta.
Dialogue: 0,0:04:33.71,0:04:37.09,Default,,0,0,0,,Đám anh của ta cũng cầm vũ khí\Nlượn qua lượn lại trông thật thảm hại.
Dialogue: 0,0:04:37.09,0:04:40.72,Default,,0,0,0,,Chẳng hiểu chúng lấy tư cách gì\Nmà coi thường Toji.
Dialogue: 0,0:04:40.76,0:04:43.35,Default,,0,0,0,,Ngươi ghét anh em của mình à?
Dialogue: 0,0:04:43.68,0:04:45.06,Default,,0,0,0,,Ghét chứ.
Dialogue: 0,0:04:45.18,0:04:48.48,Default,,0,0,0,,Làm anh mà yếu hơn thằng em\Nthì sống làm gì nữa.
Dialogue: 0,0:04:48.68,0:04:50.64,Default,,0,0,0,,Treo cổ chết quách đi cho rồi.
Dialogue: 0,0:04:51.15,0:04:53.44,Default,,0,0,0,,Không chừng\Nvì những người anh em như thế...
Dialogue: 0,0:04:53.69,0:04:56.11,Default,,0,0,0,,mà mới có ngươi ngày hôm nay đấy.
Dialogue: 0,0:04:56.73,0:05:00.86,Default,,0,0,0,,Hả?\NNgươi nói gì nghe mắc ói vậy?
Dialogue: 0,0:05:01.16,0:05:02.74,Default,,0,0,0,,Thấy gớm.
Dialogue: 0,0:05:03.98,0:05:06.29,Default,,0,0,0,,Dù giỏi giang hay kém cỏi,
Dialogue: 0,0:05:06.29,0:05:08.33,Default,,0,0,0,,anh trai vẫn là tấm gương cho em trai.
Dialogue: 0,0:05:09.25,0:05:11.25,Default,,0,0,0,,Kể cả ta lầm đường lạc lối,
Dialogue: 0,0:05:11.25,0:05:13.58,Default,,0,0,0,,em trai chỉ cần tránh vết xe đổ đó là được.
Dialogue: 0,0:05:13.88,0:05:16.17,Default,,0,0,0,,Còn nếu ta đi đúng đường,
Dialogue: 0,0:05:16.17,0:05:18.34,Default,,0,0,0,,em trai chỉ cần noi theo là được.
Dialogue: 0,0:05:18.96,0:05:23.64,Default,,0,0,0,,Nếu sức mạnh của ngươi đến từ\Nsự yếu kém của anh trai thì sao?
Dialogue: 0,0:05:24.18,0:05:26.51,Default,,0,0,0,,Ngươi hỏi tại sao ta lì lợm đúng không?
Dialogue: 0,0:05:26.93,0:05:28.10,Default,,0,0,0,,Để ta cho ngươi biết.
Dialogue: 0,0:05:28.68,0:05:32.35,Default,,0,0,0,,Do chẳng có ai làm gương,\Nta đã liên tiếp phạm sai lầm.
Dialogue: 0,0:05:32.64,0:05:33.65,Default,,0,0,0,,Dù vậy,
Dialogue: 0,0:05:33.81,0:05:36.40,Default,,0,0,0,,ta vẫn phải tiếp tục đi trước em trai mình.
Dialogue: 0,0:05:36.73,0:05:38.82,Default,,0,0,0,,Thế nên ta mới mạnh.
Dialogue: 0,0:05:43.03,0:05:44.66,Default,,0,0,0,,Thế là thế nào?
Dialogue: 0,0:05:44.82,0:05:47.03,Default,,0,0,0,,Sao mất nhiều máu vậy mà hắn vẫn còn sống?
Dialogue: 0,0:05:54.75,0:05:58.55,Default,,0,0,0,,Cửu Tương Đồ là\Ncon lai giữ chú linh và con người.
Dialogue: 0,0:05:58.67,0:06:02.42,Default,,0,0,0,,Sở hữu thể chất đặc biệt\Ncó thể chuyển hóa chú lực thành máu.
Dialogue: 0,0:06:03.18,0:06:07.68,Default,,0,0,0,,Chỉ cần chú lực chưa cạn\Nthì sẽ không thể chết vì mất máu.
Dialogue: 0,0:06:33.83,0:06:35.33,Default,,0,0,0,,Hai chân nặng quá.
Dialogue: 0,0:06:35.79,0:06:38.59,Default,,0,0,0,,Hắn làm đông máu thấm vào vải à?
Dialogue: 0,0:06:40.09,0:06:41.55,Default,,0,0,0,,Thắng thua đã rõ rồi.
Dialogue: 0,0:06:42.55,0:06:43.92,Default,,0,0,0,,Chiếu tướng.
Dialogue: 0,0:06:50.39,0:06:51.97,Default,,0,0,0,,Chắc không?
Dialogue: 0,0:06:53.43,0:06:56.94,Default,,0,0,0,,Chú thuật của mình có thể mô phỏng trước\N24 khung hình chuyển động...
Dialogue: 0,0:06:56.94,0:06:58.44,Default,,0,0,0,,và sao chép chúng.
Dialogue: 0,0:06:58.77,0:07:01.78,Default,,0,0,0,,Với mức khống chế này\Nthì vẫn thừa sức di chuyển.
Dialogue: 0,0:07:02.78,0:07:04.15,Default,,0,0,0,,Cứ thử đi.
Dialogue: 0,0:07:07.78,0:07:10.33,Default,,0,0,0,,Tại sao... hắn không bắn?
Dialogue: 0,0:07:10.95,0:07:14.87,Default,,0,0,0,,Đây là chiêu thức mà Choso tự sáng tạo ra\Ntrong suốt 150 năm liên tục...
Dialogue: 0,0:07:14.87,0:07:17.54,Default,,0,0,0,,SIÊU TÂN TINH\Ntự đối mặt với thuật thức của mình.
Dialogue: 0,0:07:42.90,0:07:44.03,Default,,0,0,0,,Xin lỗi nhé.
Dialogue: 0,0:07:44.03,0:07:47.53,Default,,0,0,0,,Ta không thể hiểu cảm xúc của\Nmột kẻ không yêu thương anh em như ngươi.
Dialogue: 0,0:08:03.00,0:08:03.50,Default,,0,0,0,,Hả?
Dialogue: 0,0:08:10.22,0:08:11.89,Default,,0,0,0,,Trông anh có vẻ chật vật nhỉ,
Dialogue: 0,0:08:13.26,0:08:14.43,Default,,0,0,0,,anh Naoya.
Dialogue: 0,0:08:18.81,0:08:20.35,Default,,0,0,0,,Đừng có coi thường ta.
Dialogue: 0,0:08:26.40,0:08:27.86,Default,,0,0,0,,Sao thế này?
Dialogue: 0,0:08:27.94,0:08:28.86,Default,,0,0,0,,Độc ư?
Dialogue: 0,0:08:29.66,0:08:31.95,Default,,0,0,0,,Xích Huyết Thao Thuật có tác dụng này sao?
Dialogue: 0,0:08:32.74,0:08:35.54,Default,,0,0,0,,Không, không phải tác dụng của chú thuật.
Dialogue: 0,0:08:35.54,0:08:37.04,Default,,0,0,0,,Nhiều máu thế này...
Dialogue: 0,0:08:37.04,0:08:39.25,Default,,0,0,0,,Tên đó không phải con người.
Dialogue: 0,0:08:39.46,0:08:41.00,Default,,0,0,0,,Chú linh nhập xác à?
Dialogue: 0,0:08:41.00,0:08:44.59,Default,,0,0,0,,Cơ thể mình đang bài xích...\Nthứ máu không phải của con người đó.
Dialogue: 0,0:08:44.59,0:08:46.09,Default,,0,0,0,,Tôi chữa cho anh nhé?
Dialogue: 0,0:08:47.46,0:08:49.51,Default,,0,0,0,,Phản Chuyển Thuật Thức của tôi...
Dialogue: 0,0:08:49.55,0:08:51.13,Default,,0,0,0,,có thể chữa cho người khác đấy.
Dialogue: 0,0:08:51.68,0:08:52.90,Default,,0,0,0,,Đổi lại,
Dialogue: 0,0:08:53.64,0:08:58.81,Default,,0,0,0,,phiền anh báo cáo về\Ncái chết của Itadori cho cấp trên.
Dialogue: 0,0:09:01.81,0:09:03.02,Default,,0,0,0,,Jin.
Dialogue: 0,0:09:08.91,0:09:10.61,Default,,0,0,0,,Sao vậy, bố?
Dialogue: 0,0:09:11.49,0:09:14.03,Default,,0,0,0,,Nếu về chuyện của cô ấy thì con về đây.
Dialogue: 0,0:09:14.91,0:09:16.00,Default,,0,0,0,,Jin.
Dialogue: 0,0:09:16.37,0:09:19.25,Default,,0,0,0,,Muốn sống sao là quyền của mày.
Dialogue: 0,0:09:19.94,0:09:23.46,Default,,0,0,0,,Nhưng đừng dính dáng đến con ả đó.
Dialogue: 0,0:09:23.71,0:09:24.71,Default,,0,0,0,,Mày sẽ chết đấy.
Dialogue: 0,0:09:25.67,0:09:28.76,Default,,0,0,0,,Đừng nói mấy điều kỳ cục đó\Ntrước mặt Yuji chứ.
Dialogue: 0,0:09:29.21,0:09:32.38,Default,,0,0,0,,Nghe nói trí nhớ của trẻ con tốt lắm đấy.
Dialogue: 0,0:09:32.90,0:09:35.64,Default,,0,0,0,,Tao biết mày rất muốn có con,
Dialogue: 0,0:09:35.64,0:09:39.18,Default,,0,0,0,,cũng biết Kaori và mày\Nđã không thể thực hiện điều đó.
Dialogue: 0,0:09:40.23,0:09:42.02,Default,,0,0,0,,Nhưng cái chết của Kaori...
Dialogue: 0,0:09:42.50,0:09:45.44,Default,,0,0,0,,Bố, hai người đang nói chuyện gì vậy?
Dialogue: 0,0:09:59.54,0:10:00.62,Default,,0,0,0,,Ủa?
Dialogue: 0,0:10:00.79,0:10:01.96,Default,,0,0,0,,Mình...
Dialogue: 0,0:10:20.27,0:10:23.39,Default,,0,0,0,,May quá!
Dialogue: 0,0:10:30.48,0:10:32.24,Default,,0,0,0,,Chắc là hồi tháng 9.
Dialogue: 0,0:10:32.94,0:10:35.41,Default,,0,0,0,,Thầy Gojo đã đến gặp tôi...
Dialogue: 0,0:10:36.17,0:10:38.16,Default,,0,0,0,,và nhờ tôi chăm sóc cho cậu.
Dialogue: 0,0:10:39.24,0:10:42.83,Default,,0,0,0,,Thế nên tôi mới diễn một vở kịch.
Dialogue: 0,0:10:43.46,0:10:44.62,Default,,0,0,0,,Diễn kịch?
Dialogue: 0,0:10:45.43,0:10:48.21,Default,,0,0,0,,Thầy có chút xíu linh cảm xấu.
Dialogue: 0,0:10:48.66,0:10:50.23,Default,,0,0,0,,Nếu thầy có bề gì...
Dialogue: 0,0:10:50.23,0:10:53.05,Default,,0,0,0,,thì nhờ em lo cho đám năm nhất năm hai nhé.
Dialogue: 0,0:10:53.55,0:10:55.37,Default,,0,0,0,,Hakari thì chắc không sao đâu.
Dialogue: 0,0:10:56.09,0:10:57.72,Default,,0,0,0,,Bề gì là gì?
Dialogue: 0,0:10:58.10,0:10:59.51,Default,,0,0,0,,Chuyện phụ nữ ạ?
Dialogue: 0,0:11:00.85,0:11:03.73,Default,,0,0,0,,Yuta cũng biết đùa rồi nhỉ.
Dialogue: 0,0:11:04.27,0:11:05.31,Default,,0,0,0,,Ấy không.
Dialogue: 0,0:11:05.31,0:11:08.27,Default,,0,0,0,,Tại không tưởng tượng nổi thầy sẽ có bề gì.
Dialogue: 0,0:11:09.69,0:11:11.73,Default,,0,0,0,,Đặc biệt là cậu Itadori Yuji năm nhất.
Dialogue: 0,0:11:11.92,0:11:13.94,Default,,0,0,0,,Thằng bé giống như em,
Dialogue: 0,0:11:13.94,0:11:15.99,Default,,0,0,0,,cũng từng bị kết án tử hình một lần.
Dialogue: 0,0:11:16.48,0:11:18.66,Default,,0,0,0,,Em giúp thầy để ý đến nó thì tốt quá.
Dialogue: 0,0:11:20.23,0:11:21.37,Default,,0,0,0,,Miguel đâu?
Dialogue: 0,0:11:21.45,0:11:23.33,Default,,0,0,0,,Bảo là không muốn gặp thầy ạ.
Dialogue: 0,0:11:25.91,0:11:28.33,Default,,0,0,0,,Thay vì để người khác thi hành án...
Dialogue: 0,0:11:28.46,0:11:30.75,Default,,0,0,0,,để rồi mất thông tin về cậu,
Dialogue: 0,0:11:31.04,0:11:33.42,Default,,0,0,0,,tôi thấy đây là cách tốt nhất.
Dialogue: 0,0:11:34.05,0:11:36.13,Default,,0,0,0,,Đám cấp trên cũng chẳng phải lũ ngốc.
Dialogue: 0,0:11:36.26,0:11:43.27,Default,,0,0,0,,Để họ đồng ý cho tôi làm đao phủ,\Ntôi đã phải lập Thúc Phược là sẽ giết cậu.
Dialogue: 0,0:11:43.77,0:11:45.31,Default,,0,0,0,,Nên tôi đã giết cậu một lần.
Dialogue: 0,0:11:45.31,0:11:46.94,Default,,0,0,0,,Thật sự xin lỗi nhé.
Dialogue: 0,0:11:49.56,0:11:50.48,Default,,0,0,0,,Khoan...
Dialogue: 0,0:11:51.31,0:11:53.07,Default,,0,0,0,,Vậy tại sao tôi vẫn còn sống?
Dialogue: 0,0:11:53.90,0:11:55.78,Default,,0,0,0,,Nhờ Phản Chuyển Thuật Thức.
Dialogue: 0,0:11:57.07,0:11:59.78,Default,,0,0,0,,Khoảnh khắc trái tim cậu ngừng đập,
Dialogue: 0,0:11:59.78,0:12:02.45,Default,,0,0,0,,tôi đã đồng thời dùng\NPhản Chuyển Thuật Thức để chữa trị.
Dialogue: 0,0:12:02.89,0:12:06.62,Default,,0,0,0,,Tôi đã nghe về cậu từ trước\Nnên nghĩ sẽ hiệu quả.
Dialogue: 0,0:12:06.90,0:12:11.67,Default,,0,0,0,,Dù sao cũng rất ít người biết tôi có thể\Ntrực tiếp phát năng lượng dương mà.
Dialogue: 0,0:12:12.17,0:12:13.25,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:12:13.77,0:12:17.09,Default,,0,0,0,,Đây lần thứ hai cậu chết giả rồi.
Dialogue: 0,0:12:17.65,0:12:19.68,Default,,0,0,0,,Có lẽ sẽ sớm bị lộ thôi,
Dialogue: 0,0:12:19.82,0:12:21.30,Default,,0,0,0,,nhưng tình thế cấp bách mà.
Dialogue: 0,0:12:21.97,0:12:23.47,Default,,0,0,0,,Hiện tại, việc xử tử cậu...
Dialogue: 0,0:12:23.47,0:12:26.27,Default,,0,0,0,,đã tạm thời được coi là hoàn thành.
Dialogue: 0,0:12:28.48,0:12:31.44,Default,,0,0,0,,Sao lại giúp tôi nhiều đến vậy?
Dialogue: 0,0:12:31.98,0:12:37.36,Default,,0,0,0,,Vì những người mà tôi trân trọng\Nđều rất trân trọng cậu.
Dialogue: 0,0:12:40.07,0:12:41.74,Default,,0,0,0,,Tôi cũng từng phải gánh vác...
Dialogue: 0,0:12:41.74,0:12:44.33,Default,,0,0,0,,một sức mạnh\Nvượt quá khả năng của bản thân.
Dialogue: 0,0:12:44.78,0:12:48.12,Default,,0,0,0,,Tôi cứ tưởng là do\Nngười khác bắt mình gánh,
Dialogue: 0,0:12:48.12,0:12:50.33,Default,,0,0,0,,nhưng hóa ra lại là chính tôi gọi nó đến.
Dialogue: 0,0:12:50.77,0:12:52.13,Default,,0,0,0,,Cậu thì khác.
Dialogue: 0,0:12:52.43,0:12:55.05,Default,,0,0,0,,Sức mạnh cậu đang mang không phải của cậu.
Dialogue: 0,0:12:58.47,0:13:00.18,Default,,0,0,0,,Cậu không hề có lỗi.
Dialogue: 0,0:13:06.06,0:13:07.27,Default,,0,0,0,,Không đâu.
Dialogue: 0,0:13:07.73,0:13:10.02,Default,,0,0,0,,Không phải vấn đề tôi có lỗi hay không.
Dialogue: 0,0:13:10.60,0:13:12.48,Default,,0,0,0,,Tôi đã... giết người...
Dialogue: 0,0:13:12.48,0:13:13.27,Default,,0,0,0,,Itadori.
Dialogue: 0,0:13:18.40,0:13:20.11,Default,,0,0,0,,- Fushiguro.\N- Cậu làm gì thế?
Dialogue: 0,0:13:21.03,0:13:22.74,Default,,0,0,0,,Mau quay về Trường Chú Thuật thôi.
Dialogue: 0,0:13:23.32,0:13:25.33,Default,,0,0,0,,Giờ kết giới của trường đang được nới lỏng.
Dialogue: 0,0:13:25.78,0:13:27.83,Default,,0,0,0,,Chỉ cần không bị bắt gặp trực tiếp,
Dialogue: 0,0:13:28.08,0:13:29.75,Default,,0,0,0,,cậu vẫn có thể trở về.
Dialogue: 0,0:13:30.25,0:13:32.12,Default,,0,0,0,,Trước hết cứ đi gặp\Ncác anh chị khóa trên...
Dialogue: 0,0:13:32.12,0:13:32.96,Default,,0,0,0,,Thôi đi!
Dialogue: 0,0:13:34.54,0:13:36.67,Default,,0,0,0,,Đừng chấp nhận hiển nhiên như thế.
Dialogue: 0,0:13:37.84,0:13:39.76,Default,,0,0,0,,Cũng đừng coi như chưa có gì xảy ra.
Dialogue: 0,0:13:41.47,0:13:44.47,Default,,0,0,0,,Tôi đã giết người.
Dialogue: 0,0:13:46.23,0:13:47.97,Default,,0,0,0,,Vì lỗi của tôi, rất nhiều người đã chết!
Dialogue: 0,0:13:47.97,0:13:49.02,Default,,0,0,0,,Là lỗi của chúng ta!
Dialogue: 0,0:13:50.64,0:13:53.23,Default,,0,0,0,,Phải rồi, cậu sẽ nói như vậy.
Dialogue: 0,0:13:53.23,0:13:54.44,Default,,0,0,0,,Đừng tự ý...
Dialogue: 0,0:13:55.81,0:13:57.40,Default,,0,0,0,,bỏ cuộc một mình.
Dialogue: 0,0:14:10.50,0:14:12.41,Default,,0,0,0,,Chúng ta không phải anh hùng...
Dialogue: 0,0:14:13.33,0:14:14.54,Default,,0,0,0,,mà là chú thuật sư.
Dialogue: 0,0:14:15.25,0:14:18.25,Default,,0,0,0,,Không ai có thể thật sự trừng phạt\Nchúng ta cả.
Dialogue: 0,0:14:19.21,0:14:20.30,Default,,0,0,0,,Chính vì vậy,
Dialogue: 0,0:14:21.01,0:14:23.88,Default,,0,0,0,,chúng ta phải tiếp tục chứng minh\Ný nghĩa tồn tại của mình.
Dialogue: 0,0:14:24.97,0:14:26.93,Default,,0,0,0,,Sai rồi, Fushiguro.
Dialogue: 0,0:14:26.95,0:14:29.89,Default,,0,0,0,,Không còn thời gian\Nđể nghĩ cho bản thân nữa đâu.
Dialogue: 0,0:14:29.89,0:14:31.10,Default,,0,0,0,,Thế thì cậu...
Dialogue: 0,0:14:31.10,0:14:33.23,Default,,0,0,0,,Chỉ có thể cố sức cứu người thôi.
Dialogue: 0,0:14:33.23,0:14:34.60,Default,,0,0,0,,chừng nào còn ở bên cạnh tôi...
Dialogue: 0,0:14:34.60,0:14:35.52,Default,,0,0,0,,Đó vốn là...
Dialogue: 0,0:14:35.60,0:14:37.11,Default,,0,0,0,,nguyên tắc hành động của ông mà.
Dialogue: 0,0:14:37.11,0:14:38.98,Default,,0,0,0,,Cậu sẽ tiếp tục chịu khổ đó!
Dialogue: 0,0:14:38.98,0:14:41.69,Default,,0,0,0,,Đầu tiên, hãy cứu tôi, Itadori.
Dialogue: 0,0:14:46.20,0:14:48.58,Default,,0,0,0,,Kamo Noritoshi đã ban chú thuật\Ncho một nhóm người...
Dialogue: 0,0:14:48.58,0:14:51.33,Default,,0,0,0,,và tạo ra một trò chơi để họ giết lẫn nhau.
Dialogue: 0,0:14:51.91,0:14:53.29,Default,,0,0,0,,Tử Diệt Hồi Du.
Dialogue: 0,0:14:54.75,0:14:57.46,Default,,0,0,0,,Tsumiki cũng bị cuốn vào Tử Diệt Hồi Du.
Dialogue: 0,0:15:00.00,0:15:02.34,Default,,0,0,0,,Làm ơn đấy, Itadori.
Dialogue: 0,0:15:08.26,0:15:10.26,Default,,0,0,0,,Tôi cần sức mạnh của ông.
Dialogue: 0,0:15:17.98,0:15:22.57,Default,,0,0,0,,LUẬT CHƠI TỬ DIỆT HỒI DU
Dialogue: 0,0:15:22.57,0:15:22.98,Default,,0,0,0,,TỬ DIỆT HỒI DU
Dialogue: 0,0:15:22.98,0:15:23.36,Default,,0,0,0,,LUẬT CHƠI
Dialogue: 0,0:15:23.57,0:15:23.94,Default,,0,0,0,,TRONG 19 NGÀY
Dialogue: 0,0:15:23.94,0:15:24.32,Default,,0,0,0,,NẾU CÓ NGƯỜI CHƠI NÀO
Dialogue: 0,0:15:25.28,0:15:25.57,Default,,0,0,0,,VI PHẠM LUẬT CHƠI
Dialogue: 0,0:15:25.57,0:15:25.95,Default,,0,0,0,,CHÚ THUẬT CỦA NGƯỜI ĐÓ
Dialogue: 0,0:15:25.95,0:15:26.24,Default,,0,0,0,,SẼ BỊ TƯỚC BỎ
Dialogue: 0,0:15:26.95,0:15:27.36,Default,,0,0,0,,NGƯỜI NÀO BƯỚC CHÂN VÀO KẾT GIỚI
Dialogue: 0,0:15:27.36,0:15:27.74,Default,,0,0,0,,CŨNG LẬP TỨC ĐƯỢC COI LÀ NGƯỜI CHƠI
Dialogue: 0,0:15:28.91,0:15:29.90,Default,,0,0,0,,PHẢI TƯỚC ĐOẠT SINH MẠNG NGƯỜI KHÁC
Dialogue: 0,0:15:30.53,0:15:31.12,Default,,0,0,0,,THUẬT SƯ ĐƯỢC 5 ĐIỂM
Dialogue: 0,0:15:31.62,0:15:32.12,Default,,0,0,0,,PHI THUẬT SƯ ĐƯỢC 1 ĐIỂM.
Dialogue: 0,0:15:32.12,0:15:38.00,Default,,0,0,0,,LUẬT CHƠI TỬ DIỆT HỒI DU
Dialogue: 0,0:15:40.63,0:15:43.00,Default,,0,0,0,,CHÚ THUẬT HỒI CHIẾN
Dialogue: 0,0:15:43.13,0:15:45.26,Default,,0,0,0,,Làm ơn đấy, Itadori.
Dialogue: 0,0:15:46.13,0:15:48.09,Default,,0,0,0,,Tôi cần sức mạnh của ông.
Dialogue: 0,0:15:50.12,0:15:51.55,Default,,0,0,0,,Anh Okkotsu.
Dialogue: 0,0:15:52.43,0:15:54.72,Default,,0,0,0,,Sukuna đang toan tính gì đó với Fushiguro.
Dialogue: 0,0:15:56.34,0:15:58.52,Default,,0,0,0,,Việc em mất kiểm soát cơ thể ở Shibuya...
Dialogue: 0,0:15:58.85,0:16:01.56,Default,,0,0,0,,có lẽ là do phải nuốt 10 ngón tay một lúc.
Dialogue: 0,0:16:02.12,0:16:04.82,Default,,0,0,0,,Giờ trong người em có 15 ngón tay.
Dialogue: 0,0:16:05.13,0:16:07.45,Default,,0,0,0,,Dù bây giờ có nuốt hết năm ngón còn lại,
Dialogue: 0,0:16:07.78,0:16:09.78,Default,,0,0,0,,chắc cơ thể cũng không bị chiếm đâu.
Dialogue: 0,0:16:09.99,0:16:11.20,Default,,0,0,0,,Dù vậy,
Dialogue: 0,0:16:11.74,0:16:14.37,Default,,0,0,0,,nếu lần tới,\Nem lại bị Sukuna chiếm cơ thể...
Dialogue: 0,0:16:14.37,0:16:15.95,Default,,0,0,0,,thì đừng do dự mà giết em.
Dialogue: 0,0:16:16.55,0:16:18.42,Default,,0,0,0,,Em tin anh có thể làm được.
Dialogue: 0,0:16:20.33,0:16:21.38,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:16:22.12,0:16:23.92,Default,,0,0,0,,Tôi sẽ cố hết sức.
Dialogue: 0,0:16:24.71,0:16:26.01,Default,,0,0,0,,Fushiguro.
Dialogue: 0,0:16:26.35,0:16:27.88,Default,,0,0,0,,Tôi phải làm gì?
Dialogue: 0,0:16:28.90,0:16:32.60,Default,,0,0,0,,Trước hết là quay về Trường Chú Thuật\Nvà liên lạc với ngài Tengen.
Dialogue: 0,0:16:35.72,0:16:38.23,Default,,0,0,0,,Phải giải được phong ấn\Ncủa Ngục Môn Cương.
Dialogue: 0,0:16:38.78,0:16:42.69,Default,,0,0,0,,Tìm ra mục đích cụ thể của Kamo Noritoshi\Nvà phương hướng hành động tiếp theo.
Dialogue: 0,0:16:43.11,0:16:45.73,Default,,0,0,0,,Tử Diệt Hồi Du\Nlà vụ khủng bố chú thuật chưa từng có.
Dialogue: 0,0:16:45.94,0:16:49.49,Default,,0,0,0,,Để đối phó với tình hình này,\Nta cần có cả hai đáp án trên.
Dialogue: 0,0:16:49.86,0:16:53.03,Default,,0,0,0,,Người duy nhất có thể trả lời\Nlà ngài Tengen.
Dialogue: 0,0:16:53.95,0:16:57.25,Default,,0,0,0,,Người đó... cô Tsukumo có biết gì không?
Dialogue: 0,0:16:57.70,0:16:59.71,Default,,0,0,0,,Tôi đã nói chuyện với cô Tsukumo.
Dialogue: 0,0:17:00.07,0:17:01.79,Default,,0,0,0,,Đây là phương án của cô ấy.
Dialogue: 0,0:17:02.25,0:17:05.09,Default,,0,0,0,,Hiện cô ấy đang ẩn náu\Ntrong Trường Chú Thuật.
Dialogue: 0,0:17:06.48,0:17:07.80,Default,,0,0,0,,Ẩn náu?
Dialogue: 0,0:17:07.96,0:17:10.51,Default,,0,0,0,,Hình như vì\Nkhông muốn dính líu đến đám cấp cao.
Dialogue: 0,0:17:11.06,0:17:14.76,Default,,0,0,0,,Vấn đề là kết giới ẩn của ngài Tengen.
Dialogue: 0,0:17:16.01,0:17:19.64,Default,,0,0,0,,Có hơn một nghìn cánh cửa\Nliên tục thay đổi vị trí.
Dialogue: 0,0:17:19.77,0:17:20.94,Default,,0,0,0,,Chỉ một trong số chúng...
Dialogue: 0,0:17:20.94,0:17:23.94,Default,,0,0,0,,có thể dẫn đến\NHoằng Tinh Cung của ngài Tengen.
Dialogue: 0,0:17:25.58,0:17:27.73,Default,,0,0,0,,Nếu không tìm được cánh cửa đó...
Dialogue: 0,0:17:27.73,0:17:30.07,Default,,0,0,0,,thì không thể gặp được ngài... Tengen nhỉ?
Dialogue: 0,0:17:34.43,0:17:35.62,Default,,0,0,0,,Xin lỗi, Fushiguro.
Dialogue: 0,0:17:45.21,0:17:46.80,Default,,0,0,0,,Quả nhiên tôi vẫn phải hỏi.
Dialogue: 0,0:17:50.53,0:17:52.26,Default,,0,0,0,,Kugisaki sao rồi?
Dialogue: 0,0:17:59.40,0:18:00.93,Default,,0,0,0,,Ra vậy.
Dialogue: 0,0:18:04.23,0:18:05.44,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:18:13.57,0:18:14.78,Default,,0,0,0,,Tôi hiểu rồi.
Dialogue: 0,0:18:16.33,0:18:18.66,Default,,0,0,0,,Cái kết giới ẩn đó...
Dialogue: 0,0:18:18.91,0:18:20.95,Default,,0,0,0,,có lẽ vẫn có cách tìm ra đấy.
Dialogue: 0,0:18:22.10,0:18:23.96,Default,,0,0,0,,Anh nghe hết rồi à?
Dialogue: 0,0:18:25.29,0:18:27.09,Default,,0,0,0,,Ý anh là sao, Choso?
Dialogue: 0,0:18:28.04,0:18:31.97,Default,,0,0,0,,Ngày trước, Mahito đã từng cướp ngón tay\Ncủa Sukuna từ chúng ta, đúng không?
Dialogue: 0,0:18:33.17,0:18:35.26,Default,,0,0,0,,Chúng ta sẽ dùng cách tương tự.
Dialogue: 0,0:18:44.02,0:18:46.94,Default,,0,0,0,,Đã lâu không gặp... mà không lâu lắm nhỉ.
Dialogue: 0,0:18:47.23,0:18:48.82,Default,,0,0,0,,Chị Maki?
Dialogue: 0,0:18:49.86,0:18:50.86,Default,,0,0,0,,Ồ, chào.
Dialogue: 0,0:18:51.57,0:18:54.32,Default,,0,0,0,,Maki! Di chuyển được rồi à?
Dialogue: 0,0:18:54.70,0:18:56.61,Default,,0,0,0,,Ừ, ổn rồi.
Dialogue: 0,0:18:57.16,0:18:58.95,Default,,0,0,0,,Vết bỏng thì chịu rồi.
Dialogue: 0,0:18:59.16,0:19:01.62,Default,,0,0,0,,Dùng Phản Chuyển Thuật Thức\Nmà vẫn để lại sẹo.
Dialogue: 0,0:19:01.99,0:19:05.37,Default,,0,0,0,,Nhưng đúng là thể chất trời ban\Ncủa Thiên Dữ Chú Phược.
Dialogue: 0,0:19:05.79,0:19:08.84,Default,,0,0,0,,Vào phút sinh tử, thứ cứu mạng\Nkhông phải sức kháng lời nguyền...
Dialogue: 0,0:19:08.84,0:19:11.71,Default,,0,0,0,,mà là sự cứng cáp của thể chất thiên phú.
Dialogue: 0,0:19:12.17,0:19:14.47,Default,,0,0,0,,Chuyện tộc trưởng thì thật đáng tiếc.
Dialogue: 0,0:19:14.67,0:19:17.14,Default,,0,0,0,,Tôi đâu định ganh đua với ai.
Dialogue: 0,0:19:18.22,0:19:21.43,Default,,0,0,0,,Megumi, về kết giới của ngài Tengen...
Dialogue: 0,0:19:22.43,0:19:23.47,Default,,0,0,0,,Về chuyện đó...
Dialogue: 0,0:19:23.81,0:19:25.19,Default,,0,0,0,,Để tôi nói.
Dialogue: 0,0:19:25.81,0:19:28.23,Default,,0,0,0,,Từ cánh cửa đến Hoằng Tinh Cung...
Dialogue: 0,0:19:28.23,0:19:31.90,Default,,0,0,0,,có một kho cấm cất giữ chú cụ\Nvà chú vật của trường.
Dialogue: 0,0:19:32.23,0:19:34.90,Default,,0,0,0,,Trong đó có di hài của các em tôi:
Dialogue: 0,0:19:34.99,0:19:35.78,Default,,0,0,0,,Noranso,
Dialogue: 0,0:19:35.86,0:19:36.78,Default,,0,0,0,,Sho-oso,
Dialogue: 0,0:19:36.86,0:19:37.61,Default,,0,0,0,,Tanso,
Dialogue: 0,0:19:37.61,0:19:38.28,Default,,0,0,0,,Sanso,
Dialogue: 0,0:19:38.28,0:19:39.12,Default,,0,0,0,,Kotsuso,
Dialogue: 0,0:19:39.12,0:19:40.95,Default,,0,0,0,,và Shoso.
Dialogue: 0,0:19:41.33,0:19:43.75,Default,,0,0,0,,Dù chỉ là di hài,\Nnhưng khi đủ cả sáu đứa ở đó,
Dialogue: 0,0:19:43.75,0:19:46.00,Default,,0,0,0,,tôi có thể cảm nhận\Nsự hiện diện của chúng...
Dialogue: 0,0:19:46.00,0:19:47.87,Default,,0,0,0,,thông qua thuật thức của mình.
Dialogue: 0,0:19:48.67,0:19:49.75,Default,,0,0,0,,Tốt!
Dialogue: 0,0:19:50.01,0:19:51.79,Default,,0,0,0,,Tạm gác lại chuyện đó...
Dialogue: 0,0:19:51.79,0:19:53.63,Default,,0,0,0,,Tên này là ai vậy?
Dialogue: 0,0:19:57.09,0:19:58.47,Default,,0,0,0,,Tạm thời cứ coi là...
Dialogue: 0,0:19:59.43,0:20:01.47,Default,,0,0,0,,anh trai của em đi.
Dialogue: 0,0:20:01.93,0:20:04.89,Default,,0,0,0,,Yuji!
Dialogue: 0,0:20:05.23,0:20:06.18,Default,,0,0,0,,Đi thôi.
Dialogue: 0,0:20:09.31,0:20:10.40,Default,,0,0,0,,Chính nó.
Dialogue: 0,0:20:11.36,0:20:12.69,Default,,0,0,0,,Không thể nhầm được.
Dialogue: 0,0:20:12.90,0:20:15.49,Default,,0,0,0,,Các em tôi đang ngủ ở phía trước.
Dialogue: 0,0:20:15.69,0:20:16.65,Default,,0,0,0,,Mở nhé.
Dialogue: 0,0:20:27.33,0:20:28.54,Default,,0,0,0,,Xuống thôi.
Dialogue: 0,0:20:30.03,0:20:33.29,Default,,0,0,0,,Sâu bên trong có thang máy\Ndẫn xuống Hoằng Tinh Cung.
Dialogue: 0,0:20:35.00,0:20:35.96,Default,,0,0,0,,Choso.
Dialogue: 0,0:20:36.84,0:20:37.97,Default,,0,0,0,,Anh biết.
Dialogue: 0,0:20:39.02,0:20:40.80,Default,,0,0,0,,Anh sẽ quay lại đón mấy đứa.
Dialogue: 0,0:20:40.98,0:20:42.72,Default,,0,0,0,,Ráng đợi một chút nhé.
Dialogue: 0,0:20:48.73,0:20:49.89,Default,,0,0,0,,Vết máu?
Dialogue: 0,0:20:50.10,0:20:51.48,Default,,0,0,0,,Đã xảy ra chuyện gì à?
Dialogue: 0,0:20:51.77,0:20:53.98,Default,,0,0,0,,Là chuyện từ 12 năm trước rồi.
Dialogue: 0,0:20:54.27,0:20:55.65,Default,,0,0,0,,Giờ nghĩ lại,
Dialogue: 0,0:20:55.82,0:20:59.45,Default,,0,0,0,,có lẽ mọi chuyện\Ndần trở nên méo mó từ lúc đó.
Dialogue: 0,0:21:00.53,0:21:01.66,Default,,0,0,0,,Nào, mọi người.
Dialogue: 0,0:21:01.74,0:21:03.57,Default,,0,0,0,,Phía trước là chính điện đấy.
Dialogue: 0,0:21:20.26,0:21:21.55,Default,,0,0,0,,Trống trơn nhỉ.
Dialogue: 0,0:21:21.72,0:21:22.89,Default,,0,0,0,,Đây là chính điện sao?
Dialogue: 0,0:21:23.18,0:21:26.22,Default,,0,0,0,,Không, chúng ta đã bị khước từ.
Dialogue: 0,0:21:27.14,0:21:29.77,Default,,0,0,0,,Tengen không can thiệp vào thế sự.
Dialogue: 0,0:21:29.89,0:21:31.98,Default,,0,0,0,,Giờ Lục Nhãn đã bị phong ấn,
Dialogue: 0,0:21:31.98,0:21:34.36,Default,,0,0,0,,tôi cứ tưởng sẽ có cơ hội tiếp xúc.
Dialogue: 0,0:21:34.56,0:21:36.32,Default,,0,0,0,,Nhưng xem ra tôi đã quá ngây thơ.
Dialogue: 0,0:21:38.15,0:21:40.78,Default,,0,0,0,,Kẻ bị khước từ không phải là mọi người...
Dialogue: 0,0:21:41.40,0:21:42.86,Default,,0,0,0,,mà là mình sao?
Dialogue: 0,0:21:44.98,0:21:46.16,Default,,0,0,0,,Về thôi.
Dialogue: 0,0:21:46.37,0:21:48.16,Default,,0,0,0,,Tsumiki không còn nhiều thời gian nữa.
Dialogue: 0,0:21:50.97,0:21:52.75,Default,,0,0,0,,Tính về sao?
Dialogue: 0,0:21:53.95,0:21:55.54,Default,,0,0,0,,Hân hạnh gặp mặt,
Dialogue: 0,0:21:55.54,0:22:01.22,Default,,0,0,0,,đứa con nhà Zen'in, giọt máu của\NMichizane, Chú Thai Cửu Tương Đồ, và...
Dialogue: 0,0:22:03.55,0:22:05.76,Default,,0,0,0,,vật chứa của Sukuna.
Dialogue: 0,0:23:40.34,0:23:42.73,Default,,0,0,0,,Ta có một điều kiện.
Dialogue: 0,0:23:42.73,0:23:44.57,Default,,0,0,0,,Tôi muốn hỏi cách giải ấn Ngục Môn Cương.
Dialogue: 0,0:23:44.57,0:23:46.03,Default,,0,0,0,,Không định chào hỏi tôi sao?
Dialogue: 0,0:23:46.03,0:23:47.07,Default,,0,0,0,,Vậy còn Tử Diệt Hồi Du...
Dialogue: 0,0:23:47.07,0:23:49.32,Default,,0,0,0,,Nó ép buộc nhân loại phải tiến hóa.
Dialogue: 0,0:23:49.32,0:23:51.33,Default,,0,0,0,,Theo luật, nếu bị tước bỏ thuật thức\Nlà chết chắc đấy.
Dialogue: 0,0:23:51.33,0:23:53.33,Default,,0,0,0,,Nếu tôi bị Sukuna chiếm xác,\Nđừng ngần ngại mà giết tôi.
Dialogue: 0,0:23:53.33,0:23:54.11,Default,,0,0,0,,Đừng chết đấy.
Dialogue: 0,0:23:54.11,0:23:55.06,Default,,0,0,0,,TẬP TỚI: TỬ DIỆT HỒI DU

