Dialogue: 0,0:01:56.47,0:01:57.90,Иноязычный,Надпись,0000,0000,0000,,[Высекай…]
Dialogue: 0,0:02:03.76,0:02:06.16,Иноязычный,Надпись,0000,0000,0000,,[Высекай на своём теле…]
Dialogue: 0,0:02:13.19,0:02:15.46,Иноязычный,Надпись,0000,0000,0000,,[Высекай на земле…]
Dialogue: 0,0:02:21.45,0:02:23.76,Иноязычный,Надпись,0000,0000,0000,,[Высекай на море…]
Dialogue: 0,0:02:28.62,0:02:31.25,Иноязычный,Надпись,0000,0000,0000,,[Высекай на врагах…]
Dialogue: 0,0:02:31.67,0:02:33.75,Иноязычный,Надпись,0000,0000,0000,,[Высекай на добыче…]
Dialogue: 0,0:02:36.17,0:02:38.15,Иноязычный,Надпись,0000,0000,0000,,[Высекай!..]
Dialogue: 0,0:02:38.88,0:02:40.76,Иноязычный,Надпись,0000,0000,0000,,[Высекай!]
Dialogue: 0,0:02:57.07,0:02:58.82,Иноязычный,Надпись,0000,0000,0000,,[Высекай прямо на мне…]
Dialogue: 0,0:02:58.88,0:03:00.18,Иноязычный,Надпись,0000,0000,0000,,[своё тепло.]
