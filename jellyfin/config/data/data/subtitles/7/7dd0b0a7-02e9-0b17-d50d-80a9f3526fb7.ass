Dialogue: 0,0:01:43.90,0:01:47.23,Default,,0000,0000,0000,,(Phục tùng các ngài quái nhân đi!)\NCứ nhìn vào hành động\Ncủa hiệp hội anh hùng thì rõ.
Dialogue: 0,0:01:47.48,0:01:49.69,Default,,0000,0000,0000,,phía nhân loại chẳng có cơ hội thắng đâu.
Dialogue: 0,0:01:50.19,0:01:52.53,Default,,0000,0000,0000,,(Đầu hàng hoàn toàn)\NNên phải đầu hàng hoàn toàn đi.
Dialogue: 0,0:01:52.53,0:01:56.16,Default,,0000,0000,0000,,(Nhân loại không có cửa thắng)\NNếu chống trả thì chắc chắn sẽ bị xóa sổ đấy.
Dialogue: 0,0:01:56.16,0:01:59.49,Default,,0000,0000,0000,,Vì vậy, chúng tôi, Đảng sùng bái Quái Nhân,
Dialogue: 0,0:01:59.49,0:02:01.66,Default,,0000,0000,0000,,đã nghĩ ra một giải pháp duy nhất.
Dialogue: 0,0:02:02.46,0:02:05.79,Default,,0000,0000,0000,,Dâng tế phẩm định kỳ cho Quái Nhân,
Dialogue: 0,0:02:05.79,0:02:08.88,Default,,0000,0000,0000,,nhờ họ điều tiết tốc độ ăn thịt,
Dialogue: 0,0:02:08.88,0:02:11.51,Default,,0000,0000,0000,,như vậy mới có thể tránh bị\N tiêu diệt cả giống loài.
Dialogue: 0,0:02:12.34,0:02:14.80,Default,,0000,0000,0000,,Chúng tôi ủng hộ các ngài Quái nhân!
Dialogue: 0,0:02:14.80,0:02:16.64,Default,,0000,0000,0000,,Hãy chung sống cùng chúng tôi!
Dialogue: 0,0:02:17.64,0:02:20.60,Default,,0000,0000,0000,,Trong một thế giới mà lẽ thường\Nvà đạo đức bị đảo lộn,
Dialogue: 0,0:02:20.60,0:02:21.68,Default,,0000,0000,0000,,chúng ta sẽ cùng nhau sống sót.
Dialogue: 0,0:02:21.68,0:02:23.18,Default,,0000,0000,0000,,Mau im đi!
Dialogue: 0,0:02:23.60,0:02:26.90,Default,,0000,0000,0000,,Thà chết còn hơn làm kẻ ủng hộ Quái Nhân!
Dialogue: 0,0:02:28.02,0:02:29.07,Default,,0000,0000,0000,,Tuyệt luôn.
Dialogue: 0,0:02:29.48,0:02:32.82,Default,,0000,0000,0000,,Vậy thì mày sẽ là ứng viên số một cho lễ tế.
Dialogue: 0,0:02:33.24,0:02:34.07,Default,,0000,0000,0000,,Bắt nó!
Dialogue: 0,0:02:36.45,0:02:37.57,Default,,0000,0000,0000,,Này, đợi đã!
Dialogue: 0,0:02:42.66,0:02:46.50,Default,,0000,0000,0000,,Dâng tế để chỉ cứu mình...
Dialogue: 0,0:02:46.71,0:02:48.92,Default,,0000,0000,0000,,Các ngươi quá coi thường Quái nhân rồi đấy!
Dialogue: 0,0:02:49.67,0:02:52.84,Default,,0000,0000,0000,,Chẳng ngờ xã hội loài người\Nbị lung lay dễ dàng thế này.
Dialogue: 0,0:02:53.09,0:02:54.22,Default,,0000,0000,0000,,Thật là thảm hại.
Dialogue: 0,0:02:55.13,0:02:56.84,Default,,0000,0000,0000,,Đến nước này rồi,
Dialogue: 0,0:02:57.26,0:02:59.10,Default,,0000,0000,0000,,liệu ta, Quái nhân mạnh nhất,
Dialogue: 0,0:02:59.10,0:03:02.47,Default,,0000,0000,0000,,xuất hiện hoành tráng có\Ncòn gây được ấn tượng nữa không?
Dialogue: 0,0:03:02.81,0:03:04.18,Default,,0000,0000,0000,,Bắt đầu thấy lo rồi.
Dialogue: 0,0:03:04.89,0:03:07.77,Default,,0000,0000,0000,,(Điều kiện của Quái nhân)\NỞ các thành phố xuất hiện bạo loạn,\N móc túi, cướp giật,
Dialogue: 0,0:03:07.77,0:03:10.36,Default,,0000,0000,0000,,một số người dân biến thành côn đồ,
Dialogue: 0,0:03:10.36,0:03:12.90,Default,,0000,0000,0000,,cảnh sát và anh hùng phải tuần tra phối hợp,
Dialogue: 0,0:03:12.90,0:03:14.65,Default,,0000,0000,0000,,liên tục phát hiện và cảnh báo.
Dialogue: 0,0:03:15.90,0:03:20.12,Default,,0000,0000,0000,,Ở thành phố S còn có nhóm tuyên truyền
Dialogue: 0,0:03:20.12,0:03:21.78,Default,,0000,0000,0000,,rằng lịch sử nhân loại đã đến hồi kết,
Dialogue: 0,0:03:21.78,0:03:23.66,Default,,0000,0000,0000,,làm bùng nổ hỗn loạn.
Dialogue: 0,0:03:24.62,0:03:29.67,Default,,0000,0000,0000,,Đừng nghĩ Quái nhân làm loạn là\N lý do để giảm nhẹ tội lỗi.
Dialogue: 0,0:03:30.25,0:03:32.96,Default,,0000,0000,0000,,Vì Hiệp hội Quái Nhân hành xử nửa vời
Dialogue: 0,0:03:33.30,0:03:35.67,Default,,0000,0000,0000,,nên mấy tên khốn vênh váo\N mới được đà lấn tới.
Dialogue: 0,0:03:37.34,0:03:40.05,Default,,0000,0000,0000,,Gì đây, ông già thích giỡn mặt tụi này à?
Dialogue: 0,0:03:40.05,0:03:41.85,Default,,0000,0000,0000,,Có vấn đề gì thì cứ nói ra!
Dialogue: 0,0:03:41.85,0:03:43.51,Default,,0000,0000,0000,,Hả, câm mồm!
Dialogue: 0,0:03:43.64,0:03:45.27,Default,,0000,0000,0000,,Chính ông già này va vào bọn tao mà!
Dialogue: 0,0:03:45.27,0:03:46.18,Default,,0000,0000,0000,,Lũ say rượu!
Dialogue: 0,0:03:46.52,0:03:47.56,Default,,0000,0000,0000,,Không thể đỡ nổi!
Dialogue: 0,0:03:47.81,0:03:50.56,Default,,0000,0000,0000,,Dù sao thì mọi người cũng rồi\Nsẽ bị Quái Nhân giết hết,
Dialogue: 0,0:03:50.56,0:03:52.32,Default,,0000,0000,0000,,còn gì mà phải kiềm chế chứ?
Dialogue: 0,0:03:52.94,0:03:53.15,Default,,0000,0000,0000,,Này!
Dialogue: 0,0:03:53.94,0:03:56.03,Default,,0000,0000,0000,,Ngươi chắn lối ra vào cửa hàng đấy!
Dialogue: 0,0:03:56.03,0:03:56.78,Default,,0000,0000,0000,,Biến đi!
Dialogue: 0,0:03:56.82,0:04:00.45,Default,,0000,0000,0000,,Mày nói gì hả, thằng nhóc?
Dialogue: 0,0:04:07.37,0:04:08.16,Default,,0000,0000,0000,,Biến đi!
Dialogue: 0,0:04:09.71,0:04:11.38,Default,,0000,0000,0000,,Mình khác với bọn chúng.
Dialogue: 0,0:04:12.50,0:04:16.51,Default,,0000,0000,0000,,Mình sẽ tạo ra nỗi sợ thực sự,\Nthứ khiến cả lũ khốn này cũng phải câm họng.
Dialogue: 0,0:04:17.30,0:04:19.97,Default,,0000,0000,0000,,Nhưng mà... giờ đói quá rồi.
Dialogue: 0,0:04:21.43,0:04:23.39,Default,,0000,0000,0000,,Suất đại tiệc bít tết siêu dày,
Dialogue: 0,0:04:23.68,0:04:25.60,Default,,0000,0000,0000,,cùng với cơm siêu to khổng lồ\Ncủa quý khách đây ạ.
Dialogue: 0,0:04:26.35,0:04:27.39,Default,,0000,0000,0000,,Quý khách ăn ngon miệng ạ!
Dialogue: 0,0:04:29.06,0:04:30.85,Default,,0000,0000,0000,,Ăn thôi nào!
Dialogue: 0,0:04:46.91,0:04:47.50,Default,,0000,0000,0000,,Ơ kìa?
Dialogue: 0,0:04:48.41,0:04:50.33,Default,,0000,0000,0000,,Chừng này chẳng đủ gì cả.
Dialogue: 0,0:04:52.63,0:04:54.88,Default,,0000,0000,0000,,Cho tôi tất cả món thịt trong\N thực đơn, từ trên xuống nhé.
Dialogue: 0,0:04:55.71,0:04:57.51,Default,,0000,0000,0000,,Salad cũng mang hết các loại ra đi.
Dialogue: 0,0:04:58.21,0:04:59.97,Default,,0000,0000,0000,,À, với lại cho thêm nhiều nước.
Dialogue: 0,0:05:00.34,0:05:01.01,Default,,0000,0000,0000,,Vâng.
Dialogue: 0,0:05:05.89,0:05:07.56,Default,,0000,0000,0000,,Gọi thêm món tiếp!
Dialogue: 0,0:05:29.91,0:05:31.08,Default,,0000,0000,0000,,No quá trời no.
Dialogue: 0,0:05:31.21,0:05:32.83,Default,,0000,0000,0000,,Cảm ơn vì bữa ăn.
Dialogue: 0,0:05:33.17,0:05:34.42,Default,,0000,0000,0000,,Rồi, bây giờ thì…
Dialogue: 0,0:05:36.50,0:05:36.88,Default,,0000,0000,0000,,Ơ kìa?
Dialogue: 0,0:05:39.05,0:05:40.05,Default,,0000,0000,0000,,(Không có ví)\NKhông có ví.
Dialogue: 0,0:05:41.80,0:05:44.84,Default,,0000,0000,0000,,Chắc lúc mua cải thảo ở siêu thị rớt mất rồi!
Dialogue: 0,0:05:45.85,0:05:47.64,Default,,0000,0000,0000,,C-Chết rồi!
Dialogue: 0,0:05:47.64,0:05:51.06,Default,,0000,0000,0000,,Genos thì đang bị hỏng không gọi được.
Dialogue: 0,0:05:53.94,0:05:56.77,Default,,0000,0000,0000,,Bữa trưa tháng này là cá biển chiên.
Dialogue: 0,0:05:57.23,0:05:59.40,Default,,0000,0000,0000,,Có những lo ngại về việc rối loạn\N trật tự công cộng,
Dialogue: 0,0:05:59.40,0:06:05.66,Default,,0000,0000,0000,,Nhà hàng của chúng tôi luôn cảnh giác cao độ\Nvới nạn cướp giật, côn đồ, ăn uống mất kiểm soát...
Dialogue: 0,0:06:07.70,0:06:11.29,Default,,0000,0000,0000,,Có những cựu anh hùng chuyên nghiệp\N đang đóng quân trong phòng an ninh,
Dialogue: 0,0:06:11.29,0:06:15.04,Default,,0000,0000,0000,,nên quý khách hãy an tâm\Ntận hưởng bữa ăn ngon lành ạ!
Dialogue: 0,0:06:16.38,0:06:18.46,Default,,0000,0000,0000,,Trong tình huống này mà nói với nhân viên
Dialogue: 0,0:06:18.46,0:06:20.67,Default,,0000,0000,0000,,chẳng khác nào tự thú ăn quịt
Dialogue: 0,0:06:21.88,0:06:23.42,Default,,0000,0000,0000,,Chết thật, nguy quá!
Dialogue: 0,0:06:24.26,0:06:25.47,Default,,0000,0000,0000,,Thế này thì tiêu thật rồi.
Dialogue: 0,0:06:25.80,0:06:27.39,Default,,0000,0000,0000,,Đây đúng là khủng hoảng\N lớn nhất trong năm nay.
Dialogue: 0,0:06:29.26,0:06:32.10,Default,,0000,0000,0000,,- Này anh! Có nghe không?\N- Chắc đây là kết thúc của mình.
Dialogue: 0,0:06:32.85,0:06:33.68,Default,,0000,0000,0000,,Saitama!
Dialogue: 0,0:06:34.19,0:06:36.15,Default,,0000,0000,0000,,K-Không phải đâu, tôi chỉ là…
Dialogue: 0,0:06:36.73,0:06:38.36,Default,,0000,0000,0000,,Anh nói cái gì vậy?
Dialogue: 0,0:06:38.36,0:06:40.90,Default,,0000,0000,0000,,Ế, cô làm gì ở đây vậy?
Dialogue: 0,0:06:41.15,0:06:43.36,Default,,0000,0000,0000,,Tìm anh vất vả lắm đó, Saitama.
Dialogue: 0,0:06:44.07,0:06:46.49,Default,,0000,0000,0000,,Anh bỏ đi giữa chừng khi\Nvẫn đang nói chuyện mà.
Dialogue: 0,0:06:47.28,0:06:49.91,Default,,0000,0000,0000,,Này, chẳng phải anh\N định tìm kẻ săn anh hùng sao?
Dialogue: 0,0:06:50.66,0:06:54.04,Default,,0000,0000,0000,,Được rồi, đặc biệt lần này tôi sẽ giúp anh.
Dialogue: 0,0:06:54.04,0:06:55.83,Default,,0000,0000,0000,,Xin lỗi, cho gọi thêm món nhé.
Dialogue: 0,0:06:55.83,0:06:59.71,Default,,0000,0000,0000,,- Thêm một phần khoai tây Yamamori.\N- Nhưng đổi lại, điểm thành công chia 70% cho tôi đấy.
Dialogue: 0,0:07:00.75,0:07:04.01,Default,,0000,0000,0000,,Dù sao thì anh cũng đã leo đến hạng B top 7 rồi,
Dialogue: 0,0:07:04.01,0:07:06.51,Default,,0000,0000,0000,,nhưng từ đây lên cao hơn thì khó lắm đó.
Dialogue: 0,0:07:07.55,0:07:08.85,Default,,0000,0000,0000,,Nếu lần này thuận lợi,
Dialogue: 0,0:07:09.10,0:07:12.60,Default,,0000,0000,0000,,lọt hạng B top 5 không thành vấn đề.
Dialogue: 0,0:07:13.27,0:07:17.35,Default,,0000,0000,0000,,Nhưng mà, để làm được thế thì\Nchắc chắn cần đến sự hợp tác của tôi.
Dialogue: 0,0:07:17.94,0:07:22.90,Default,,0000,0000,0000,,Biết tính anh, kiểu gì cũng chẳng chịu tra kỹ\Ndiện mạo hay đặc điểm của hắn đúng không?
Dialogue: 0,0:07:23.03,0:07:27.53,Default,,0000,0000,0000,,Thật hết cách, tôi sẽ cung cấp thông tin cho.
Dialogue: 0,0:07:27.57,0:07:31.16,Default,,0000,0000,0000,,Từ giờ nghe theo chỉ dẫn của tôi nhé!
Dialogue: 0,0:07:31.74,0:07:32.62,Default,,0000,0000,0000,,Có nghe không đấy?
Dialogue: 0,0:07:33.33,0:07:35.75,Default,,0000,0000,0000,,Khoai tây chiên của quý khách đây, mời dùng.
Dialogue: 0,0:07:41.34,0:07:42.25,Default,,0000,0000,0000,,Cho tôi sao?
Dialogue: 0,0:07:44.67,0:07:45.30,Default,,0000,0000,0000,,Cảm ơn!
Dialogue: 0,0:07:51.43,0:07:53.85,Default,,0000,0000,0000,,Cái kiểu cười kia là gì vậy?
Dialogue: 0,0:07:53.85,0:07:56.93,Default,,0000,0000,0000,,Làm việc cùng mình khiến anh ta\N vui đến thế sao?
Dialogue: 0,0:07:57.48,0:08:00.44,Default,,0000,0000,0000,,Vậy là Saitama cũng xem như\Ngia nhập băng Fubuki rồi nhỉ?
Dialogue: 0,0:08:00.44,0:08:02.02,Default,,0000,0000,0000,,Ăn quỵt kìa!
Dialogue: 0,0:08:02.11,0:08:04.03,Default,,0000,0000,0000,,Mình chưa làm gì mà!
Dialogue: 0,0:08:04.15,0:08:06.36,Default,,0000,0000,0000,,Ai đó, bắt người đàn ông lúc nãy lại đi!
Dialogue: 0,0:08:08.95,0:08:10.41,Default,,0000,0000,0000,,Ăn quỵt à, thật là tên tội đồ!
Dialogue: 0,0:08:10.41,0:08:11.41,Default,,0000,0000,0000,,- Khoan đã!\N- Để tôi đuổi theo hắn!
Dialogue: 0,0:08:11.41,0:08:12.03,Default,,0000,0000,0000,,Saitama!
Dialogue: 0,0:08:12.03,0:08:15.33,Default,,0000,0000,0000,,Này, cô cũng ăn khoai tây mà đúng không?\NThanh toán nhé.
Dialogue: 0,0:08:19.04,0:08:22.17,Default,,0000,0000,0000,,Khoai tây á? Không thể nào!
Dialogue: 0,0:08:22.96,0:08:27.67,Default,,0000,0000,0000,,Thời buổi này loạn lạc mà còn\Ncó người bủn xỉn  đến vậy sao.
Dialogue: 0,0:08:30.09,0:08:32.89,Default,,0000,0000,0000,,Chạy marathon trong tình trạng này\N đúng là hơi quá sức thật.
Dialogue: 0,0:08:34.35,0:08:38.14,Default,,0000,0000,0000,,Tốt hơn là nên để bọn ta chữa trị vết thương cho\N ngươi dưới sự bảo hộ của Hiệp hội Quái Nhân.
Dialogue: 0,0:08:39.44,0:08:43.19,Default,,0000,0000,0000,,Nhưng trước hết, ngươi phải\Nhoàn thành điều kiện đã.
Dialogue: 0,0:08:44.11,0:08:46.32,Default,,0000,0000,0000,,Mang đầu của một anh hùng về à?
Dialogue: 0,0:08:47.40,0:08:51.11,Default,,0000,0000,0000,,Giết một anh hùng thì được\Ncông nhận là quái nhân là sao chứ?
Dialogue: 0,0:08:51.86,0:08:53.20,Default,,0000,0000,0000,,Quái nhân nên phải là...
Dialogue: 0,0:08:53.20,0:08:57.16,Default,,0000,0000,0000,,thứ chỉ tồn tại thôi cũng khiến\Nngười khác khiếp sợ.
Dialogue: 0,0:08:59.83,0:09:01.25,Default,,0000,0000,0000,,Đau đầu quá.
Dialogue: 0,0:09:06.88,0:09:07.96,Default,,0000,0000,0000,,Thôi kệ đi.
Dialogue: 0,0:09:11.68,0:09:12.72,Default,,0000,0000,0000,,Này, Tareo!
Dialogue: 0,0:09:12.72,0:09:15.18,Default,,0000,0000,0000,,Sao mày vẫn còn sống vậy?
Dialogue: 0,0:09:15.39,0:09:17.31,Default,,0000,0000,0000,,Mày cũng là quái nhân mà?
Dialogue: 0,0:09:17.31,0:09:19.39,Default,,0000,0000,0000,,Chết đi, đồ quái nhân!
Dialogue: 0,0:09:19.39,0:09:21.98,Default,,0000,0000,0000,,Đau quá, đau quá, đau quá!
Dialogue: 0,0:09:25.31,0:09:26.15,Default,,0000,0000,0000,,Dừng lại!
Dialogue: 0,0:09:27.19,0:09:29.94,Default,,0000,0000,0000,,Mẹ ơi!
Dialogue: 0,0:09:31.20,0:09:33.03,Default,,0000,0000,0000,,Sao lại khóc với cái mặt thảm hại thế kia…
Dialogue: 0,0:09:33.82,0:09:37.08,Default,,0000,0000,0000,,Thảo nào bị bắt nạt, tội nghiệp thật.
Dialogue: 0,0:09:37.74,0:09:38.58,Default,,0000,0000,0000,,Chào!
Dialogue: 0,0:09:38.87,0:09:41.25,Default,,0000,0000,0000,,Gặp lại trong cùng ngày, tình cờ nhỉ?
Dialogue: 0,0:09:41.25,0:09:41.96,Default,,0000,0000,0000,,Chú!
Dialogue: 0,0:09:41.96,0:09:43.12,Default,,0000,0000,0000,,Không phải chú!
Dialogue: 0,0:09:43.12,0:09:44.71,Default,,0000,0000,0000,,Ta mới có 18 tuổi thôi!
Dialogue: 0,0:09:47.13,0:09:47.96,Default,,0000,0000,0000,,Mau về nhà đi!
Dialogue: 0,0:09:48.30,0:09:49.13,Default,,0000,0000,0000,,Mặt trời lặn rồi.
Dialogue: 0,0:09:49.84,0:09:52.17,Default,,0000,0000,0000,,Biết đâu quái nhân lại xuất hiện đấy.
Dialogue: 0,0:09:54.39,0:09:55.09,Default,,0000,0000,0000,,Chú à!
Dialogue: 0,0:09:57.10,0:09:58.85,Default,,0000,0000,0000,,Cháu xin lỗi.
Dialogue: 0,0:09:59.31,0:10:01.10,Default,,0000,0000,0000,,Lúc đó cháu đã chạy trốn.
Dialogue: 0,0:10:03.89,0:10:04.65,Default,,0000,0000,0000,,Hả?
Dialogue: 0,0:10:05.35,0:10:08.32,Default,,0000,0000,0000,,Cháu đã nhìn thấy tất cả mà.
Dialogue: 0,0:10:09.23,0:10:11.99,Default,,0000,0000,0000,,Các anh hùng định tấn công chú...
Dialogue: 0,0:10:12.57,0:10:14.70,Default,,0000,0000,0000,,Nhưng rõ ràng họ đã sai, đúng không?
Dialogue: 0,0:10:15.57,0:10:17.66,Default,,0000,0000,0000,,Vì lúc đó...
Dialogue: 0,0:10:17.87,0:10:20.66,Default,,0000,0000,0000,,Chú đã che chắn cho cháu khỏi đạn mà.
Dialogue: 0,0:10:21.12,0:10:22.20,Default,,0000,0000,0000,,Giờ cũng thế.
Dialogue: 0,0:10:22.83,0:10:23.75,Default,,0000,0000,0000,,chú lại cứu cháu lần nữa.
Dialogue: 0,0:10:24.54,0:10:26.71,Default,,0000,0000,0000,,Chắc chắn chú là người đứng về phía chính nghĩa!
Dialogue: 0,0:10:28.17,0:10:29.17,Default,,0000,0000,0000,,Dừng lại đi!
Dialogue: 0,0:10:29.63,0:10:31.13,Default,,0000,0000,0000,,Nổi hết cả da gà rồi này!
Dialogue: 0,0:10:31.51,0:10:32.67,Default,,0000,0000,0000,,Này, tên ăn quỵt kia!
Dialogue: 0,0:10:34.30,0:10:36.14,Default,,0000,0000,0000,,Này, đồ ăn quỵt!
Dialogue: 0,0:10:36.34,0:10:38.55,Default,,0000,0000,0000,,Cái tên này lại dám ăn quịt...
Dialogue: 0,0:10:38.55,0:10:39.51,Default,,0000,0000,0000,,Anh hùng hả?
Dialogue: 0,0:10:39.51,0:10:41.81,Default,,0000,0000,0000,,Đúng lúc thật đấy, đồ chết tiệt.
Dialogue: 0,0:10:42.18,0:10:43.31,Default,,0000,0000,0000,,Lần này tha cho ngươi đấy!
Dialogue: 0,0:10:43.31,0:10:44.60,Default,,0000,0000,0000,,Khoan đã, cái gì thế hả?
Dialogue: 0,0:10:44.60,0:10:46.27,Default,,0000,0000,0000,,Coi như ta đã cảnh cáo rồi nhé!
Dialogue: 0,0:10:46.81,0:10:48.69,Default,,0000,0000,0000,,Ngươi không đến để tiêu diệt ta sao?
Dialogue: 0,0:10:49.15,0:10:50.19,Default,,0000,0000,0000,,Run sợ rồi à?
Dialogue: 0,0:10:50.32,0:10:51.90,Default,,0000,0000,0000,,Tên anh hùng của ngươi là gì?
Dialogue: 0,0:10:57.24,0:10:59.41,Default,,0000,0000,0000,,Áo Choàng Hói...
Dialogue: 0,0:11:00.99,0:11:03.45,Default,,0000,0000,0000,,Nghe không rõ lắm, nhưng nghe\N như tên của một anh hùng đấy.
Dialogue: 0,0:11:04.66,0:11:07.96,Default,,0000,0000,0000,,Dù có yếu đến mấy, anh hùng thì vẫn phải bị ta săn.
Dialogue: 0,0:11:08.04,0:11:11.55,Default,,0000,0000,0000,,Không có tên trong tạp chí,\Nchắc là lính mới rồi.
Dialogue: 0,0:11:11.80,0:11:13.01,Default,,0000,0000,0000,,Nhóc con, mau về đi.
Dialogue: 0,0:11:15.13,0:11:17.43,Default,,0000,0000,0000,,Chú ơi, chú ăn quỵt à?
Dialogue: 0,0:11:18.14,0:11:21.06,Default,,0000,0000,0000,,Trông hắn có vẻ sẽ bỏ qua cho chú đấy,\Ntốt nhất đừng dính líu nữa.
Dialogue: 0,0:11:24.48,0:11:25.73,Default,,0000,0000,0000,,Đừng có giỡn mặt!
Dialogue: 0,0:11:27.10,0:11:29.06,Default,,0000,0000,0000,,Không chỉ bị Hiệp hội Quái Nhân từ chối,
Dialogue: 0,0:11:29.06,0:11:32.44,Default,,0000,0000,0000,,mà đến cả mấy anh hùng tép riu\Nhay lũ nhóc con cũng tỏ lòng thương hại,
Dialogue: 0,0:11:32.44,0:11:33.82,Default,,0000,0000,0000,,đúng là chạm đáy rồi!
Dialogue: 0,0:11:34.90,0:11:37.20,Default,,0000,0000,0000,,Nghe tin lão già đó sống sót,
Dialogue: 0,0:11:37.61,0:11:40.07,Default,,0000,0000,0000,,mà trong lòng lại thấy nhẹ nhõm, chết tiệt thật!
Dialogue: 0,0:11:40.83,0:11:42.95,Default,,0000,0000,0000,,Bỏ qua chuyện "định nghĩa quái nhân" đi,
Dialogue: 0,0:11:42.95,0:11:45.91,Default,,0000,0000,0000,,rõ ràng là bản thân mình\N vẫn còn thiếu quyết tâm.
Dialogue: 0,0:11:46.91,0:11:47.79,Default,,0000,0000,0000,,Được rồi, ta sẽ làm!
Dialogue: 0,0:11:48.50,0:11:51.25,Default,,0000,0000,0000,,Ta sẽ lấy một cái đầu anh hùng đem về!
Dialogue: 0,0:11:51.84,0:11:53.63,Default,,0000,0000,0000,,Đừng có xem thường ta!
Dialogue: 0,0:11:53.63,0:11:55.30,Default,,0000,0000,0000,,Ta là quái nhân!
Dialogue: 0,0:11:57.30,0:11:58.26,Default,,0000,0000,0000,,Này!
Dialogue: 0,0:11:58.26,0:12:00.43,Default,,0000,0000,0000,,Giờ ta sẽ...
Dialogue: 0,0:12:01.14,0:12:04.60,Default,,0000,0000,0000,,Xin lỗi nhé, tôi là đồng phạm,\Nđừng kéo tôi vào thêm nữa!
Dialogue: 0,0:12:12.77,0:12:14.61,Default,,0000,0000,0000,,Chết tiệt, lỡ tay rồi…
Dialogue: 0,0:12:14.78,0:12:17.07,Default,,0000,0000,0000,,Không định đấm bay hắn mà…
Dialogue: 0,0:12:17.99,0:12:20.61,Default,,0000,0000,0000,,Trời ơi, có nhân chứng nữa chứ!
Dialogue: 0,0:12:20.61,0:12:21.53,Default,,0000,0000,0000,,Cái quyển sách đó là gì vậy?
Dialogue: 0,0:12:22.28,0:12:24.58,Default,,0000,0000,0000,,Lại còn là một thằng nhóc\Nmê anh hùng nữa à?
Dialogue: 0,0:12:25.79,0:12:27.91,Default,,0000,0000,0000,,Chắc bị lộ thân phận rồi.
Dialogue: 0,0:12:27.91,0:12:28.87,Default,,0000,0000,0000,,Tiêu thật!
Dialogue: 0,0:12:30.25,0:12:32.13,Default,,0000,0000,0000,,Cháu có biết chú là ai không?
Dialogue: 0,0:12:34.38,0:12:35.09,Default,,0000,0000,0000,,Ế?
Dialogue: 0,0:12:36.80,0:12:37.97,Default,,0000,0000,0000,,Cho chú xem nó được không?
Dialogue: 0,0:12:40.38,0:12:41.39,Default,,0000,0000,0000,,Thật luôn?
Dialogue: 0,0:12:42.18,0:12:43.93,Default,,0000,0000,0000,,Hoàn toàn không có mình.
Dialogue: 0,0:12:43.93,0:12:44.89,Default,,0000,0000,0000,,Ra vậy.
Dialogue: 0,0:12:48.64,0:12:49.85,Default,,0000,0000,0000,,Là ai vậy trời?
Dialogue: 0,0:12:51.06,0:12:52.31,Default,,0000,0000,0000,,À đúng rồi!
Dialogue: 0,0:12:52.65,0:12:55.73,Default,,0000,0000,0000,,Chú ơi, tỉnh lại đi chú!
Dialogue: 0,0:12:56.78,0:12:58.19,Default,,0000,0000,0000,,One Punch Man!
Dialogue: 0,0:13:01.82,0:13:03.28,Default,,0000,0000,0000,,One Punch Man!
Dialogue: 0,0:13:18.21,0:13:19.92,Default,,0000,0000,0000,,Chú à, chú không sao chứ?
Dialogue: 0,0:13:20.67,0:13:24.55,Default,,0000,0000,0000,,Cái tên anh hùng đầu hói ấy,\Nhắn nói "lỡ tay rồi" rồi bỏ chạy đó!
Dialogue: 0,0:13:25.35,0:13:26.76,Default,,0000,0000,0000,,Ta thua sao?
Dialogue: 0,0:13:27.06,0:13:28.64,Default,,0000,0000,0000,,Hắn là anh hùng nào vậy?
Dialogue: 0,0:13:29.02,0:13:30.27,Default,,0000,0000,0000,,Chú không nhớ sao?
Dialogue: 0,0:13:30.94,0:13:32.60,Default,,0000,0000,0000,,Có lẽ bị đánh vào chỗ hiểm quá.
Dialogue: 0,0:13:33.98,0:13:35.82,Default,,0000,0000,0000,,Garou-kun!
Dialogue: 0,0:13:36.02,0:13:38.11,Default,,0000,0000,0000,,Cậu đang làm cái gì vậy?
Dialogue: 0,0:13:42.03,0:13:44.03,Default,,0000,0000,0000,,Ta vẫn luôn theo dõi cậu.
Dialogue: 0,0:13:45.03,0:13:49.58,Default,,0000,0000,0000,,Garou-kun đúng là khác chúng ta nhỉ?
Dialogue: 0,0:13:49.58,0:13:50.83,Default,,0000,0000,0000,,Ừ, khác thật!
Dialogue: 0,0:13:51.46,0:13:52.83,Default,,0000,0000,0000,,Thật đáng tiếc...
Dialogue: 0,0:13:52.83,0:13:56.92,Default,,0000,0000,0000,,Ta không cảm thấy trong ngươi\Ncó chất quái nhân nào cả.
Dialogue: 0,0:13:58.50,0:13:59.55,Default,,0000,0000,0000,,Này, thằng nhóc kia!
Dialogue: 0,0:14:00.34,0:14:02.42,Default,,0000,0000,0000,,Đừng có đứng ngây ra đó, mau về nhà đi!
Dialogue: 0,0:14:03.09,0:14:06.51,Default,,0000,0000,0000,,Bọn này hình như có chuyện muốn nói với ta.
Dialogue: 0,0:14:15.48,0:14:17.11,Default,,0000,0000,0000,,Hắn có trong cuốn tạp chí...
Dialogue: 0,0:14:17.57,0:14:19.57,Default,,0000,0000,0000,,Hóa ra không chỉ là lời đồn.
Dialogue: 0,0:14:21.36,0:14:24.20,Default,,0000,0000,0000,,Tại sao hắn lại ở chỗ này?
Dialogue: 0,0:14:25.82,0:14:27.20,Default,,0000,0000,0000,,Là Kirisaking!
Dialogue: 0,0:14:27.95,0:14:30.33,Default,,0000,0000,0000,,Hắn từng bắt cóc rất nhiều trẻ con.
Dialogue: 0,0:14:31.16,0:14:32.87,Default,,0000,0000,0000,,Là Kirisaking!
Dialogue: 0,0:14:34.75,0:14:36.33,Default,,0000,0000,0000,,Này, bình tĩnh lại đi!
Dialogue: 0,0:14:36.33,0:14:38.25,Default,,0000,0000,0000,,Đừng khóc nữa, đứng dậy mau!
Dialogue: 0,0:14:38.25,0:14:43.05,Default,,0000,0000,0000,,Không ngờ Garou-kun lại có\Nmột người bạn nhỏ tuổi như thế nhỉ.
Dialogue: 0,0:14:43.05,0:14:45.72,Default,,0000,0000,0000,,Này, dừng lại đi, ta sẽ nghe chuyện ở đây.
Dialogue: 0,0:14:45.72,0:14:48.01,Default,,0000,0000,0000,,Ồ, xin lỗi nhé.
Dialogue: 0,0:14:48.60,0:14:51.43,Default,,0000,0000,0000,,Ta chưa định làm thằng bé khóc đâu mà.
Dialogue: 0,0:14:51.97,0:14:53.14,Default,,0000,0000,0000,,Xin lỗi nhé.
Dialogue: 0,0:14:53.98,0:14:58.81,Default,,0000,0000,0000,,Ta định để dành tiếng thét sợ hãi\Ncủa nó cho sau này cơ…
Dialogue: 0,0:14:59.32,0:15:00.40,Default,,0000,0000,0000,,Xin lỗi nhé.
Dialogue: 0,0:15:01.28,0:15:02.94,Default,,0000,0000,0000,,Tội nghiệp thật.
Dialogue: 0,0:15:02.94,0:15:06.24,Default,,0000,0000,0000,,Nhưng đừng lo, ta sẽ từ từ xé nát\Ntoàn thân ngươi ra nhé.
Dialogue: 0,0:15:06.24,0:15:08.07,Default,,0000,0000,0000,,Xin lỗi nhé.
Dialogue: 0,0:15:09.95,0:15:11.12,Default,,0000,0000,0000,,Cậu bé à…
Dialogue: 0,0:15:11.58,0:15:14.46,Default,,0000,0000,0000,,Dù sao thì ngươi cũng chẳng thể\Nsống sót đâu, xin lỗi nhé.
Dialogue: 0,0:15:16.00,0:15:17.25,Default,,0000,0000,0000,,Lui lại đi.
Dialogue: 0,0:15:21.75,0:15:22.76,Default,,0000,0000,0000,,Xin phép!
Dialogue: 0,0:15:23.09,0:15:24.09,Default,,0000,0000,0000,,Tôi có chuyện muốn hỏi.
Dialogue: 0,0:15:24.47,0:15:27.05,Default,,0000,0000,0000,,Ta đang trong giờ thiền, đừng làm phiền.
Dialogue: 0,0:15:27.09,0:15:28.01,Default,,0000,0000,0000,,Chuyện gì?
Dialogue: 0,0:15:28.39,0:15:30.72,Default,,0000,0000,0000,,Tại sao ông lại phái Kirisaking và Mushigami đi?
Dialogue: 0,0:15:31.26,0:15:35.10,Default,,0000,0000,0000,,Nếu chỉ muốn quan sát, đâu cần\N gửi hai tên hiếu chiến đó chứ.
Dialogue: 0,0:15:35.10,0:15:37.90,Default,,0000,0000,0000,,Tại sao à? Biết đâu chúng lại hợp nhau thì sao?
Dialogue: 0,0:15:37.90,0:15:41.57,Default,,0000,0000,0000,,Nói gì vậy? Bọn đó có bao giờ\Nchịu nghe lệnh đâu?
Dialogue: 0,0:15:41.90,0:15:44.23,Default,,0000,0000,0000,,Kiểu gì chúng cũng hứng tay\Nmà giết chết Garou mất thôi.
Dialogue: 0,0:15:44.57,0:15:45.74,Default,,0000,0000,0000,,Đặc biệt là Kirisaking.
Dialogue: 0,0:15:45.74,0:15:48.41,Default,,0000,0000,0000,,Hắn là tên sát nhân điên loạn\Ntìm khoái cảm trong giết chóc.
Dialogue: 0,0:15:48.41,0:15:52.45,Default,,0000,0000,0000,,Ngay cả những quái nhân khác\N ở đây cũng tránh xa hắn.
Dialogue: 0,0:15:52.45,0:15:56.16,Default,,0000,0000,0000,,Ừ, chính vì thế ta mới để hắn tiếp xúc Garou.
Dialogue: 0,0:15:56.16,0:15:59.00,Default,,0000,0000,0000,,Gặp nhau sẽ tạo nên va chạm, và sự va chạm đó\N sẽ thúc đẩy Garo phát triển.
Dialogue: 0,0:15:59.29,0:16:00.17,Default,,0000,0000,0000,,Phát triển?
Dialogue: 0,0:16:00.50,0:16:03.55,Default,,0000,0000,0000,,Đây là thử thách dành cho hắn, kẻ còn đang do dự.
Dialogue: 0,0:16:03.88,0:16:08.55,Default,,0000,0000,0000,,Trước hết, hắn phải bị đánh cho\Ncả thân xác lẫn tinh thần nát bươm đã.
Dialogue: 0,0:16:09.22,0:16:14.26,Default,,0000,0000,0000,,Ta muốn xem, khi được nếm nỗi kinh hoàng của\Nmột quái nhân thật sự, Garou sẽ thay đổi thế nào.
Dialogue: 0,0:16:14.26,0:16:17.14,Default,,0000,0000,0000,,Gyoro Gyoro… rốt cuộc ông\N đang nhắm đến điều gì?
Dialogue: 0,0:16:17.14,0:16:19.98,Default,,0000,0000,0000,,Ông định lợi dụng Garou làm chuyện gì?
Dialogue: 0,0:16:20.06,0:16:21.65,Default,,0000,0000,0000,,Biết thì có ích gì nào?
Dialogue: 0,0:16:21.77,0:16:23.82,Default,,0000,0000,0000,,Chẳng có gì.\NTò mò thôi.
Dialogue: 0,0:16:23.94,0:16:28.95,Default,,0000,0000,0000,,Này, Phoenix Man, ngươi nghĩ\Nngài Orochi là loại quái nhân nào?
Dialogue: 0,0:16:29.20,0:16:32.41,Default,,0000,0000,0000,,Ai biết, một loài sinh vật cổ đại chăng?
Dialogue: 0,0:16:33.33,0:16:37.29,Default,,0000,0000,0000,,Ngài Orochi vốn dĩ cũng từng\Nlà con người, giống như Garo.
Dialogue: 0,0:16:38.41,0:16:42.71,Default,,0000,0000,0000,,Sau vô số thất bại và hi sinh, cuối cùng\Nngài ấy đã trở thành sinh vật tối thượng.
Dialogue: 0,0:16:42.71,0:16:46.09,Default,,0000,0000,0000,,Một sinh vật xứng đáng\N được gọi là Vua Quái Nhân.
Dialogue: 0,0:16:46.63,0:16:49.22,Default,,0000,0000,0000,,Và ngài Orochi là do ta tạo ra.
Dialogue: 0,0:16:49.22,0:16:51.34,Default,,0000,0000,0000,,Tạo ra? Là do ông sao?
Dialogue: 0,0:16:51.34,0:16:55.68,Default,,0000,0000,0000,,Nếu được nuôi dưỡng đúng cách,\NGarou-kun cũng có thể trở thành ngài Orochi thứ hai.
Dialogue: 0,0:16:55.68,0:16:58.39,Default,,0000,0000,0000,,Và bí quyết đó… chỉ mình ta biết.
Dialogue: 0,0:16:58.39,0:17:01.35,Default,,0000,0000,0000,,Ta đã dặn Mushigami rằng
Dialogue: 0,0:17:01.35,0:17:03.86,Default,,0000,0000,0000,,nếu Kirisaking có lỡ tay làm quá thì hãy ngăn lại.
Dialogue: 0,0:17:04.27,0:17:07.07,Default,,0000,0000,0000,,Nhưng nếu Garou chết thì cũng đành chịu vậy.
Dialogue: 0,0:17:07.07,0:17:10.36,Default,,0000,0000,0000,,Chúng ta sẽ chờ vật thí nghiệm\Ntiếp theo xuất hiện thôi.
Dialogue: 0,0:17:15.24,0:17:17.83,Default,,0000,0000,0000,,Việc điều tra xung quanh đã hoàn tất,\Ncửa sau cũng bị phong tỏa.
Dialogue: 0,0:17:18.41,0:17:21.00,Default,,0000,0000,0000,,Trong vài tiếng vừa rồi, ngoài con khỉ máy ra\Nthì không có ai ra vào cả.
Dialogue: 0,0:17:21.62,0:17:23.38,Default,,0000,0000,0000,,Những thành viên khác đều đã rời khỏi căn cứ.
Dialogue: 0,0:17:23.88,0:17:25.13,Default,,0000,0000,0000,,Giờ là thời điểm thích hợp.
Dialogue: 0,0:17:25.38,0:17:27.38,Default,,0000,0000,0000,,Bộ chỉ huy chắc chắn nằm bên trong.
Dialogue: 0,0:17:27.38,0:17:28.76,Default,,0000,0000,0000,,Có thể là ở phòng điều khiển.
Dialogue: 0,0:17:29.63,0:17:32.63,Default,,0000,0000,0000,,Một nhóm người lạ vừa chuyển đến gần đây,\Nthân phận không rõ ràng.
Dialogue: 0,0:17:33.39,0:17:36.47,Default,,0000,0000,0000,,Liên tục vận chuyển vào trong\N một lượng lớn thiết bị và bột bí ẩn.
Dialogue: 0,0:17:37.35,0:17:39.31,Default,,0000,0000,0000,,Còn có cả những thùng chứa vật thể tanh hôi.
Dialogue: 0,0:17:40.06,0:17:44.19,Default,,0000,0000,0000,,Các thông tin thu thập được\Nhoàn toàn khớp với dự đoán của tôi.
Dialogue: 0,0:17:45.19,0:17:46.11,Default,,0000,0000,0000,,Không còn nghi ngờ gì nữa.
Dialogue: 0,0:17:46.19,0:17:47.78,Default,,0000,0000,0000,,Chính là bọn chúng.
Dialogue: 0,0:17:47.78,0:17:50.28,Default,,0000,0000,0000,,Đến lúc rồi, xông vào!
Dialogue: 0,0:17:51.99,0:17:56.83,Default,,0000,0000,0000,,Bọn ta được Gyoro Gyoro-chan\Nlệnh giám sát Garou-kun đấy.
Dialogue: 0,0:17:57.33,0:18:01.71,Default,,0000,0000,0000,,Để xem cậu có thực sự xứng đáng\Nlàm đồng đội của bọn ta không.
Dialogue: 0,0:18:13.34,0:18:14.89,Default,,0000,0000,0000,,Kẻ săn anh hùng à...
Dialogue: 0,0:18:14.93,0:18:20.81,Default,,0000,0000,0000,,Ngươi chỉ là một con người bệnh hoạn,\Ngiả vờ làm quái nhân để thấy phấn khích,
Dialogue: 0,0:18:21.27,0:18:22.98,Default,,0000,0000,0000,,hay thật sự là Quái nhân?
Dialogue: 0,0:18:23.89,0:18:25.48,Default,,0000,0000,0000,,Ngươi nói cái giọng kẻ cả gì thế hả?
Dialogue: 0,0:18:25.81,0:18:29.27,Default,,0000,0000,0000,,Ta vừa thất vọng vì sự yếu kém\Ncủa các ngươi đấy.
Dialogue: 0,0:18:29.27,0:18:31.69,Default,,0000,0000,0000,,Vậy thì thử giết đứa trẻ đó xem nào.
Dialogue: 0,0:18:32.49,0:18:34.49,Default,,0000,0000,0000,,Lý lẽ kiểu quái gì vậy?
Dialogue: 0,0:18:34.99,0:18:38.24,Default,,0000,0000,0000,,Quái nhân là kẻ đã từ bỏ nhân tính,
Dialogue: 0,0:18:38.24,0:18:40.79,Default,,0000,0000,0000,,cắt đứt mọi ràng buộc với loài người.
Dialogue: 0,0:18:40.79,0:18:44.67,Default,,0000,0000,0000,,Ta đã thấy ngươi cứu thằng bé đó, Garo.
Dialogue: 0,0:18:44.67,0:18:47.46,Default,,0000,0000,0000,,Như thế là không được, ngươi phải giết nó.
Dialogue: 0,0:18:47.46,0:18:49.88,Default,,0000,0000,0000,,Muốn trở thành thành viên của Hiệp hội Quái Nhân,
Dialogue: 0,0:18:49.88,0:18:53.38,Default,,0000,0000,0000,,ngươi phải chứng minh mình đáng tin.
Dialogue: 0,0:18:53.38,0:18:56.72,Default,,0000,0000,0000,,Ngươi vẫn chưa hoàn toàn vứt bỏ\Nphần con người trong mình.
Dialogue: 0,0:18:56.72,0:18:59.97,Default,,0000,0000,0000,,Bọn ta không cần những kẻ nửa vời.
Dialogue: 0,0:18:59.97,0:19:03.56,Default,,0000,0000,0000,,Bọn ta là tổ chức sẽ phá hủy và thống trị loài người.
Dialogue: 0,0:19:03.56,0:19:05.89,Default,,0000,0000,0000,,Trẻ con à? Giết thoải mái thôi.
Dialogue: 0,0:19:05.89,0:19:09.11,Default,,0000,0000,0000,,Với lại ngươi vừa mới bị một anh hùng\Ntầm thường đánh bại còn gì.
Dialogue: 0,0:19:09.11,0:19:12.57,Default,,0000,0000,0000,,Dù là do sơ suất, nhưng thế thì ngươi\N chẳng có giá trị chiến đấu gì cả.
Dialogue: 0,0:19:13.36,0:19:14.15,Default,,0000,0000,0000,,Này!
Dialogue: 0,0:19:14.36,0:19:17.66,Default,,0000,0000,0000,,Ta đã bảo rồi, nhóc mau về đi!
Dialogue: 0,0:19:19.20,0:19:21.03,Default,,0000,0000,0000,,C-Chân cháu run quá, không đi nổi.
Dialogue: 0,0:19:21.99,0:19:23.58,Default,,0000,0000,0000,,Không thể cử động được.
Dialogue: 0,0:19:23.58,0:19:24.91,Default,,0000,0000,0000,,Đồ ngốc!
Dialogue: 0,0:19:25.12,0:19:28.29,Default,,0000,0000,0000,,Đừng có nghĩ rằng sẽ có ai đó chìa tay cứu\Nchỉ vì nhóc ngã xuống.
Dialogue: 0,0:19:28.71,0:19:30.59,Default,,0000,0000,0000,,Sẽ không ai đến cứu đâu.
Dialogue: 0,0:19:30.59,0:19:32.88,Default,,0000,0000,0000,,Nhóc phải tự bảo vệ chính mình!
Dialogue: 0,0:19:33.26,0:19:35.97,Default,,0000,0000,0000,,Trong những lúc như thế này,\Nchỉ có mạnh mẽ lên mới có thể sống sót!
Dialogue: 0,0:19:38.14,0:19:39.89,Default,,0000,0000,0000,,Chỉ cần mạnh lên là được.
Dialogue: 0,0:19:40.80,0:19:42.76,Default,,0000,0000,0000,,Đứng dậy đi, Tareo!
Dialogue: 0,0:20:22.68,0:20:23.26,Default,,0000,0000,0000,,Chạy đi!
Dialogue: 0,0:20:25.27,0:20:26.77,Default,,0000,0000,0000,,Không được rồi.
Dialogue: 0,0:20:26.89,0:20:30.06,Default,,0000,0000,0000,,Vậy là ngươi đã chọn làm kẻ thù của bọn ta rồi nhỉ.
Dialogue: 0,0:20:30.06,0:20:33.27,Default,,0000,0000,0000,,Kẻ săn anh hùng à, nghe đâu đến giờ\Nngươi vẫn chưa giết được một ai.
Dialogue: 0,0:20:33.65,0:20:36.61,Default,,0000,0000,0000,,Đúng như ta nghĩ, chỉ là một kẻ yếu đuối.
Dialogue: 0,0:20:36.90,0:20:40.41,Default,,0000,0000,0000,,Bọn ngươi đúng là khiến ta phát cáu.
Dialogue: 0,0:20:43.58,0:20:44.62,Default,,0000,0000,0000,,Tới đây!
Dialogue: 0,0:22:19.88,0:22:20.59,Default,,0000,0000,0000,,Cuối cùng...
Dialogue: 0,0:22:20.59,0:22:23.09,Default,,0000,0000,0000,,Cuối cùng ta cũng lần ra được rồi.
Dialogue: 0,0:22:23.80,0:22:25.84,Default,,0000,0000,0000,,Những kẻ ta theo đuổi suốt bao năm qua...
Dialogue: 0,0:22:26.30,0:22:27.93,Default,,0000,0000,0000,,những kẻ mang thâm thù đại hận.
Dialogue: 0,0:22:29.06,0:22:33.98,Default,,0000,0000,0000,,Tổ chức tồi tệ nhất lịch sử, những kẻ âm mưu\Ntiêu diệt loài người và thay đổi cả thế giới này.
Dialogue: 0,0:22:35.35,0:22:37.11,Default,,0000,0000,0000,,Qua những sự kiện gần đây,
Dialogue: 0,0:22:37.11,0:22:39.61,Default,,0000,0000,0000,,ta đã bắt đầu nghi ngờ danh tính thật của chúng.
Dialogue: 0,0:22:40.48,0:22:43.11,Default,,0000,0000,0000,,Dù mãi không tóm được dấu vết,
Dialogue: 0,0:22:44.40,0:22:47.03,Default,,0000,0000,0000,,nhưng lời tiên tri "trái đất đang lâm nguy"\N đã chỉ điểm rõ ràng.
Dialogue: 0,0:22:47.78,0:22:50.95,Default,,0000,0000,0000,,Chính những kẻ đứng sau\NHiệp hội Quái Nhân là thủ phạm!
Dialogue: 0,0:22:52.29,0:22:54.04,Default,,0000,0000,0000,,Tất cả đều do chúng gây ra.
Dialogue: 0,0:22:55.21,0:22:56.33,Default,,0000,0000,0000,,Không còn nghi ngờ gì nữa.
Dialogue: 0,0:23:01.34,0:23:04.55,Default,,0000,0000,0000,,Hôm nay là ngày tàn của các ngươi,\N Ngôi Nhà Tiến Hóa!
Dialogue: 0,0:23:04.93,0:23:05.59,Default,,0000,0000,0000,,Ô?
Dialogue: 0,0:23:05.59,0:23:08.55,Default,,0000,0000,0000,,Quý khách? Là quý khách hả?
Dialogue: 0,0:23:09.89,0:23:13.06,Default,,0000,0000,0000,,Thay đổi căn cứ liên tục,\Ngiờ lại giả làm tiệm bạch tuộc nướng à?
Dialogue: 0,0:23:13.85,0:23:15.14,Default,,0000,0000,0000,,Dám giỡn mặt ta hả!
Dialogue: 0,0:23:15.56,0:23:17.73,Default,,0000,0000,0000,,Ta đã biết rõ âm mưu của các ngươi rồi!
Dialogue: 0,0:23:18.15,0:23:19.02,Default,,0000,0000,0000,,Đừng hòng lừa ta nữa!
Dialogue: 0,0:23:19.86,0:23:22.73,Default,,0000,0000,0000,,Chờ chút nhé, tôi chuẩn bị xong ngay đây.
Dialogue: 0,0:23:24.82,0:23:27.82,Default,,0000,0000,0000,,Ta là anh hùng Zombie Man,
Dialogue: 0,0:23:27.82,0:23:29.66,Default,,0000,0000,0000,,kẻ mang thân thể không thể chết.
Dialogue: 0,0:23:31.08,0:23:35.58,Default,,0000,0000,0000,,Nghe đến mẫu thí nghiệm số 66 thì nhớ ra rồi chứ?
Dialogue: 0,0:23:36.16,0:23:38.75,Default,,0000,0000,0000,,Ủa, anh là người đã đến tiêu diệt\NNgồi Nhà Tiến Hóa à?
Dialogue: 0,0:23:39.13,0:23:42.42,Default,,0000,0000,0000,,Xin lỗi, nhưng Ngôi Nhà Tiến Hóa\Nđã bị tiêu diệt lâu rồi.
Dialogue: 0,0:23:46.59,0:23:50.47,Default,,0000,0000,0000,,À… vậy thì cho tôi vào trong chút nhé.
Dialogue: 0,0:23:50.80,0:23:52.81,Default,,0000,0000,0000,,Dạo này tôi rảnh rỗi quá mà.
Dialogue: 0,0:23:53.35,0:23:55.77,Default,,0000,0000,0000,,(Tiếp tục vào tập sau)
Dialogue: 0,0:23:56.27,0:24:00.86,Default,,0000,0000,0000,,(Giới hạn của sinh vật)

