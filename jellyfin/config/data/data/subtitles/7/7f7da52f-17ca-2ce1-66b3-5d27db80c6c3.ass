Dialogue: 0,0:00:20.58,0:00:22.75,Default,,0000,0000,0000,,{\fad(50,300)\pos(310,270)\bord0\fax-.3}رجل اللّكمة الواحدة
Dialogue: 0,0:01:40.99,0:01:45.70,Default,Sign,0000,0000,0000,,{\fad(0,500)\pos(482,242)\fs30}اجتماع استراتيجيّ
Dialogue: 0,0:01:41.53,0:01:44.66,Default,,0000,0000,0000,,{\an8}حين ظنّ الجميع أنّ الدّمار\N،سيضرب المدينة لا محالة
Dialogue: 0,0:01:44.66,0:01:48.13,Default,,0000,0000,0000,,{\an8}جاء هجومٌ هائل وسحق ذلك\N.المخلوق العملاق تمامًا
Dialogue: 0,0:01:48.24,0:01:52.30,Default,,0000,0000,0000,,أتقصد أنّ الحريش العظيم\Nاختفى دون أن يترك أثرًا؟
Dialogue: 0,0:01:52.87,0:01:57.18,Default,,0000,0000,0000,,هذا صعب التّصديق، لكنّه إنجاز\N.لا يقدر عليه سوى كينغ
Dialogue: 0,0:01:57.29,0:02:00.26,Default,,0000,0000,0000,,.نحن محظوظون حقًّا لكون كينغ حليفنا
Dialogue: 0,0:02:00.26,0:02:05.32,Default,,0000,0000,0000,,أمّا بخصوص صائد الأبطال، فقد سمعت \N.أنّ النّاب الفضّيّ فشل في القبض عليه
Dialogue: 0,0:02:05.38,0:02:07.64,Default,,0000,0000,0000,,ما الّذي تنوي فعله حيال ذلك يا سيتش؟
Dialogue: 0,0:02:07.84,0:02:09.65,Default,,0000,0000,0000,,،إن واصل صيد الأبطال على هذا النّحو
Dialogue: 0,0:02:09.65,0:02:12.32,Default,,0000,0000,0000,,.فإنّ جمعيّة الأبطال ستنهار تمامًا
Dialogue: 0,0:02:13.18,0:02:18.12,Default,,0000,0000,0000,,يجب الكفّ عن النّظّر إلى غارو\N.كبشريّ ومعاملته كوحش الآن
Dialogue: 0,0:02:18.27,0:02:20.28,Default,,0000,0000,0000,,...في المرّة القادمة الّتي يظهر فيها
Dialogue: 0,0:02:20.44,0:02:22.28,Default,,0000,0000,0000,,سيُصنَّف كتهديدٍ من مستوى تنّين
Dialogue: 0,0:02:22.28,0:02:24.63,Default,,0000,0000,0000,,.ويجب إعلان حالة الطّوارئ في الحال
Dialogue: 0,0:02:24.94,0:02:27.30,Default,,0000,0000,0000,,لكنّه ما يزال بشريًّا، أليس كذلك؟
Dialogue: 0,0:02:27.86,0:02:31.99,Default,,0000,0000,0000,,أيستطيع أن يقف أيّ شخص عاديّ\Nفي وجه أبطالنا من الفئة س وهو أعزل؟
Dialogue: 0,0:02:31.99,0:02:33.43,Default,,0000,0000,0000,,.فكّروا في الأمر فحسب
Dialogue: 0,0:02:33.87,0:02:35.60,Default,,0000,0000,0000,,ربّما الاستراتيجيّة هي المشكلة؟
Dialogue: 0,0:02:35.83,0:02:37.21,Default,,0000,0000,0000,,{\i1}أبطالنا من الفئة س؟
Dialogue: 0,0:02:37.21,0:02:40.14,Default,,0000,0000,0000,,{\i1}حتّى في هذه اللّحظة، ما زال\N.يتعامل مع الأمر كأنّه صفقة تجاريّة
Dialogue: 0,0:02:40.75,0:02:45.06,Default,,0000,0000,0000,,لم يكن متوقّعًا أن يعجز النّاب الفضّيّ\N،في القضاء على غارو
Dialogue: 0,0:02:45.06,0:02:47.73,Default,,0000,0000,0000,,.لكنّه على الأقلّ تركه مصابًا بجراحٍ خطيرة
Dialogue: 0,0:02:48.18,0:02:52.82,Default,,0000,0000,0000,,وهذا يعني أنّه على الأقلّ\N.لن ينضمّ إلى قوّات جمعيّة الوحوش
Dialogue: 0,0:02:52.93,0:02:55.36,Default,,0000,0000,0000,,.على الأقلّ، يمكننا اعتباره فوزًا لنا
Dialogue: 0,0:02:55.36,0:02:57.53,Default,,0000,0000,0000,,!أحضروا بلاست إلى هنا! بلاست لا غير
Dialogue: 0,0:02:57.73,0:03:00.49,Default,,0000,0000,0000,,إنّه في القمّة، ومع ذلك\N!لا يفعل شيئًا إطلاقًا، صحيح؟
Dialogue: 0,0:03:00.65,0:03:03.83,Default,,0000,0000,0000,,.من المستحيل إصدار أوامر لبلاست
Dialogue: 0,0:03:03.94,0:03:08.12,Default,,0000,0000,0000,,.إنّه يعمل كبطلٍ طوعًا فقط
Dialogue: 0,0:03:08.61,0:03:12.37,Default,,0000,0000,0000,,إنّه يرفض الخضوع لأيّ أحد\N،ويكره جذب الأنظار إليه
Dialogue: 0,0:03:12.37,0:03:15.09,Default,,0000,0000,0000,,.حتّى اسمه الحقيقيّ مخفيّ في السّجلاّت
Dialogue: 0,0:03:15.49,0:03:20.47,Default,,0000,0000,0000,,لكنّنا نعامله معاملةً خاصّة\N.لأنّنا نؤمن بأنّه يستحقّها
Dialogue: 0,0:03:20.67,0:03:24.30,Default,,0000,0000,0000,,،ومع ذلك، إن احتاجت البشريّة إليه حقًّا
Dialogue: 0,0:03:24.30,0:03:26.35,Default,,0000,0000,0000,,.أنا واثق أنّه سيتحرّك عندها
Dialogue: 0,0:03:26.35,0:03:28.02,Default,,0000,0000,0000,,!وماذا تعني بهذا؟
Dialogue: 0,0:03:28.02,0:03:32.56,Default,,0000,0000,0000,,!حان ذلك الوقت بالفعل\N!لقد اختطف وحشٌ ابني
Dialogue: 0,0:03:32.97,0:03:35.39,Default,,0000,0000,0000,,!مرّ على ذلك أربعٌ وعشرون ساعة
Dialogue: 0,0:03:35.39,0:03:37.69,Default,,0000,0000,0000,,!لماذا لم تهاجموا بعد؟
Dialogue: 0,0:03:37.89,0:03:40.45,Default,,0000,0000,0000,,.أنا أعدك. سننقذ ابنك
Dialogue: 0,0:03:41.10,0:03:42.03,Default,,0000,0000,0000,,ومن تكون أنت؟
Dialogue: 0,0:03:42.40,0:03:45.33,Default,,0000,0000,0000,,.سأتولّى قيادة عمليّة الإنقاذ هذه
Dialogue: 0,0:03:45.52,0:03:47.29,Default,,0000,0000,0000,,.اسمي سيكينغال
Dialogue: 0,0:03:47.86,0:03:49.67,Default,,0000,0000,0000,,.تشرّفتُ بلقائكم
Dialogue: 0,0:03:50.20,0:03:51.29,Default,,0000,0000,0000,,ماذا؟
Dialogue: 0,0:03:51.82,0:03:53.97,Default,,0000,0000,0000,,أيّ عمليّة؟
Dialogue: 0,0:03:54.20,0:03:58.30,Default,,0000,0000,0000,,.سأتدخّل بنفسي وأُنهي الأمر بسرعة
Dialogue: 0,0:03:58.50,0:04:00.42,Default,,0000,0000,0000,,هل نعرف مكان مخبئهم؟
Dialogue: 0,0:04:00.71,0:04:03.64,Default,,0000,0000,0000,,يعمل الطّفل الإمبراطور الآن\N.بأقصى سرعته لتحديده
Dialogue: 0,0:04:04.34,0:04:09.27,Default,,0000,0000,0000,,أرسلتُ روبوتات الاستطلاع لتتبع\N.مسار الحريش العظيم تحت الأرض
Dialogue: 0,0:04:09.63,0:04:12.89,Default,,0000,0000,0000,,...لكنّ المنطقة واسعة جدًّا\Nلدينا ثلاثة أيّام، أليس كذلك؟
Dialogue: 0,0:04:12.89,0:04:14.02,Default,,0000,0000,0000,,.بقي يومان فقط
Dialogue: 0,0:04:14.30,0:04:16.45,Default,,0000,0000,0000,,!كلاّ... هذا يعني أنّي لن أنام
Dialogue: 0,0:04:16.68,0:04:20.49,Default,,0000,0000,0000,,الملجأ موجود في البلدة المهجورة\Nللمدينة زد، أليس كذلك؟
Dialogue: 0,0:04:20.64,0:04:22.90,Default,,0000,0000,0000,,هل أدمّرها فحسب؟
Dialogue: 0,0:04:20.69,0:04:26.07,Default,Sign,0000,0000,0000,,{\an8}"انفجار"
Dialogue: 0,0:04:22.90,0:04:26.07,Default,,0000,0000,0000,,،يجب أن نتحرّك بحذر\N.فالمسألة تتعلّق برهينة
Dialogue: 0,0:04:26.27,0:04:28.58,Default,,0000,0000,0000,,.يبدو الأمر مزعجًا
Dialogue: 0,0:04:28.69,0:04:31.67,Default,,0000,0000,0000,,لو لم يحتجزوا رهينة، لما كانت\N.لهم أيّ فرصة أمامي
Dialogue: 0,0:04:32.07,0:04:34.58,Default,,0000,0000,0000,,.لا بدّ أنّ الوحوش خائفة منّي
Dialogue: 0,0:04:34.58,0:04:36.58,Default,,0000,0000,0000,,.خصومنا هذه المرّة أقوياء للغاية
Dialogue: 0,0:04:36.58,0:04:38.05,Default,,0000,0000,0000,,.نعم، نعم
Dialogue: 0,0:04:38.29,0:04:42.01,Default,,0000,0000,0000,,هل استدعيتنا فقط لتحذّرنا من هذا؟
Dialogue: 0,0:04:44.54,0:04:45.60,Default,,0000,0000,0000,,...في الواقع
Dialogue: 0,0:04:45.71,0:04:48.39,Default,,0000,0000,0000,,تابع الفارس المندفع التّحقيق\N.بمفرده البارحة رغم الأوامر
Dialogue: 0,0:04:48.55,0:04:53.27,Default,,0000,0000,0000,,تجاهل تحذيراتنا\N.ودخل البلدة المهجورة قبلنا
Dialogue: 0,0:04:53.84,0:04:55.14,Default,,0000,0000,0000,,!لماذا ذهب وحده؟
Dialogue: 0,0:04:55.51,0:05:00.24,Default,,0000,0000,0000,,،لم يخسر أيّ معركة من قبل\N.لا بدّ أنّ ثقته بنفسه كانت عالية
Dialogue: 0,0:05:00.64,0:05:05.00,Default,,0000,0000,0000,,لكن منذ اللّيلة الماضية، لم نلتقط أيّ\N.إشارة من جهاز الإرسال الخاصّ به
Dialogue: 0,0:05:05.77,0:05:09.63,Default,,0000,0000,0000,,.يبدو أنّه بإمكاننا الافتراض أنّه قد هُزم
Dialogue: 0,0:05:11.19,0:05:12.79,Default,,0000,0000,0000,,.لا يهمّني الأمر أصلاً
Dialogue: 0,0:05:12.79,0:05:15.67,Default,,0000,0000,0000,,.عليك أن تسرع في تجميع فريقك
Dialogue: 0,0:05:15.82,0:05:17.25,Default,,0000,0000,0000,,من بقي غيرنا؟
Dialogue: 0,0:05:17.74,0:05:21.85,Default,,0000,0000,0000,,.منحتنا جمعيّة الوحوش مهلةً من ثلاثة أيّام
Dialogue: 0,0:05:21.95,0:05:23.26,Default,,0000,0000,0000,,.ما يزال لدينا بعض الوقت
Dialogue: 0,0:05:24.37,0:05:28.64,Default,,0000,0000,0000,,،حالما يستعدّ بقيّة الأبطال\N.سيتحرّكون للانضمام إلينا
Dialogue: 0,0:05:29.96,0:05:32.51,Default,,0000,0000,0000,,ما زالوا في وضع الانتظار؟\Nما الّذي يحدث؟
Dialogue: 0,0:05:32.97,0:05:35.23,Default,,0000,0000,0000,,هناك طفل يُحتجز كرهينة؟
Dialogue: 0,0:05:35.51,0:05:38.15,Default,,0000,0000,0000,,ألم تعرف بذلك أيّها السّاموراي الذّرّيّ؟
Dialogue: 0,0:05:38.39,0:05:40.69,Default,,0000,0000,0000,,.كما أنّه تنبعث منك رائحة الدّم
Dialogue: 0,0:05:41.22,0:05:44.53,Default,,0000,0000,0000,,منذ البارحة، وأنا أُفتّش الجبال والكهوف
Dialogue: 0,0:05:44.53,0:05:49.16,Default,,0000,0000,0000,,،بحثًا عن الوحوش المختبئة\N.وأقتل كلّ من أصادفه منها
Dialogue: 0,0:05:49.94,0:05:53.95,Default,,0000,0000,0000,,لكن للأسف، لم أستطع العثور\N.على مخبأ جمعيّة الوحوش
Dialogue: 0,0:05:54.32,0:05:55.46,Default,,0000,0000,0000,,.هذا منطقيّ
Dialogue: 0,0:05:55.61,0:05:59.21,Default,,0000,0000,0000,,سمعت أنّ مخبأ جمعيّة الوحوش\N.يقع في البلدة المهجورة
Dialogue: 0,0:05:59.21,0:06:01.68,Default,,0000,0000,0000,,!ماذا؟! نعرف هذا القدر بالفعل؟
Dialogue: 0,0:06:02.20,0:06:05.72,Default,,0000,0000,0000,,يبدو أنّ القتال وجهًا لوجه هناك\N.أسهل ممّا توقّعت
Dialogue: 0,0:06:06.29,0:06:08.70,Default,,0000,0000,0000,,أقترح أن نأخذ جميعًا قسطًا\N.من الرّاحة حتّى ذلك الحين
Dialogue: 1,0:06:08.70,0:06:11.18,Default,,0000,0000,0000,,{\an3\pos(386,340)}.حسنًا –\N.سأذهب للاستحمام –
Dialogue: 0,0:06:12.96,0:06:13.86,Default,,0000,0000,0000,,!يا إلهي
Dialogue: 0,0:06:14.47,0:06:18.03,Default,,0000,0000,0000,,سمعت أنّ فرقة الهجوم ستتكوّن\N...من نخبة محدودة، لكن
Dialogue: 0,0:06:18.43,0:06:21.45,Default,,0000,0000,0000,,لسبب ما، ثمّة أشخاص هنا\N.لا يبدون مؤهّلين للمشاركة
Dialogue: 0,0:06:21.93,0:06:23.41,Default,,0000,0000,0000,,.هذه ليست نزهة
Dialogue: 0,0:06:23.85,0:06:28.25,Default,,0000,0000,0000,,فلنحاول ألاّ نحضر أصدقاءنا المقرّبين\N.هذه المرّة أيّها السّاموراي الذّرّيّ
Dialogue: 0,0:06:29.31,0:06:31.92,Default,,0000,0000,0000,,أفضّل أن يقوم الضّعفاء\N.بمقاتلة الضّعفاء أمثالهم فحسب
Dialogue: 0,0:06:32.19,0:06:33.25,Default,,0000,0000,0000,,أتفهم ما أعنيه؟
Dialogue: 0,0:06:33.48,0:06:35.95,Default,,0000,0000,0000,,...لا بأس إن ماتوا، لكن
Dialogue: 0,0:06:35.95,0:06:38.46,Default,,0000,0000,0000,,ماذا لو استُخدموا كرهائن أو دروعٍ بشريّة؟
Dialogue: 0,0:06:38.66,0:06:40.54,Default,,0000,0000,0000,,.سيكون ذلك عبئًا كبيرًا علينا
Dialogue: 0,0:06:40.99,0:06:45.30,Default,,0000,0000,0000,,إن حدث ذلك يومًا، هل يمكنك\Nأن تأمرهم بشقّ بطونهم؟
Dialogue: 0,0:06:45.37,0:06:47.32,Default,,0000,0000,0000,,...على مهلك يا سيّد وسيم
Dialogue: 0,0:06:47.32,0:06:50.09,Default,,0000,0000,0000,,أماي ماسك، هل أنت في الفريق؟
Dialogue: 0,0:06:50.46,0:06:55.76,Default,,0000,0000,0000,,.بالطّبع. قاطعت تلك الوحوش حفلي
Dialogue: 0,0:06:55.96,0:07:00.65,Default,,0000,0000,0000,,.فهمت، فهمت. إنّ تلاميذي أقوياء
Dialogue: 0,0:07:00.76,0:07:04.48,Default,,0000,0000,0000,,سأخبرهم بحماية معبود\Nالجماهير الوسيم الصّغير
Dialogue: 0,0:07:04.48,0:07:06.74,Default,,0000,0000,0000,,.عندما يقع في مأزق ما
Dialogue: 0,0:07:06.93,0:07:08.74,Default,,0000,0000,0000,,.لذلك أرح بالك
Dialogue: 0,0:07:08.74,0:07:10.20,Default,,0000,0000,0000,,في مأزق؟
Dialogue: 0,0:07:10.60,0:07:14.79,Default,,0000,0000,0000,,لا أصدّق أنّ هناك من لا يزال\N.يشكّ بقدراتي القتاليّة
Dialogue: 0,0:07:15.23,0:07:18.70,Default,,0000,0000,0000,,أنا أبقى في الفئة أ فقط لأنّه من\N.السّهل عليّ مراقبة الأمور هكذا
Dialogue: 0,0:07:18.70,0:07:20.67,Default,,0000,0000,0000,,.بإمكاني الارتقاء للفئة س متى شئت
Dialogue: 0,0:07:21.53,0:07:23.47,Default,,0000,0000,0000,,.حسنًا إذًا
Dialogue: 0,0:07:23.78,0:07:26.26,Default,,0000,0000,0000,,...سأبسّط الأمر حتّى يفهمه أبلهٌ مثلك
Dialogue: 0,0:07:26.70,0:07:28.30,Default,,0000,0000,0000,,.أنا أقوى منك
Dialogue: 0,0:07:28.30,0:07:31.68,Default,,0000,0000,0000,,ماذا؟ أأنت جادّ؟
Dialogue: 0,0:07:31.68,0:07:34.30,Default,,0000,0000,0000,,{\i1}!معلّمي! لا تفقد أعصابك رجاءً
Dialogue: 0,0:07:35.97,0:07:41.06,Default,,0000,0000,0000,,أيّها المأمور، أوثق أنّ بإمكاني\Nالخروج من الباب الرّئيسيّ مباشرة؟
Dialogue: 0,0:07:41.06,0:07:43.90,Default,,0000,0000,0000,,.هذا إجراء خارج نطاق القانون
Dialogue: 0,0:07:44.22,0:07:49.15,Default,,0000,0000,0000,,دعني أذكّرك أنّك في كلّ مرّة هربتَ\N،فيها من السّجن للقيام بعمل بطوليّ
Dialogue: 0,0:07:49.15,0:07:50.94,Default,,0000,0000,0000,,.كانت تُعدّ مخالفة صريحة
Dialogue: 0,0:07:51.85,0:07:56.25,Default,,0000,0000,0000,,لا يُعجبني كيف تمنح جمعيّة\N.الأبطال شخصًا مثلك معاملة خاصّة
Dialogue: 0,0:07:56.48,0:07:58.46,Default,,0000,0000,0000,,.لكنّي لا أستطيع الاعتراض هذه المرّة
Dialogue: 0,0:07:59.54,0:08:03.54,Default,,0000,0000,0000,,ظهر وحشٌ يشبه القطّ
Dialogue: 0,0:08:03.54,0:08:06.50,Default,,0000,0000,0000,,وحوّل عددًا من السّجناء\N.إلى وحوش، ثمّ أخذهم معه
Dialogue: 0,0:08:06.79,0:08:10.26,Default,,0000,0000,0000,,.لقا الكثير من الضّبّاط الّذين واجهوه حتفهم
Dialogue: 0,0:08:10.58,0:08:12.77,Default,,0000,0000,0000,,أنت بطل في الخارج، أليس كذلك؟
Dialogue: 0,0:08:12.83,0:08:14.73,Default,,0000,0000,0000,,أليس كذلك يا زعيم السّجناء؟
Dialogue: 0,0:08:15.34,0:08:18.10,Default,,0000,0000,0000,,!انتقم من أجلنا
Dialogue: 0,0:08:18.76,0:08:20.07,Default,,0000,0000,0000,,.اتركوا الأمر لي
Dialogue: 0,0:08:20.63,0:08:26.11,Default,,0000,0000,0000,,سأجعلهم يدفعون ثمنًا باهظًا\N.لما فعلوه بهذا المكان أثناء غيابي
Dialogue: 0,0:08:26.93,0:08:28.62,Default,,0000,0000,0000,,!انتظر يا زعيم
Dialogue: 0,0:08:29.14,0:08:31.24,Default,,0000,0000,0000,,.حِكتُ لك سترة صوفيّة
Dialogue: 0,0:08:31.60,0:08:33.07,Default,,0000,0000,0000,,.ارتدِها إن أحببت
Dialogue: 0,0:08:37.02,0:08:40.04,Default,,0000,0000,0000,,.شكرًا لك ستمنحني الشّجاعة
Dialogue: 0,0:08:42.65,0:08:43.62,Default,,0000,0000,0000,,.اسمعوا
Dialogue: 0,0:08:43.91,0:08:45.88,Default,,0000,0000,0000,,هلاّ خرجتم من الغرفة قليلاً؟
Dialogue: 0,0:08:45.95,0:08:47.88,Default,,0000,0000,0000,,.لا أستطيع التّركيز وأنتم تحدّقون بي
Dialogue: 0,0:08:50.62,0:08:51.81,Default,,0000,0000,0000,,.أيّها الفارس المعدنيّ
Dialogue: 0,0:08:51.87,0:08:54.68,Default,,0000,0000,0000,,أعلم أنّك تتظاهر بأنّك لست \N.هناك، أجبني من فضلك
Dialogue: 0,0:08:55.79,0:08:56.94,Default,,0000,0000,0000,,{\i1}ماذا؟
Dialogue: 0,0:08:57.04,0:09:00.39,Default,,0000,0000,0000,,.أشعر أنّني أُهدر الكثير من الوقت والجهد
Dialogue: 0,0:09:01.92,0:09:04.99,Default,,0000,0000,0000,,لا بدّ أنّك اكتشفت مكان\Nالمخبأ الآن، أليس كذلك؟
Dialogue: 0,0:09:05.09,0:09:07.76,Default,,0000,0000,0000,,.أخبرني رجاءً، فالوقت يداهمنا
Dialogue: 0,0:09:07.76,0:09:09.73,Default,,0000,0000,0000,,هل ستسمح بموت الرّهينة؟
Dialogue: 0,0:09:10.64,0:09:14.04,Default,,0000,0000,0000,,{\i1}.قد يموت الرّهينة إن لم أخبرك
Dialogue: 0,0:09:14.10,0:09:19.12,Default,,0000,0000,0000,,{\i1}لكن إن أخبرتك، فلن أجلب الموت\N.للرّهينة فقط، بل لكم جميعًا
Dialogue: 0,0:09:19.27,0:09:23.58,Default,,0000,0000,0000,,{\i1}سأتّخذ القرار العقلانيّ\N.الّذي تمليه عليّ العدالة
Dialogue: 0,0:09:23.58,0:09:25.71,Default,,0000,0000,0000,,.هناك خيار آخر
Dialogue: 0,0:09:25.71,0:09:27.79,Default,,0000,0000,0000,,.انضمّ إلينا في العمليّة
Dialogue: 0,0:09:28.28,0:09:30.72,Default,,0000,0000,0000,,ممّ تخاف بالضّبط؟
Dialogue: 0,0:09:30.79,0:09:33.68,Default,,0000,0000,0000,,ما حالة جسدك الآليّ حاليًّا؟
Dialogue: 0,0:09:34.04,0:09:37.59,Default,,0000,0000,0000,,إن كان قد دُمّر فعلاً، فأيّ\Nوحش فعل بك ذلك؟ وكيف؟
Dialogue: 0,0:09:38.92,0:09:40.90,Default,,0000,0000,0000,,{\i1}.ملك الوحوش، أوروتشي
Dialogue: 0,0:09:41.64,0:09:43.25,Default,,0000,0000,0000,,{\i1}.بضربة واحدة فقط
Dialogue: 0,0:09:43.25,0:09:45.14,Default,,0000,0000,0000,,{\i1}دُمّرت الذّراع الّتي استخدمتها\N.لصدّ الهجوم تمامًا
Dialogue: 0,0:09:45.14,0:09:47.40,Default,,0000,0000,0000,,{\i1}.حتّى جهاز التّدمير الذّاتيّ عُطّل
Dialogue: 0,0:09:48.55,0:09:51.62,Default,,0000,0000,0000,,...لستُ أخشى جمعيّة الوحوش
Dialogue: 0,0:09:52.27,0:09:55.62,Default,,0000,0000,0000,,.تترصّد قوى الشّرّ فرصتها لتستولي على العالم
Dialogue: 0,0:09:55.89,0:09:58.20,Default,,0000,0000,0000,,،وحين تضعف دفاعات البشريّة
Dialogue: 0,0:09:58.20,0:10:00.32,Default,,0000,0000,0000,,ستنقضّ كلّها دفعةً واحدة\N.لتستولي على كلّ شيء
Dialogue: 0,0:10:00.57,0:10:02.38,Default,,0000,0000,0000,,{\i1}.كن حذرًا
Dialogue: 0,0:10:02.53,0:10:05.17,Default,,0000,0000,0000,,{\i1}.لا تثق بأحدٍ من حولك
Dialogue: 0,0:10:05.53,0:10:08.26,Default,,0000,0000,0000,,{\i1}،إن أردت أن تُقيم العدالة\N.فافعل ذلك وحدك
Dialogue: 0,0:10:08.62,0:10:10.75,Default,,0000,0000,0000,,{\i1}...قوّ نفسك
Dialogue: 0,0:10:10.75,0:10:13.05,Default,,0000,0000,0000,,{\i1}وادّخر قوّتك للّحظة المناسبة\N.أيّها الطّفل الإمبراطور
Dialogue: 0,0:10:18.75,0:10:21.27,Default,,0000,0000,0000,,.جمعيّة الأبطال عديمة الفائدة
Dialogue: 0,0:10:21.34,0:10:22.56,Default,,0000,0000,0000,,!اسمعوني جميعًا
Dialogue: 0,0:10:22.75,0:10:26.53,Default,,0000,0000,0000,,في هذه اللّحظة، يرتجف ابني\N.من الخوف وهو ينتظر من ينقذه
Dialogue: 0,0:10:26.88,0:10:30.95,Default,,0000,0000,0000,,توجّهوا فورًا إلى المنطقة المهجورة\N!في المدينة زد وابحثوا عن مخبأ الوحوش
Dialogue: 0,0:10:31.01,0:10:32.74,Default,,0000,0000,0000,,!وأنقذوا ابني
Dialogue: 0,0:10:33.02,0:10:37.08,Default,,0000,0000,0000,,البدلات القتاليّة الّتي ترتدونها هي أسلحةٌ\N.سرّيّة حصلنا عليها عبر طرق خاصّة
Dialogue: 0,0:10:37.39,0:10:42.03,Default,,0000,0000,0000,,.يفوق أداؤها قوّة أيّ بطلٍ محترف بسهولة
Dialogue: 0,0:10:42.03,0:10:46.24,Default,Sign,0000,0000,0000,,{\an8}"قوّات نارينكي الخاصّة"
Dialogue: 0,0:10:42.23,0:10:44.08,Default,,0000,0000,0000,,استخدموا البدلات القتاليّة إلى أقصى حدّ
Dialogue: 0,0:10:44.15,0:10:46.24,Default,,0000,0000,0000,,!واقضوا على كلّ وحشٍ تصادفونه
Dialogue: 0,0:10:46.86,0:10:48.92,Default,,0000,0000,0000,,!سأدفع ما تشاؤون كمكافأةٍ على النّجاح
Dialogue: 0,0:10:49.16,0:10:52.88,Default,,0000,0000,0000,,أعيدوا واغانما حيًّا وستعيشون\N!في رخاء لأجيالٍ قادمة
Dialogue: 0,0:10:52.95,0:10:53.92,Default,,0000,0000,0000,,!انطلقوا
Dialogue: 0,0:10:59.76,0:11:03.69,Default,,0000,0000,0000,,.واثق أنّه ذلك المبنى الصّغير هناك
Dialogue: 0,0:11:04.55,0:11:05.94,Default,,0000,0000,0000,,!لا مهرب من هذا الآن
Dialogue: 0,0:11:07.72,0:11:10.15,Default,,0000,0000,0000,,{\i1}.أُبيدت مجموعة العاصفة الثّلجيّة بالكامل
Dialogue: 0,0:11:10.34,0:11:12.65,Default,,0000,0000,0000,,{\i1}.يقع نصفُ اللّوم على أختي أيضًا
Dialogue: 0,0:11:13.51,0:11:15.03,Default,,0000,0000,0000,,{\i1}.هذه حالة طارئة
Dialogue: 0,0:11:15.39,0:11:19.45,Default,,0000,0000,0000,,{\i1}سأستخدم هذا المكان فرعًا مؤقّتًا لمجموعة \N.العاصفة الثّلجيّة لعقد اجتماعٍ عاجل
Dialogue: 0,0:11:20.10,0:11:21.16,Default,,0000,0000,0000,,.مهلاً لحظة
Dialogue: 0,0:11:21.48,0:11:22.87,Default,,0000,0000,0000,,يا سايتا— من تكون؟
Dialogue: 0,0:11:23.24,0:11:25.49,Default,,0000,0000,0000,,ماذا؟ أأنت صديقة؟
Dialogue: 0,0:11:25.94,0:11:28.42,Default,,0000,0000,0000,,!لديك ضيفة يا سايتاما
Dialogue: 0,0:11:30.33,0:11:33.11,Default,,0000,0000,0000,,.جاءت العاصفة الثّلجيّة ثانية
Dialogue: 0,0:11:33.11,0:11:38.22,Default,,0000,0000,0000,,مهلاً، لماذا الوحش الّذي ربّيته\Nمات بضربةٍ واحدة منك؟
Dialogue: 0,0:11:38.46,0:11:40.39,Default,,0000,0000,0000,,ماذا تريدين أيّتها العاصفة\Nالثّلجيّة الجهنّميّة؟
Dialogue: 0,0:11:40.54,0:11:42.58,Default,,0000,0000,0000,,.لا يقبل معلّمي أيّ تلاميذ جدد
Dialogue: 0,0:11:42.58,0:11:44.19,Default,,0000,0000,0000,,.نتأسّف لأنّ المكان مكتظّ
Dialogue: 0,0:11:44.25,0:11:46.90,Default,,0000,0000,0000,,هلاّ ناولتني ذلك المرهم من فضلك؟
Dialogue: 0,0:11:47.18,0:11:49.42,Default,,0000,0000,0000,,لماذا تكون الرّياح نقطة ضعف الأرض؟
Dialogue: 0,0:11:49.42,0:11:51.99,Default,,0000,0000,0000,,لكنّي في المستوى 27 وأنت\N.في المستوى 15 كما هو واضح
Dialogue: 0,0:11:52.14,0:11:56.32,Default,,0000,0000,0000,,حتّى لو كنتَ في أعلى مستوى، لن يستطيع \N.الغولم العجوز هزيمة أنواع مياو-مياو
Dialogue: 0,0:11:56.64,0:11:58.24,Default,,0000,0000,0000,,.إنّه شخصيّة ضعيفة في الأساس
Dialogue: 0,0:11:58.35,0:12:00.44,Default,,0000,0000,0000,,.ماذا؟ كان عليك أن تخبرني بهذا من قبل
Dialogue: 0,0:12:00.44,0:12:02.66,Default,,0000,0000,0000,,{\an3\pos(386,340)}...وشخصيّة الإبط هذه –\N.إنّها ضعيفة أيضًا –
Dialogue: 0,0:12:02.73,0:12:05.32,Default,,0000,0000,0000,,في الحقيقة، الشّخصيّات اللّطيفة\N.فقط هي القويّة
Dialogue: 0,0:12:05.32,0:12:07.58,Default,,0000,0000,0000,,.انس الأمر. أفسد ذلك اللّعبة عليّ
Dialogue: 0,0:12:08.03,0:12:09.42,Default,,0000,0000,0000,,{\i1}ما الّذي يحدث هنا؟
Dialogue: 0,0:12:10.15,0:12:11.91,Default,,0000,0000,0000,,ماذا؟ لِمَ أنت هنا؟
Dialogue: 0,0:12:11.91,0:12:13.17,Default,,0000,0000,0000,,.الأمر طارئ
Dialogue: 0,0:12:13.17,0:12:15.47,Default,,0000,0000,0000,,!قُضي على مجموعة العاصفة الثّلجيّة
Dialogue: 0,0:12:15.53,0:12:17.84,Default,,0000,0000,0000,,.جمعيّة الوحوش خطيرة للغاية
Dialogue: 0,0:12:17.99,0:12:20.01,Default,,0000,0000,0000,,!هذا ليس الوقت المناسب للّعب
Dialogue: 0,0:12:20.01,0:12:22.47,Default,,0000,0000,0000,,هل لديك أدنى فكرة ما الّذي يحدث الآن؟
Dialogue: 0,0:12:23.08,0:12:24.73,Default,,0000,0000,0000,,.لا حاجة للصّراخ
Dialogue: 0,0:12:25.04,0:12:28.01,Default,,0000,0000,0000,,عدتُ إلى المنزل منذ قليل فقط\N.وكنتُ آخذ قسطًا من الرّاحة
Dialogue: 0,0:12:28.01,0:12:29.43,Default,,0000,0000,0000,,!لا تستلقي الآن
Dialogue: 0,0:12:29.43,0:12:33.44,Default,,0000,0000,0000,,كما قال معلّمي، واجهنا\N.نحن أيضًا خصومًا أقوياء
Dialogue: 0,0:12:33.80,0:12:35.49,Default,,0000,0000,0000,,.لا تظنّي أنّكم وحدكم من قاتلوا بضراوة
Dialogue: 0,0:12:35.60,0:12:39.03,Default,,0000,0000,0000,,.صحيح، ذلك واضح بالنّظر إليكم
Dialogue: 0,0:12:39.68,0:12:41.69,Default,,0000,0000,0000,,،أعلم أنّ كينغ كان هنا من قبل
Dialogue: 0,0:12:41.69,0:12:44.70,Default,,0000,0000,0000,,لكن ما الّذي يفعله النّاب الفضّيّ هنا الآن؟
Dialogue: 0,0:12:45.23,0:12:50.34,Default,,0000,0000,0000,,قاتلتُ إلى جانبهما، لذا سمح لي\N.سايتاما بأن أستريح هنا
Dialogue: 0,0:12:50.53,0:12:54.54,Default,,0000,0000,0000,,بالغتُ قليلاً في القتال، فأصبتُ\N.في ظهري ولم أعد أقدر على الحركة
Dialogue: 0,0:12:54.54,0:12:56.13,Default,,0000,0000,0000,,.كما أنّ ركبتاي قد خانتاني أيضًا
Dialogue: 0,0:12:56.24,0:12:59.47,Default,,0000,0000,0000,,إنّ استعمال قبضة كي المزمجر الممزّقة \N.للهواء بعد كلّ هذا الوقت أرهقني تمامًا
Dialogue: 0,0:12:59.91,0:13:03.01,Default,,0000,0000,0000,,.فهمت، لا بدّ أنّها كانت معركةً طاحنة
Dialogue: 0,0:13:03.38,0:13:07.19,Default,,0000,0000,0000,,{\i1}لكن لماذا؟ لماذا يبدو \Nهذا الرّجل كما هو دائمًا؟
Dialogue: 0,0:13:07.47,0:13:11.34,Default,,0000,0000,0000,,،يا سايتاما! تتصرّف وكأنّك هادئ ومتّزن\N لكّنك في الواقع قلق، أليس كذلك؟
Dialogue: 0,0:13:11.34,0:13:13.43,Default,,0000,0000,0000,,.ليس تمامًا... الأمر عاديّ كالعادة
Dialogue: 0,0:13:13.43,0:13:14.39,Default,,0000,0000,0000,,ماذا؟
Dialogue: 0,0:13:14.39,0:13:16.90,Default,,0000,0000,0000,,!لا يمكن أن يكون الوضع عاديًّا كما تقول
Dialogue: 0,0:13:17.26,0:13:18.95,Default,,0000,0000,0000,,لماذا هي غاضبة هكذا؟
Dialogue: 0,0:13:19.31,0:13:23.15,Default,,0000,0000,0000,,،أكره أن أقول هذا\N.لكنّ الوضع ليس كالمعتاد أبدًا
Dialogue: 0,0:13:23.39,0:13:24.36,Default,,0000,0000,0000,,{\an8}"ضرب، ضرب"
Dialogue: 0,0:13:23.39,0:13:24.79,Default,,0000,0000,0000,,!تعال واجلس
Dialogue: 0,0:13:25.10,0:13:27.53,Default,,0000,0000,0000,,!سنعقد اجتماعًا لوضع استراتيجيّة الآن
Dialogue: 0,0:13:26.40,0:13:27.36,Default,Sign,0000,0000,0000,,{\an8}"ضرب، ضرب"
Dialogue: 0,0:13:27.53,0:13:28.99,Default,,0000,0000,0000,,أنا جادّ، لماذا أنتِ هنا؟
Dialogue: 0,0:13:29.15,0:13:31.63,Default,,0000,0000,0000,,.جينوس! أنت بطل من الفئة س
Dialogue: 0,0:13:31.69,0:13:35.04,Default,,0000,0000,0000,,ألم يخبرك كبار جمعيّة الأبطال\Nبخطوتهم التّالية؟
Dialogue: 0,0:13:37.03,0:13:38.83,Default,,0000,0000,0000,,كنتُ أساند معلّمي سايتاما بالأمس
Dialogue: 0,0:13:38.83,0:13:42.05,Default,,0000,0000,0000,,،في بطولة فنون القتال\N.كما خضتُ معركةً أنا أيضًا
Dialogue: 0,0:13:42.41,0:13:46.28,Default,,0000,0000,0000,,ناهيك عن ذكر أنّ جهاز الجمعيّة\N.للإرسال انصهر وتدمّر
Dialogue: 0,0:13:46.28,0:13:49.44,Default,,0000,0000,0000,,.أمّا أنا فقد أسقطتُ جهازي في شقٍّ بالأرض
Dialogue: 0,0:13:49.68,0:13:51.76,Default,,0000,0000,0000,,.وأنا اكتشفتُ أنّ جهازي تحطّم هو الآخر
Dialogue: 0,0:13:51.76,0:13:54.31,Default,,0000,0000,0000,,لعلّ ذلك بسبب موجات\N.الصّدمة النّاتجة عن لكمة سايتاما
Dialogue: 0,0:13:54.63,0:13:56.18,Default,,0000,0000,0000,,ما خطوتنا التّالية إذًا؟
Dialogue: 0,0:13:56.18,0:13:58.81,Default,,0000,0000,0000,,.نحن على شفا حربٍ ضدّ الوحوش
Dialogue: 0,0:13:58.97,0:14:01.03,Default,,0000,0000,0000,,.عليّ أن أخضع لإصلاحاتٍ أوّلاً
Dialogue: 0,0:14:01.14,0:14:03.19,Default,,0000,0000,0000,,.نعم، هذا واضح
Dialogue: 0,0:14:03.19,0:14:07.30,Default,,0000,0000,0000,,سنحتاج بعض الوقت لنستعيد عافيتنا \N.قبل أن نعود إلى القتال مجدّدًا
Dialogue: 0,0:14:07.30,0:14:08.82,Default,,0000,0000,0000,,.لا أحد يستطيع هزيمة التّقدّم في العمر
Dialogue: 0,0:14:09.36,0:14:10.28,Default,,0000,0000,0000,,ماذا عنك يا كينغ؟
Dialogue: 0,0:14:10.28,0:14:13.20,Default,,0000,0000,0000,,أظنّ أن لديّ بعض الأمور الأخرى\N...الّتي عليّ القيام بها
Dialogue: 0,0:14:13.44,0:14:16.50,Default,,0000,0000,0000,,إذًا أنا وسايتاما هما الوحيدان\N.الجاهزان للتّحرّك
Dialogue: 0,0:14:17.20,0:14:18.63,Default,,0000,0000,0000,,ما رأيك إذًا؟
Dialogue: 0,0:14:18.78,0:14:22.80,Default,,0000,0000,0000,,ربّما لدى المقرّ الرّئيسيّ قوّات\N.خاصّة تعمل على وضع الخطط
Dialogue: 0,0:14:23.25,0:14:24.42,Default,,0000,0000,0000,,،لكن في مثل هذه الأوقات
Dialogue: 0,0:14:24.42,0:14:28.93,Default,,0000,0000,0000,,قد تؤثّر تصرّفات الأبطال من الفئة ب\N.وما دون على تقييمهم مستقبلاً
Dialogue: 0,0:14:29.13,0:14:31.39,Default,,0000,0000,0000,,.لذا ينبغي أن نحاول فعل شيءٍ نُسهم به
Dialogue: 0,0:14:31.39,0:14:32.89,Default,Sign,0000,0000,0000,,{\an8}"دائخ"
Dialogue: 0,0:14:31.80,0:14:32.89,Default,,0000,0000,0000,,هل تسمعني؟
Dialogue: 0,0:14:33.46,0:14:34.81,Default,,0000,0000,0000,,إنّ العدوّ هذه المرّة
Dialogue: 0,0:14:34.81,0:14:39.69,Default,,0000,0000,0000,,مجموعةٌ كبيرة من الوحوش كانت تعمل عادةً \N.بشكلٍ منفصل، لكنّها اتّحدت، وذلك أمرٌ نادر
Dialogue: 0,0:14:40.51,0:14:43.32,Default,,0000,0000,0000,,على الأرجح أنّ هيكلهم التّنظيميّ
Dialogue: 0,0:14:43.52,0:14:48.37,Default,,0000,0000,0000,,،يعتمد على السّيطرة أكثر من التّعاون\N.تحت قيادة زعيمٍ واحدٍ يُصدر الأوامر
Dialogue: 0,0:14:48.52,0:14:51.12,Default,,0000,0000,0000,,.هذا صحيح، جماعة وحوش
Dialogue: 0,0:14:51.52,0:14:55.23,Default,,0000,0000,0000,,،إن كان غارو قد انضمّ إليها\N.فذلك سيُسبّب لنا المتاعب
Dialogue: 0,0:14:55.23,0:15:00.01,Default,,0000,0000,0000,,ربّما لن نحصل على فرصةٍ\N.أخرى لمواجهة غارو وحده
Dialogue: 0,0:15:00.07,0:15:04.50,Default,,0000,0000,0000,,وإذا كان ما زال لديها وحوشٌ أقوياء\N،مثل ذلك الحريش العملاق
Dialogue: 0,0:15:04.50,0:15:05.67,Default,,0000,0000,0000,,.فلا يبشّر الوضع بخير
Dialogue: 0,0:15:05.67,0:15:08.05,Default,,0000,0000,0000,,قد يكون من الأفضل لك\N.أن تعتزل كونك بطلاً يا بانغ
Dialogue: 0,0:15:08.05,0:15:09.22,Default,,0000,0000,0000,,.يا سايتاما
Dialogue: 0,0:15:09.33,0:15:12.85,Default,,0000,0000,0000,,يبدو أنّ صائد الأبطال الّذي كنتَ\N،تبحث عنه كان في تلك المنطقة
Dialogue: 0,0:15:12.92,0:15:14.77,Default,,0000,0000,0000,,.لكنّك وصلت متأخّرًا
Dialogue: 0,0:15:15.13,0:15:19.03,Default,,0000,0000,0000,,سمعتُ في طريقي إلى المنزل\N.أنّه سعى خلف مزيد من الأبطال
Dialogue: 0,0:15:21.30,0:15:22.40,Default,,0000,0000,0000,,.ما فعله لا يُغتفر
Dialogue: 0,0:15:22.55,0:15:25.32,Default,,0000,0000,0000,,.خصوصًا وأنّه لم يأتِ سعيًا خلفي بعد
Dialogue: 0,0:15:25.39,0:15:26.83,Default,,0000,0000,0000,,هل السّبب لأنّي الأصلع ذو الرّداء؟
Dialogue: 0,0:15:28.14,0:15:29.85,Default,,0000,0000,0000,,سايتاما؟ –\Nمعلّمي؟ –
Dialogue: 0,0:15:29.85,0:15:31.08,Default,,0000,0000,0000,,.سأخرج لبعض الوقت
Dialogue: 0,0:15:31.74,0:15:33.74,Default,,0000,0000,0000,,هل تعرف أين يوجد غارو؟
Dialogue: 0,0:15:33.98,0:15:35.17,Default,,0000,0000,0000,,.سأبحث عنه بنفسي
Dialogue: 0,0:15:35.94,0:15:38.59,Default,,0000,0000,0000,,.وعندما أجده، سألكمه
Dialogue: 0,0:15:40.11,0:15:41.92,Default,,0000,0000,0000,,وسأشتري بعض الملفوف\N.الصّينيّ في طريقي إلى المنزل
Dialogue: 0,0:15:45.66,0:15:48.93,Default,,0000,0000,0000,,{\i1}ها أنا كنتُ أقود النّقاش قبل قليل\N...فقط لأجد نفسي مستبعدةً مجدّدًا
Dialogue: 0,0:15:49.37,0:15:51.47,Default,,0000,0000,0000,,{\i1}لن تكون محاولة إقناع سايتاما ورفاقه
Dialogue: 0,0:15:51.47,0:15:53.48,Default,,0000,0000,0000,,{\i1}بالانضمام إلى جماعة العاصفة\N.الثّلجيّة مهمّةً سهلة
Dialogue: 0,0:16:06.40,0:16:09.58,Default,,0000,0000,0000,,{\i1}أين أنا؟ هل نجوت؟
Dialogue: 0,0:16:09.73,0:16:11.29,Default,,0000,0000,0000,,{\i1}.ذاكرتي مشوّشة بعض الشّيء
Dialogue: 0,0:16:12.40,0:16:14.58,Default,,0000,0000,0000,,{\i1}.مرحبًا بك في جمعيّة الوحوش
Dialogue: 0,0:16:14.81,0:16:18.95,Default,,0000,0000,0000,,{\i1}،بما أنّك تقرأ هذه الرّسالة\N.فهذا يعني أنّك نجوت
Dialogue: 0,0:16:19.40,0:16:23.34,Default,,0000,0000,0000,,{\i1}.اعلم أنّنا نحن من أنقذ حياتك
Dialogue: 0,0:16:23.41,0:16:27.34,Default,,0000,0000,0000,,{\i1}لذا انتظر بهدوءٍ في هذه\N.الغرفة ولا تُسبّب أيّ متاعب
Dialogue: 0,0:16:27.54,0:16:30.85,Default,,0000,0000,0000,,{\i1}إن خرجت الآن، فستصبح\N.هدفًا للأبطال لا غير
Dialogue: 0,0:16:31.08,0:16:32.97,Default,,0000,0000,0000,,{\i1}.ما تحتاج إليه هو مكانٌ تنتمي إليه
Dialogue: 0,0:16:33.08,0:16:36.43,Default,,0000,0000,0000,,{\i1}.هناك بعض الملابس، لا تتردّد في استخدامها
Dialogue: 0,0:16:38.21,0:16:42.23,Default,,0000,0000,0000,,{\i1}!كم هذا مؤلم! الألم ينهش جسدي كلّه
Dialogue: 0,0:16:42.59,0:16:45.77,Default,,0000,0000,0000,,{\i1}...أشعر بالعطش، وأحتاج إلى طعام
Dialogue: 0,0:16:45.77,0:16:47.78,Default,,0000,0000,0000,,{\i1}.لإعادة تزويد دمائي
Dialogue: 0,0:16:50.68,0:16:55.41,Default,,0000,0000,0000,,{\i1}كنتُ أقاتل العجوز، ثمّ ظهر\N...ذلك الطّائر اللّعين
Dialogue: 0,0:16:55.77,0:16:58.41,Default,,0000,0000,0000,,{\i1}.جمعيّة الوحوش...  إنّها تثير أعصابي
Dialogue: 0,0:16:58.98,0:17:00.38,Default,,0000,0000,0000,,{\i1}ماذا حدث للعجوز؟
Dialogue: 0,0:17:00.69,0:17:02.34,Default,,0000,0000,0000,,{\i1}...كان يقاتل ذلك الحريش
Dialogue: 0,0:17:03.15,0:17:04.38,Default,,0000,0000,0000,,{\i1}...لا بأس، لا يهمّ
Dialogue: 0,0:17:05.03,0:17:08.09,Default,,0000,0000,0000,,{\i1}.تملأ رائحة الدّم الهواء الرّاكد
Dialogue: 0,0:17:08.41,0:17:09.47,Default,,0000,0000,0000,,{\i1}.إنّها تثير غثياني
Dialogue: 0,0:17:09.79,0:17:12.47,Default,,0000,0000,0000,,{\i1}.الصّمت يخيّم لدرجة أنّ أذناي ترنّان
Dialogue: 0,0:17:12.62,0:17:14.55,Default,,0000,0000,0000,,{\i1}هل أنا في أعماق الأرض؟
Dialogue: 0,0:17:14.55,0:17:15.68,Default,,0000,0000,0000,,{\i1}...لا يهمّ
Dialogue: 0,0:17:18.80,0:17:21.22,Default,,0000,0000,0000,,!أرجوك، ارحمنا! كنّا مخطئين
Dialogue: 0,0:17:21.22,0:17:23.89,Default,,0000,0000,0000,,!لن نجابهكم مرّةً أخرى أبدًا
Dialogue: 0,0:17:23.89,0:17:26.10,Default,,0000,0000,0000,,!لا، لا أريد أن أموت
Dialogue: 0,0:17:26.10,0:17:30.63,Default,,0000,0000,0000,,.لكنّكم قضيتم على اثنين من جنودي
Dialogue: 0,0:17:30.63,0:17:33.36,Default,,0000,0000,0000,,.لا يمكنني أن أدعكم ترحلون بسهولة
Dialogue: 0,0:17:33.64,0:17:37.41,Default,,0000,0000,0000,,،زوّدكم مشغّلكم بمعدّاتٍ قويّة
Dialogue: 0,0:17:37.41,0:17:39.29,Default,,0000,0000,0000,,.فقاتلوا حتّى النّهاية
Dialogue: 0,0:17:39.48,0:17:44.42,Default,,0000,0000,0000,,يعشق الجميع هنا تحويل كلّ\N.من يقاوم إلى لعبةٍ يتسلّون بها
Dialogue: 0,0:17:44.78,0:17:47.58,Default,,0000,0000,0000,,!تبًّا... كلّ هذا خطؤه
Dialogue: 0,0:17:47.58,0:17:50.63,Default,,0000,0000,0000,,،اللّعنة، لو لم يظهر ذلك الرّوبوت الغريب
Dialogue: 0,0:17:50.63,0:17:52.34,Default,,0000,0000,0000,,.لكُنّا تمكّنّا من الفرار إلى السّطح
Dialogue: 0,0:17:52.54,0:17:54.56,Default,,0000,0000,0000,,.يبدو أنّ الدّعاية قد نجحت
Dialogue: 0,0:17:54.71,0:17:56.42,Default,,0000,0000,0000,,.شكرًا على الهديّة
Dialogue: 0,0:17:56.42,0:17:59.51,Default,,0000,0000,0000,,.يسعدني انضمام وافد جديد بهذه الكفاءة
Dialogue: 0,0:17:59.51,0:18:01.40,Default,,0000,0000,0000,,.اجتزتَ الاختبار بامتياز
Dialogue: 0,0:18:01.46,0:18:04.10,Default,,0000,0000,0000,,ما اسمك أيّها المستجدّ؟
Dialogue: 0,0:18:04.38,0:18:06.23,Default,,0000,0000,0000,,.أنا الآليّ الإله جي 5
Dialogue: 0,0:18:04.51,0:18:10.81,Default,Sign,0000,0000,0000,,{\an8}"مستوى التّهديد: شيطان"\N"الآليّ الإله جي 5"
Dialogue: 0,0:18:06.59,0:18:10.81,Default,,0000,0000,0000,,أُرسلت من قِبَل المنظّمة لمساعدة\N.جمعيّة الوحوش
Dialogue: 0,0:18:10.81,0:18:12.07,Default,,0000,0000,0000,,المنظّمة"؟"
Dialogue: 0,0:18:12.22,0:18:14.98,Default,,0000,0000,0000,,كيف وصلت إلى هذا المخبأ دون أن تضيع؟
Dialogue: 0,0:18:14.98,0:18:16.74,Default,,0000,0000,0000,,أيمكنني التّحدّث إلى صانعك؟
Dialogue: 0,0:18:17.78,0:18:19.82,Default,,0000,0000,0000,,.حسنٌ إذًا. على أيّ حال، نرحّب بانضمامك إلينا
Dialogue: 0,0:18:19.82,0:18:21.66,Default,,0000,0000,0000,,.ثمّ إنّ لدينا وافدًا آخر أيضًا
Dialogue: 0,0:18:21.66,0:18:25.00,Default,,0000,0000,0000,,{\i1}.ابقَ مختبئًا وانتظر قليلاً بعد يا غارو
Dialogue: 0,0:18:25.58,0:18:29.08,Default,,0000,0000,0000,,{\i1}!صوتٌ في رأسي مباشرة\Nأهو تخاطرٌ ذهنيّ؟
Dialogue: 0,0:18:29.08,0:18:32.75,Default,,0000,0000,0000,,لقد واجهتهم بنفسي، وأستطيع القول
Dialogue: 0,0:18:32.75,0:18:37.76,Default,,0000,0000,0000,,أنّ دروعهم القتاليّة بالغة\N.القوّة وذات قيمةٍ كبيرة
Dialogue: 0,0:18:38.25,0:18:41.35,Default,,0000,0000,0000,,غير أنّها تبدو مخصّصةً\N.لكلّ مستخدمٍ على حدة
Dialogue: 0,0:18:41.46,0:18:45.64,Default,,0000,0000,0000,,لذا لا يستطيع أحدٌ غيرهم\N.استخدامها، فضلاً عن الوحوش
Dialogue: 0,0:18:45.64,0:18:49.60,Default,,0000,0000,0000,,أي أنّ علينا أن نُبقيهم أحياء\N.ونستخدمهم كبيادق في خططنا
Dialogue: 0,0:18:51.10,0:18:54.87,Default,,0000,0000,0000,,.إذًا أنتم ملكي. سأدرّبكم كما ينبغي
Dialogue: 0,0:18:56.39,0:18:57.90,Default,,0000,0000,0000,,تدريب؟ ما الّذي تعنينه بذلك؟
Dialogue: 0,0:18:57.90,0:18:59.57,Default,,0000,0000,0000,,!دعونا نرحل فحسب
Dialogue: 0,0:19:00.06,0:19:01.21,Default,,0000,0000,0000,,!اخرسوا
Dialogue: 0,0:19:07.40,0:19:13.13,Default,,0000,0000,0000,,ممتاز! يا لي من محظوظة\N!بعبيدٍ واعدين كهؤلاء
Dialogue: 0,0:19:23.43,0:19:26.18,Default,,0000,0000,0000,,.مرحبًا يا غارو. استيقظت باكرًا
Dialogue: 0,0:19:26.18,0:19:27.93,Default,,0000,0000,0000,,{\an3\pos(386,340)}.إذًا ذاك هو صائد الأبطال –\N...تمّ إنقاذه –
Dialogue: 0,0:19:27.93,0:19:29.81,Default,,0000,0000,0000,,{\an3\pos(386,340)}.إنّه يعجبني –\N.وعولجت إصاباته –
Dialogue: 0,0:19:29.81,0:19:32.81,Default,,0000,0000,0000,,لماذا يهتمّ غيورو-غيورو ببشريّ تافه؟
Dialogue: 0,0:19:32.81,0:19:35.15,Default,,0000,0000,0000,,{\an3\pos(386,340)}أهو بشريّ أم وحش؟ –\N!اصمتوا –
Dialogue: 0,0:19:35.39,0:19:37.78,Default,,0000,0000,0000,,.سأجري معه محادثةً مهمّة الآن
Dialogue: 0,0:19:38.14,0:19:40.45,Default,,0000,0000,0000,,{\i1}ما ذلك العملاق في الخلف؟
Dialogue: 0,0:19:41.23,0:19:42.91,Default,,0000,0000,0000,,ماذا تريدني أن أفعل؟
Dialogue: 0,0:19:43.11,0:19:47.04,Default,,0000,0000,0000,,بعد المعركة الأخيرة، لم يبقَ سوى أقلّ
Dialogue: 0,0:19:47.04,0:19:49.83,Default,,0000,0000,0000,,من 30 وحشًا من مستوى تهديد\N.الشّيطان أو أعلى
Dialogue: 0,0:19:50.16,0:19:53.05,Default,,0000,0000,0000,,.ما زلنا رغم ذلك أقوياء بما يكفي لنفوز
Dialogue: 0,0:19:53.28,0:19:57.96,Default,,0000,0000,0000,,لكن ما نفتقر إليه الآن\N.هو الوحدة... وقائد يجمعنا
Dialogue: 0,0:19:58.41,0:20:02.23,Default,,0000,0000,0000,,أودّ منك أن تصير عضوًا\N.من القيادة وتساعدني
Dialogue: 0,0:20:02.68,0:20:04.23,Default,,0000,0000,0000,,قائد بهذه السّرعة؟
Dialogue: 0,0:20:04.29,0:20:05.80,Default,,0000,0000,0000,,.عرض مغرٍ للغاية
Dialogue: 0,0:20:06.00,0:20:07.51,Default,,0000,0000,0000,,كنت أبحث عن شخصٍ
Dialogue: 0,0:20:07.51,0:20:12.19,Default,,0000,0000,0000,,.يملك فكرًا قويًّا مناهضًا للأبطال مثله
Dialogue: 0,0:20:12.51,0:20:14.52,Default,,0000,0000,0000,,،إنّه يعمل وحده
Dialogue: 0,0:20:14.52,0:20:18.82,Default,,0000,0000,0000,,لكن رغم ما ناله من جراح، فإنّ طريقته\N،في مهاجمة الأبطال من الفئة س
Dialogue: 0,0:20:18.82,0:20:20.08,Default,,0000,0000,0000,,.تستحقّ الإشادة حقًّا
Dialogue: 0,0:20:21.28,0:20:24.87,Default,,0000,0000,0000,,.غير أنّ زعيمنا أوروتشي له شرطٌ واحد
Dialogue: 0,0:20:25.24,0:20:29.16,Default,,0000,0000,0000,,.أثبِت أنّك وحشٌ حقيقيّ
Dialogue: 0,0:20:29.16,0:20:30.79,Default,,0000,0000,0000,,أتريدني أن أنبت قرنًا مثلاً؟
Dialogue: 0,0:20:30.79,0:20:32.37,Default,,0000,0000,0000,,.أمامك يومٌ واحد
Dialogue: 0,0:20:32.61,0:20:36.04,Default,,0000,0000,0000,,،أحضر لي رأس أحد الأبطال\N.ولا يهمّ من يكون
Dialogue: 0,0:20:36.41,0:20:37.92,Default,,0000,0000,0000,,...إن كنت تسعى خلف حياة بطلٍ ما
Dialogue: 0,0:20:37.92,0:20:39.71,Default,,0000,0000,0000,,،يؤسفني أن أبلغك بأخبار سيّئة
Dialogue: 0,0:20:39.71,0:20:42.17,Default,,0000,0000,0000,,.لكنّ النّاب الفضّيّ والبقيّة ما زالوا أحياء
Dialogue: 0,0:20:42.17,0:20:44.18,Default,,0000,0000,0000,,.وهُزم الحريش العظيم
Dialogue: 0,0:20:48.50,0:20:52.39,Default,,0000,0000,0000,,.أعتذر على الإزعاج، لكن لديّ طلب
Dialogue: 0,0:20:52.39,0:20:54.63,Default,,0000,0000,0000,,ما الّذي تريده؟
Dialogue: 0,0:20:52.77,0:20:54.64,Default,,0000,0000,0000,,{\an8}"مستوى التّهديد: شيطان"\N"إله الحشرات"
Dialogue: 0,0:20:54.63,0:20:56.95,Default,,0000,0000,0000,,.أنا توّاق بشدّة إلى سماع صرخة بشريّ
Dialogue: 0,0:20:55.05,0:21:00.53,Default,Sign,0000,0000,0000,,{\an8}"مستوى التّهديد: شيطان"\N"الملك الممزِّق"
Dialogue: 0,0:20:57.01,0:21:00.53,Default,,0000,0000,0000,,.أوشك على فقدان رشدي. لنسرع
Dialogue: 0,0:21:00.53,0:21:02.61,Default,,0000,0000,0000,,.ذهب غارو للخارج
Dialogue: 0,0:21:03.39,0:21:04.66,Default,,0000,0000,0000,,.اتبعاه
Dialogue: 0,0:22:36.86,0:22:38.66,Default,,0000,0000,0000,,.هُزم غوكيتسو البارحة
Dialogue: 0,0:22:38.66,0:22:41.22,Default,,0000,0000,0000,,.واليوم، هُزم الحريش العظيم
Dialogue: 0,0:22:41.33,0:22:44.50,Default,,0000,0000,0000,,لا أظنّ أنّه حتّى غيورو-غيورو توقّع\Nأن يخسر اثنان من أقوى الوحوش
Dialogue: 0,0:22:44.50,0:22:46.56,Default,,0000,0000,0000,,.قبل المعركة الحاسمة
Dialogue: 0,0:22:46.62,0:22:50.76,Default,,0000,0000,0000,,ألهذا يحاول ضمّ صائد الأبطال؟\N ليجعله أحد المقاتلين الرّئيسيّين؟
Dialogue: 0,0:22:50.76,0:22:53.06,Default,,0000,0000,0000,,.لا أفهم ما يدور في رأس غيورو-غيورو
Dialogue: 0,0:22:53.13,0:22:55.27,Default,,0000,0000,0000,,.مع أنّي لستُ مهتمًّا بالأمر أصلاً
Dialogue: 0,0:22:55.51,0:22:58.60,Default,,0000,0000,0000,,طالما أستطيع تدمير جمعيّة الأبطال\N.والوميض، فذلك يكفيني
Dialogue: 0,0:22:59.09,0:23:02.56,Default,,0000,0000,0000,,،لقد ضممنا سرعة الصّوت سونيك\Nلكن ما الّذي حلّ به؟
Dialogue: 0,0:23:02.56,0:23:04.07,Default,,0000,0000,0000,,.لم أره في الجوار
Dialogue: 0,0:23:04.18,0:23:06.53,Default,,0000,0000,0000,,.ربّما لم يتحمّل خلايا الوحوش
Dialogue: 0,0:23:10.65,0:23:14.54,Default,,0000,0000,0000,,،عانيتُ طوال اللّيل\N.لكن يبدو أن الأسوأ قد مرّ
Dialogue: 0,0:23:14.99,0:23:17.20,Default,,0000,0000,0000,,.كم أكره أولئك الأوغاد في جمعيّة الوحوش
Dialogue: 0,0:23:17.20,0:23:19.55,Default,,0000,0000,0000,,!لم يخبرني أحد أنّ معدتي ستنقلب هكذا
Dialogue: 0,0:23:19.61,0:23:21.17,Default,,0000,0000,0000,,.سأجعلهم يدفعون الثّمن يومًا ما
Dialogue: 0,0:23:23.24,0:23:24.13,Default,,0000,0000,0000,,.لا يهمّ
Dialogue: 0,0:23:24.54,0:23:27.51,Default,,0000,0000,0000,,.لم تكن نيّتي أبدًا أن أتحالف مع الوحوش
Dialogue: 0,0:23:27.51,0:23:30.13,Default,,0000,0000,0000,,.أردت فقط استغلالهم لمصالحي
Dialogue: 0,0:23:30.13,0:23:32.85,Default,,0000,0000,0000,,.هدفي الوحيد هو سايتاما
Dialogue: 0,0:23:33.17,0:23:34.35,Default,,0000,0000,0000,,...ومع ذلك
Dialogue: 0,0:23:34.35,0:23:36.98,Default,,0000,0000,0000,,.أشعر بها... قوّة جديدة تتملّكني
Dialogue: 0,0:23:37.39,0:23:40.27,Default,,0000,0000,0000,,.إنّ جسدي يتغيّر بكلّ تأكيد
Dialogue: 0,0:23:40.55,0:23:42.50,Default,,0000,0000,0000,,.أشعر بخفّةٍ في جسدي
