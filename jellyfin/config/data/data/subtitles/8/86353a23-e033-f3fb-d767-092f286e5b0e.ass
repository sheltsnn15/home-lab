Dialogue: 0,0:01:41.02,0:01:44.10,Default,,0000,0000,0000,,(Tunduk pada tuan raksasa!)
Dialogue: 0,0:01:44.10,0:01:47.57,Default,,0000,0000,0000,,Melihat kemelut dalam\NPersatuan Hero, jelas bahawa
Dialogue: 0,0:01:47.58,0:01:50.05,Default,,0000,0000,0000,,umat manusia tiada peluang untuk menang.
Dialogue: 0,0:01:50.05,0:01:52.40,Default,,0000,0000,0000,,Kita mesti menyerah sepenuhnya.
Dialogue: 0,0:01:52.40,0:01:53.64,Default,,0000,0000,0000,,(Kerjasama dengan raksasa)\NJika melawan,
Dialogue: 0,0:01:53.64,0:01:56.55,Default,,0000,0000,0000,,(Manusia tiada peluang menang!)\Nkita pasti dihapuskan.
Dialogue: 0,0:01:56.55,0:01:59.58,Default,,0000,0000,0000,,Maka, kami Kumpulan Penyembah Raksasa,
Dialogue: 0,0:01:59.59,0:02:01.90,Default,,0000,0000,0000,,mencadangkan satu-satunya penyelesaian.
Dialogue: 0,0:02:02.41,0:02:06.08,Default,,0000,0000,0000,,Dengan memberi korban\Nkepada raksasa secara berkala,
Dialogue: 0,0:02:06.08,0:02:08.79,Default,,0000,0000,0000,,dan mengawal kadar pemangsaan mereka,
Dialogue: 0,0:02:08.80,0:02:11.60,Default,,0000,0000,0000,,kita boleh mengelakkan pemupusan.
Dialogue: 0,0:02:12.28,0:02:14.95,Default,,0000,0000,0000,,Jika anda sanggup berpihak di sisi raksasa,
Dialogue: 0,0:02:14.95,0:02:16.96,Default,,0000,0000,0000,,sertailah kami!
Dialogue: 0,0:02:17.58,0:02:19.47,Default,,0000,0000,0000,,Kita mesti mandiri dalam dunia
Dialogue: 0,0:02:19.47,0:02:21.96,Default,,0000,0000,0000,,di mana akal budi dan nilai\Netika sedang ditulis semula.
Dialogue: 0,0:02:21.96,0:02:23.65,Default,,0000,0000,0000,,Diamlah!
Dialogue: 0,0:02:23.65,0:02:27.39,Default,,0000,0000,0000,,Aku lebih rela mati daripada\Nbersekongkol dengan raksasa!
Dialogue: 0,0:02:28.04,0:02:29.38,Default,,0000,0000,0000,,Sesuai.
Dialogue: 0,0:02:29.38,0:02:33.23,Default,,0000,0000,0000,,Kalau begitu, awak bakal menjadi\Npilihan pertama untuk korban kita!
Dialogue: 0,0:02:33.24,0:02:34.24,Default,,0000,0000,0000,,Tangkap dia!
Dialogue: 0,0:02:35.91,0:02:37.93,Default,,0000,0000,0000,,O-Oi, nanti!
Dialogue: 0,0:02:42.81,0:02:46.15,Default,,0000,0000,0000,,Korbankan seorang manusia\Nuntuk selamatkan diri kalian sendiri?
Dialogue: 0,0:02:46.62,0:02:49.11,Default,,0000,0000,0000,,Kalian terlalu pandang rendah pada raksasa.
Dialogue: 0,0:02:49.67,0:02:54.37,Default,,0000,0000,0000,,Tak sangka umat manusia\Nbegitu mudah digoyahkan.
Dialogue: 0,0:02:55.01,0:02:57.12,Default,,0000,0000,0000,,Sekarang pun dah jadi macam ni,
Dialogue: 0,0:02:57.12,0:02:59.26,Default,,0000,0000,0000,,bila aku, raksasa terkuat,
Dialogue: 0,0:02:59.26,0:03:00.84,Default,,0000,0000,0000,,muncul dengan megah nanti,
Dialogue: 0,0:03:00.84,0:03:02.69,Default,,0000,0000,0000,,kesannya mungkin takkan sekuat dulu,
Dialogue: 0,0:03:02.69,0:03:04.36,Default,,0000,0000,0000,,dan itu makin buat aku risau.
Dialogue: 0,0:03:04.87,0:03:07.94,Default,,0000,0000,0000,,(Syarat Raksasa)\NDi pelbagai kawasan, segelintir orang
Dialogue: 0,0:03:07.95,0:03:10.27,Default,,0000,0000,0000,,telah melakukan rompakan dan\Npecah masuk ke rumah orang.
Dialogue: 0,0:03:10.27,0:03:12.94,Default,,0000,0000,0000,,Pihak polis dan hero sedang giat meronda
Dialogue: 0,0:03:12.94,0:03:14.84,Default,,0000,0000,0000,,dan memberi amaran kepada orang ramai.
Dialogue: 0,0:03:15.78,0:03:18.49,Default,,0000,0000,0000,,Malah, sebuah kumpulan muncul di Bandar S,
Dialogue: 0,0:03:18.49,0:03:20.67,Default,,0000,0000,0000,,berarak dan menyebabkan kekacauan
Dialogue: 0,0:03:20.67,0:03:23.69,Default,,0000,0000,0000,,lalu mengisytiharkan pengakhiran\Nsejarah manusia telah tiba.
Dialogue: 0,0:03:24.44,0:03:26.55,Default,,0000,0000,0000,,Walaupun raksasa mengganas di mana-mana,
Dialogue: 0,0:03:26.56,0:03:29.07,Default,,0000,0000,0000,,itu tak bermakna dosa\Nkamu akan jadi lebih ringan.
Dialogue: 0,0:03:30.09,0:03:33.13,Default,,0000,0000,0000,,Oleh kerana Persatuan Raksasa\Nhanya lakukan sesuatu main-main sahaja,
Dialogue: 0,0:03:33.13,0:03:35.82,Default,,0000,0000,0000,,orang sampah pun fikir dialah ketua.
Dialogue: 0,0:03:37.68,0:03:40.00,Default,,0000,0000,0000,,- Wah, ada pergaduhan!\N- Hentikan!
Dialogue: 0,0:03:40.00,0:03:42.21,Default,,0000,0000,0000,,Cukup, kau dah melampau\Ndengan orang tua ni...
Dialogue: 0,0:03:42.71,0:03:45.22,Default,,0000,0000,0000,,Diam! Orang ni langgar aku tadi!
Dialogue: 0,0:03:45.22,0:03:47.55,Default,,0000,0000,0000,,Dia mabuklah. Dia dah hilang kawalan.
Dialogue: 0,0:03:47.55,0:03:50.76,Default,,0000,0000,0000,,Semua orang pun akan mati dibunuh raksasa.
Dialogue: 0,0:03:50.76,0:03:52.49,Default,,0000,0000,0000,,Aku tak puas hatilah!
Dialogue: 0,0:03:52.78,0:03:53.78,Default,,0000,0000,0000,,Oi.
Dialogue: 0,0:03:53.79,0:03:56.69,Default,,0000,0000,0000,,- Kau halang pintu masuk. Berambus.\N- Apa?
Dialogue: 0,0:03:56.70,0:03:57.95,Default,,0000,0000,0000,,Apa?!
Dialogue: 0,0:03:57.95,0:04:00.89,Default,,0000,0000,0000,,Apa kau cakap, budak tak guna—!
Dialogue: 0,0:04:07.21,0:04:08.40,Default,,0000,0000,0000,,Berambus.
Dialogue: 0,0:04:09.71,0:04:11.61,Default,,0000,0000,0000,,Aku tak macam mereka.
Dialogue: 0,0:04:12.34,0:04:13.82,Default,,0000,0000,0000,,Aku akan hasilkan ketakutan yang
Dialogue: 0,0:04:13.82,0:04:16.30,Default,,0000,0000,0000,,boleh senyapkan sampah-sampah ni.
Dialogue: 0,0:04:17.35,0:04:20.04,Default,,0000,0000,0000,,Tapi, sekarang aku dah kebulur.
Dialogue: 0,0:04:21.34,0:04:23.56,Default,,0000,0000,0000,,Set makan besar stik saiz ekstra tebal
Dialogue: 0,0:04:23.57,0:04:25.88,Default,,0000,0000,0000,,dan nasi lebih!
Dialogue: 0,0:04:26.27,0:04:27.63,Default,,0000,0000,0000,,Selamat menjamu.
Dialogue: 0,0:04:28.85,0:04:30.73,Default,,0000,0000,0000,,Terima-mmoth kasih.
Dialogue: 0,0:04:46.84,0:04:50.58,Default,,0000,0000,0000,,Eh, ini tak cukuplah...
Dialogue: 0,0:04:52.47,0:04:55.75,Default,,0000,0000,0000,,Bawakan semua menu\Ndaging dari atas ke bawah,
Dialogue: 0,0:04:55.75,0:04:58.09,Default,,0000,0000,0000,,dan semua salad yang ada.
Dialogue: 0,0:04:58.09,0:05:00.01,Default,,0000,0000,0000,,Dan minta banyak air.
Dialogue: 0,0:05:05.86,0:05:07.60,Default,,0000,0000,0000,,Nak pesan lagi.
Dialogue: 0,0:05:07.60,0:05:16.53,Default,,0000,0000,0000,,(Makan) (Kunyah)
Dialogue: 0,0:05:20.40,0:05:22.86,Default,,0000,0000,0000,,(Teguk)
Dialogue: 0,0:05:23.03,0:05:24.16,Default,,0000,0000,0000,,(Hentak)
Dialogue: 0,0:05:30.06,0:05:31.36,Default,,0000,0000,0000,,Kenyang, kenyang.
Dialogue: 0,0:05:31.36,0:05:32.89,Default,,0000,0000,0000,,Teri-monyet kasih atas hidangan.
Dialogue: 0,0:05:33.29,0:05:34.47,Default,,0000,0000,0000,,Seterusnya...
Dialogue: 0,0:05:36.53,0:05:37.53,Default,,0000,0000,0000,,Eh?
Dialogue: 0,0:05:38.96,0:05:40.81,Default,,0000,0000,0000,,(Dompet tak ada...)\NDompet tak ada.
Dialogue: 0,0:05:41.73,0:05:44.99,Default,,0000,0000,0000,,Rasanya aku tercicir di pasar\Nraya semasa beli kubis Cina.
Dialogue: 0,0:05:45.67,0:05:47.20,Default,,0000,0000,0000,,Tak, alamak...
Dialogue: 0,0:05:47.89,0:05:49.22,Default,,0000,0000,0000,,Kalau aku panggil Genos pun,
Dialogue: 0,0:05:49.22,0:05:50.88,Default,,0000,0000,0000,,dia tengah rosak sekarang.
Dialogue: 0,0:05:53.84,0:05:57.04,Default,,0000,0000,0000,,Menu bulan ini ialah\Nikan laut dalam goreng.
Dialogue: 0,0:05:57.04,0:06:00.32,Default,,0000,0000,0000,,Walaupun kebimbangan tentang\Nkeselamatan awam meningkat,
Dialogue: 0,0:06:00.33,0:06:03.11,Default,,0000,0000,0000,,restoran kami berwaspada\Nterhadap perompak, perusuh
Dialogue: 0,0:06:03.11,0:06:05.53,Default,,0000,0000,0000,,dan pelanggan yang makan tanpa bayar.
Dialogue: 0,0:06:07.63,0:06:11.33,Default,,0000,0000,0000,,Kami telah menempatkan bekas\Nhero profesional di bilik keselamatan,
Dialogue: 0,0:06:11.33,0:06:14.85,Default,,0000,0000,0000,,jadi anda boleh menikmati\Nhidangan dengan aman.
Dialogue: 0,0:06:16.27,0:06:18.43,Default,,0000,0000,0000,,Kalau aku terus jelaskan ini pada pelayan,
Dialogue: 0,0:06:18.43,0:06:20.70,Default,,0000,0000,0000,,akan nampak seolah-olah aku\Nketakutan dan menyerah diri saja.
Dialogue: 0,0:06:21.81,0:06:23.61,Default,,0000,0000,0000,,Alamak, habislah.
Dialogue: 0,0:06:24.13,0:06:25.67,Default,,0000,0000,0000,,Betul-betul tersepit sekarang.
Dialogue: 0,0:06:25.68,0:06:27.65,Default,,0000,0000,0000,,Ini krisis terbesar sepanjang tahun ini.
Dialogue: 0,0:06:28.63,0:06:29.47,Default,,0000,0000,0000,,Hei, kamu!
Dialogue: 0,0:06:29.48,0:06:31.02,Default,,0000,0000,0000,,Aku dah habislah.
Dialogue: 0,0:06:31.02,0:06:32.08,Default,,0000,0000,0000,,Dengar, tak?!
Dialogue: 0,0:06:32.76,0:06:33.86,Default,,0000,0000,0000,,Saitama!
Dialogue: 0,0:06:34.37,0:06:36.60,Default,,0000,0000,0000,,Eh, bukan! Aku cuma...!
Dialogue: 0,0:06:36.60,0:06:37.85,Default,,0000,0000,0000,,Apa kau cakapkan?
Dialogue: 0,0:06:38.24,0:06:41.01,Default,,0000,0000,0000,,Eh, kenapa kau di sini?
Dialogue: 0,0:06:41.01,0:06:43.62,Default,,0000,0000,0000,,Susah betul mencari kau, Saitama!
Dialogue: 0,0:06:43.95,0:06:46.80,Default,,0000,0000,0000,,Kau terus keluar semasa\Nkita masih berbincang.
Dialogue: 0,0:06:47.19,0:06:50.16,Default,,0000,0000,0000,,Hei, awak nak cari pemburu hero, kan?
Dialogue: 0,0:06:50.51,0:06:54.28,Default,,0000,0000,0000,,Baiklah, saya akan\Nberikan bantuan istimewa.
Dialogue: 0,0:06:54.28,0:06:55.70,Default,,0000,0000,0000,,Maaf, nak pesan sesuatu.
Dialogue: 0,0:06:55.71,0:06:58.82,Default,,0000,0000,0000,,- Balasannya, aku dapat 70 peratus\N- Satu pinggan besar kentang goreng.
Dialogue: 0,0:06:58.82,0:06:59.99,Default,,0000,0000,0000,,markah kejayaan, tau.
Dialogue: 0,0:07:00.66,0:07:04.31,Default,,0000,0000,0000,,Kau pun sudah naik ke tempat\Nke-7 dalam kedudukan Kelas B,
Dialogue: 0,0:07:04.31,0:07:06.77,Default,,0000,0000,0000,,tapi sukar untuk mendaki\Nlebih tinggi dari itu, kan?
Dialogue: 0,0:07:07.44,0:07:09.10,Default,,0000,0000,0000,,Kalau kau berjaya kali ini,
Dialogue: 0,0:07:09.10,0:07:12.73,Default,,0000,0000,0000,,tempat lima teratas Kelas B\Nbukan suatu matlamat yang mustahil.
Dialogue: 0,0:07:13.13,0:07:17.44,Default,,0000,0000,0000,,Cuma, kerjasama aku\Nadalah penting untuk itu.
Dialogue: 0,0:07:17.81,0:07:19.48,Default,,0000,0000,0000,,Kalau ikut perangai kau,
Dialogue: 0,0:07:19.48,0:07:23.01,Default,,0000,0000,0000,,kau takkan peduli menyiasat siapa\Nsasaran kau atau rupa wajah mereka, kan?
Dialogue: 0,0:07:23.01,0:07:25.59,Default,,0000,0000,0000,,Terpaksalah, kan?
Dialogue: 0,0:07:25.59,0:07:27.53,Default,,0000,0000,0000,,Aku akan berikan maklumat.
Dialogue: 0,0:07:27.89,0:07:29.05,Default,,0000,0000,0000,,(Termenung)\NMulai sekarang,
Dialogue: 0,0:07:29.05,0:07:31.03,Default,,0000,0000,0000,,(Termenung)\Nikut arahan aku betul-betul.
Dialogue: 0,0:07:31.71,0:07:32.84,Default,,0000,0000,0000,,Dengar, tak?
Dialogue: 0,0:07:33.22,0:07:35.57,Default,,0000,0000,0000,,Kentang goreng. Selamat menjamu.
Dialogue: 0,0:07:41.18,0:07:42.47,Default,,0000,0000,0000,,Kau bagi aku?
Dialogue: 0,0:07:44.59,0:07:45.66,Default,,0000,0000,0000,,Terima kasih.
Dialogue: 0,0:07:51.45,0:07:53.56,Default,,0000,0000,0000,,Kenapa dia tersengih-sengih?
Dialogue: 0,0:07:54.02,0:07:57.08,Default,,0000,0000,0000,,Dia nampaknya gembira bekerja dengan aku.
Dialogue: 0,0:07:57.40,0:08:00.37,Default,,0000,0000,0000,,Ini bermaksud Saitama pun\Nmenjadi ahli Kumpulan Fubuki.
Dialogue: 0,0:08:00.37,0:08:02.11,Default,,0000,0000,0000,,Ada pelanggan makan lari!
Dialogue: 0,0:08:02.11,0:08:04.09,Default,,0000,0000,0000,,Aku belum habislah!
Dialogue: 0,0:08:04.10,0:08:06.70,Default,,0000,0000,0000,,Sesiapa tolong tangkap lelaki tadi!
Dialogue: 0,0:08:08.85,0:08:10.30,Default,,0000,0000,0000,,Teruknya penyangak makan lari itu.
Dialogue: 0,0:08:10.31,0:08:12.24,Default,,0000,0000,0000,,- Tunggu... Saitama!\N- Aku akan kejar dia.
Dialogue: 0,0:08:12.24,0:08:13.83,Default,,0000,0000,0000,,Kau pun makan kentang goreng, kan?
Dialogue: 0,0:08:13.83,0:08:15.25,Default,,0000,0000,0000,,Tolong bayarkan bil!
Dialogue: 0,0:08:18.34,0:08:20.34,Default,,0000,0000,0000,,K-Kentang goreng?
Dialogue: 0,0:08:20.64,0:08:22.84,Default,,0000,0000,0000,,Biar betul...
Dialogue: 0,0:08:22.84,0:08:25.20,Default,,0000,0000,0000,,Pada waktu payah begini pun,
Dialogue: 0,0:08:25.21,0:08:27.47,Default,,0000,0000,0000,,dia boleh jadi kedekut.
Dialogue: 0,0:08:30.14,0:08:33.35,Default,,0000,0000,0000,,Aku memang tak patut lari maraton.
Dialogue: 0,0:08:34.25,0:08:36.31,Default,,0000,0000,0000,,Lebih baik kau rawat kecederaan di
Dialogue: 0,0:08:36.31,0:08:38.33,Default,,0000,0000,0000,,bawah perlindungan Persatuan Raksasa.
Dialogue: 0,0:08:38.72,0:08:43.48,Default,,0000,0000,0000,,Cuma, kami perlukan kau\Npenuhi satu syarat dahulu.
Dialogue: 0,0:08:44.15,0:08:46.68,Default,,0000,0000,0000,,"Bawakan aku kepala Hero"?
Dialogue: 0,0:08:47.28,0:08:50.04,Default,,0000,0000,0000,,Kalau bunuh hero, kau\Nakan diiktiraf sebagai raksasa,
Dialogue: 0,0:08:50.04,0:08:51.49,Default,,0000,0000,0000,,tapi apa logiknya?
Dialogue: 0,0:08:51.87,0:08:53.58,Default,,0000,0000,0000,,Raksasa itu lebih macam,
Dialogue: 0,0:08:53.58,0:08:56.83,Default,,0000,0000,0000,,kewujudannya pun boleh\Ncetuskan ketakutan sebenar.
Dialogue: 0,0:08:59.58,0:09:01.11,Default,,0000,0000,0000,,Sakitnya kepala...
Dialogue: 0,0:09:06.73,0:09:08.17,Default,,0000,0000,0000,,Tak kisahlah.
Dialogue: 0,0:09:11.54,0:09:13.15,Default,,0000,0000,0000,,Oi, Tareo.
Dialogue: 0,0:09:13.15,0:09:15.37,Default,,0000,0000,0000,,Kenapa kau masih selamat?
Dialogue: 0,0:09:15.37,0:09:17.51,Default,,0000,0000,0000,,Entah-entah, kau pun raksasa, kan?!
Dialogue: 0,0:09:17.51,0:09:19.88,Default,,0000,0000,0000,,Tidak, raksasa hodoh!
Dialogue: 0,0:09:19.88,0:09:21.98,Default,,0000,0000,0000,,Aduh! Aduh! Aduh!
Dialogue: 0,0:09:25.32,0:09:26.63,Default,,0000,0000,0000,,Hentikan!
Dialogue: 0,0:09:27.20,0:09:29.31,Default,,0000,0000,0000,,Mama!
Dialogue: 0,0:09:31.09,0:09:33.37,Default,,0000,0000,0000,,Teruknya wajah kau menangis.
Dialogue: 0,0:09:33.71,0:09:36.68,Default,,0000,0000,0000,,Kau dibuli. Kasihan.
Dialogue: 0,0:09:38.02,0:09:41.26,Default,,0000,0000,0000,,Hai, kebetulan kita\Nberjumpa dua kali hari ini.
Dialogue: 0,0:09:41.26,0:09:42.11,Default,,0000,0000,0000,,Pakcik?!
Dialogue: 0,0:09:42.12,0:09:44.67,Default,,0000,0000,0000,,Bukan pakciklah! Umur aku baru 18!
Dialogue: 0,0:09:45.86,0:09:46.97,Default,,0000,0000,0000,,Cis.
Dialogue: 0,0:09:46.97,0:09:49.35,Default,,0000,0000,0000,,Cepatlah balik. Matahari nak terbenam.
Dialogue: 0,0:09:49.74,0:09:51.89,Default,,0000,0000,0000,,Raksasa boleh muncul bila-bila masa.
Dialogue: 0,0:09:54.27,0:09:55.34,Default,,0000,0000,0000,,Pakcik...
Dialogue: 0,0:09:56.93,0:09:57.93,Default,,0000,0000,0000,,minta maaf.
Dialogue: 0,0:09:59.20,0:10:01.36,Default,,0000,0000,0000,,Sebab larikan diri waktu itu.
Dialogue: 0,0:10:03.80,0:10:04.80,Default,,0000,0000,0000,,Hah?
Dialogue: 0,0:10:05.40,0:10:08.15,Default,,0000,0000,0000,,Aku... nampak semuanya.
Dialogue: 0,0:10:09.17,0:10:12.49,Default,,0000,0000,0000,,Semua hero nak membunuh Pakcik,
Dialogue: 0,0:10:12.49,0:10:15.40,Default,,0000,0000,0000,,tapi itu sebenarnya satu kesilapan, kan?
Dialogue: 0,0:10:15.41,0:10:18.06,Default,,0000,0000,0000,,Lagipun, waktu itu, Pakcik
Dialogue: 0,0:10:18.06,0:10:21.04,Default,,0000,0000,0000,,lindungi saya dari semua peluru tu!
Dialogue: 0,0:10:21.04,0:10:22.75,Default,,0000,0000,0000,,Tadi pun sama...
Dialogue: 0,0:10:22.75,0:10:24.02,Default,,0000,0000,0000,,Pakcik selamatkan saya.
Dialogue: 0,0:10:24.67,0:10:27.02,Default,,0000,0000,0000,,Pakcik pasti seorang pejuang keadilan—
Dialogue: 0,0:10:28.24,0:10:31.29,Default,,0000,0000,0000,,Berhenti. Buat aku meremang sajalah.
Dialogue: 0,0:10:31.30,0:10:32.91,Default,,0000,0000,0000,,Oi, orang makan lari!
Dialogue: 0,0:10:34.21,0:10:35.90,Default,,0000,0000,0000,,Oi, orang makan lari!
Dialogue: 0,0:10:36.22,0:10:38.42,Default,,0000,0000,0000,,Tak guna! Makan dan lari saja!
Dialogue: 0,0:10:38.43,0:10:39.54,Default,,0000,0000,0000,,Herokah?
Dialogue: 0,0:10:39.54,0:10:42.10,Default,,0000,0000,0000,,Berani kau cari masa tepat untuk lari.
Dialogue: 0,0:10:42.10,0:10:43.27,Default,,0000,0000,0000,,Kali ini saja aku maafkan!
Dialogue: 0,0:10:43.27,0:10:44.70,Default,,0000,0000,0000,,Nanti, oi! Apa benda tu?!
Dialogue: 0,0:10:44.70,0:10:46.75,Default,,0000,0000,0000,,Baiklah, aku dah beri amaran.
Dialogue: 0,0:10:46.75,0:10:49.04,Default,,0000,0000,0000,,Kau tak datang untuk hapuskan akukah?!
Dialogue: 0,0:10:49.04,0:10:50.53,Default,,0000,0000,0000,,Kau tak takutkah?
Dialogue: 0,0:10:50.53,0:10:52.05,Default,,0000,0000,0000,,Apa nama hero kau?
Dialogue: 0,0:10:57.21,0:10:59.60,Default,,0000,0000,0000,,Ma..., Mantel Botak.
Dialogue: 0,0:11:01.14,0:11:03.65,Default,,0000,0000,0000,,Aku tak berapa dengar,\Ntapi kau macam herolah.
Dialogue: 0,0:11:04.54,0:11:06.93,Default,,0000,0000,0000,,Walau betapa lemah pun kau,\Nasalkan dia hero, aku akan buru.
Dialogue: 0,0:11:07.88,0:11:09.80,Default,,0000,0000,0000,,Dia tak tersenarai dalam direktori,
Dialogue: 0,0:11:09.80,0:11:11.69,Default,,0000,0000,0000,,jadi dia mesti orang baru.
Dialogue: 0,0:11:11.69,0:11:13.21,Default,,0000,0000,0000,,Cepatlah balik, budak.
Dialogue: 0,0:11:14.97,0:11:17.99,Default,,0000,0000,0000,,Pakcik, makan dan larikan dirikah?
Dialogue: 0,0:11:17.99,0:11:19.54,Default,,0000,0000,0000,,Rasanya dia tak peduli sangat pun,
Dialogue: 0,0:11:19.54,0:11:21.13,Default,,0000,0000,0000,,jadi lebih baik jangan cari gaduh.
Dialogue: 0,0:11:24.52,0:11:26.17,Default,,0000,0000,0000,,Jangan main-mainlah.
Dialogue: 0,0:11:27.06,0:11:29.08,Default,,0000,0000,0000,,Kalau Persatuan Raksasa saja tak apalah,
Dialogue: 0,0:11:29.08,0:11:32.35,Default,,0000,0000,0000,,tapi kalau sampai hero kelas bawahan\Ndan budak pula kasihankan aku,
Dialogue: 0,0:11:32.35,0:11:33.73,Default,,0000,0000,0000,,habislah semuanya.
Dialogue: 0,0:11:34.92,0:11:37.51,Default,,0000,0000,0000,,Apabila aku dapat tahu\Norang tua tu terselamat,
Dialogue: 0,0:11:37.51,0:11:40.17,Default,,0000,0000,0000,,aku rasa geram pada diri sebab berasa lega.
Dialogue: 0,0:11:40.80,0:11:42.92,Default,,0000,0000,0000,,Tak kiralah apa maksud raksasa,
Dialogue: 0,0:11:42.92,0:11:45.87,Default,,0000,0000,0000,,nampaknya aku belum bersedia.
Dialogue: 0,0:11:46.20,0:11:47.98,Default,,0000,0000,0000,,Aku akan lakukan...
Dialogue: 0,0:11:48.54,0:11:51.31,Default,,0000,0000,0000,,Aku akan penggal dan ambil kepala hero.
Dialogue: 0,0:11:51.86,0:11:53.40,Default,,0000,0000,0000,,Jangan pandang rendah...
Dialogue: 0,0:11:53.71,0:11:55.67,Default,,0000,0000,0000,,Aku seekor raksasa...
Dialogue: 0,0:11:57.34,0:11:58.34,Default,,0000,0000,0000,,Oi!
Dialogue: 0,0:11:58.71,0:12:00.70,Default,,0000,0000,0000,,Sekarang habislah kau—
Dialogue: 0,0:12:01.29,0:12:02.76,Default,,0000,0000,0000,,Maaf, aku pun rakan subahat juga,
Dialogue: 0,0:12:02.77,0:12:04.58,Default,,0000,0000,0000,,jadi jangan ikut aku lagi.
Dialogue: 0,0:12:10.29,0:12:11.29,Default,,0000,0000,0000,,Alah...
Dialogue: 0,0:12:12.60,0:12:13.69,Default,,0000,0000,0000,,terlanjur.
Dialogue: 0,0:12:14.66,0:12:16.76,Default,,0000,0000,0000,,Aku tak cuba buat dia melayang pun.
Dialogue: 0,0:12:17.75,0:12:20.49,Default,,0000,0000,0000,,Wah, ada saksi pula.
Dialogue: 0,0:12:20.49,0:12:21.77,Default,,0000,0000,0000,,Apa buku tu?
Dialogue: 0,0:12:22.16,0:12:24.71,Default,,0000,0000,0000,,Budak ni pun sukakan hero juga!
Dialogue: 0,0:12:25.65,0:12:27.95,Default,,0000,0000,0000,,Rasanya identiti aku dah terbongkar.
Dialogue: 0,0:12:27.96,0:12:29.01,Default,,0000,0000,0000,,Habislah.
Dialogue: 0,0:12:30.10,0:12:32.46,Default,,0000,0000,0000,,Kau... kenal aku tak?
Dialogue: 0,0:12:34.40,0:12:35.40,Default,,0000,0000,0000,,Eh?
Dialogue: 0,0:12:36.70,0:12:38.12,Default,,0000,0000,0000,,Boleh aku tengok sekejap?
Dialogue: 0,0:12:40.48,0:12:43.41,Default,,0000,0000,0000,,Biar betul... aku tak ada langsung.
Dialogue: 0,0:12:44.19,0:12:45.19,Default,,0000,0000,0000,,Begitu...
Dialogue: 0,0:12:48.56,0:12:49.79,Default,,0000,0000,0000,,Siapa dia?
Dialogue: 0,0:12:50.94,0:12:52.72,Default,,0000,0000,0000,,Oh, yalah!
Dialogue: 0,0:12:52.73,0:12:55.55,Default,,0000,0000,0000,,Pakcik! Bangunlah, Pakcik!
Dialogue: 0,0:12:56.97,0:12:58.43,Default,,0000,0000,0000,,(One Punch Man)\NOne Punch Man.
Dialogue: 0,0:13:02.00,0:13:03.56,Default,,0000,0000,0000,,(One Punch Man)\NOne Punch Man.
Dialogue: 0,0:13:18.28,0:13:20.48,Default,,0000,0000,0000,,Pakcik tak apa-apa?
Dialogue: 0,0:13:20.48,0:13:24.66,Default,,0000,0000,0000,,Hero botak tadi lari\Nsambil kata, "Terlanjur."
Dialogue: 0,0:13:25.34,0:13:26.89,Default,,0000,0000,0000,,Aku kalah!
Dialogue: 0,0:13:26.89,0:13:28.95,Default,,0000,0000,0000,,Dia hero macam mana?
Dialogue: 0,0:13:28.95,0:13:30.76,Default,,0000,0000,0000,,Tak ingatkah?
Dialogue: 0,0:13:30.76,0:13:33.01,Default,,0000,0000,0000,,Mungkin Pakcik dipukul\Ndi tempat yang sakit.
Dialogue: 0,0:13:34.20,0:13:38.15,Default,,0000,0000,0000,,Garou, apa kau sedang buat?
Dialogue: 0,0:13:42.18,0:13:44.20,Default,,0000,0000,0000,,Sekian lama aku perhatikan.
Dialogue: 0,0:13:45.18,0:13:48.86,Default,,0000,0000,0000,,Garou memang berbeza daripada kami.
Dialogue: 0,0:13:49.46,0:13:51.24,Default,,0000,0000,0000,,Ya, berbeza.
Dialogue: 0,0:13:51.59,0:13:56.79,Default,,0000,0000,0000,,Malangnya, aku tak rasakan\Nsifat raksasa dalam diri kau.
Dialogue: 0,0:13:58.63,0:14:00.55,Default,,0000,0000,0000,,Oi, budak.
Dialogue: 0,0:14:00.55,0:14:02.72,Default,,0000,0000,0000,,Berhenti termenung dan balik cepat.
Dialogue: 0,0:14:03.27,0:14:06.28,Default,,0000,0000,0000,,Mereka ni macam ada\Nsesuatu nak beritahu aku.
Dialogue: 0,0:14:06.28,0:14:07.47,Default,,0000,0000,0000,,Eh?
Dialogue: 0,0:14:15.40,0:14:17.05,Default,,0000,0000,0000,,Dalam direktori pun ada...
Dialogue: 0,0:14:17.47,0:14:19.80,Default,,0000,0000,0000,,Mereka bukan khabar angin saja...
Dialogue: 0,0:14:21.57,0:14:22.72,Default,,0000,0000,0000,,Kenapa...
Dialogue: 0,0:14:22.73,0:14:24.82,Default,,0000,0000,0000,,(Raksasa Legenda Urban)\NDi sini pula...
Dialogue: 0,0:14:25.93,0:14:27.47,Default,,0000,0000,0000,,Raja Pembunuh muncul.
Dialogue: 0,0:14:27.47,0:14:30.37,Default,,0000,0000,0000,,Ramai kanak-kanak diculik.
Dialogue: 0,0:14:31.22,0:14:33.72,Default,,0000,0000,0000,,Dia Raja Pembunuh!
Dialogue: 0,0:14:34.69,0:14:36.61,Default,,0000,0000,0000,,Oi, bawa bertenang.
Dialogue: 0,0:14:36.61,0:14:38.41,Default,,0000,0000,0000,,Jangan menangis dan bangunlah!
Dialogue: 0,0:14:38.42,0:14:43.18,Default,,0000,0000,0000,,Tak sangka Garo ada kawan yang kecil, kan?
Dialogue: 0,0:14:43.18,0:14:45.66,Default,,0000,0000,0000,,Oi, berhenti! Aku dengar cakap kau di situ!
Dialogue: 0,0:14:45.66,0:14:48.48,Default,,0000,0000,0000,,Alahai, maaf, ya...
Dialogue: 0,0:14:48.48,0:14:51.56,Default,,0000,0000,0000,,Aku tak berniat buat kau menangis...
Dialogue: 0,0:14:52.18,0:14:53.46,Default,,0000,0000,0000,,Maaf, ya.
Dialogue: 0,0:14:53.91,0:14:56.67,Default,,0000,0000,0000,,Aku berniat untuk buat kau
Dialogue: 0,0:14:56.67,0:14:59.23,Default,,0000,0000,0000,,betul-betul menjerit nanti.
Dialogue: 0,0:14:59.23,0:15:00.59,Default,,0000,0000,0000,,Maaf, ya...
Dialogue: 0,0:15:01.23,0:15:02.78,Default,,0000,0000,0000,,Malangnya...
Dialogue: 0,0:15:02.78,0:15:06.53,Default,,0000,0000,0000,,Aku pastikan badan kau dicarik-carik nanti.
Dialogue: 0,0:15:06.54,0:15:08.10,Default,,0000,0000,0000,,Maaf, ya...
Dialogue: 0,0:15:09.82,0:15:10.95,Default,,0000,0000,0000,,Budak...
Dialogue: 0,0:15:11.40,0:15:13.40,Default,,0000,0000,0000,,Kau tak boleh diselamatkan lagi.
Dialogue: 0,0:15:13.40,0:15:14.79,Default,,0000,0000,0000,,Maaf, ya...
Dialogue: 0,0:15:16.09,0:15:17.26,Default,,0000,0000,0000,,Jangan dekat.
Dialogue: 0,0:15:21.70,0:15:23.05,Default,,0000,0000,0000,,Maaf mengganggu.
Dialogue: 0,0:15:23.05,0:15:24.40,Default,,0000,0000,0000,,Aku ada soalan.
Dialogue: 0,0:15:24.40,0:15:27.21,Default,,0000,0000,0000,,Aku tak mahu diganggu semasa bertafakur.
Dialogue: 0,0:15:27.21,0:15:28.31,Default,,0000,0000,0000,,Apa dia?
Dialogue: 0,0:15:28.31,0:15:31.18,Default,,0000,0000,0000,,Kenapa kau benarkan\NRaja Pembunuh dan Dewa Kumbang pergi?
Dialogue: 0,0:15:31.18,0:15:32.55,Default,,0000,0000,0000,,Kalau sekadar memantau pun,
Dialogue: 0,0:15:32.55,0:15:35.01,Default,,0000,0000,0000,,tak perlulah panggil yang paling agresif.
Dialogue: 0,0:15:35.01,0:15:37.84,Default,,0000,0000,0000,,Kenapa? Mereka berdua nampak sesuai.
Dialogue: 0,0:15:37.84,0:15:39.22,Default,,0000,0000,0000,,Jangan merepek.
Dialogue: 0,0:15:39.22,0:15:41.83,Default,,0000,0000,0000,,Tak mungkin mereka akan dengar arahan.
Dialogue: 0,0:15:41.83,0:15:44.21,Default,,0000,0000,0000,,Silap-silap, boleh terbawa-bawa\Nsampai bunuh Garou.
Dialogue: 0,0:15:44.49,0:15:46.15,Default,,0000,0000,0000,,Lebih-lebih lagi Raja Pembunuh.
Dialogue: 0,0:15:46.15,0:15:48.61,Default,,0000,0000,0000,,Pembunuh sadis yang jarang wujud.
Dialogue: 0,0:15:48.61,0:15:50.33,Default,,0000,0000,0000,,Bahkan raksasa lain di sini pun
Dialogue: 0,0:15:50.33,0:15:52.35,Default,,0000,0000,0000,,tak berani mendekatinya.
Dialogue: 0,0:15:52.35,0:15:54.54,Default,,0000,0000,0000,,Ya, sebab itulah.
Dialogue: 0,0:15:54.54,0:15:56.16,Default,,0000,0000,0000,,Dengan membuat Garou bertemu dengannya,
Dialogue: 0,0:15:56.16,0:15:59.18,Default,,0000,0000,0000,,kita boleh galakkan pertumbuhannya.
Dialogue: 0,0:15:59.18,0:16:00.37,Default,,0000,0000,0000,,Pertumbuhan?
Dialogue: 0,0:16:00.38,0:16:03.88,Default,,0000,0000,0000,,Bagi orang macam dia, yang masih\Nragu-ragu, ini ialah ujian untuknya.
Dialogue: 0,0:16:03.88,0:16:07.29,Default,,0000,0000,0000,,Mula-mula dia perlu\Ndihancurkan secara menyeluruh,
Dialogue: 0,0:16:07.29,0:16:08.79,Default,,0000,0000,0000,,jiwa dan raganya.
Dialogue: 0,0:16:09.22,0:16:11.73,Default,,0000,0000,0000,,Aku tak sabar melihat perubahan Garou
Dialogue: 0,0:16:11.73,0:16:14.41,Default,,0000,0000,0000,,selepas dia rasakan apa\Nmaksud menjadi raksasa sebenar.
Dialogue: 0,0:16:14.42,0:16:17.52,Default,,0000,0000,0000,,Gyoro Gyoro, apakah matlamat kau?
Dialogue: 0,0:16:17.52,0:16:20.23,Default,,0000,0000,0000,,Apa kau cuba lakukan dengan Garou?
Dialogue: 0,0:16:20.23,0:16:21.71,Default,,0000,0000,0000,,Kalau diberitahu, apa kau nak buat?
Dialogue: 0,0:16:21.71,0:16:23.89,Default,,0000,0000,0000,,Tak ada apa. Cuma nak tahu.
Dialogue: 0,0:16:23.90,0:16:25.83,Default,,0000,0000,0000,,Hei, Lelaki Phoenix.
Dialogue: 0,0:16:25.83,0:16:29.12,Default,,0000,0000,0000,,Kau rasa dari mana asal Tuan Orochi?
Dialogue: 0,0:16:29.12,0:16:32.44,Default,,0000,0000,0000,,Entahlah, mungkin dia makhluk purba?
Dialogue: 0,0:16:33.40,0:16:37.21,Default,,0000,0000,0000,,Tuan Orochi pun asalnya\Nmanusia sama macam Garou.
Dialogue: 0,0:16:38.40,0:16:40.63,Default,,0000,0000,0000,,Selepas berapa banyak kegagalan dan korban,
Dialogue: 0,0:16:40.63,0:16:43.03,Default,,0000,0000,0000,,makhluk teragung akhirnya tercipta.
Dialogue: 0,0:16:43.04,0:16:46.27,Default,,0000,0000,0000,,Yang paling layak bergelar "Raja Raksasa".
Dialogue: 0,0:16:46.76,0:16:49.16,Default,,0000,0000,0000,,Akulah yang membuat Tuan Orochi.
Dialogue: 0,0:16:49.16,0:16:51.58,Default,,0000,0000,0000,,Buat... Kaukah orangnya?
Dialogue: 0,0:16:51.58,0:16:53.98,Default,,0000,0000,0000,,Kalau kita besarkan Garou dengan baik,
Dialogue: 0,0:16:53.99,0:16:55.99,Default,,0000,0000,0000,,dia boleh jadi Tuan Orochi seterusnya.
Dialogue: 0,0:16:55.99,0:16:58.76,Default,,0000,0000,0000,,Aku saja yang tahu rahsianya.
Dialogue: 0,0:16:58.76,0:17:01.35,Default,,0000,0000,0000,,Aku minta Dewa Kumbang\Nuntuk hentikan Raja Pembunuh
Dialogue: 0,0:17:01.35,0:17:04.28,Default,,0000,0000,0000,,daripada melampau-lampau.
Dialogue: 0,0:17:04.29,0:17:06.06,Default,,0000,0000,0000,,Tapi kalau dia mati macam tu saja,
Dialogue: 0,0:17:06.06,0:17:07.38,Default,,0000,0000,0000,,maknanya dia memang tak seberapa pun.
Dialogue: 0,0:17:07.38,0:17:10.65,Default,,0000,0000,0000,,Aku tunggu bahan lain muncul nanti.
Dialogue: 0,0:17:15.17,0:17:16.70,Default,,0000,0000,0000,,Aku sudah habis siasat kawasan,
Dialogue: 0,0:17:16.70,0:17:18.37,Default,,0000,0000,0000,,dan tutup pintu belakang.
Dialogue: 0,0:17:18.38,0:17:21.15,Default,,0000,0000,0000,,Cuma ada gorila yang keluar\Nmasuk sejak beberapa jam.
Dialogue: 0,0:17:21.54,0:17:23.44,Default,,0000,0000,0000,,Ahli lain sudah keluar.
Dialogue: 0,0:17:23.83,0:17:25.31,Default,,0000,0000,0000,,Sekarang peluang kita.
Dialogue: 0,0:17:25.32,0:17:27.68,Default,,0000,0000,0000,,Menara kawalan mungkin ada di dalam.
Dialogue: 0,0:17:27.68,0:17:28.76,Default,,0000,0000,0000,,Atau bilik kawalan.
Dialogue: 0,0:17:29.51,0:17:33.30,Default,,0000,0000,0000,,Baru-baru ini, ada kumpulan aneh\Nyang tak diketahui asal-usul telah masuk.
Dialogue: 0,0:17:33.30,0:17:35.20,Default,,0000,0000,0000,,Mereka bawa banyak peralatan,
Dialogue: 0,0:17:35.20,0:17:36.98,Default,,0000,0000,0000,,dan serbuk misteri.
Dialogue: 0,0:17:37.36,0:17:39.59,Default,,0000,0000,0000,,Kotak-kotak penuh dengan\Nbahan berbau hanyir.
Dialogue: 0,0:17:40.23,0:17:42.63,Default,,0000,0000,0000,,Maklumat aku kumpul melalui penyiasatan
Dialogue: 0,0:17:42.64,0:17:44.51,Default,,0000,0000,0000,,menyamai sangkaan aku.
Dialogue: 0,0:17:45.20,0:17:46.48,Default,,0000,0000,0000,,Tak silap lagi.
Dialogue: 0,0:17:46.49,0:17:47.55,Default,,0000,0000,0000,,Itulah mereka!
Dialogue: 0,0:17:48.03,0:17:49.17,Default,,0000,0000,0000,,Inilah masanya.
Dialogue: 0,0:17:49.17,0:17:50.22,Default,,0000,0000,0000,,Ayuh serbu.
Dialogue: 0,0:17:52.17,0:17:57.24,Default,,0000,0000,0000,,Gyoro Gyoro suruh aku pantau gerakan Garou.
Dialogue: 0,0:17:57.24,0:18:02.00,Default,,0000,0000,0000,,Untuk ketahui sama ada\Ndia layak menjadi rakan kita.
Dialogue: 0,0:18:13.34,0:18:15.07,Default,,0000,0000,0000,,Mari kita tengok Pemburu hero ini...
Dialogue: 0,0:18:15.07,0:18:18.65,Default,,0000,0000,0000,,Pembunuh biasa yang\Nketagih berlakon jadi "raksasa",
Dialogue: 0,0:18:18.66,0:18:20.71,Default,,0000,0000,0000,,atau memang raksasa sebenar?
Dialogue: 0,0:18:21.14,0:18:22.84,Default,,0000,0000,0000,,Raksasa, ya?
Dialogue: 0,0:18:23.79,0:18:25.73,Default,,0000,0000,0000,,Apa yang bagus sangat kau cakap?
Dialogue: 0,0:18:25.73,0:18:29.41,Default,,0000,0000,0000,,Aku mula jadi tawar hati\Ndengan sikap suam kau.
Dialogue: 0,0:18:29.42,0:18:31.68,Default,,0000,0000,0000,,Kalau macam tu, cubalah bunuh budak tu.
Dialogue: 0,0:18:31.68,0:18:34.70,Default,,0000,0000,0000,,Apa? Aku tak faham maksud kau.
Dialogue: 0,0:18:34.70,0:18:38.44,Default,,0000,0000,0000,,Raksasa ialah orang yang\Nmengabaikan nilai manusia.
Dialogue: 0,0:18:38.44,0:18:41.12,Default,,0000,0000,0000,,Makhluk yang terputus\Ndaripada dunia manusia.
Dialogue: 0,0:18:41.12,0:18:44.78,Default,,0000,0000,0000,,Garou, aku nampak kau selamatkan budak tu.
Dialogue: 0,0:18:44.78,0:18:47.23,Default,,0000,0000,0000,,Itu tak boleh. Kau mesti bunuh.
Dialogue: 0,0:18:47.67,0:18:50.02,Default,,0000,0000,0000,,Untuk menjadi ahli Persatuan Raksasa,
Dialogue: 0,0:18:50.02,0:18:53.61,Default,,0000,0000,0000,,kau perlu berusaha dapatkan keyakinan kami.
Dialogue: 0,0:18:53.61,0:18:56.80,Default,,0000,0000,0000,,Kau belum abaikan\Nkemanusiaan kau sepenuhnya.
Dialogue: 0,0:18:56.80,0:19:00.36,Default,,0000,0000,0000,,Kita pun tak perlu orang\Nyang separuh masak, kan?
Dialogue: 0,0:19:00.36,0:19:03.97,Default,,0000,0000,0000,,Kita akan jadi kumpulan yang\Nmenghancurkan dan menakluk manusia.
Dialogue: 0,0:19:03.98,0:19:06.15,Default,,0000,0000,0000,,Aku akan bunuh budak beramai-ramai.
Dialogue: 0,0:19:06.15,0:19:09.53,Default,,0000,0000,0000,,Malah, kau tadi tewas pada hero biasa, kan?
Dialogue: 0,0:19:09.54,0:19:10.60,Default,,0000,0000,0000,,Walaupun sebab cuai,
Dialogue: 0,0:19:10.61,0:19:12.73,Default,,0000,0000,0000,,agaknya bergunakah kau\Ndalam pasukan berlawan?
Dialogue: 0,0:19:13.33,0:19:16.03,Default,,0000,0000,0000,,Oi, aku dah kata tadi.
Dialogue: 0,0:19:16.03,0:19:17.43,Default,,0000,0000,0000,,Pergilah balik, budak.
Dialogue: 0,0:19:18.83,0:19:21.39,Default,,0000,0000,0000,,K-Kaki berketar, tak boleh bergerak.
Dialogue: 0,0:19:21.40,0:19:23.83,Default,,0000,0000,0000,,T-Tak boleh bergeraklah...!
Dialogue: 0,0:19:23.83,0:19:25.07,Default,,0000,0000,0000,,Bodoh!
Dialogue: 0,0:19:25.07,0:19:28.72,Default,,0000,0000,0000,,Jangan ingat akan ada orang tolong\Nhanya sebab kau tak boleh berdiri!
Dialogue: 0,0:19:28.72,0:19:30.56,Default,,0000,0000,0000,,Tiada siapa akan selamatkan kau!
Dialogue: 0,0:19:30.56,0:19:32.83,Default,,0000,0000,0000,,Kau jagalah diri sendiri!
Dialogue: 0,0:19:32.83,0:19:34.44,Default,,0000,0000,0000,,Pada waktu macam ni,
Dialogue: 0,0:19:34.44,0:19:36.43,Default,,0000,0000,0000,,kau terpaksa jadi lebih kuat.
Dialogue: 0,0:19:38.06,0:19:39.86,Default,,0000,0000,0000,,Tak apa asalkan jadi kuat.
Dialogue: 0,0:19:40.81,0:19:42.82,Default,,0000,0000,0000,,Bangun, Tareo!
Dialogue: 0,0:20:22.75,0:20:24.00,Default,,0000,0000,0000,,Lari!
Dialogue: 0,0:20:25.13,0:20:26.99,Default,,0000,0000,0000,,Dah tak boleh.
Dialogue: 0,0:20:26.99,0:20:29.98,Default,,0000,0000,0000,,Kau baru jadikan kami musuh.
Dialogue: 0,0:20:29.98,0:20:33.56,Default,,0000,0000,0000,,Kau mengaku memburu hero,\Ntapi tak bunuh walau seorang pun.
Dialogue: 0,0:20:33.57,0:20:36.44,Default,,0000,0000,0000,,Kau memang selemah macam aku sangka!
Dialogue: 0,0:20:36.86,0:20:39.76,Default,,0000,0000,0000,,Aku cuma bencikan perangai kau.
Dialogue: 0,0:20:43.60,0:20:44.60,Default,,0000,0000,0000,,Ayuh.
Dialogue: 0,0:22:19.74,0:22:21.09,Default,,0000,0000,0000,,Akhirnya.
Dialogue: 0,0:22:21.09,0:22:23.25,Default,,0000,0000,0000,,Akhirnya aku tiba.
Dialogue: 0,0:22:23.72,0:22:26.22,Default,,0000,0000,0000,,Orang yang selama ini aku kejar,
Dialogue: 0,0:22:26.22,0:22:28.16,Default,,0000,0000,0000,,dengan ikatan terdalam bagiku.
Dialogue: 0,0:22:28.97,0:22:30.51,Default,,0000,0000,0000,,Organisasi paling teruk dalam sejarah,
Dialogue: 0,0:22:30.51,0:22:32.42,Default,,0000,0000,0000,,merancang menghapuskan umat manusia,
Dialogue: 0,0:22:32.42,0:22:34.21,Default,,0000,0000,0000,,dan menulis semula dunia.
Dialogue: 0,0:22:35.17,0:22:36.99,Default,,0000,0000,0000,,Berdasarkan kejadian baru-baru ini,
Dialogue: 0,0:22:36.99,0:22:39.78,Default,,0000,0000,0000,,aku pun dapat rasa sedikit\Ntentang siapa mereka sebenarnya.
Dialogue: 0,0:22:40.44,0:22:43.21,Default,,0000,0000,0000,,Cuma aku masih tak dapat tangkap\Nhelah sebenar di sebalik semua tu.
Dialogue: 0,0:22:44.47,0:22:47.20,Default,,0000,0000,0000,,Ramalan besar Tuan Sibabawa\Ntentang "Bumi akan musnah"…
Dialogue: 0,0:22:47.72,0:22:49.59,Default,,0000,0000,0000,,dan organisasi yang menamakan\Ndiri mereka "Persatuan Raksasa",
Dialogue: 0,0:22:49.59,0:22:51.32,Default,,0000,0000,0000,,serta dalang di sebalik semua itu…
Dialogue: 0,0:22:52.24,0:22:54.35,Default,,0000,0000,0000,,Merekalah punca segalanya.
Dialogue: 0,0:22:55.17,0:22:56.49,Default,,0000,0000,0000,,Tak syak lagi.
Dialogue: 0,0:22:58.47,0:23:01.13,Default,,0000,0000,0000,,(Rumah Takoyaki)
Dialogue: 0,0:23:01.13,0:23:03.35,Default,,0000,0000,0000,,Tamatlah kalian hari ini!
Dialogue: 0,0:23:03.35,0:23:04.64,Default,,0000,0000,0000,,Rumah Evolusi!
Dialogue: 0,0:23:05.05,0:23:07.03,Default,,0000,0000,0000,,Eh, pelanggan?
Dialogue: 0,0:23:07.33,0:23:08.72,Default,,0000,0000,0000,,Kamu pelanggan, kan?
Dialogue: 0,0:23:09.85,0:23:13.30,Default,,0000,0000,0000,,Kau berubah markas berkali-kali,\Ndan sekarang kedai takoyaki pula.
Dialogue: 0,0:23:13.79,0:23:15.31,Default,,0000,0000,0000,,Jangan main-mainkan aku.
Dialogue: 0,0:23:15.73,0:23:18.23,Default,,0000,0000,0000,,Aku tahu pasal rancangan kalian.
Dialogue: 0,0:23:18.23,0:23:19.31,Default,,0000,0000,0000,,Aku takkan diperbodohkan.
Dialogue: 0,0:23:19.77,0:23:21.42,Default,,0000,0000,0000,,Tunggu sekejap, ya?
Dialogue: 0,0:23:21.43,0:23:23.25,Default,,0000,0000,0000,,Kami sedang bersiap-siap.
Dialogue: 0,0:23:24.82,0:23:27.65,Default,,0000,0000,0000,,Kini aku ialah hero! Zombie Man.
Dialogue: 0,0:23:27.96,0:23:29.88,Default,,0000,0000,0000,,Orang dengan badan yang takkan mati.
Dialogue: 0,0:23:31.06,0:23:35.51,Default,,0000,0000,0000,,Kau ingatkah tentang\NSubjek Eksperimen Sampel No. 66?
Dialogue: 0,0:23:35.51,0:23:38.98,Default,,0000,0000,0000,,Eh, kamu hero yang datang\Nuntuk musnahkan Rumah Evolusi?
Dialogue: 0,0:23:38.98,0:23:42.57,Default,,0000,0000,0000,,Minta maaf. Rumah Evolusi dah lama musnah.
Dialogue: 0,0:23:46.50,0:23:50.46,Default,,0000,0000,0000,,Err, apapun, nak masuk tak?
Dialogue: 0,0:23:50.72,0:23:52.57,Default,,0000,0000,0000,,Saya tak berapa sibuk sekarang.
Dialogue: 0,0:23:53.39,0:23:56.02,Default,,0000,0000,0000,,(Bersambung akan datang)
Dialogue: 0,0:23:56.02,0:24:01.02,Default,,0000,0000,0000,,(Had Hidupan)

