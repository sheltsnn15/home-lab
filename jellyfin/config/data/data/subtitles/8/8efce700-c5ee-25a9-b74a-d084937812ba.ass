Dialogue: 0,0:00:00.04,0:00:03.00,Default,,0,0,0,,(EPISOD 48: PENGHAPUSAN)
Dialogue: 0,0:03:38.05,0:03:43.97,Default,,0,0,0,,(JUJUTSU KAISEN THE CULLING GAME)
Dialogue: 0,0:04:18.55,0:04:22.60,Default,,0,0,0,,(JUJUTSU KAISEN THE CULLING GAME PART 1)
Dialogue: 0,0:05:15.90,0:05:17.94,Default,,0,0,0,,Jadi, dia dah mati?
Dialogue: 0,0:05:18.57,0:05:19.57,Default,,0,0,0,,Maksud saya, Mai.
Dialogue: 0,0:05:21.03,0:05:23.07,Default,,0,0,0,,Risaukan ketua keluarga dulu.
Dialogue: 0,0:05:23.37,0:05:25.58,Default,,0,0,0,,Lagipun, Maki yang akan mati.
Dialogue: 0,0:05:25.91,0:05:26.79,Default,,0,0,0,,Yakah?
Dialogue: 0,0:05:27.33,0:05:28.45,Default,,0,0,0,,Kalau begitu, tak apa.
Dialogue: 0,0:05:28.87,0:05:31.37,Default,,0,0,0,,Maki mungkin cantik\Ntapi personalitinya teruk.
Dialogue: 0,0:05:31.67,0:05:33.58,Default,,0,0,0,,Dia tak suka biarkan lelaki memimpin.
Dialogue: 0,0:05:33.88,0:05:35.75,Default,,0,0,0,,Wanita yang tak menyokong lelaki
Dialogue: 0,0:05:35.84,0:05:37.84,Default,,0,0,0,,memang patut ditikam\Ndari belakang dan mati.
Dialogue: 0,0:05:38.88,0:05:41.51,Default,,0,0,0,,Mai lebih baik dari segi itu.
Dialogue: 0,0:05:41.72,0:05:43.80,Default,,0,0,0,,(PENYIHIR GRED KHAS SATU, NAOYA ZEN'IN)
Dialogue: 0,0:05:44.34,0:05:47.47,Default,,0,0,0,,Muka dan dadanya sama seperti Maki.
Dialogue: 0,0:05:47.72,0:05:48.81,Default,,0,0,0,,Dia suka berlagak kuat,
Dialogue: 0,0:05:48.89,0:05:51.64,Default,,0,0,0,,tapi dia sedar yang dia seorang wanita.
Dialogue: 0,0:05:52.73,0:05:53.81,Default,,0,0,0,,Awak lewat.
Dialogue: 0,0:05:54.35,0:05:55.69,Default,,0,0,0,,Apa yang awak buat tadi?
Dialogue: 0,0:05:56.06,0:05:59.53,Default,,0,0,0,,Ketika ayah awak sendiri hampir mati…
Dialogue: 0,0:05:59.61,0:06:00.82,Default,,0,0,0,,Maafkan saya.
Dialogue: 0,0:06:01.15,0:06:04.11,Default,,0,0,0,,Namun sama saja\Nkalau saya datang atau tak.
Dialogue: 0,0:06:04.74,0:06:07.45,Default,,0,0,0,,Saya tetap ketua keluarga Zen'in\Nyang seterusnya.
Dialogue: 0,0:06:08.79,0:06:11.71,Default,,0,0,0,,Abang-abang saya semuanya tak berguna.
Dialogue: 0,0:06:12.79,0:06:13.62,Default,,0,0,0,,Pak cik.
Dialogue: 0,0:06:13.92,0:06:15.96,Default,,0,0,0,,Sebagai adik, awak pun sama saja.
Dialogue: 0,0:06:16.29,0:06:18.05,Default,,0,0,0,,Apatah lagi anak perempuan awak.
Dialogue: 0,0:06:18.80,0:06:20.51,Default,,0,0,0,,Jinichi pula…
Dialogue: 0,0:06:22.93,0:06:24.68,Default,,0,0,0,,Dia terlalu hodoh.
Dialogue: 0,0:06:25.09,0:06:27.47,Default,,0,0,0,,Kalaulah awak dan Toji bertukar tempat.
Dialogue: 0,0:06:31.14,0:06:33.77,Default,,0,0,0,,(PENYIHIR GRED KHAS SATU, OGI ZEN'IN)
Dialogue: 0,0:06:33.85,0:06:35.40,Default,,0,0,0,,(PENYIHIR GRED KHAS SATU, JINICHI ZEN'IN)
Dialogue: 0,0:06:35.48,0:06:38.02,Default,,0,0,0,,Ayah sedang nazak.
Dialogue: 0,0:06:38.44,0:06:39.86,Default,,0,0,0,,Tak bolehkah awak bersabar?
Dialogue: 0,0:06:41.07,0:06:42.99,Default,,0,0,0,,Semua orang ada di sini?
Dialogue: 0,0:06:45.41,0:06:48.03,Default,,0,0,0,,Ketua keluarga Zen'in, Naobito Zen'in
Dialogue: 0,0:06:48.12,0:06:51.58,Default,,0,0,0,,baru saja meninggal dunia.
Dialogue: 0,0:06:55.75,0:06:59.92,Default,,0,0,0,,Saya, Furudate, ialah penyimpan wasiatnya.
Dialogue: 0,0:07:00.17,0:07:03.67,Default,,0,0,0,,Atas permintaan Tuan Naobito…
Dialogue: 0,0:07:04.30,0:07:05.97,Default,,0,0,0,,Tuan Ogi Zen'in.
Dialogue: 0,0:07:06.43,0:07:08.43,Default,,0,0,0,,Tuan Jinichi Zen'in.
Dialogue: 0,0:07:09.01,0:07:10.72,Default,,0,0,0,,Tuan Naoya Zen'in.
Dialogue: 0,0:07:11.47,0:07:16.69,Default,,0,0,0,,Saya akan bacakan wasiatnya\Ndengan kehadiran kamu bertiga.
Dialogue: 0,0:07:18.06,0:07:21.86,Default,,0,0,0,,Jika tiada bantahan,\Nsaya akan mulakan pembacaan wasiat.
Dialogue: 0,0:07:28.53,0:07:29.66,Default,,0,0,0,,Pertama sekali,
Dialogue: 0,0:07:29.95,0:07:34.29,Default,,0,0,0,,Naoya Zen'in akan menjadi\Nketua keluarga Zen'in yang ke-27.
Dialogue: 0,0:07:35.08,0:07:36.29,Default,,0,0,0,,Seterusnya,
Dialogue: 0,0:07:36.50,0:07:40.21,Default,,0,0,0,,Naoya akan mewarisi semua aset\Ntermasuk alat-alat sumpahan
Dialogue: 0,0:07:40.29,0:07:44.80,Default,,0,0,0,,yang disimpan di Sekolah Tinggi Jujutsu\Ndan gudang sumpahan keluarga Zen'in.
Dialogue: 0,0:07:45.47,0:07:50.85,Default,,0,0,0,,Dengan persetujuan Ogi Zen'in\Natau Jinichi Zen'in,
Dialogue: 0,0:07:51.47,0:07:54.52,Default,,0,0,0,,Naoya boleh mengambil alih semua tugas.
Dialogue: 0,0:07:56.10,0:07:57.31,Default,,0,0,0,,Apa-apa saja.
Dialogue: 0,0:07:57.73,0:07:58.81,Default,,0,0,0,,Walau bagaimanapun…
Dialogue: 0,0:07:59.31,0:08:02.61,Default,,0,0,0,,Jika atas apa-apa sebab, Satoru Gojo mati
Dialogue: 0,0:08:02.69,0:08:06.32,Default,,0,0,0,,atau hilang kewarasannya,
Dialogue: 0,0:08:06.53,0:08:10.03,Default,,0,0,0,,ikrar dengan Toji Fushiguro akan dipenuhi,
Dialogue: 0,0:08:10.20,0:08:13.24,Default,,0,0,0,,Megumi Fushiguro akan diterima\Nke dalam keluarga Zen'in.
Dialogue: 0,0:08:13.33,0:08:16.12,Default,,0,0,0,,Dia akan menjadi ketua keluarga Zen'in
Dialogue: 0,0:08:16.71,0:08:19.67,Default,,0,0,0,,dan semua aset\Nakan dipindahkan kepada dia.
Dialogue: 0,0:08:21.92,0:08:22.75,Default,,0,0,0,,Apa?
Dialogue: 0,0:08:22.84,0:08:26.22,Default,,0,0,0,,Saya dah agak dua pengecut itu\Ntak boleh diharap.
Dialogue: 0,0:08:26.63,0:08:29.84,Default,,0,0,0,,Mereka lebih rela diketuai seorang budak\Nyang tak dikenali berbanding saya,
Dialogue: 0,0:08:29.93,0:08:31.22,Default,,0,0,0,,jadi mereka takkan bertindak.
Dialogue: 0,0:08:32.76,0:08:35.02,Default,,0,0,0,,Di mana Megumi sekarang?\NApa yang dia buat?
Dialogue: 0,0:08:35.56,0:08:36.73,Default,,0,0,0,,Saya tak tahu butirannya.
Dialogue: 0,0:08:37.10,0:08:40.90,Default,,0,0,0,,Saya cuma tahu dia sedang mencari\NYuji Itadori di Tokyo.
Dialogue: 0,0:08:40.98,0:08:41.94,Default,,0,0,0,,Siapa itu?
Dialogue: 0,0:08:42.48,0:08:44.36,Default,,0,0,0,,Vesel Sukuna.
Dialogue: 0,0:08:44.78,0:08:46.78,Default,,0,0,0,,Kalau begitu, beritahu orang atasan
Dialogue: 0,0:08:47.07,0:08:49.91,Default,,0,0,0,,yang Naoya Zen'in akan bunuh vesel Sukuna.
Dialogue: 0,0:08:50.53,0:08:53.33,Default,,0,0,0,,Megumi ada bersama vesel Sukuna, bukan?
Dialogue: 0,0:08:53.87,0:08:55.62,Default,,0,0,0,,Saya akan bunuh mereka berdua sekali gus.
Dialogue: 0,0:08:56.70,0:08:58.50,Default,,0,0,0,,Kini Tokyo ialah Makyo Raksasa.
Dialogue: 0,0:08:59.21,0:09:01.88,Default,,0,0,0,,Tak kisah masa atau cara\Nseseorang itu mati.
Dialogue: 0,0:09:02.88,0:09:05.96,Default,,0,0,0,,Saya boleh fikirkan langkah seterusnya\Nselepas saya bunuh mereka.
Dialogue: 0,0:09:09.42,0:09:11.51,Default,,0,0,0,,Saya ketua keluarga Zen'in.
Dialogue: 0,0:09:21.77,0:09:22.65,Default,,0,0,0,,Matilah.
Dialogue: 0,0:09:23.11,0:09:24.27,Default,,0,0,0,,- Kugisaki!\N- Saya seorang saja yang patut mati.
Dialogue: 0,0:09:24.36,0:09:25.19,Default,,0,0,0,,Saya serahkan selebihnya kepada awak.
Dialogue: 0,0:09:25.27,0:09:26.15,Default,,0,0,0,,- Matilah!\N- Itadori.
Dialogue: 0,0:09:26.23,0:09:27.15,Default,,0,0,0,,Itadori.
Dialogue: 0,0:09:27.53,0:09:28.53,Default,,0,0,0,,Apa rancangan awak?
Dialogue: 0,0:09:53.68,0:09:54.51,Default,,0,0,0,,Yuji.
Dialogue: 0,0:09:56.22,0:09:57.76,Default,,0,0,0,,Bagaimana kecederaan awak?
Dialogue: 0,0:09:59.18,0:10:02.60,Default,,0,0,0,,Selain bahagian yang terkena Kilat Hitam,\Nsaya tak apa-apa.
Dialogue: 0,0:10:04.31,0:10:06.15,Default,,0,0,0,,Ia mungkin pengaruh Sukuna.
Dialogue: 0,0:10:06.94,0:10:09.28,Default,,0,0,0,,Saya boleh rasa kuasanya semakin kuat.
Dialogue: 0,0:10:10.94,0:10:11.90,Default,,0,0,0,,Yuji!
Dialogue: 0,0:10:12.15,0:10:13.66,Default,,0,0,0,,Jangan risau tentang saya.
Dialogue: 0,0:10:14.16,0:10:15.74,Default,,0,0,0,,Awak boleh balik\Nke Sekolah Tinggi Jujutsu.
Dialogue: 0,0:10:16.74,0:10:19.79,Default,,0,0,0,,Saya masih perlu ambil\Nmayat Shoso dan yang lain.
Dialogue: 0,0:10:21.33,0:10:22.66,Default,,0,0,0,,Saya tak risau tentang awak.
Dialogue: 0,0:10:23.33,0:10:25.75,Default,,0,0,0,,Ini bukan tentang sama ada\Nsaya nak balik atau tak.
Dialogue: 0,0:10:26.96,0:10:29.76,Default,,0,0,0,,Sukuna nak gunakan Fushiguro\Nuntuk sesuatu.
Dialogue: 0,0:10:30.63,0:10:34.18,Default,,0,0,0,,Lagipun, saya dah bunuh ramai orang.
Dialogue: 0,0:10:34.84,0:10:38.81,Default,,0,0,0,,Bagaimana kalau orang yang awak selamatkan\Nbunuh orang lain suatu hari nanti?
Dialogue: 0,0:10:40.18,0:10:43.23,Default,,0,0,0,,Saya tak boleh bersama semua orang lagi.
Dialogue: 0,0:10:44.19,0:10:45.44,Default,,0,0,0,,Bagaimana dengan awak, Choso?
Dialogue: 0,0:10:45.81,0:10:48.02,Default,,0,0,0,,Saya bunuh adik-adik awak juga.
Dialogue: 0,0:10:48.32,0:10:50.40,Default,,0,0,0,,Tak apa. Itu satu kemalangan.
Dialogue: 0,0:10:50.90,0:10:54.86,Default,,0,0,0,,Eso dan Kechizu juga akan cakap perkara\Nyang sama kalau kami bertukar tempat.
Dialogue: 0,0:10:55.32,0:10:57.24,Default,,0,0,0,,Ini bukan soal memaafkan atau tak.
Dialogue: 0,0:10:57.78,0:10:59.83,Default,,0,0,0,,Adik-beradik memang begitu.
Dialogue: 0,0:11:03.33,0:11:04.29,Default,,0,0,0,,Mari kita pergi.
Dialogue: 0,0:11:04.83,0:11:06.88,Default,,0,0,0,,Kita perlu kurangkan\Njumlah semangat sumpahan dulu.
Dialogue: 0,0:12:59.61,0:13:00.45,Default,,0,0,0,,Choso!
Dialogue: 0,0:13:07.96,0:13:08.83,Default,,0,0,0,,Yuji.
Dialogue: 0,0:13:21.30,0:13:22.97,Default,,0,0,0,,Menakjubkan.
Dialogue: 0,0:13:23.39,0:13:26.35,Default,,0,0,0,,Ketika dia lawan saya,\Nkekuatannya dah mengagumkan.
Dialogue: 0,0:13:26.72,0:13:29.31,Default,,0,0,0,,Sekarang, dia dah tambah kehalusan juga.
Dialogue: 0,0:13:29.73,0:13:31.40,Default,,0,0,0,,Kawalan tenaga sumpahan\Nyang kemas dan tepat.
Dialogue: 0,0:13:31.48,0:13:33.19,Default,,0,0,0,,Kekuatan lengan yang luar biasa.
Dialogue: 0,0:13:36.07,0:13:37.57,Default,,0,0,0,,Dia seperti syaitan.
Dialogue: 0,0:13:38.07,0:13:40.86,Default,,0,0,0,,Malah dia belum sembuh sepenuhnya pun.
Dialogue: 0,0:13:42.70,0:13:45.12,Default,,0,0,0,,Begitulah adik saya.
Dialogue: 0,0:13:45.49,0:13:46.99,Default,,0,0,0,,Awak masih panggil saya adik awak?
Dialogue: 0,0:13:48.04,0:13:49.41,Default,,0,0,0,,Saya akan ulang tak kira berapa kali pun.
Dialogue: 0,0:13:50.00,0:13:51.00,Default,,0,0,0,,Cuba ingat.
Dialogue: 0,0:13:51.25,0:13:52.50,Default,,0,0,0,,Sepatutnya ada satu.
Dialogue: 0,0:13:56.04,0:13:59.21,Default,,0,0,0,,Sepatutnya ada jahitan\Npada dahi ayah awak juga.
Dialogue: 0,0:14:01.88,0:14:03.64,Default,,0,0,0,,Megumi tiada di sini?
Dialogue: 0,0:14:04.14,0:14:05.51,Default,,0,0,0,,Saya yang pertama sampai?
Dialogue: 0,0:14:05.60,0:14:06.64,Default,,0,0,0,,Bagaimana boleh jadi begini?
Dialogue: 0,0:14:06.72,0:14:07.89,Default,,0,0,0,,Dia begitu perlahan?
Dialogue: 0,0:14:08.85,0:14:10.02,Default,,0,0,0,,Siapa lelaki itu?
Dialogue: 0,0:14:10.60,0:14:12.39,Default,,0,0,0,,Adakah dia bercakap\Ntentang Fushiguro tadi?
Dialogue: 0,0:14:12.94,0:14:14.48,Default,,0,0,0,,Apa kamu berdua buat di sana?
Dialogue: 0,0:14:14.65,0:14:15.90,Default,,0,0,0,,Kamu terlalu menarik perhatian.
Dialogue: 0,0:14:16.11,0:14:17.27,Default,,0,0,0,,Kamu tak nak lari?
Dialogue: 0,0:14:18.11,0:14:18.94,Default,,0,0,0,,Lari?
Dialogue: 0,0:14:19.36,0:14:20.82,Default,,0,0,0,,Apa? Awak tak tahu?
Dialogue: 0,0:14:21.49,0:14:23.03,Default,,0,0,0,,Awak dijatuhkan hukuman mati.
Dialogue: 0,0:14:23.74,0:14:26.28,Default,,0,0,0,,Sebab sokongan Satoru dah tiada.
Dialogue: 0,0:14:29.24,0:14:30.79,Default,,0,0,0,,Gojo terlalu fleksibel dengan peraturan
Dialogue: 0,0:14:30.87,0:14:34.33,Default,,0,0,0,,sampai ramai penyihir jujutsu\Nyang dia selamatkan.
Dialogue: 0,0:14:34.75,0:14:37.04,Default,,0,0,0,,Saya mencari Megumi.
Dialogue: 0,0:14:37.13,0:14:39.88,Default,,0,0,0,,Sejujurnya,\Nsaya tak peduli awak hidup atau mati.
Dialogue: 0,0:14:40.30,0:14:42.38,Default,,0,0,0,,Namun saya tak nak awak mengganggu saya.
Dialogue: 0,0:14:42.47,0:14:44.89,Default,,0,0,0,,Mari patahkan kaki awak dulu.
Dialogue: 0,0:14:45.51,0:14:47.26,Default,,0,0,0,,Kenapa awak cari Fushiguro?
Dialogue: 0,0:14:47.64,0:14:49.56,Default,,0,0,0,,Saya nak bunuh dia.
Dialogue: 0,0:14:49.93,0:14:53.23,Default,,0,0,0,,Lebih baik jika dia boleh tulis surat\Nuntuk saya sebelum dia mati.
Dialogue: 0,0:14:53.60,0:14:55.94,Default,,0,0,0,,Saya dengar Megumi cari awak.
Dialogue: 0,0:15:16.71,0:15:19.55,Default,,0,0,0,,Dia memang laju,\Ntapi ada sesuatu yang tak kena.
Dialogue: 0,0:15:20.09,0:15:21.46,Default,,0,0,0,,Ia mungkin teknik sumpahan.
Dialogue: 0,0:15:21.80,0:15:23.88,Default,,0,0,0,,Awak lebih kuat daripada jangkaan saya.
Dialogue: 0,0:15:24.38,0:15:26.05,Default,,0,0,0,,Sejujurnya, saya pandang rendah pada awak.
Dialogue: 0,0:15:26.89,0:15:28.76,Default,,0,0,0,,Tak hairan kalau vesel itu kuat.
Dialogue: 0,0:15:29.01,0:15:30.43,Default,,0,0,0,,Namun siapa orang di sebelahnya itu?
Dialogue: 0,0:15:31.01,0:15:33.23,Default,,0,0,0,,Saya akan tambah sedikit kelajuan saya.
Dialogue: 0,0:15:39.57,0:15:40.86,Default,,0,0,0,,Cikgu Gojo?
Dialogue: 0,0:15:41.28,0:15:43.65,Default,,0,0,0,,Tak, ia sesuatu yang lebih pelik…
Dialogue: 0,0:15:51.08,0:15:51.91,Default,,0,0,0,,Apa?
Dialogue: 0,0:15:52.33,0:15:53.70,Default,,0,0,0,,Awak tak berseorangan.
Dialogue: 0,0:15:56.12,0:15:58.92,Default,,0,0,0,,(JUJUTSU KAISEN)
Dialogue: 0,0:16:00.04,0:16:00.96,Default,,0,0,0,,Siapa itu?
Dialogue: 0,0:16:01.04,0:16:02.88,Default,,0,0,0,,Siapa pun dia, matlamat dia tentu…
Dialogue: 0,0:16:03.34,0:16:05.92,Default,,0,0,0,,Siapa awak kepada Itadori?
Dialogue: 0,0:16:06.93,0:16:09.34,Default,,0,0,0,,Awak penghapus Yuji, ya?
Dialogue: 0,0:16:18.06,0:16:19.27,Default,,0,0,0,,Tunggu sekejap.
Dialogue: 0,0:16:19.35,0:16:20.44,Default,,0,0,0,,Saya di pihak awak.
Dialogue: 0,0:16:21.02,0:16:22.77,Default,,0,0,0,,Awak Okkotsu, bukan?
Dialogue: 0,0:16:23.03,0:16:24.03,Default,,0,0,0,,Okkotsu…
Dialogue: 0,0:16:24.40,0:16:26.03,Default,,0,0,0,,Dia pelajar tahun dua\Nyang Fushiguro sebut.
Dialogue: 0,0:16:26.65,0:16:29.28,Default,,0,0,0,,Dia Penyihir Gred Khas seperti Cikgu Gojo.
Dialogue: 0,0:16:29.99,0:16:30.87,Default,,0,0,0,,Siapa awak?
Dialogue: 0,0:16:31.03,0:16:32.49,Default,,0,0,0,,Saya Naoya Zen'in.
Dialogue: 0,0:16:32.58,0:16:33.99,Default,,0,0,0,,Saya sepupu Maki.
Dialogue: 0,0:16:34.41,0:16:37.08,Default,,0,0,0,,Sama seperti awak,\Nsaya datang untuk bunuh Itadori.
Dialogue: 0,0:16:37.16,0:16:38.25,Default,,0,0,0,,Lari, Yuji.
Dialogue: 0,0:16:38.33,0:16:39.63,Default,,0,0,0,,- Jangan risau.\N- Apa?
Dialogue: 0,0:16:39.92,0:16:41.42,Default,,0,0,0,,Saya takkan ganggu awak.
Dialogue: 0,0:16:41.59,0:16:43.71,Default,,0,0,0,,Si rambut perang itu jenis laju\Ntapi dengan helah tersembunyi.
Dialogue: 0,0:16:44.25,0:16:46.01,Default,,0,0,0,,Bermain kejar-kejar dengan dia\Nialah pilihan buruk.
Dialogue: 0,0:16:46.76,0:16:48.05,Default,,0,0,0,,Saya akan lengahkan dia.
Dialogue: 0,0:16:48.47,0:16:49.43,Default,,0,0,0,,Awak pasti?
Dialogue: 0,0:16:49.80,0:16:50.89,Default,,0,0,0,,Sebagai ganti,
Dialogue: 0,0:16:50.97,0:16:52.35,Default,,0,0,0,,selepas kita bunuh Itadori,
Dialogue: 0,0:16:52.43,0:16:55.31,Default,,0,0,0,,boleh awak jangan laporkan hal ini\Nkepada pihak atasan buat sementara?
Dialogue: 0,0:16:55.47,0:16:57.73,Default,,0,0,0,,Saya nak jadikan dia umpan\Nuntuk tarik seseorang keluar.
Dialogue: 0,0:16:58.02,0:16:59.02,Default,,0,0,0,,Saya tak kisah.
Dialogue: 0,0:16:59.27,0:17:01.56,Default,,0,0,0,,Sasaran mereka ialah awak, Yuji.
Dialogue: 0,0:17:02.15,0:17:03.07,Default,,0,0,0,,Si rambut hitam itu…
Dialogue: 0,0:17:03.57,0:17:05.78,Default,,0,0,0,,Awak cuma perlu fikir cara\Nuntuk lari daripada Okkotsu.
Dialogue: 0,0:17:06.65,0:17:08.78,Default,,0,0,0,,Nampaknya dia jenis yang sama\Ndengan Satoru Gojo.
Dialogue: 0,0:17:09.11,0:17:10.49,Default,,0,0,0,,Kita akan mati kalau kita lawan dia.
Dialogue: 0,0:17:10.86,0:17:13.70,Default,,0,0,0,,Nasib baik saya tak beritahu dia\Ntentang Megumi.
Dialogue: 0,0:17:13.78,0:17:14.95,Default,,0,0,0,,Menakutkan betul.
Dialogue: 0,0:17:15.16,0:17:17.37,Default,,0,0,0,,Cadangan ini boleh mencegah Yuji\Ndaripada melawan manusia.
Dialogue: 0,0:17:17.45,0:17:20.33,Default,,0,0,0,,Pada masa yang sama, dia takkan rasa\Nterhutang budi dengan saya.
Dialogue: 0,0:17:21.58,0:17:23.04,Default,,0,0,0,,Dia perlu dijaga.
Dialogue: 0,0:17:23.50,0:17:25.21,Default,,0,0,0,,Nanti kita jumpa di tempat semalam.
Dialogue: 0,0:17:25.75,0:17:26.80,Default,,0,0,0,,Okey.
Dialogue: 0,0:17:27.09,0:17:28.63,Default,,0,0,0,,Saya serahkan yang seorang lagi\Nkepada awak.
Dialogue: 0,0:17:28.80,0:17:29.68,Default,,0,0,0,,Okey.
Dialogue: 0,0:17:32.30,0:17:34.81,Default,,0,0,0,,Lajunya. Malah sambil memegang\Npedang yang dikeluarkan?
Dialogue: 0,0:17:36.81,0:17:37.72,Default,,0,0,0,,Lajunya dia.
Dialogue: 0,0:17:38.06,0:17:40.06,Default,,0,0,0,,Sepatutnya saya nak bunuh dia\Ndengan terpaan pertama saya.
Dialogue: 0,0:17:41.35,0:17:44.57,Default,,0,0,0,,Dia dapat baca yang saya\Nnak halang Okkotsu?
Dialogue: 0,0:17:45.07,0:17:46.86,Default,,0,0,0,,Saya nampak tadi.
Dialogue: 0,0:17:47.07,0:17:48.99,Default,,0,0,0,,Itu Manipulasi Darah, bukan?
Dialogue: 0,0:17:49.49,0:17:52.28,Default,,0,0,0,,Saya tak tahu sebab awak boleh gunakannya,
Dialogue: 0,0:17:52.57,0:17:54.91,Default,,0,0,0,,tapi selain Tusukan Darah,\Ntiada apa-apa yang perlu ditakutkan.
Dialogue: 0,0:17:55.28,0:17:57.91,Default,,0,0,0,,Untuk menggunakan Tusukan Darah,\Nawak mesti guna Pertumpuan.
Dialogue: 0,0:17:58.08,0:17:59.45,Default,,0,0,0,,Itu memerlukan awak berhenti lama.
Dialogue: 0,0:17:59.83,0:18:01.75,Default,,0,0,0,,Saya tak perlu beritahu awak\Nyang selebihnya, bukan?
Dialogue: 0,0:18:02.04,0:18:04.13,Default,,0,0,0,,Awak dah terkepung. Awak akan mati.
Dialogue: 0,0:18:04.71,0:18:05.88,Default,,0,0,0,,Tak, awak yang akan mati.
Dialogue: 0,0:18:06.34,0:18:08.42,Default,,0,0,0,,Awak fikir awak boleh balik hidup-hidup
Dialogue: 0,0:18:08.59,0:18:11.34,Default,,0,0,0,,selepas cuba menyakiti adik saya?
Dialogue: 0,0:18:32.91,0:18:34.78,Default,,0,0,0,,Saya sangka saya dah belah dia.
Dialogue: 0,0:18:35.20,0:18:36.58,Default,,0,0,0,,Dia seperti Maki.
Dialogue: 0,0:18:58.56,0:18:59.60,Default,,0,0,0,,Awak terkejut?
Dialogue: 0,0:19:00.31,0:19:01.98,Default,,0,0,0,,Saya tak nampak macam jenis yang kuat.
Dialogue: 0,0:19:02.64,0:19:04.31,Default,,0,0,0,,Walaupun tanpa kekuatan,
Dialogue: 0,0:19:04.94,0:19:06.81,Default,,0,0,0,,jumlah tenaga sumpahannya sangat besar.
Dialogue: 0,0:19:06.90,0:19:08.77,Default,,0,0,0,,Sebenarnya, saya jenis yang lemah.
Dialogue: 0,0:19:09.32,0:19:11.94,Default,,0,0,0,,Dia menebus kekurangan kekuatan\Ndengan menguatkan tenaga sumpahan.
Dialogue: 0,0:19:12.53,0:19:13.70,Default,,0,0,0,,Semua orang buat begitu.
Dialogue: 0,0:19:13.95,0:19:15.11,Default,,0,0,0,,Namun apabila dia lakukannya…
Dialogue: 0,0:19:15.70,0:19:17.03,Default,,0,0,0,,Dia bertentangan dengan saya.
Dialogue: 0,0:19:19.95,0:19:20.87,Default,,0,0,0,,Awak perasan?
Dialogue: 0,0:19:21.45,0:19:24.16,Default,,0,0,0,,Tenaga sumpahan saya lebih banyak\Ndaripada Cikgu Gojo.
Dialogue: 0,0:19:25.83,0:19:27.92,Default,,0,0,0,,Namun disebabkan Cikgu Gojo ada Enam Mata,
Dialogue: 0,0:19:28.42,0:19:31.05,Default,,0,0,0,,tenaga yang dia hilang\Napabila mengaktifkan teknik sumpahan
Dialogue: 0,0:19:31.13,0:19:32.80,Default,,0,0,0,,hampir kepada kosong.
Dialogue: 0,0:19:33.84,0:19:36.09,Default,,0,0,0,,Dari segi kecekapan,\Ndia memang yang paling kuat.
Dialogue: 0,0:19:37.30,0:19:39.14,Default,,0,0,0,,Saya mungkin akan kehabisan\Ntenaga sumpahan,
Dialogue: 0,0:19:39.35,0:19:40.64,Default,,0,0,0,,tapi dia tak begitu.
Dialogue: 0,0:19:42.18,0:19:43.60,Default,,0,0,0,,Saya dah habis cakap.
Dialogue: 0,0:19:49.57,0:19:50.40,Default,,0,0,0,,Tak guna.
Dialogue: 0,0:19:50.48,0:19:52.07,Default,,0,0,0,,Semakin mahir penyihir jujutsu itu,
Dialogue: 0,0:19:52.15,0:19:54.32,Default,,0,0,0,,semakin sukar untuk kita lihat\Naliran tenaga sumpahan mereka.
Dialogue: 0,0:19:54.53,0:19:56.32,Default,,0,0,0,,Namun atas sebab\Nyang berbeza daripada awak.
Dialogue: 0,0:19:56.41,0:19:57.70,Default,,0,0,0,,(BAGI PENYIHIR DENGAN KAWALAN YANG LEMAH)\NSaya kata begitu kerana
Dialogue: 0,0:19:57.78,0:19:58.62,Default,,0,0,0,,(TENAGA SUMPAHAN MEREKA TERTUMPU)\Npenyihir kelas pertama lebih tepat
Dialogue: 0,0:19:58.70,0:19:59.95,Default,,0,0,0,,(DAN TERDEDAH)\Ndalam mengawal tenaga sumpahan,
Dialogue: 0,0:20:00.03,0:20:00.87,Default,,0,0,0,,(JIKA PANDAI MENGAWAL TENAGA SUMPAHAN)\Njadi sukar untuk kita ramal serangannya
Dialogue: 0,0:20:00.95,0:20:02.95,Default,,0,0,0,,(IA AKAN LEBIH SEKATA)\Nsehingga ke saat akhir.
Dialogue: 0,0:20:04.96,0:20:06.21,Default,,0,0,0,,Namun orang ini…
Dialogue: 0,0:20:06.54,0:20:10.34,Default,,0,0,0,,Seluruh badan dan pedangnya\Nsentiasa melimpah dengan tenaga sumpahan.
Dialogue: 0,0:20:10.88,0:20:13.09,Default,,0,0,0,,Masalahnya bukan sekadar\Nmeramal pergerakannya.
Dialogue: 0,0:20:13.76,0:20:16.09,Default,,0,0,0,,Semua serangannya membawa maut.
Dialogue: 0,0:20:16.43,0:20:18.93,Default,,0,0,0,,Pada masa yang sama,\Ndia minimumkan semua kerosakan.
Dialogue: 0,0:20:19.97,0:20:21.31,Default,,0,0,0,,Saya serahkan selebihnya kepada awak.
Dialogue: 0,0:20:22.10,0:20:25.43,Default,,0,0,0,,Maaf, tapi saya belum boleh mati lagi.
Dialogue: 0,0:20:33.53,0:20:34.86,Default,,0,0,0,,Bagi sesetengah jenis pelajar,
Dialogue: 0,0:20:34.94,0:20:37.61,Default,,0,0,0,,saya latih mereka\Ndalam cara menggunakan senjata.
Dialogue: 0,0:20:39.07,0:20:42.95,Default,,0,0,0,,Namun tak bagus kalau terlalu mengharapkan\Nalat sumpahan dan abaikan tenaga sumpahan.
Dialogue: 0,0:20:43.49,0:20:45.45,Default,,0,0,0,,Yuji, awak belum sedia untuk ini.
Dialogue: 0,0:20:47.00,0:20:48.67,Default,,0,0,0,,Syaitan Pembunuh hanya untuk kecemasan.
Dialogue: 0,0:20:50.21,0:20:52.00,Default,,0,0,0,,Saya belum belajar menggunakannya!
Dialogue: 0,0:20:53.84,0:20:54.76,Default,,0,0,0,,Awak…
Dialogue: 0,0:20:55.09,0:20:56.30,Default,,0,0,0,,terlalu fokus pada pedang saya.
Dialogue: 0,0:21:04.18,0:21:05.06,Default,,0,0,0,,Dia patahkannya.
Dialogue: 0,0:21:05.68,0:21:06.85,Default,,0,0,0,,Tak hairan.
Dialogue: 0,0:21:07.14,0:21:08.81,Default,,0,0,0,,Sebab dia pelajar Cikgu Gojo.
Dialogue: 0,0:21:09.31,0:21:10.94,Default,,0,0,0,,Nampaknya dia tak mudah untuk ditangani.
Dialogue: 0,0:21:11.90,0:21:12.86,Default,,0,0,0,,Luka saya dalam.
Dialogue: 0,0:21:12.94,0:21:14.19,Default,,0,0,0,,Namun organ dalaman saya tak tersembul.
Dialogue: 0,0:21:14.65,0:21:16.15,Default,,0,0,0,,Dengan ini, kami berdua tak bersenjata.
Dialogue: 0,0:21:16.28,0:21:17.11,Default,,0,0,0,,Saya mungkin boleh menang.
Dialogue: 0,0:21:22.78,0:21:25.58,Default,,0,0,0,,Apa yang awak buat?
Dialogue: 0,0:21:28.96,0:21:31.63,Default,,0,0,0,,Kami cuma bermain-main, Rika.
Dialogue: 0,0:21:32.88,0:21:33.71,Default,,0,0,0,,Rika?
Dialogue: 0,0:21:33.96,0:21:34.96,Default,,0,0,0,,Apa benda ini?
Dialogue: 0,0:21:35.05,0:21:35.88,Default,,0,0,0,,Shikigami?
Dialogue: 0,0:21:36.13,0:21:37.26,Default,,0,0,0,,Dari mana ia datang?
Dialogue: 0,0:21:39.30,0:21:40.55,Default,,0,0,0,,Tolong pegang dia.
Dialogue: 0,0:21:41.43,0:21:42.39,Default,,0,0,0,,Saya tak boleh bergerak.
Dialogue: 0,0:21:44.81,0:21:46.56,Default,,0,0,0,,Ia terlalu kuat.
Dialogue: 0,0:21:53.98,0:21:54.94,Default,,0,0,0,,Maafkan saya.
Dialogue: 0,0:22:01.99,0:22:03.07,Default,,0,0,0,,Itadori.
Dialogue: 0,0:23:40.46,0:23:42.88,Default,,0,0,0,,Tiada sebab untuk abang\Nyang lemah wujud, bukan?
Dialogue: 0,0:23:42.97,0:23:45.51,Default,,0,0,0,,Saya tak faham sebab awak\Ntak sayang keluarga awak.
Dialogue: 0,0:23:45.59,0:23:47.97,Default,,0,0,0,,- Itadori dah mati.\N- Mungkin semua herotan itu
Dialogue: 0,0:23:48.05,0:23:49.51,Default,,0,0,0,,bermula dari saat itu.
Dialogue: 0,0:23:49.60,0:23:50.47,Default,,0,0,0,,Jangan pandang rendah pada saya.
Dialogue: 0,0:23:50.56,0:23:52.02,Default,,0,0,0,,- Jadi, tolong saya dulu.\N- Awak dah tiada jalan.
Dialogue: 0,0:23:52.10,0:23:53.14,Default,,0,0,0,,(EPISOD SETERUSNYA, SEKALI LAGI)\NTsumiki juga telah diheret
Dialogue: 0,0:23:53.23,0:23:54.85,Default,,0,0,0,,(EPISOD SETERUSNYA, SEKALI LAGI)\Nuntuk menyertai Culling Game.

