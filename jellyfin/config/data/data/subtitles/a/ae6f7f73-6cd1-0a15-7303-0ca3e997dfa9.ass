Dialogue: 0,0:00:00.00,0:00:02.95,Default,,0,0,0,,(第48集 执行)
Dialogue: 0,0:03:38.08,0:03:43.98,Default,,0,0,0,,《咒术回战 死灭回游》
Dialogue: 0,0:04:18.55,0:04:22.60,Default,,0,0,0,,《咒术回战 死灭回游 前篇》
Dialogue: 0,0:05:15.91,0:05:17.94,Default,,0,0,0,,所以是死了吗?
Dialogue: 0,0:05:18.58,0:05:19.58,Default,,0,0,0,,我说真依
Dialogue: 0,0:05:21.03,0:05:23.39,Default,,0,0,0,,现在请先担心当家吧
Dialogue: 0,0:05:23.39,0:05:25.94,Default,,0,0,0,,而且濒死的是真希
Dialogue: 0,0:05:25.94,0:05:28.89,Default,,0,0,0,,是吗 那就没差
Dialogue: 0,0:05:28.89,0:05:31.69,Default,,0,0,0,,真希虽然是个美女 但个性不行
Dialogue: 0,0:05:31.69,0:05:33.87,Default,,0,0,0,,她不懂得让男人出头
Dialogue: 0,0:05:33.87,0:05:35.77,Default,,0,0,0,,不会退在男人后方的女人
Dialogue: 0,0:05:35.77,0:05:38.04,Default,,0,0,0,,被刺中背部死掉最好
Dialogue: 0,0:05:38.88,0:05:41.73,Default,,0,0,0,,关于这点 真依就做得很好
Dialogue: 0,0:05:41.73,0:05:43.81,Default,,0,0,0,,(特别一级术师 禅院直哉)
Dialogue: 0,0:05:44.33,0:05:47.74,Default,,0,0,0,,脸蛋和胸部都和真希一样
Dialogue: 0,0:05:47.74,0:05:48.80,Default,,0,0,0,,虽然爱逞强
Dialogue: 0,0:05:48.81,0:05:52.45,Default,,0,0,0,,但她打从心底了解自己是个女人
Dialogue: 0,0:05:52.74,0:05:54.28,Default,,0,0,0,,太慢了
Dialogue: 0,0:05:54.28,0:05:56.00,Default,,0,0,0,,刚才跑去做什么?
Dialogue: 0,0:05:56.00,0:05:59.55,Default,,0,0,0,,在你亲生父亲徘徊在生死关头时…
Dialogue: 0,0:05:59.56,0:06:01.09,Default,,0,0,0,,对不起嘛
Dialogue: 0,0:06:01.09,0:06:04.68,Default,,0,0,0,,但我来不来都无所谓吧
Dialogue: 0,0:06:04.68,0:06:07.74,Default,,0,0,0,,毕竟禅院家的下一任当家就是我啊
Dialogue: 0,0:06:08.80,0:06:12.08,Default,,0,0,0,,我的哥哥们全都是废物
Dialogue: 0,0:06:12.75,0:06:13.91,Default,,0,0,0,,叔叔…
Dialogue: 0,0:06:13.91,0:06:16.21,Default,,0,0,0,,身为弟弟的你也不怎么样
Dialogue: 0,0:06:16.21,0:06:18.73,Default,,0,0,0,,更别说你女儿
Dialogue: 0,0:06:18.73,0:06:20.50,Default,,0,0,0,,至于甚一
Dialogue: 0,0:06:22.95,0:06:25.02,Default,,0,0,0,,长得太丑了
Dialogue: 0,0:06:25.02,0:06:27.79,Default,,0,0,0,,如果你跟甚尔反过来就好了
Dialogue: 0,0:06:31.16,0:06:33.88,Default,,0,0,0,,(特别一级术师 禅院扇)
Dialogue: 0,0:06:33.89,0:06:35.49,Default,,0,0,0,,(特别一级术师 禅院甚一)
Dialogue: 0,0:06:35.50,0:06:38.37,Default,,0,0,0,,爸爸正在生死关头徘徊
Dialogue: 0,0:06:38.37,0:06:40.44,Default,,0,0,0,,不能忍一忍吗?
Dialogue: 0,0:06:41.08,0:06:43.36,Default,,0,0,0,,各位都到齐了吗?
Dialogue: 0,0:06:45.40,0:06:48.11,Default,,0,0,0,,就在刚才 禅院家的当家
Dialogue: 0,0:06:48.11,0:06:52.08,Default,,0,0,0,,禅院直毘人大人过世了
Dialogue: 0,0:06:55.75,0:07:00.20,Default,,0,0,0,,而他的遗嘱由我古馆保管
Dialogue: 0,0:07:00.20,0:07:03.84,Default,,0,0,0,,依照禅院直毘人大人的意思…
Dialogue: 0,0:07:04.31,0:07:06.46,Default,,0,0,0,,禅院扇大人
Dialogue: 0,0:07:06.46,0:07:09.00,Default,,0,0,0,,禅院甚一大人
Dialogue: 0,0:07:09.00,0:07:11.00,Default,,0,0,0,,禅院直哉大人
Dialogue: 0,0:07:11.48,0:07:17.10,Default,,0,0,0,,当三位同时在场时\N由我来宣读遗嘱
Dialogue: 0,0:07:18.06,0:07:22.01,Default,,0,0,0,,若没有异议的话\N我要开始宣读遗嘱了
Dialogue: 0,0:07:28.54,0:07:29.96,Default,,0,0,0,,首先
Dialogue: 0,0:07:29.97,0:07:34.37,Default,,0,0,0,,禅院家第27代当家由禅院直哉担任
Dialogue: 0,0:07:35.09,0:07:36.51,Default,,0,0,0,,再来
Dialogue: 0,0:07:36.51,0:07:41.84,Default,,0,0,0,,存放在高专忌库\N与禅院家忌库的咒具
Dialogue: 0,0:07:41.84,0:07:44.87,Default,,0,0,0,,与所有财产由直哉继承
Dialogue: 0,0:07:45.47,0:07:51.51,Default,,0,0,0,,获得禅院扇或禅院甚一\N其中一人同意
Dialogue: 0,0:07:51.51,0:07:54.93,Default,,0,0,0,,直哉才能动用
Dialogue: 0,0:07:56.12,0:07:57.74,Default,,0,0,0,,算了 没差
Dialogue: 0,0:07:57.74,0:07:59.34,Default,,0,0,0,,但是…
Dialogue: 0,0:07:59.34,0:08:02.70,Default,,0,0,0,,如果五条悟因为某些理由而死亡
Dialogue: 0,0:08:02.70,0:08:06.53,Default,,0,0,0,,或是丧失意识
Dialogue: 0,0:08:06.53,0:08:10.19,Default,,0,0,0,,则履行与伏黑甚尔的誓约书
Dialogue: 0,0:08:10.19,0:08:13.33,Default,,0,0,0,,迎接伏黑惠进入禅院家
Dialogue: 0,0:08:13.33,0:08:16.72,Default,,0,0,0,,由他担任禅院家当家
Dialogue: 0,0:08:16.72,0:08:20.16,Default,,0,0,0,,并将所有财产让渡给他
Dialogue: 0,0:08:21.93,0:08:22.54,Default,,0,0,0,,啊?
Dialogue: 0,0:08:22.77,0:08:24.64,Default,,0,0,0,,果然不行
Dialogue: 0,0:08:24.64,0:08:26.63,Default,,0,0,0,,那两个没胆的
Dialogue: 0,0:08:26.63,0:08:28.81,Default,,0,0,0,,即使让一个不熟悉的小鬼头当当家
Dialogue: 0,0:08:28.81,0:08:31.34,Default,,0,0,0,,他们也觉得比我好 不想采取行动
Dialogue: 0,0:08:32.70,0:08:35.58,Default,,0,0,0,,惠他现在在哪里做什么?
Dialogue: 0,0:08:35.58,0:08:37.12,Default,,0,0,0,,详细我不清楚
Dialogue: 0,0:08:37.12,0:08:40.99,Default,,0,0,0,,只知道他在东京奉命搜索虎杖悠仁
Dialogue: 0,0:08:40.99,0:08:42.48,Default,,0,0,0,,那谁啊?
Dialogue: 0,0:08:42.48,0:08:44.78,Default,,0,0,0,,就是那个宿傩的容器
Dialogue: 0,0:08:44.78,0:08:47.09,Default,,0,0,0,,那妳去告诉高层
Dialogue: 0,0:08:47.09,0:08:50.53,Default,,0,0,0,,禅院直哉会杀了宿傩的容器
Dialogue: 0,0:08:50.53,0:08:53.86,Default,,0,0,0,,惠就在宿傩的容器那边吧?
Dialogue: 0,0:08:53.86,0:08:55.82,Default,,0,0,0,,我要一次把他们两个杀了
Dialogue: 0,0:08:56.72,0:08:59.24,Default,,0,0,0,,现在的东京是魔境
Dialogue: 0,0:08:59.24,0:09:01.87,Default,,0,0,0,,有人在何时又怎么死的 都无所谓
Dialogue: 0,0:09:02.87,0:09:04.05,Default,,0,0,0,,只要杀了他
Dialogue: 0,0:09:04.06,0:09:06.25,Default,,0,0,0,,接下来的事情都有办法解决
Dialogue: 0,0:09:09.46,0:09:11.80,Default,,0,0,0,,禅院家的当家是我
Dialogue: 0,0:09:21.78,0:09:23.12,Default,,0,0,0,,去死
Dialogue: 0,0:09:23.12,0:09:24.44,Default,,0,0,0,,-钉崎\N-只有我该死
Dialogue: 0,0:09:24.44,0:09:25.11,Default,,0,0,0,,之后就交给你了
Dialogue: 0,0:09:25.11,0:09:26.18,Default,,0,0,0,,-去死\N-虎杖
Dialogue: 0,0:09:26.18,0:09:27.45,Default,,0,0,0,,虎杖同学
Dialogue: 0,0:09:27.45,0:09:28.61,Default,,0,0,0,,你打算怎么做?
Dialogue: 0,0:09:53.70,0:09:54.70,Default,,0,0,0,,悠仁
Dialogue: 0,0:09:56.24,0:09:58.05,Default,,0,0,0,,你的伤势还好吗?
Dialogue: 0,0:09:59.21,0:10:03.11,Default,,0,0,0,,除了被黑闪打中的地方以外都还好
Dialogue: 0,0:10:04.33,0:10:06.94,Default,,0,0,0,,大概是宿傩的影响吧
Dialogue: 0,0:10:06.94,0:10:09.73,Default,,0,0,0,,我能感受到那家伙的力量变强大了
Dialogue: 0,0:10:10.96,0:10:12.15,Default,,0,0,0,,悠仁
Dialogue: 0,0:10:12.15,0:10:14.09,Default,,0,0,0,,你不需要顾虑我
Dialogue: 0,0:10:14.09,0:10:16.66,Default,,0,0,0,,可以回去高专没关系
Dialogue: 0,0:10:16.66,0:10:19.87,Default,,0,0,0,,毕竟我也想去回收烧相他们的遗骸
Dialogue: 0,0:10:21.34,0:10:23.34,Default,,0,0,0,,我没在顾虑你
Dialogue: 0,0:10:23.34,0:10:26.17,Default,,0,0,0,,这不是我想不想回去的问题
Dialogue: 0,0:10:26.97,0:10:30.60,Default,,0,0,0,,宿傩打算利用伏黑做些什么
Dialogue: 0,0:10:30.61,0:10:34.87,Default,,0,0,0,,而且我杀了很多人
Dialogue: 0,0:10:34.87,0:10:39.18,Default,,0,0,0,,但是如果你救的人\N将来夺走别人性命 怎么办?
Dialogue: 0,0:10:40.20,0:10:44.19,Default,,0,0,0,,我已经没办法跟大家待在一起了
Dialogue: 0,0:10:44.19,0:10:45.84,Default,,0,0,0,,倒是胀相你不在意吗?
Dialogue: 0,0:10:45.84,0:10:48.31,Default,,0,0,0,,我可是杀了你的弟弟
Dialogue: 0,0:10:48.31,0:10:50.92,Default,,0,0,0,,没关系 那是意外
Dialogue: 0,0:10:50.92,0:10:52.39,Default,,0,0,0,,坏相跟血涂
Dialogue: 0,0:10:52.39,0:10:55.33,Default,,0,0,0,,如果站在我的立场也会这么做
Dialogue: 0,0:10:55.33,0:10:57.78,Default,,0,0,0,,这不是原谅 不原谅的问题
Dialogue: 0,0:10:57.78,0:11:00.24,Default,,0,0,0,,兄弟就是这样
Dialogue: 0,0:11:03.33,0:11:04.81,Default,,0,0,0,,走吧
Dialogue: 0,0:11:04.82,0:11:07.16,Default,,0,0,0,,现在必须先减少咒灵的数量
Dialogue: 0,0:12:59.56,0:13:00.56,Default,,0,0,0,,胀相
Dialogue: 0,0:13:07.98,0:13:08.84,Default,,0,0,0,,悠仁
Dialogue: 0,0:13:21.32,0:13:23.40,Default,,0,0,0,,真是惊人
Dialogue: 0,0:13:23.40,0:13:24.78,Default,,0,0,0,,当初他和我交手时
Dialogue: 0,0:13:24.78,0:13:26.74,Default,,0,0,0,,给人的印象是强而有力
Dialogue: 0,0:13:26.74,0:13:29.73,Default,,0,0,0,,而现在又多了一分细腻
Dialogue: 0,0:13:29.73,0:13:31.41,Default,,0,0,0,,干净利落的咒力操控
Dialogue: 0,0:13:31.41,0:13:33.52,Default,,0,0,0,,超乎常人的臂力
Dialogue: 0,0:13:36.06,0:13:38.09,Default,,0,0,0,,简直就是鬼神
Dialogue: 0,0:13:38.09,0:13:41.49,Default,,0,0,0,,更别说他现在是尚未痊愈的状态
Dialogue: 0,0:13:42.73,0:13:45.52,Default,,0,0,0,,不愧是我的弟弟
Dialogue: 0,0:13:45.52,0:13:46.99,Default,,0,0,0,,你还在说这个?
Dialogue: 0,0:13:47.98,0:13:50.02,Default,,0,0,0,,要我说几次都可以
Dialogue: 0,0:13:50.02,0:13:51.27,Default,,0,0,0,,快想起来吧
Dialogue: 0,0:13:51.27,0:13:52.87,Default,,0,0,0,,应该也有才对
Dialogue: 0,0:13:56.07,0:13:58.23,Default,,0,0,0,,你父亲的额头上
Dialogue: 0,0:13:58.23,0:13:59.80,Default,,0,0,0,,应该也有缝线
Dialogue: 0,0:14:01.88,0:14:04.15,Default,,0,0,0,,惠不在啊?
Dialogue: 0,0:14:04.15,0:14:05.62,Default,,0,0,0,,我是第一个到的吗?
Dialogue: 0,0:14:05.62,0:14:06.75,Default,,0,0,0,,竟然有这种事?
Dialogue: 0,0:14:06.75,0:14:08.26,Default,,0,0,0,,动作太慢了吧?
Dialogue: 0,0:14:08.86,0:14:10.58,Default,,0,0,0,,那家伙是谁?
Dialogue: 0,0:14:10.58,0:14:12.48,Default,,0,0,0,,他刚才提到了伏黑?
Dialogue: 0,0:14:12.95,0:14:14.66,Default,,0,0,0,,你们也是 在那边做什么?
Dialogue: 0,0:14:14.66,0:14:18.04,Default,,0,0,0,,太引人注目了 不打算逃跑吗?
Dialogue: 0,0:14:18.04,0:14:19.44,Default,,0,0,0,,逃跑?
Dialogue: 0,0:14:19.44,0:14:21.40,Default,,0,0,0,,什么 你不知道吗?
Dialogue: 0,0:14:21.40,0:14:23.69,Default,,0,0,0,,你被判死刑了
Dialogue: 0,0:14:23.69,0:14:26.40,Default,,0,0,0,,因为悟的后盾消失了
Dialogue: 0,0:14:29.28,0:14:30.87,Default,,0,0,0,,五条先生的变通
Dialogue: 0,0:14:30.87,0:14:34.50,Default,,0,0,0,,换言之是耍任性\N让许多术师得到拯救
Dialogue: 0,0:14:34.77,0:14:37.14,Default,,0,0,0,,我要找的是惠
Dialogue: 0,0:14:37.15,0:14:40.31,Default,,0,0,0,,坦白说你是死是活都没差
Dialogue: 0,0:14:40.31,0:14:42.49,Default,,0,0,0,,但是我也不想要你们来搅局
Dialogue: 0,0:14:42.49,0:14:45.05,Default,,0,0,0,,总之先把你的脚折断再说吧
Dialogue: 0,0:14:45.53,0:14:47.64,Default,,0,0,0,,你找伏黑要做什么?
Dialogue: 0,0:14:47.64,0:14:49.93,Default,,0,0,0,,我打算杀了他
Dialogue: 0,0:14:49.93,0:14:53.54,Default,,0,0,0,,如果他能在死前\N替我写一封信就更好了
Dialogue: 0,0:14:53.54,0:14:56.06,Default,,0,0,0,,听说惠在找你呢
Dialogue: 0,0:15:16.74,0:15:19.63,Default,,0,0,0,,要说快是挺快的 但有哪里不对劲
Dialogue: 0,0:15:20.08,0:15:21.72,Default,,0,0,0,,八成是术式吧
Dialogue: 0,0:15:21.72,0:15:24.05,Default,,0,0,0,,比我想的还能打呢
Dialogue: 0,0:15:24.40,0:15:26.21,Default,,0,0,0,,坦白说 我小看你们了
Dialogue: 0,0:15:26.88,0:15:28.97,Default,,0,0,0,,容器厉害也不奇怪
Dialogue: 0,0:15:28.97,0:15:30.51,Default,,0,0,0,,但旁边那又是谁?
Dialogue: 0,0:15:31.03,0:15:33.60,Default,,0,0,0,,我再稍微加速好了
Dialogue: 0,0:15:39.58,0:15:41.27,Default,,0,0,0,,五条老师?
Dialogue: 0,0:15:41.27,0:15:43.98,Default,,0,0,0,,不对 是一种更怪异的…
Dialogue: 0,0:15:51.10,0:15:52.32,Default,,0,0,0,,咦?
Dialogue: 0,0:15:52.32,0:15:53.91,Default,,0,0,0,,原来不只一个人
Dialogue: 0,0:15:56.15,0:15:58.93,Default,,0,0,0,,《咒术回战》
Dialogue: 0,0:16:00.04,0:16:00.88,Default,,0,0,0,,是谁?
Dialogue: 0,0:16:00.88,0:16:02.81,Default,,0,0,0,,不论是谁 目的应该都是…
Dialogue: 0,0:16:03.30,0:16:05.85,Default,,0,0,0,,你们是虎杖的什么人?
Dialogue: 0,0:16:06.88,0:16:09.61,Default,,0,0,0,,果然是悠仁的死刑执行人吗?
Dialogue: 0,0:16:18.02,0:16:19.32,Default,,0,0,0,,先等一下
Dialogue: 0,0:16:19.32,0:16:20.98,Default,,0,0,0,,我跟你是站同一边的
Dialogue: 0,0:16:20.98,0:16:22.88,Default,,0,0,0,,你是乙骨吧
Dialogue: 0,0:16:22.88,0:16:24.32,Default,,0,0,0,,乙骨…
Dialogue: 0,0:16:24.32,0:16:26.51,Default,,0,0,0,,是之前伏黑提过的二年级生
Dialogue: 0,0:16:26.52,0:16:29.59,Default,,0,0,0,,跟五条老师一样是特级术师
Dialogue: 0,0:16:29.91,0:16:30.91,Default,,0,0,0,,你是谁?
Dialogue: 0,0:16:30.91,0:16:32.51,Default,,0,0,0,,我叫禅院直哉
Dialogue: 0,0:16:32.51,0:16:34.37,Default,,0,0,0,,是真希的堂哥
Dialogue: 0,0:16:34.37,0:16:37.00,Default,,0,0,0,,跟你一样是奉命来杀虎杖的
Dialogue: 0,0:16:37.00,0:16:38.21,Default,,0,0,0,,-快逃吧 悠仁\N-跟你一样是奉命来杀虎杖的
Dialogue: 0,0:16:38.22,0:16:39.13,Default,,0,0,0,,放心吧
Dialogue: 0,0:16:39.14,0:16:39.79,Default,,0,0,0,,什么?
Dialogue: 0,0:16:39.79,0:16:41.47,Default,,0,0,0,,我不会妨碍你
Dialogue: 0,0:16:41.47,0:16:44.13,Default,,0,0,0,,金发男是藏了一手的速度型
Dialogue: 0,0:16:44.13,0:16:46.63,Default,,0,0,0,,跟他玩你追我跑不会有好下场
Dialogue: 0,0:16:46.64,0:16:48.33,Default,,0,0,0,,我会挡下他
Dialogue: 0,0:16:48.33,0:16:49.37,Default,,0,0,0,,没问题吗?
Dialogue: 0,0:16:49.67,0:16:50.84,Default,,0,0,0,,相对的
Dialogue: 0,0:16:50.84,0:16:52.28,Default,,0,0,0,,杀死虎杖以后
Dialogue: 0,0:16:52.29,0:16:55.32,Default,,0,0,0,,可以暂时别和高层报告吗?
Dialogue: 0,0:16:55.32,0:16:57.87,Default,,0,0,0,,我想把他当作诱饵 把某人引出来
Dialogue: 0,0:16:57.87,0:16:59.15,Default,,0,0,0,,我是没问题
Dialogue: 0,0:16:59.15,0:17:02.02,Default,,0,0,0,,他们的目标是你 悠仁
Dialogue: 0,0:17:02.02,0:17:03.44,Default,,0,0,0,,那个黑发…
Dialogue: 0,0:17:03.44,0:17:06.52,Default,,0,0,0,,你只需要思考如何逃脱乙骨的追杀
Dialogue: 0,0:17:06.53,0:17:08.98,Default,,0,0,0,,看起来和五条悟是相同的类型
Dialogue: 0,0:17:08.98,0:17:10.72,Default,,0,0,0,,和他打起来必死无疑
Dialogue: 0,0:17:10.72,0:17:13.65,Default,,0,0,0,,幸好我没把惠的事情讲出来
Dialogue: 0,0:17:13.65,0:17:15.11,Default,,0,0,0,,害我捏了一把冷汗
Dialogue: 0,0:17:15.11,0:17:17.34,Default,,0,0,0,,这个提案能避免悠仁和人类战斗
Dialogue: 0,0:17:17.34,0:17:20.80,Default,,0,0,0,,同时也不会让他觉得对我有所亏欠
Dialogue: 0,0:17:21.54,0:17:23.47,Default,,0,0,0,,就是需要我照顾
Dialogue: 0,0:17:23.47,0:17:25.70,Default,,0,0,0,,在昨天的那个地点会合吧
Dialogue: 0,0:17:25.70,0:17:27.05,Default,,0,0,0,,好啊
Dialogue: 0,0:17:27.05,0:17:28.73,Default,,0,0,0,,那么 那边就交给你处理
Dialogue: 0,0:17:28.73,0:17:29.73,Default,,0,0,0,,好
Dialogue: 0,0:17:32.23,0:17:33.07,Default,,0,0,0,,好快
Dialogue: 0,0:17:33.07,0:17:34.73,Default,,0,0,0,,拿着一把出鞘的刀还能这么快
Dialogue: 0,0:17:36.77,0:17:37.99,Default,,0,0,0,,真快呢
Dialogue: 0,0:17:37.99,0:17:40.28,Default,,0,0,0,,原本打算一冲出去就收拾掉他的
Dialogue: 0,0:17:41.29,0:17:44.59,Default,,0,0,0,,早就料到我会阻挡乙骨的去路吗?
Dialogue: 0,0:17:45.02,0:17:46.99,Default,,0,0,0,,我刚才看到了
Dialogue: 0,0:17:46.99,0:17:49.10,Default,,0,0,0,,那是"赤血操术" 对吧?
Dialogue: 0,0:17:49.39,0:17:52.52,Default,,0,0,0,,虽然我不知道你为何会用那招
Dialogue: 0,0:17:52.52,0:17:55.21,Default,,0,0,0,,但除了"穿血"以外 没什么好怕的
Dialogue: 0,0:17:55.22,0:17:57.93,Default,,0,0,0,,而要使出"穿血"就必须先用"百敛"
Dialogue: 0,0:17:57.93,0:17:59.68,Default,,0,0,0,,会出现很长的停顿时间
Dialogue: 0,0:17:59.68,0:18:01.90,Default,,0,0,0,,结果不用我说 你也知道吧?
Dialogue: 0,0:18:01.90,0:18:04.22,Default,,0,0,0,,你走投无路了 死定了
Dialogue: 0,0:18:04.67,0:18:06.27,Default,,0,0,0,,你才是
Dialogue: 0,0:18:06.28,0:18:08.53,Default,,0,0,0,,竟敢对我弟弟出手
Dialogue: 0,0:18:08.53,0:18:11.48,Default,,0,0,0,,以为自己能活着回去吗?
Dialogue: 0,0:18:32.81,0:18:35.13,Default,,0,0,0,,还以为一定砍到了
Dialogue: 0,0:18:35.13,0:18:36.59,Default,,0,0,0,,跟真希好像
Dialogue: 0,0:18:58.44,0:19:00.18,Default,,0,0,0,,吓到你了吗?
Dialogue: 0,0:19:00.18,0:19:02.32,Default,,0,0,0,,毕竟我看起来不像力量型
Dialogue: 0,0:19:02.57,0:19:04.81,Default,,0,0,0,,就算没有力量
Dialogue: 0,0:19:04.81,0:19:06.77,Default,,0,0,0,,他咒力的量也大到惊人
Dialogue: 0,0:19:06.77,0:19:08.93,Default,,0,0,0,,实际上我也是属于孱弱的类型
Dialogue: 0,0:19:09.26,0:19:12.37,Default,,0,0,0,,用咒力强化弥补力量不足之处
Dialogue: 0,0:19:12.37,0:19:13.80,Default,,0,0,0,,这种事情大家都会做
Dialogue: 0,0:19:13.80,0:19:15.59,Default,,0,0,0,,但这个人做起来却…
Dialogue: 0,0:19:15.59,0:19:17.13,Default,,0,0,0,,跟我完全相反呢
Dialogue: 0,0:19:19.88,0:19:21.39,Default,,0,0,0,,你发现了吗?
Dialogue: 0,0:19:21.39,0:19:24.55,Default,,0,0,0,,我咒力的量比五条老师还要多
Dialogue: 0,0:19:25.75,0:19:28.37,Default,,0,0,0,,不过因为老师有"六眼"
Dialogue: 0,0:19:28.37,0:19:29.71,Default,,0,0,0,,在发动术式的时候
Dialogue: 0,0:19:29.71,0:19:33.74,Default,,0,0,0,,逸散的能量趋近于"0"
Dialogue: 0,0:19:33.74,0:19:36.78,Default,,0,0,0,,要论效能的话 最强的果然是老师
Dialogue: 0,0:19:37.25,0:19:39.21,Default,,0,0,0,,我的咒力有可能会用尽
Dialogue: 0,0:19:39.21,0:19:40.82,Default,,0,0,0,,但是老师不会
Dialogue: 0,0:19:42.14,0:19:43.78,Default,,0,0,0,,我话讲完了
Dialogue: 0,0:19:49.53,0:19:50.33,Default,,0,0,0,,可恶
Dialogue: 0,0:19:50.33,0:19:52.01,Default,,0,0,0,,越是一流的咒术师
Dialogue: 0,0:19:52.01,0:19:54.39,Default,,0,0,0,,越难让人看穿他的咒力流动
Dialogue: 0,0:19:54.39,0:19:56.35,Default,,0,0,0,,难以看穿的原因和你不同
Dialogue: 0,0:19:56.35,0:19:57.88,Default,,0,0,0,,(若是不擅操控咒力的术师)\N那么说是因为
Dialogue: 0,0:19:57.88,0:19:59.96,Default,,0,0,0,,(预备动作的咒力会偏一边)\N(被对方识破下一步)\N一流术师操控咒力的技巧更加精准
Dialogue: 0,0:19:59.96,0:20:02.88,Default,,0,0,0,,(若熟练操控咒力)\N(则咒力分布均匀)\N(直到行动前一刻都难以预测)\N直到前一刻都预测不到对方的攻击
Dialogue: 0,0:20:04.91,0:20:06.50,Default,,0,0,0,,但是这个人…
Dialogue: 0,0:20:06.50,0:20:07.70,Default,,0,0,0,,包括刀身
Dialogue: 0,0:20:07.70,0:20:10.72,Default,,0,0,0,,全身随时都具备着暴涨的咒力
Dialogue: 0,0:20:10.73,0:20:13.64,Default,,0,0,0,,这已经不是能不能预测动作的问题
Dialogue: 0,0:20:13.64,0:20:16.30,Default,,0,0,0,,他的每一招攻击都能让人一击毙命
Dialogue: 0,0:20:16.30,0:20:19.43,Default,,0,0,0,,同时让所有的伤害降到最低
Dialogue: 0,0:20:19.90,0:20:21.23,Default,,0,0,0,,之后就交给你了
Dialogue: 0,0:20:21.95,0:20:25.70,Default,,0,0,0,,很抱歉 我现在还不能死
Dialogue: 0,0:20:33.45,0:20:34.82,Default,,0,0,0,,有些类型的学生
Dialogue: 0,0:20:34.82,0:20:37.54,Default,,0,0,0,,我会以如何使用武器为主轴\N让他们进行修练
Dialogue: 0,0:20:39.02,0:20:40.37,Default,,0,0,0,,但是因此太依赖咒具
Dialogue: 0,0:20:40.37,0:20:43.45,Default,,0,0,0,,疏于咒力操控也不是好事
Dialogue: 0,0:20:43.45,0:20:45.93,Default,,0,0,0,,我想悠仁暂时还不用学这些
Dialogue: 0,0:20:46.95,0:20:48.72,Default,,0,0,0,,屠坐魔只是应急用的
Dialogue: 0,0:20:50.15,0:20:51.93,Default,,0,0,0,,我根本没学过啊
Dialogue: 0,0:20:53.77,0:20:55.05,Default,,0,0,0,,你的意识…
Dialogue: 0,0:20:55.05,0:20:56.23,Default,,0,0,0,,过于集中在我的刀上
Dialogue: 0,0:21:04.05,0:21:05.63,Default,,0,0,0,,被弄断了
Dialogue: 0,0:21:05.63,0:21:07.00,Default,,0,0,0,,这也难免
Dialogue: 0,0:21:07.00,0:21:09.19,Default,,0,0,0,,毕竟是五条老师的学生
Dialogue: 0,0:21:09.19,0:21:11.12,Default,,0,0,0,,果然没那么好对付
Dialogue: 0,0:21:11.76,0:21:12.88,Default,,0,0,0,,伤口很深
Dialogue: 0,0:21:12.88,0:21:14.53,Default,,0,0,0,,但是内脏没跑出来
Dialogue: 0,0:21:14.53,0:21:16.16,Default,,0,0,0,,这么一来 我和他都是手无寸铁了
Dialogue: 0,0:21:16.16,0:21:17.37,Default,,0,0,0,,有胜算
Dialogue: 0,0:21:22.72,0:21:25.84,Default,,0,0,0,,你在做什么?
Dialogue: 0,0:21:28.84,0:21:31.64,Default,,0,0,0,,只是在玩玩而已 里香
Dialogue: 0,0:21:32.79,0:21:33.90,Default,,0,0,0,,里香?
Dialogue: 0,0:21:33.90,0:21:34.97,Default,,0,0,0,,这家伙是什么东西?
Dialogue: 0,0:21:34.97,0:21:36.06,Default,,0,0,0,,式神?
Dialogue: 0,0:21:36.06,0:21:37.60,Default,,0,0,0,,是从哪里冒出来的?
Dialogue: 0,0:21:39.19,0:21:40.56,Default,,0,0,0,,帮我压住他
Dialogue: 0,0:21:41.39,0:21:42.65,Default,,0,0,0,,我完全动不了
Dialogue: 0,0:21:44.72,0:21:46.65,Default,,0,0,0,,好惊人的力量
Dialogue: 0,0:21:53.89,0:21:55.16,Default,,0,0,0,,抱歉了
Dialogue: 0,0:22:01.94,0:22:03.29,Default,,0,0,0,,虎杖
Dialogue: 0,0:23:40.48,0:23:42.95,Default,,0,0,0,,能力比弟弟还差的哥哥\N没有存在的意义吧
Dialogue: 0,0:23:42.95,0:23:45.59,Default,,0,0,0,,我无法理解你这种\N不爱自己兄弟的人的心情
Dialogue: 0,0:23:45.59,0:23:48.05,Default,,0,0,0,,-虎杖已死\N-所有的扭曲
Dialogue: 0,0:23:48.05,0:23:49.57,Default,,0,0,0,,或许都是从那个时候开始的
Dialogue: 0,0:23:49.57,0:23:50.54,Default,,0,0,0,,别看扁我
Dialogue: 0,0:23:50.54,0:23:51.47,Default,,0,0,0,,所以你先来帮助我吧
Dialogue: 0,0:23:51.47,0:23:52.07,Default,,0,0,0,,你走投无路了
Dialogue: 0,0:23:52.07,0:23:55.02,Default,,0,0,0,,(下一集 再一次)\N津美纪也被卷进死灭回游之中了

