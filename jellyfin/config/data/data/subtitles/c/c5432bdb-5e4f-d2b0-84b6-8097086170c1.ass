Dialogue: 0,0:11:37.92,0:11:39.42,Main,Mahito,0000,0000,0000,,!تعدد الأرواح
Dialogue: 0,0:11:40.77,0:11:42.09,Main,Mahito,0000,0000,0000,,!ردع الجسد
Dialogue: 0,0:12:15.32,0:12:17.65,Main,Mahito,0000,0000,0000,,،لو استعملت المزيد من القوة
Dialogue: 0,0:12:17.65,0:12:20.04,Main,Mahito,0000,0000,0000,,.لاخترقت وجهك
Dialogue: 0,0:12:23.60,0:12:26.88,Main,Yuji,0000,0000,0000,,كيف يمكنك
Dialogue: 0,0:12:26.88,0:12:29.16,Main,Yuji,0000,0000,0000,,التلاعب بالكثير
Dialogue: 0,0:12:29.16,0:12:32.73,Main,Yuji,0000,0000,0000,,!من أرواح الناس مرارًا وتكرارًا؟
Dialogue: 0,0:12:37.68,0:12:41.94,Main,Mahito,0000,0000,0000,,هل ستشعر بالرضى إن عددت كلّ روح بأصابعي وأنا نادم؟
Dialogue: 0,0:12:42.58,0:12:44.27,Main,Mahito,0000,0000,0000,,.سأبدأ بفعل ذلك بدءًا من الروح التالية
Dialogue: 0,0:12:45.27,0:12:49.80,Main,Mahito,0000,0000,0000,,.سأعطيك جوابًا بسيطًا بما أنّك شخص بسيط
Dialogue: 0,0:12:50.79,0:12:52.60,Main,Mahito,0000,0000,0000,,.إيتادوري يوجي
Dialogue: 0,0:12:55.20,0:12:57.64,Main,Junpei,0000,0000,0000,,!النجدة
Dialogue: 0,0:13:00.59,0:13:02.49,Main,Mahito,0000,0000,0000,,.أنت أنا
Dialogue: 0,0:13:03.64,0:13:05.02,Main,Yuji,0000,0000,0000,,!ماذا؟
Dialogue: 0,0:13:05.02,0:13:07.31,Main,Mahito,0000,0000,0000,,.كفّ عن الغضب على كل شيء
Dialogue: 0,0:13:07.31,0:13:09.43,Main,Mahito,0000,0000,0000,,هذا مجرد هراء لعنة، أليس كذلك؟
Dialogue: 0,0:13:13.28,0:13:14.54,Main,Mahito,0000,0000,0000,,،لكن
Dialogue: 0,0:13:15.44,0:13:17.99,Main,Mahito,0000,0000,0000,,،إلى أن تتقبل ذلك
Dialogue: 0,0:13:21.34,0:13:23.45,Main,Mahito,0000,0000,0000,,.لا يمكنك هزيمتي
Dialogue: 0,0:13:23.88,0:13:25.69,Main,Yuji,0000,0000,0000,,...أنت لا تتوقف
Dialogue: 0,0:13:25.95,0:13:27.88,Main,Yuji,0000,0000,0000,,.تتحدث كثيرًا
Dialogue: 0,0:13:27.88,0:13:29.35,Main,Yuji,0000,0000,0000,,هل تلك كلماتك الأخيرة قبل موتك؟
Dialogue: 0,0:13:30.31,0:13:32.30,Italics,Nanami,0000,0000,0000,,.سأدع الباقي لك
Dialogue: 0,0:13:33.71,0:13:38.18,Italics,Yuji,0000,0000,0000,,.ما كان نانامين ليخطئ ويدع الغضب يسيطر عليه أبدًا
Dialogue: 0,0:13:39.11,0:13:40.85,Italics,Yuji,0000,0000,0000,,.أثبت ذلك
Dialogue: 0,0:13:41.30,0:13:42.46,Italics,Nanami,0000,0000,0000,,...أنت
Dialogue: 0,0:13:41.30,0:13:42.46,Main,Yuji,0000,0000,0000,,...أنا
