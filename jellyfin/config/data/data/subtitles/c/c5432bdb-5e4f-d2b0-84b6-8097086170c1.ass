Dialogue: 0,0:18:12.37,0:18:13.56,Main,Mahito,0000,0000,0000,,!كان هذا وشيكًا
Dialogue: 0,0:18:13.98,0:18:17.11,Italics,Mahito,0000,0000,0000,,.إن اخترت اللحظات الخاطئة للمجازفة، فسأموت
Dialogue: 0,0:18:17.11,0:18:20.24,Italics,Mahito,0000,0000,0000,,.أظنني سأهاجم على الأغلب بالبشر المتحولين لبعض الوقت
Dialogue: 0,0:18:20.24,0:18:21.78,Main,Mahito,0000,0000,0000,,!كم أنت مخيف
Dialogue: 0,0:18:22.10,0:18:24.29,Italics,Yuji,0000,0000,0000,,.لديه خدع أكثر من السابق
Dialogue: 0,0:18:33.33,0:18:34.34,Main,YouthA,0000,0000,0000,,!طفل؟
Dialogue: 0,0:18:34.34,0:18:36.34,Main,YouthB,0000,0000,0000,,!أنت! تعال إلى هنا
Dialogue: 0,0:18:36.34,0:18:39.04,Main,YouthB,0000,0000,0000,,!المكان خطير ومليء بالوحوش هناك
Dialogue: 0,0:18:39.04,0:18:41.04,Italics,Yuji,0000,0000,0000,,...إنّه
Dialogue: 0,0:18:41.04,0:18:42.38,Italics,Yuji,0000,0000,0000,,!فوق؟
