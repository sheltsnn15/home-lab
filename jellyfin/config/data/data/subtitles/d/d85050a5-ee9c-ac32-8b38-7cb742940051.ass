Dialogue: 0,0:16:02.02,0:16:03.56,Sign_Basic,Sign,0000,0000,0000,,{\an1\fnArial\bord1.5\3a&HE0&\blur1\shad0\b1\fs26\pos(31,308)}23:19\h\h\h\h\h\h\h\h{\fs20}Stazione di Shibuya, tornelli di Dogenzaka
Dialogue: 0,0:18:12.37,0:18:13.56,Main,Mahito,0000,0000,0000,,Per un pelo!
Dialogue: 0,0:18:13.98,0:18:17.11,Italics,Mahito,0000,0000,0000,,Se corro rischi \Nnel momento sbagliato, ci resto secco.
Dialogue: 0,0:18:17.11,0:18:20.24,Italics,Mahito,0000,0000,0000,,Direi che per un po' \Nlo attaccherò con gli umani modificati.
Dialogue: 0,0:18:20.24,0:18:21.78,Main,Mahito,0000,0000,0000,,Che paura, che paura!
Dialogue: 0,0:18:21.78,0:18:24.29,Italics,Yuji,0000,0000,0000,,Ora sa fare molte più cose.
Dialogue: 0,0:18:33.33,0:18:34.34,Main,Ragazzo A,0000,0000,0000,,Un ragazzino?!
Dialogue: 0,0:18:34.34,0:18:36.34,Main,Ragazzo B,0000,0000,0000,,Ehi! Vieni qui!
Dialogue: 0,0:18:36.34,0:18:39.04,Main,Ragazzo B,0000,0000,0000,,Lì è pieno di mostri, è pericoloso!
Dialogue: 0,0:18:39.04,0:18:41.04,Italics,Yuji,0000,0000,0000,,Quel bastardo...
Dialogue: 0,0:18:41.04,0:18:42.38,Italics,Yuji,0000,0000,0000,,è andato di sopra?!
Dialogue: 0,0:18:44.00,0:18:45.11,Main,Yuji,0000,0000,0000,,Scusate.
Dialogue: 0,0:18:45.47,0:18:49.06,Main,Yuji,0000,0000,0000,,Al momento non ci sono luoghi sicuri a Shibuya, \Nallontanatevi più che—
Dialogue: 0,0:18:51.57,0:18:54.06,Italics,Yuji,0000,0000,0000,,Merda! Maledetto bastardo!
Dialogue: 0,0:19:03.08,0:19:04.79,Main,Mahito,0000,0000,0000,,Senti un po'...
Dialogue: 0,0:19:06.74,0:19:09.76,Main,Mahito,0000,0000,0000,,Mi sa che tu non hai molta immaginazione, vero?
Dialogue: 0,0:19:10.11,0:19:10.75,Main,Yuji,0000,0000,0000,,Smettila!
Dialogue: 0,0:19:11.20,0:19:12.60,Main,Mahito,0000,0000,0000,,Ma sei scemo?
Dialogue: 0,0:19:12.60,0:19:14.40,Main,Mahito,0000,0000,0000,,Spetta a te fermarmi, no?
Dialogue: 0,0:19:14.94,0:19:18.72,Italics,Mahito,0000,0000,0000,,Questo è il modo migliore \Nper minare la salute mentale di Itadori.
Dialogue: 0,0:19:18.72,0:19:20.20,Italics,Mahito,0000,0000,0000,,Inoltre...
Dialogue: 0,0:19:20.20,0:19:24.76,Italics,Mahito,0000,0000,0000,,abbiamo un altro asso nella manica \Ncome assicurazione!
Dialogue: 0,0:19:26.58,0:19:27.42,Flashback,Gente,0000,0000,0000,,Ma cosa...
Dialogue: 0,0:19:27.42,0:19:28.52,Flashback,Gente,0000,0000,0000,,Ehi!
Dialogue: 0,0:19:28.88,0:19:30.80,Flashback,Mahito,0000,0000,0000,,Forza bevi, bevi, bevi!
Dialogue: 0,0:19:30.80,0:19:32.23,Flashback,Mahito,0000,0000,0000,,Bevi, bevi, bevi!
Dialogue: 0,0:19:32.23,0:19:33.72,Flashback,Mahito,0000,0000,0000,,Bevi, bevi, bevi!
Dialogue: 0,0:19:33.72,0:19:34.92,Flashback,Mahito,0000,0000,0000,,Bevi!
Dialogue: 0,0:19:35.77,0:19:40.78,Sign_Basic,Sign,0000,0000,0000,,{\fad(0,932)\an1\fnArial\bord1.5\3a&HE0&\blur1\shad0\b1\fs26\pos(32,312)}21:30\h\h\h\h\h\h\h\h\hStazione di Shibuya, piano -4
Dialogue: 0,0:19:36.96,0:19:38.14,Flashback,Mahito,0000,0000,0000,,{\an8}Evvai!
Dialogue: 0,0:19:38.14,0:19:42.58,Flashback,Mahito,0000,0000,0000,,{\an8}Io ho già fatto scorta, potete fare ciò che volete \Ncon gli umani al piano di sotto.
Dialogue: 0,0:19:42.90,0:19:46.05,Flashback,Mahito,0000,0000,0000,,Forza! Ripartiamo con lo show "Ammazziamo Itadori"!
Dialogue: 0,0:19:47.63,0:19:48.63,Flashback,Jogo,0000,0000,0000,,No!
Dialogue: 0,0:19:48.63,0:19:49.62,Flashback,Mahito,0000,0000,0000,,Jogo...
Dialogue: 0,0:19:50.53,0:19:52.32,Flashback,Mahito,0000,0000,0000,,Prova a prendermi!
Dialogue: 0,0:19:55.12,0:19:58.98,Flashback,Mahito,0000,0000,0000,,Io sto di sotto, \Ntu va' a gironzolare in superficie.
Dialogue: 0,0:19:58.98,0:20:01.13,Flashback,Mahito,0000,0000,0000,,Torna quando ti chiamo, ok?
Dialogue: 0,0:20:01.13,0:20:03.69,Flashback,Mahito,0000,0000,0000,,Sì, sì, non serve che tu me lo dica!
Dialogue: 0,0:20:03.69,0:20:05.26,Flashback,Mahito,0000,0000,0000,,Non hai tutti i torti...
Dialogue: 1,0:20:07.14,0:20:07.76,sign_11038_173__Japan_s_Nationa,Sign,0000,0000,0000,,{\fs20\pos(428,324)\frz15.48\c&H6F6F6F&\3c&HF5F6F8&\bord1.4}Si è\Ndiviso\Nin due!
Dialogue: 0,0:20:07.14,0:20:07.76,sign_11038_173__Japan_s_Nationa,Sign,0000,0000,0000,,{\fs20\pos(428,324)\frz15.48\bord2.6\3c&H393B3D&}Si è\Ndiviso\Nin due!
Dialogue: 0,0:20:07.76,0:20:10.85,Sign_Basic,Sign,0000,0000,0000,,{\fs20\fnArial\3c&HF6F9F6&\shad0\c&H7E817E&\pos(57,35)}Ciao ciao!
Dialogue: 0,0:20:08.24,0:20:09.77,Flashback,Mahito,0000,0000,0000,,Ciao ciao!
Dialogue: 0,0:20:11.01,0:20:13.02,Flashback,Jogo,0000,0000,0000,,Boing!
Dialogue: 0,0:20:11.06,0:20:13.02,sign_7836_100_Laid_Off_From_Wo,Sign,0000,0000,0000,,{\fad(233,0)\an4\fs18\fnComic Sans MS\c&H282D25&\3c&HBFC3B7&\bord1.6\pos(405,195)}B\NO\NI\NN\NG
Dialogue: 0,0:20:15.74,0:20:17.19,Flashback,Choso,0000,0000,0000,,Se l'è svignata...
Dialogue: 0,0:20:21.86,0:20:24.86,Flashback,Jogo,0000,0000,0000,,Mahito!
Dialogue: 0,0:20:24.86,0:20:32.87,Sign_Basic,Sign,0000,0000,0000,,{\an1\fnArial\bord1.5\3a&HE0&\blur1\shad0\b1\fs26\pos(347,311)}23:16\h\h\h\h\hDogenzaka-koji
Dialogue: 0,0:20:25.94,0:20:27.75,Top,Mahito,0000,0000,0000,,Hai visto quella roba di prima?
Dialogue: 0,0:20:27.75,0:20:29.40,Top,Mahito,0000,0000,0000,,Da paura, vero?
Dialogue: 0,0:20:29.40,0:20:32.52,Top,Mahito,0000,0000,0000,,Pensare che fino a poco fa \Ngironzolavo da quelle parti!
Dialogue: 0,0:20:33.12,0:20:34.79,Main,Nobara,0000,0000,0000,,Hai la faccia ricucita...
Dialogue: 0,0:20:34.79,0:20:36.10,Main,Nobara,0000,0000,0000,,Sei tu, vero?
Dialogue: 0,0:20:36.10,0:20:40.01,Main,Nobara,0000,0000,0000,,Sei lo spirito maledetto di livello speciale \Nche infastidisce lo scemo del nostro gruppo.
Dialogue: 0,0:20:40.38,0:20:42.20,Main,Mahito,0000,0000,0000,,Beccato!
Dialogue: 0,0:20:42.20,0:20:44.13,Main,Mahito,0000,0000,0000,,Cos'è, sono famoso?
Dialogue: 0,0:20:44.13,0:20:47.77,Main,Nobara,0000,0000,0000,,Sì, per essere fuggito con la coda tra le gambe.
Dialogue: 0,0:20:49.36,0:20:50.58,Main,Mahito,0000,0000,0000,,Mi piaci.
Dialogue: 0,0:20:51.02,0:20:53.06,Main,Mahito,0000,0000,0000,,Forse varrà la pena ammazzarti.
Dialogue: 0,0:20:53.36,0:20:56.64,Main,Nobara,0000,0000,0000,,Anche io oggi non ho avuto molta fortuna...
Dialogue: 0,0:20:57.88,0:21:02.05,Italics,Nobara,0000,0000,0000,,Pare che la sua tecnica\N abbia qualcosa a che fare con l'anima.
Dialogue: 0,0:21:02.05,0:21:04.56,Italics,Nobara,0000,0000,0000,,E mi hanno anche detto di non farmi toccare da lui...
Dialogue: 0,0:21:05.60,0:21:08.81,Main,Nobara,0000,0000,0000,,Mi accontenterò di esorcizzare\N un insetto codardo come te.
Dialogue: 0,0:21:09.46,0:21:10.83,Italics,Nobara,0000,0000,0000,,Ricordala...
Dialogue: 0,0:21:11.19,0:21:15.21,Italics,Nobara,0000,0000,0000,,Ricorda di quando hai afferrato\N l'essenza dell'energia malefica!
Dialogue: 0,0:21:17.42,0:21:18.94,Main,Mahito,0000,0000,0000,,Pessimo controllo.
Dialogue: 0,0:21:28.16,0:21:29.18,Main,Nobara,0000,0000,0000,,Fermacapelli.
Dialogue: 0,0:21:37.59,0:21:39.11,Main,Mahito,0000,0000,0000,,Ci sai fare!
Dialogue: 0,0:21:39.11,0:21:42.23,Main,Mahito,0000,0000,0000,,Peccato però che su di me non funziona.
Dialogue: 0,0:21:42.79,0:21:44.85,Italics,Mahito,0000,0000,0000,,A giudicare dalle sue parole,
Dialogue: 0,0:21:44.85,0:21:47.36,Italics,Mahito,0000,0000,0000,,dev'essere molto legata a lui.
Dialogue: 0,0:21:47.77,0:21:50.71,Italics,Mahito,0000,0000,0000,,Gli mostrerò il cadavere di questa donna...
Dialogue: 0,0:21:50.71,0:21:54.04,Italics,Mahito,0000,0000,0000,,e spezzerò l'anima di Yuji Itadori!
Dialogue: 0,0:23:25.52,0:23:27.27,Main,Mahito,0000,0000,0000,,Facciamo un test della personalità!
Dialogue: 0,0:23:27.27,0:23:31.36,Main,Mahito,0000,0000,0000,,Ricordi con più chiarezza la persona che amavi, \Noppure la persona che odiavi?
Dialogue: 0,0:23:31.36,0:23:33.26,Main,Mahito,0000,0000,0000,,I risultati dopo il titolo!
Dialogue: 0,0:23:33.26,0:23:35.20,Top,Mahito,0000,0000,0000,,Prossimo episodio: "Giusto e sbagliato 2".
Dialogue: 0,0:23:33.26,0:23:39.93,Next_Ep_Title,Sign,0000,0000,0000,,{\c&HFFFFFF&\bord2\blur4}Prossimamente\N{\fs30\fscy150}Giusto e sbagliato 2
Dialogue: 0,0:23:35.20,0:23:39.75,Top,Mahito,0000,0000,0000,,Pensare esclusivamente al passato \Nvuol dire che sei un fissato!

