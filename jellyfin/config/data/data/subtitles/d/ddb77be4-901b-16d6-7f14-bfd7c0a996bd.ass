Dialogue: 0,0:00:15.91,0:00:19.46,Default,,0000,0000,0000,,Kekuatan untuk orang-orang♪
Dialogue: 0,0:00:19.46,0:00:23.71,Default,,0000,0000,0000,,Kekuatan luar biasa♪
Dialogue: 0,0:00:23.71,0:00:25.17,Default,,0000,0000,0000,,Ayo buktikan♪
Dialogue: 0,0:00:29.47,0:00:33.18,Default,,0000,0000,0000,,Ini giliranku!♪
Dialogue: 0,0:00:33.18,0:00:35.39,Default,,0000,0000,0000,,Cerita ini dimulai lagi♪
Dialogue: 0,0:00:35.39,0:00:37.81,Default,,0000,0000,0000,,Asosiasi bersatu dan menyerbu!♪
Dialogue: 0,0:00:37.81,0:00:40.23,Default,,0000,0000,0000,,Penuh bahaya, lewati batas♪
Dialogue: 0,0:00:40.23,0:00:42.52,Default,,0000,0000,0000,,Tidak ada tapi-tapian♪
Dialogue: 0,0:00:42.52,0:00:44.69,Default,,0000,0000,0000,,Oh oh oh oh oh♪
Dialogue: 0,0:00:44.69,0:00:46.90,Default,,0000,0000,0000,,Menang dan kalah\Nbukan dari angka♪
Dialogue: 0,0:00:46.90,0:00:49.20,Default,,0000,0000,0000,,Hi hi hi hi hi♪
Dialogue: 0,0:00:49.20,0:00:51.45,Default,,0000,0000,0000,,Waktunya pertunjukan,\Nayo kita meriahkan!♪
Dialogue: 0,0:00:51.45,0:00:55.58,Default,,0000,0000,0000,,Cobaan dari langit♪
Dialogue: 0,0:00:55.58,0:00:59.96,Default,,0000,0000,0000,,Kita lewati semuanya♪
Dialogue: 0,0:00:59.96,0:01:03.88,Default,,0000,0000,0000,,Angkat tinju apimu!♪
Dialogue: 0,0:01:04.07,0:01:07.00,Default,,0000,0000,0000,,Pahlawan itu bangkit melawan!♪
Dialogue: 0,0:01:07.00,0:01:08.42,Default,,0000,0000,0000,,Kapan pun itu♪
Dialogue: 0,0:01:08.42,0:01:11.38,Default,,0000,0000,0000,,Monster jahat yang menyerang♪
Dialogue: 0,0:01:11.38,0:01:13.22,Default,,0000,0000,0000,,Kalahkan mereka!♪
Dialogue: 0,0:01:13.22,0:01:18.06,Default,,0000,0000,0000,,Ayo, lagi (lagi), lagi (lagi),\Nberikan gejolakmu!♪
Dialogue: 0,0:01:18.06,0:01:22.44,Default,,0000,0000,0000,,Belum cukup, aku belum puas, yeah♪
Dialogue: 0,0:01:22.66,0:01:25.15,Default,,0000,0000,0000,,Lebih dari siapa pun♪
Dialogue: 0,0:01:25.15,0:01:27.23,Default,,0000,0000,0000,,Lebih kuat lagi, hey!♪
Dialogue: 0,0:01:27.23,0:01:29.40,Default,,0000,0000,0000,,Menarilah, menarilah♪
Dialogue: 0,0:01:29.40,0:01:31.32,Default,,0000,0000,0000,,Langit kehancuran, hey!♪
Dialogue: 0,0:01:31.55,0:01:36.37,Default,,0000,0000,0000,,Selalu selesaikan\Ndengan satu serangan!♪
Dialogue: 0,0:01:36.87,0:01:40.49,Default,,0000,0000,0000,,One Punch!♪
Dialogue: 0,0:01:41.00,0:01:45.71,Default,,0000,0000,0000,,{\an8}(Rapat Strategi)
Dialogue: 0,0:01:41.57,0:01:44.71,Default,,0000,0000,0000,,Kupikir kehancuran kota\Nsudah tak terhindarkan,
Dialogue: 0,0:01:44.71,0:01:48.21,Default,,0000,0000,0000,,tapi ternyata monster sebesar itu\Nbisa dikalahkan dengan serangan kuat.
Dialogue: 0,0:01:48.21,0:01:52.34,Default,,0000,0000,0000,,Lipan Tetua pun musnah\Ntanpa sisa di tempat, ya.
Dialogue: 0,0:01:52.79,0:01:54.93,Default,,0000,0000,0000,,Aku masih belum bisa percaya.
Dialogue: 0,0:01:54.93,0:01:57.30,Default,,0000,0000,0000,,Cuma King yang bisa lakukan trik itu.
Dialogue: 0,0:01:57.30,0:02:00.27,Default,,0000,0000,0000,,Syukurlah King ada di pihak kita.
Dialogue: 0,0:02:00.27,0:02:01.60,Default,,0000,0000,0000,,Namun...
Dialogue: 0,0:02:01.60,0:02:05.52,Default,,0000,0000,0000,,Silver Fang gagal mengurus\Nsi Pemburu Pahlawan.
Dialogue: 0,0:02:05.52,0:02:07.65,Default,,0000,0000,0000,,Sitch, bagaimana ini?
Dialogue: 0,0:02:07.89,0:02:12.60,Default,,0000,0000,0000,,Kalau pahlawan kita diburu terus,\NAsosiasi Pahlawan tak bisa berfungsi lagi.
Dialogue: 0,0:02:13.23,0:02:15.48,Default,,0000,0000,0000,,Garou sudah bukan manusia,
Dialogue: 0,0:02:15.48,0:02:18.37,Default,,0000,0000,0000,,kita anggap saja dia sebagai monster.
Dialogue: 0,0:02:18.37,0:02:20.28,Default,,0000,0000,0000,,Saat dia muncul lagi,
Dialogue: 0,0:02:20.28,0:02:24.96,Default,,0000,0000,0000,,kita harus mengeluarkan peringatan darurat\Nsebagai Bencana Level Naga.
Dialogue: 0,0:02:24.96,0:02:27.80,Default,,0000,0000,0000,,Tapi aslinya dia manusia, 'kan?
Dialogue: 0,0:02:27.80,0:02:32.09,Default,,0000,0000,0000,,Apa ada manusia yang bisa\Nmenghadapi pahlawan Kelas S kita?
Dialogue: 0,0:02:32.09,0:02:33.74,Default,,0000,0000,0000,,Coba dipikir normal.
Dialogue: 0,0:02:33.74,0:02:35.84,Default,,0000,0000,0000,,Mungkin strateginya kurang bagus.
Dialogue: 0,0:02:35.84,0:02:37.30,Default,,0000,0000,0000,,Pahlawan asosiasi...
Dialogue: 0,0:02:37.30,0:02:40.43,Default,,0000,0000,0000,,Masih sempat-sempatnya berpikir bisnis?
Dialogue: 0,0:02:40.43,0:02:45.10,Default,,0000,0000,0000,,Silver Fang gagal mengalahkan Garou\Nmemang di luar perkiraan,
Dialogue: 0,0:02:45.10,0:02:48.06,Default,,0000,0000,0000,,tapi dia berhasil\Nmemberikan luka berat padanya.
Dialogue: 0,0:02:48.19,0:02:52.94,Default,,0000,0000,0000,,Sekarang, Garou tidak mungkin jadi daya tempur\NAsosiasi Monster untuk menghalangi kita.
Dialogue: 0,0:02:52.94,0:02:55.36,Default,,0000,0000,0000,,Jika kita ambil\Nsisi positifnya dari situ saja...
Dialogue: 0,0:02:55.36,0:02:57.78,Default,,0000,0000,0000,,Panggil Blast!
Dialogue: 0,0:02:57.78,0:03:00.49,Default,,0000,0000,0000,,Dia kelas tertinggi,\Ntapi tidak bergerak sama sekali.
Dialogue: 0,0:03:00.49,0:03:04.00,Default,,0000,0000,0000,,Mustahil menggerakkan Blast\Ndengan perintah.
Dialogue: 0,0:03:04.00,0:03:08.13,Default,,0000,0000,0000,,Dia hanya beraktivitas sebagai pahlawan\Natas kehendak bebasnya sendiri.
Dialogue: 0,0:03:08.51,0:03:12.38,Default,,0000,0000,0000,,Intinya dia menolak terikat,\Nbenci tampak menonjol,
Dialogue: 0,0:03:12.38,0:03:15.40,Default,,0000,0000,0000,,jadi identitasnya dirahasiakan\Nbahkan saat mendaftar.
Dialogue: 0,0:03:15.40,0:03:20.68,Default,,0000,0000,0000,,Tentu, semua itu diputuskan karena\Ndia memang layak diperlakukan istimewa.
Dialogue: 0,0:03:20.68,0:03:24.35,Default,,0000,0000,0000,,Namun saat umat manusia\Nbenar-benar butuh pertolongan,
Dialogue: 0,0:03:24.35,0:03:26.27,Default,,0000,0000,0000,,dia pasti bergerak.
Dialogue: 0,0:03:26.27,0:03:28.02,Default,,0000,0000,0000,,Apa-apaan itu?!
Dialogue: 0,0:03:28.02,0:03:29.73,Default,,0000,0000,0000,,Sekaranglah waktunya!
Dialogue: 0,0:03:29.73,0:03:32.57,Default,,0000,0000,0000,,Putraku diculik monster, tahu!
Dialogue: 0,0:03:32.89,0:03:35.44,Default,,0000,0000,0000,,Sudah berlalu 24 jam sejak itu,
Dialogue: 0,0:03:35.44,0:03:37.70,Default,,0000,0000,0000,,tapi kenapa masih belum\Nmenyergap juga?!
Dialogue: 0,0:03:37.70,0:03:40.45,Default,,0000,0000,0000,,Putra Anda pasti kami selamatkan.
Dialogue: 0,0:03:40.98,0:03:42.03,Default,,0000,0000,0000,,Siapa kau?
Dialogue: 0,0:03:42.33,0:03:45.62,Default,,0000,0000,0000,,Saya yang akan memimpin\Noperasi penyelamatan ini,
Dialogue: 0,0:03:45.62,0:03:47.50,Default,,0000,0000,0000,,Sekingar.
Dialogue: 0,0:03:47.73,0:03:50.21,Default,,0000,0000,0000,,Salam kenal.
Dialogue: 0,0:03:50.21,0:03:51.29,Default,,0000,0000,0000,,Hah?
Dialogue: 0,0:03:51.74,0:03:54.13,Default,,0000,0000,0000,,Buat apa strategi?
Dialogue: 0,0:03:54.13,0:03:58.55,Default,,0000,0000,0000,,Aku tinggal masuk\Nterus bereskan semuanya.
Dialogue: 0,0:03:58.55,0:04:00.43,Default,,0000,0000,0000,,Sarang mereka belum ketemu?
Dialogue: 0,0:04:00.43,0:04:04.29,Default,,0000,0000,0000,,Saat ini, Kaisar Cilik sedang\Nmencarinya secepat mungkin.
Dialogue: 0,0:04:04.29,0:04:09.65,Default,,0000,0000,0000,,Robot penjelajah sedang menggali\Nbawah tanah tempat Lipan Tetua muncul,
Dialogue: 0,0:04:09.65,0:04:11.42,Default,,0000,0000,0000,,tapi lingkupnya luas sekali.
Dialogue: 0,0:04:11.42,0:04:12.89,Default,,0000,0000,0000,,Tiga hari lagi?
Dialogue: 0,0:04:12.89,0:04:14.02,Default,,0000,0000,0000,,Tinggal dua hari lagi.
Dialogue: 0,0:04:14.02,0:04:16.44,Default,,0000,0000,0000,,Duh, aku tidak bisa tidur.
Dialogue: 0,0:04:16.44,0:04:20.70,Default,,0000,0000,0000,,Sarangnya pasti ada di suatu\Ntempat di Kota Hantu Z, 'kan?
Dialogue: 0,0:04:20.70,0:04:23.03,Default,,0000,0000,0000,,Mau aku acak-acak?
Dialogue: 0,0:04:20.70,0:04:26.08,Default,,0000,0000,0000,,{\an8}(Gruak)
Dialogue: 0,0:04:23.03,0:04:26.08,Default,,0000,0000,0000,,Tolong bertindak hati-hati\Nkarena ada sandera.
Dialogue: 0,0:04:26.08,0:04:28.83,Default,,0000,0000,0000,,Cara kalian merepotkan.
Dialogue: 0,0:04:28.83,0:04:31.95,Default,,0000,0000,0000,,Kalau tidak begitu\Nmemang tidak sepadan, sih.
Dialogue: 0,0:04:31.95,0:04:34.59,Default,,0000,0000,0000,,Para monster pasti ketakutan denganku.
Dialogue: 0,0:04:34.59,0:04:36.63,Default,,0000,0000,0000,,Lawan kita cukup kuat.
Dialogue: 0,0:04:36.63,0:04:38.05,Default,,0000,0000,0000,,Ah, iya, iya.
Dialogue: 0,0:04:38.05,0:04:42.39,Default,,0000,0000,0000,,Kamu bicara pada kami\Nhanya untuk melontarkan fakta itu?
Dialogue: 0,0:04:44.42,0:04:48.39,Default,,0000,0000,0000,,Kemarin, Kesatria Pusa melakukan\Npenyelidikan mandiri...
Dialogue: 0,0:04:48.39,0:04:50.60,Default,,0000,0000,0000,,Dia mengabaikan larangan kami
Dialogue: 0,0:04:50.60,0:04:53.27,Default,,0000,0000,0000,,dan masuk Kota Hantu lebih dahulu.
Dialogue: 0,0:04:53.76,0:04:55.15,Default,,0000,0000,0000,,Kenapa sendirian?
Dialogue: 0,0:04:55.48,0:04:58.74,Default,,0000,0000,0000,,Karena dia tidak mau kalah\Ndalam pertarungan.
Dialogue: 0,0:04:58.74,0:05:00.52,Default,,0000,0000,0000,,Mungkin dia percaya diri.
Dialogue: 0,0:05:00.52,0:05:05.45,Default,,0000,0000,0000,,Tapi sejak semalam, sinyal\Ndari pemancarnya menghilang.
Dialogue: 0,0:05:05.78,0:05:07.95,Default,,0000,0000,0000,,Kesatria Pusa telah dikalahkan.
Dialogue: 0,0:05:07.95,0:05:09.95,Default,,0000,0000,0000,,Sebaiknya kita anggap demikian.
Dialogue: 0,0:05:11.19,0:05:12.79,Default,,0000,0000,0000,,Masa bodoh dengan itu.
Dialogue: 0,0:05:12.79,0:05:15.88,Default,,0000,0000,0000,,Kalau begitu, cepat kumpulkan anggota.
Dialogue: 0,0:05:15.88,0:05:17.25,Default,,0000,0000,0000,,Sisanya siapa lagi?
Dialogue: 0,0:05:17.66,0:05:21.97,Default,,0000,0000,0000,,Asosiasi Monster memberikan\Nwaktu tiga hari pada kita.
Dialogue: 0,0:05:21.97,0:05:23.50,Default,,0000,0000,0000,,Kita masih punya waktu.
Dialogue: 0,0:05:24.29,0:05:27.47,Default,,0000,0000,0000,,Setelah pahlawan lain selesai\Ndengan persiapan masing-masing,
Dialogue: 0,0:05:27.47,0:05:29.35,Default,,0000,0000,0000,,mereka pasti akan menyusul.
Dialogue: 0,0:05:29.89,0:05:31.56,Default,,0000,0000,0000,,Masih harus siaga?
Dialogue: 0,0:05:31.56,0:05:32.52,Default,,0000,0000,0000,,Kenapa?
Dialogue: 0,0:05:32.93,0:05:35.48,Default,,0000,0000,0000,,Anak-anak disandera?
Dialogue: 0,0:05:35.48,0:05:38.40,Default,,0000,0000,0000,,Kau tidak tahu apa-apa, Atomic Samurai?
Dialogue: 0,0:05:38.40,0:05:40.69,Default,,0000,0000,0000,,Dan kau sedikit bau darah.
Dialogue: 0,0:05:41.10,0:05:44.49,Default,,0000,0000,0000,,Sejak kemarin, aku patroli\Ndi gunung dan gua,
Dialogue: 0,0:05:44.49,0:05:49.77,Default,,0000,0000,0000,,lalu menghabisi para monster\Nyang bersembunyi lagi dan lagi.
Dialogue: 0,0:05:49.77,0:05:53.96,Default,,0000,0000,0000,,Sayangnya, aku tidak menemukan\Nsarang Asosiasi Monster.
Dialogue: 0,0:05:54.32,0:05:55.63,Default,,0000,0000,0000,,Ya iya, dong.
Dialogue: 0,0:05:55.63,0:05:59.21,Default,,0000,0000,0000,,Katanya, sarang Asosiasi Monster\Nada di Kota Hantu.
Dialogue: 0,0:05:59.21,0:06:02.11,Default,,0000,0000,0000,,Apa? Kalian sudah tahu sejauh itu?
Dialogue: 0,0:06:02.11,0:06:06.16,Default,,0000,0000,0000,,Yah, lebih gampang kalau\Nbertarung langsung di sarang mereka.
Dialogue: 0,0:06:06.16,0:06:08.72,Default,,0000,0000,0000,,Beristirahatlah sampai saat itu tiba.
Dialogue: 0,0:06:08.72,0:06:09.35,Default,,0000,0000,0000,,Baik.
Dialogue: 0,0:06:09.35,0:06:11.18,Default,,0000,0000,0000,,Aku mandi dulu, ah.
Dialogue: 0,0:06:12.96,0:06:13.85,Default,,0000,0000,0000,,Lo?
Dialogue: 0,0:06:14.38,0:06:18.23,Default,,0000,0000,0000,,Kudengar tim penyergap\Nadalah kelompok kecil elite...
Dialogue: 0,0:06:18.23,0:06:21.76,Default,,0000,0000,0000,,Entah kenapa, ada orang\Nyang tidak pantas di sini.
Dialogue: 0,0:06:21.76,0:06:23.74,Default,,0000,0000,0000,,Ini bukan piknik.
Dialogue: 0,0:06:23.74,0:06:28.61,Default,,0000,0000,0000,,Bisakah kau tidak membawa\Nteman nyentrikmu, Atomic Samurai?
Dialogue: 0,0:06:29.24,0:06:32.16,Default,,0000,0000,0000,,Biarkan keroco melawan keroco.
Dialogue: 0,0:06:32.16,0:06:33.46,Default,,0000,0000,0000,,Paham?
Dialogue: 0,0:06:33.46,0:06:36.00,Default,,0000,0000,0000,,Masih mending kalau langsung mati,
Dialogue: 0,0:06:36.00,0:06:38.60,Default,,0000,0000,0000,,tapi bisa repot kalau mereka\Nmenjadi sandera atau tameng.
Dialogue: 0,0:06:38.60,0:06:40.55,Default,,0000,0000,0000,,Cuma tambah repot saja.
Dialogue: 0,0:06:40.90,0:06:45.30,Default,,0000,0000,0000,,Jika itu terjadi, bisakah kau perintah\Nmereka untuk bunuh diri?
Dialogue: 0,0:06:45.30,0:06:47.39,Default,,0000,0000,0000,,Woi, Cowok Ganteng!
Dialogue: 0,0:06:47.39,0:06:50.09,Default,,0000,0000,0000,,Topeng Manis, kau juga ikut?
Dialogue: 0,0:06:50.38,0:06:51.97,Default,,0000,0000,0000,,Tentu saja.
Dialogue: 0,0:06:51.97,0:06:55.77,Default,,0000,0000,0000,,Karena para monster\Nmengganggu konserku.
Dialogue: 0,0:06:55.97,0:07:00.73,Default,,0000,0000,0000,,Oh, begitu.\NMurid-muridku kuat, lo.
Dialogue: 0,0:07:00.73,0:07:04.40,Default,,0000,0000,0000,,Aku sudah memberi tahu mereka
Dialogue: 0,0:07:04.40,0:07:06.99,Default,,0000,0000,0000,,untuk melindungi mas idola\Nsaat kesulitan.
Dialogue: 0,0:07:06.99,0:07:08.74,Default,,0000,0000,0000,,Tenang saja.
Dialogue: 0,0:07:08.74,0:07:10.55,Default,,0000,0000,0000,,Kesulitan?
Dialogue: 0,0:07:10.55,0:07:15.19,Default,,0000,0000,0000,,Aku tidak percaya masih ada\Nyang meragukan kemampuan tempurku.
Dialogue: 0,0:07:15.19,0:07:18.54,Default,,0000,0000,0000,,Aku ada di Kelas A hanya karena\Nlebih mudah mengawasi keseluruhan
Dialogue: 0,0:07:18.54,0:07:21.21,Default,,0000,0000,0000,,dan bisa naik ke Kelas S\Nkapan pun aku mau.
Dialogue: 0,0:07:22.45,0:07:23.80,Default,,0000,0000,0000,,Oh, ya.
Dialogue: 0,0:07:23.80,0:07:26.61,Default,,0000,0000,0000,,Agar orang tolol bisa paham juga...
Dialogue: 0,0:07:26.61,0:07:28.30,Default,,0000,0000,0000,,Aku lebih kuat darimu.
Dialogue: 0,0:07:29.79,0:07:31.43,Default,,0000,0000,0000,,Begitu, ya. Begitu, ya.
Dialogue: 0,0:07:31.43,0:07:34.31,Default,,0000,0000,0000,,Guru, tahan!
Dialogue: 0,0:07:35.98,0:07:38.15,Default,,0000,0000,0000,,Pak Sipir, kau yakin?
Dialogue: 0,0:07:38.15,0:07:41.06,Default,,0000,0000,0000,,Membebaskanku terang-terangan...
Dialogue: 0,0:07:41.06,0:07:44.28,Default,,0000,0000,0000,,Ini namanya tindakan khusus\Ndi luar ketentuan hukum.
Dialogue: 0,0:07:44.28,0:07:49.11,Default,,0000,0000,0000,,Asal kau tahu saja, kau bisa kabur\Ndan beraktivitas sebagai pahlawan selama ini
Dialogue: 0,0:07:49.11,0:07:50.95,Default,,0000,0000,0000,,adalah pelanggaran hukum.
Dialogue: 0,0:07:51.69,0:07:56.50,Default,,0000,0000,0000,,Aku benci cara Asosiasi Pahlawan\Nmemperlakukan orang sepertimu,
Dialogue: 0,0:07:56.50,0:07:58.78,Default,,0000,0000,0000,,tapi khusus kali ini tidak bisa begitu.
Dialogue: 0,0:07:59.54,0:08:03.59,Default,,0000,0000,0000,,Hanya karena ulah satu\Nmonster jenis kucing,
Dialogue: 0,0:08:03.59,0:08:06.51,Default,,0000,0000,0000,,beberapa napi menjadi monster\Ndan dibawa pergi.
Dialogue: 0,0:08:06.79,0:08:10.59,Default,,0000,0000,0000,,Banyak pegawai yang melawan\Nkehilangan nyawanya!
Dialogue: 0,0:08:10.59,0:08:12.97,Default,,0000,0000,0000,,Kau juga seorang\Npahlawan di luar sana, 'kan?
Dialogue: 0,0:08:12.97,0:08:14.97,Default,,0000,0000,0000,,Ya, 'kan, Bos Napi?!
Dialogue: 0,0:08:15.30,0:08:18.10,Default,,0000,0000,0000,,Balaskan dendam kami!
Dialogue: 0,0:08:18.71,0:08:20.49,Default,,0000,0000,0000,,Serahkan padaku.
Dialogue: 0,0:08:20.49,0:08:23.89,Default,,0000,0000,0000,,Sebagai balasan karena sudah berbuat\Nsesuka hati selagi aku tidak ada,
Dialogue: 0,0:08:23.89,0:08:26.32,Default,,0000,0000,0000,,akan kuberi mereka pelajaran.
Dialogue: 0,0:08:26.89,0:08:28.86,Default,,0000,0000,0000,,Bos, tunggu!
Dialogue: 0,0:08:28.86,0:08:31.24,Default,,0000,0000,0000,,Aku merajut sweter baru!
Dialogue: 0,0:08:31.61,0:08:33.08,Default,,0000,0000,0000,,Tolong dipakai.
Dialogue: 0,0:08:36.79,0:08:38.21,Default,,0000,0000,0000,,Terima kasih.
Dialogue: 0,0:08:38.21,0:08:40.41,Default,,0000,0000,0000,,Aku jadi makin berani.
Dialogue: 0,0:08:42.65,0:08:43.62,Default,,0000,0000,0000,,Hei.
Dialogue: 0,0:08:43.62,0:08:45.92,Default,,0000,0000,0000,,Bisa kalian pergi sebentar?
Dialogue: 0,0:08:45.92,0:08:47.88,Default,,0000,0000,0000,,Kalau dilihat, aku jadi tidak bisa fokus.
Dialogue: 0,0:08:50.38,0:08:53.42,Default,,0000,0000,0000,,Metal Knight, aku tahu\Nwalau kau pura-pura bodoh.
Dialogue: 0,0:08:53.42,0:08:55.05,Default,,0000,0000,0000,,Jawab aku.
Dialogue: 0,0:08:55.75,0:08:57.02,Default,,0000,0000,0000,,Apa?
Dialogue: 0,0:08:57.02,0:09:00.39,Default,,0000,0000,0000,,Saat ini, aku merasa kita\Nbuang-buang tenaga.
Dialogue: 0,0:09:01.93,0:09:05.06,Default,,0000,0000,0000,,Kau pasti tahu lokasi\Nsarangnya sejak lama, 'kan?
Dialogue: 0,0:09:05.06,0:09:07.65,Default,,0000,0000,0000,,Beri tahu aku!\NNanti terlambat, lo!
Dialogue: 0,0:09:07.65,0:09:09.74,Default,,0000,0000,0000,,Kau mau membiarkan\Nsanderanya dibunuh?
Dialogue: 0,0:09:10.60,0:09:14.20,Default,,0000,0000,0000,,Membiarkan sandera mati\Ndengan tak memberitahumu
Dialogue: 0,0:09:14.20,0:09:19.33,Default,,0000,0000,0000,,atau memberitahumu sehingga\Nmembuat kalian dan sandera mati.
Dialogue: 0,0:09:19.33,0:09:23.58,Default,,0000,0000,0000,,Aku berpikir rasional\Ndan membuat pilihan atas keadilan.
Dialogue: 0,0:09:23.58,0:09:25.84,Default,,0000,0000,0000,,Masih ada satu pilihan lagi!
Dialogue: 0,0:09:25.84,0:09:27.80,Default,,0000,0000,0000,,Kau ikut dalam operasi ini juga!
Dialogue: 0,0:09:28.20,0:09:30.88,Default,,0000,0000,0000,,Kenapa setakut itu?
Dialogue: 0,0:09:30.88,0:09:33.93,Default,,0000,0000,0000,,Apa yang terjadi dengan\Ntubuh mesin Metal Knight?
Dialogue: 0,0:09:33.93,0:09:37.60,Default,,0000,0000,0000,,Kalau memang hancur, oleh monster\Nseperti apa dan cara seperti apa?
Dialogue: 0,0:09:38.79,0:09:41.64,Default,,0000,0000,0000,,Raja Monster, Orochi.
Dialogue: 0,0:09:41.64,0:09:43.35,Default,,0000,0000,0000,,Hanya sekali serang.
Dialogue: 0,0:09:43.35,0:09:48.10,Default,,0000,0000,0000,,Mode penghancuran diri dimatikan\Nbersamaan dengan lengan yang melindunginya.
Dialogue: 0,0:09:48.43,0:09:52.22,Default,,0000,0000,0000,,Yang kutakuti bukanlah\NAsosiasi Monster itu sendiri.
Dialogue: 0,0:09:52.22,0:09:55.99,Default,,0000,0000,0000,,Kejahatan lain pun masih\Nmengincar dunia dengan waspada.
Dialogue: 0,0:09:55.99,0:10:00.33,Default,,0000,0000,0000,,Begitu pelindung umat manusia lengah,\Nmereka akan mengambil alih dalam sekejap.
Dialogue: 0,0:10:00.62,0:10:02.53,Default,,0000,0000,0000,,Kau juga harus hati-hati.
Dialogue: 0,0:10:02.53,0:10:05.50,Default,,0000,0000,0000,,Jangan percaya pada orang di sekitarmu.
Dialogue: 0,0:10:05.50,0:10:08.57,Default,,0000,0000,0000,,Kau bisa menegakkan keadilan seorang diri.
Dialogue: 0,0:10:08.57,0:10:13.42,Default,,0000,0000,0000,,Kumpulkan dan simpan kekuatanmu\Nsampai saat itu tiba, Kaisar Cilik.
Dialogue: 0,0:10:18.63,0:10:21.48,Default,,0000,0000,0000,,Asosiasi Pahlawan sama sekali\Ntak bisa diandalkan!
Dialogue: 0,0:10:21.48,0:10:22.56,Default,,0000,0000,0000,,Dengar!
Dialogue: 0,0:10:22.56,0:10:26.81,Default,,0000,0000,0000,,Selagi kita berdiri di sini, putraku\Nmenunggu pertolongan sambil gemetar!
Dialogue: 0,0:10:26.81,0:10:31.15,Default,,0000,0000,0000,,Cepat pergi ke reruntuhan Kota Z\Ndan temukan sarang para monster!
Dialogue: 0,0:10:31.15,0:10:32.77,Default,,0000,0000,0000,,Selamatkan putraku!
Dialogue: 0,0:10:32.77,0:10:34.82,Default,,0000,0000,0000,,Baju tempur yang kalian pakai
Dialogue: 0,0:10:34.82,0:10:37.49,Default,,0000,0000,0000,,adalah senjata rahasia\Nyang diperoleh dari jalur khusus!
Dialogue: 0,0:10:37.49,0:10:42.04,Default,,0000,0000,0000,,Kemampuan baju itu melampaui\Nkekuatan pahlawan profesional mana pun!
Dialogue: 0,0:10:42.04,0:10:44.25,Default,,0000,0000,0000,,Gunakan baju tempur itu\Nsemaksimal mungkin
Dialogue: 0,0:10:42.04,0:10:46.25,Default,,0000,0000,0000,,{\an8}(Pasukan Pribadi Narinki)
Dialogue: 0,0:10:44.25,0:10:46.25,Default,,0000,0000,0000,,dan habisi semua monster\Nyang kalian temui!
Dialogue: 0,0:10:46.78,0:10:49.17,Default,,0000,0000,0000,,Imbalan keberhasilan kalian\Nakan kubayar mahal!
Dialogue: 0,0:10:49.17,0:10:51.00,Default,,0000,0000,0000,,Bawa kembali Waganma dengan selamat
Dialogue: 0,0:10:51.00,0:10:52.96,Default,,0000,0000,0000,,dan hiduplah bahagia\Nsampai generasi cucumu!
Dialogue: 0,0:10:52.96,0:10:53.92,Default,,0000,0000,0000,,Pergi!
Dialogue: 0,0:10:59.76,0:11:04.10,Default,,0000,0000,0000,,{\an8}(Pusat Perbelanjaan South Road)
Dialogue: 0,0:10:59.76,0:11:04.10,Default,,0000,0000,0000,,Tampaknya memang benar\Ndi bangunan kecil itu.
Dialogue: 0,0:11:04.51,0:11:06.18,Default,,0000,0000,0000,,Aku sudah memojokkanmu.
Dialogue: 0,0:11:07.67,0:11:09.89,Default,,0000,0000,0000,,Kelompok Fubuki dikalahkan.
Dialogue: 0,0:11:10.40,0:11:12.65,Default,,0000,0000,0000,,Yah, setengahnya karena Kakak, sih.
Dialogue: 0,0:11:13.32,0:11:15.28,Default,,0000,0000,0000,,Ini kondisi darurat.
Dialogue: 0,0:11:15.28,0:11:19.66,Default,,0000,0000,0000,,Sebagai cabang Kelompok Fubuki,\Nkita harus mengadakan pertemuan.
Dialogue: 0,0:11:20.10,0:11:21.49,Default,,0000,0000,0000,,Ya.
Dialogue: 0,0:11:21.49,0:11:22.29,Default,,0000,0000,0000,,Saita—
Dialogue: 0,0:11:22.29,0:11:23.25,Default,,0000,0000,0000,,Siapa?
Dialogue: 0,0:11:23.25,0:11:25.50,Default,,0000,0000,0000,,Oh, teman, ya?
Dialogue: 0,0:11:25.86,0:11:28.91,Default,,0000,0000,0000,,Ada tamu, Saitama!
Dialogue: 0,0:11:30.34,0:11:33.26,Default,,0000,0000,0000,,Fubuki datang bermain lagi, lo.
Dialogue: 0,0:11:33.26,0:11:38.21,Default,,0000,0000,0000,,Hei, kenapa monster yang kubesarkan\Nlangsung mati dengan satu seranganmu?
Dialogue: 0,0:11:38.21,0:11:40.55,Default,,0000,0000,0000,,Ada perlu apa,\NFubuki sang Badai Neraka?
Dialogue: 0,0:11:38.71,0:11:40.64,Default,,0000,0000,0000,,{\an8}Cocok-cocokan saja.
Dialogue: 0,0:11:40.55,0:11:42.60,Default,,0000,0000,0000,,Asal kau tahu saja,\NGuru tidak mencari murid.
Dialogue: 0,0:11:41.08,0:11:43.89,Default,,0000,0000,0000,,{\an8}Om Golem punyamu elemennya tanah,
Dialogue: 0,0:11:42.60,0:11:44.18,Default,,0000,0000,0000,,Maaf kalau sempit.
Dialogue: 0,0:11:43.89,0:11:47.19,Default,,0000,0000,0000,,{\an8}serangan angin Kucing Empus\Njadi kelemahannya.
Dialogue: 0,0:11:44.18,0:11:47.19,Default,,0000,0000,0000,,Bisa sekalian ambilkan kompres di situ?
Dialogue: 0,0:11:47.19,0:11:49.31,Default,,0000,0000,0000,,Kenapa kelemahanku angin?
Dialogue: 0,0:11:49.31,0:11:52.19,Default,,0000,0000,0000,,Levelku 27 dan levelmu 15, tahu.
Dialogue: 0,0:11:52.19,0:11:56.61,Default,,0000,0000,0000,,Walau beda level, Om Golem tidak\Nbisa menang melawan Kucing Empus.
Dialogue: 0,0:11:56.61,0:11:58.36,Default,,0000,0000,0000,,Lagian, itu karakter keroco.
Dialogue: 0,0:11:58.36,0:12:00.40,Default,,0000,0000,0000,,Hah? Bisa bilang dulu dari awal?
Dialogue: 0,0:12:00.40,0:12:02.70,Default,,0000,0000,0000,,- Terus, Iblis Bulu Ketek—\N- Ah, itu juga lemah.
Dialogue: 0,0:12:02.70,0:12:05.37,Default,,0000,0000,0000,,Yang kuat itu cuma karakter yang imut.
Dialogue: 0,0:12:05.37,0:12:07.91,Default,,0000,0000,0000,,Malas. Aku jadi nggak niat main.
Dialogue: 0,0:12:07.91,0:12:10.16,Default,,0000,0000,0000,,Situasi apa ini?
Dialogue: 0,0:12:10.78,0:12:12.00,Default,,0000,0000,0000,,Kenapa kau di sini?
Dialogue: 0,0:12:12.00,0:12:13.17,Default,,0000,0000,0000,,Kondisi darurat!
Dialogue: 0,0:12:13.17,0:12:15.59,Default,,0000,0000,0000,,Orang-orang dari\NKelompok Fubuki dikalahkan.
Dialogue: 0,0:12:15.59,0:12:18.18,Default,,0000,0000,0000,,Organisasi monster ini\Nlumayan berbahaya, tahu.
Dialogue: 0,0:12:18.18,0:12:19.97,Default,,0000,0000,0000,,Bukan waktunya main gim!
Dialogue: 0,0:12:19.97,0:12:22.84,Default,,0000,0000,0000,,Apa kamu tahu apa\Nyang terjadi sekarang?
Dialogue: 0,0:12:22.84,0:12:24.97,Default,,0000,0000,0000,,Tidak usah marah-marah juga.
Dialogue: 0,0:12:24.97,0:12:28.14,Default,,0000,0000,0000,,Aku baru saja pulang\Ndan cuma istirahat sebentar.
Dialogue: 0,0:12:28.14,0:12:29.44,Default,,0000,0000,0000,,Jangan malah senderan!
Dialogue: 0,0:12:29.44,0:12:33.73,Default,,0000,0000,0000,,Seperti kata Guru,\Nkami juga melawan musuh tangguh.
Dialogue: 0,0:12:33.73,0:12:35.65,Default,,0000,0000,0000,,Jangan pikir cuma kalian\Nyang hadapi masalah.
Dialogue: 0,0:12:35.65,0:12:39.24,Default,,0000,0000,0000,,Yah, aku tahu dengan melihat\Npenampilanmu, sih...
Dialogue: 0,0:12:39.60,0:12:41.62,Default,,0000,0000,0000,,Aku pernah lihat King di sini\Nsebelumnya, sih...
Dialogue: 0,0:12:41.62,0:12:44.99,Default,,0000,0000,0000,,Tapi kenapa Silver Fang juga ada\Ndi rumah Saitama sekarang?
Dialogue: 0,0:12:44.99,0:12:47.75,Default,,0000,0000,0000,,Aku juga sempat bertarung,
Dialogue: 0,0:12:47.75,0:12:50.62,Default,,0000,0000,0000,,jadi aku numpang istirahat\Ndi kamar Saitama.
Dialogue: 0,0:12:50.62,0:12:54.54,Default,,0000,0000,0000,,Gara-gara agak nekat, pinggangku\Ncedera dan tidak bisa bergerak.
Dialogue: 0,0:12:54.54,0:12:56.38,Default,,0000,0000,0000,,Lututku cedera.
Dialogue: 0,0:12:56.38,0:12:59.46,Default,,0000,0000,0000,,Sudah lama tidak pakai Tinju Auman Ki,\NPengoyak Udara, badanku tak kuat lagi.
Dialogue: 0,0:12:59.46,0:13:00.91,Default,,0000,0000,0000,,Oh.
Dialogue: 0,0:13:00.91,0:13:03.38,Default,,0000,0000,0000,,Tampaknya pertarungan\Nkalian sangat sengit.
Dialogue: 0,0:13:03.39,0:13:04.81,Default,,0000,0000,0000,,Tapi kenapa?
Dialogue: 0,0:13:04.81,0:13:07.47,Default,,0000,0000,0000,,Kenapa pria ini bisa\Nbersikap seperti biasa?
Dialogue: 0,0:13:07.47,0:13:08.73,Default,,0000,0000,0000,,Hei, Saitama.
Dialogue: 0,0:13:08.73,0:13:11.26,Default,,0000,0000,0000,,Kamu pura-pura tenang,\Ntapi sebenarnya agak cemas, 'kan?
Dialogue: 0,0:13:11.26,0:13:13.36,Default,,0000,0000,0000,,Tidak, ini sudah biasa.
Dialogue: 0,0:13:13.36,0:13:14.35,Default,,0000,0000,0000,,Hah?!
Dialogue: 0,0:13:14.35,0:13:16.90,Default,,0000,0000,0000,,Mana mungkin kondisi ini sudah biasa!
Dialogue: 0,0:13:17.27,0:13:19.32,Default,,0000,0000,0000,,Kenapa dia marah?
Dialogue: 0,0:13:19.32,0:13:23.15,Default,,0000,0000,0000,,Agak aneh juga kalau aku yang bilang,\Nini memang tidak biasa.
Dialogue: 0,0:13:23.15,0:13:25.08,Default,,0000,0000,0000,,Duduk di sini!
Dialogue: 0,0:13:23.41,0:13:24.37,Default,,0000,0000,0000,,{\an8}(Blak)
Dialogue: 0,0:13:25.08,0:13:27.45,Default,,0000,0000,0000,,Ayo rapat strategi bersama-sama!
Dialogue: 0,0:13:27.45,0:13:29.00,Default,,0000,0000,0000,,Lagian, kenapa kau kemari?
Dialogue: 0,0:13:29.00,0:13:31.70,Default,,0000,0000,0000,,Genos! Kamu itu Kelas S!
Dialogue: 0,0:13:31.70,0:13:35.04,Default,,0000,0000,0000,,Apa kamu diberi tahu strategi selanjutnya\Ndari markas Asosiasi Pahlawan?!
Dialogue: 0,0:13:36.91,0:13:38.96,Default,,0000,0000,0000,,Sejak kemarin, aku sibuk
Dialogue: 0,0:13:38.96,0:13:42.40,Default,,0000,0000,0000,,mendukung Guru Saitama\Ndi turnamen bela diri dan bertarung.
Dialogue: 0,0:13:42.40,0:13:46.39,Default,,0000,0000,0000,,Alat komunikasiku dengan Asosiasi\Njuga meleleh dan hilang.
Dialogue: 0,0:13:46.39,0:13:49.68,Default,,0000,0000,0000,,Oh, punyaku juga jatuh\Ndi retakan tanah.
Dialogue: 0,0:13:49.68,0:13:51.89,Default,,0000,0000,0000,,Punyaku juga rusak tanpa kusadari.
Dialogue: 0,0:13:51.89,0:13:54.31,Default,,0000,0000,0000,,Mungkin karena gelombang\Nkejut pukulan Saitama?
Dialogue: 0,0:13:54.31,0:13:56.27,Default,,0000,0000,0000,,Lalu bagaimana kita bergerak sekarang?
Dialogue: 0,0:13:56.27,0:13:58.82,Default,,0000,0000,0000,,Pertarungan kita melawan mereka\Nakan dimulai.
Dialogue: 0,0:13:58.82,0:14:01.19,Default,,0000,0000,0000,,Aku harus diperbaiki dulu.
Dialogue: 0,0:14:01.19,0:14:03.20,Default,,0000,0000,0000,,Yah, memang, sih.
Dialogue: 0,0:14:03.20,0:14:07.41,Default,,0000,0000,0000,,Kami juga butuh sedikit waktu lagi\Nuntuk bisa bergerak.
Dialogue: 0,0:14:07.41,0:14:08.83,Default,,0000,0000,0000,,Umur tidak bisa bohong.
Dialogue: 0,0:14:09.27,0:14:10.29,Default,,0000,0000,0000,,Kalau King?
Dialogue: 0,0:14:10.29,0:14:13.21,Default,,0000,0000,0000,,Aku juga ada urusan lain.
Dialogue: 0,0:14:13.49,0:14:16.96,Default,,0000,0000,0000,,Berarti yang bisa bergerak\Nsekarang cuma aku dan Saitama.
Dialogue: 0,0:14:16.96,0:14:18.66,Default,,0000,0000,0000,,Hei, bagaimana ini?
Dialogue: 0,0:14:18.66,0:14:23.19,Default,,0000,0000,0000,,Markas pasti merancang strategi\Ndengan satgas khusus.
Dialogue: 0,0:14:23.19,0:14:26.76,Default,,0000,0000,0000,,Di saat seperti ini, pergerakan\Npahlawan Kelas B ke bawah
Dialogue: 0,0:14:26.76,0:14:29.18,Default,,0000,0000,0000,,akan berdampak pada\Nreputasi kita ke depannya.
Dialogue: 0,0:14:29.18,0:14:31.39,Default,,0000,0000,0000,,Kita harus berkontribusi juga.
Dialogue: 0,0:14:31.39,0:14:32.89,Default,,0000,0000,0000,,{\an8}(Hah)
Dialogue: 0,0:14:31.76,0:14:32.89,Default,,0000,0000,0000,,Dengar, tidak?
Dialogue: 0,0:14:33.38,0:14:36.73,Default,,0000,0000,0000,,Musuh kita kali ini adalah kelompok besar\Ndari monster yang bertindak terencana,
Dialogue: 0,0:14:36.73,0:14:39.98,Default,,0000,0000,0000,,tidak seperti biasanya yang seenak sendiri.
Dialogue: 0,0:14:40.47,0:14:44.74,Default,,0000,0000,0000,,Yah, tapi kemungkinan struktur\Norganisasinya dipimpin oleh bos
Dialogue: 0,0:14:44.74,0:14:48.37,Default,,0000,0000,0000,,yang mengendalikan mereka,\Nbukan karena bekerja sama.
Dialogue: 0,0:14:48.37,0:14:51.49,Default,,0000,0000,0000,,Benar. Kelompok monster.
Dialogue: 0,0:14:51.49,0:14:55.25,Default,,0000,0000,0000,,Bisa agak repot kalau\NGarou terlibat di sana.
Dialogue: 0,0:14:55.25,0:14:56.33,Default,,0000,0000,0000,,Ya.
Dialogue: 0,0:14:56.33,0:15:00.17,Default,,0000,0000,0000,,Mungkin kesempatan kita menyerang\NGarou sendirian tidak akan datang lagi.
Dialogue: 0,0:15:00.17,0:15:04.51,Default,,0000,0000,0000,,Jika masih ada lawan\Nselevel lipan itu di pihak musuh...
Dialogue: 0,0:15:04.51,0:15:05.63,Default,,0000,0000,0000,,Ini gawat.
Dialogue: 0,0:15:05.63,0:15:08.05,Default,,0000,0000,0000,,Bang, berhenti saja jadi pahlawan.
Dialogue: 0,0:15:08.05,0:15:09.39,Default,,0000,0000,0000,,Saitama.
Dialogue: 0,0:15:09.39,0:15:12.97,Default,,0000,0000,0000,,Di lokasi pertarungan tadi,\Nada pemburu pahlawan yang kau cari itu.
Dialogue: 0,0:15:12.97,0:15:15.06,Default,,0000,0000,0000,,Sepertinya kalian kecele.
Dialogue: 0,0:15:15.06,0:15:16.77,Default,,0000,0000,0000,,Aku sudah dengar di perjalanan pulang.
Dialogue: 0,0:15:16.77,0:15:19.19,Default,,0000,0000,0000,,Katanya banyak pahlawan\Nyang dikalahkan dia lagi.
Dialogue: 0,0:15:21.26,0:15:22.54,Default,,0000,0000,0000,,Tidak bisa kumaafkan.
Dialogue: 0,0:15:22.54,0:15:25.65,Default,,0000,0000,0000,,Makin tak bisa kumaafkan\Nkarena dia tidak memburuku.
Dialogue: 0,0:15:25.65,0:15:27.32,Default,,0000,0000,0000,,Apa karena aku cuma\NBotak Bermantel?
Dialogue: 0,0:15:27.95,0:15:29.20,Default,,0000,0000,0000,,Saitama?!
Dialogue: 0,0:15:29.20,0:15:29.95,Default,,0000,0000,0000,,Guru!
Dialogue: 0,0:15:29.95,0:15:31.74,Default,,0000,0000,0000,,Aku pergi dulu, deh.
Dialogue: 0,0:15:31.74,0:15:33.75,Default,,0000,0000,0000,,Kau tahu keberadaan Garou?
Dialogue: 0,0:15:33.75,0:15:35.90,Default,,0000,0000,0000,,Akan kucari.
Dialogue: 0,0:15:35.90,0:15:38.83,Default,,0000,0000,0000,,Akan kucari si Garou\Ndan kuhajar dia.
Dialogue: 0,0:15:40.00,0:15:42.21,Default,,0000,0000,0000,,Aku juga mau beli\Nsawi putih sekalian.
Dialogue: 0,0:15:45.62,0:15:49.32,Default,,0000,0000,0000,,Aku yang memimpin,\Ntapi malah diasingkan lagi.
Dialogue: 0,0:15:49.32,0:15:53.80,Default,,0000,0000,0000,,Sepertinya cukup sulit menyeret\Nmereka ke Kelompok Fubuki.
Dialogue: 0,0:16:06.40,0:16:09.74,Default,,0000,0000,0000,,Di mana ini?\NAku selamat?
Dialogue: 0,0:16:09.74,0:16:12.03,Default,,0000,0000,0000,,Ingatanku samar-samar.
Dialogue: 0,0:16:12.36,0:16:14.83,Default,,0000,0000,0000,,Selamat datang di Asosiasi Monster.
Dialogue: 0,0:16:14.83,0:16:18.96,Default,,0000,0000,0000,,Kalau kau membaca ini,\Nberarti kau selamat.
Dialogue: 0,0:16:19.36,0:16:23.42,Default,,0000,0000,0000,,Pahamilah baik-baik bahwa\Nkami yang menyelamatkan nyawamu
Dialogue: 0,0:16:23.42,0:16:27.55,Default,,0000,0000,0000,,dan tunggu dengan tenang\Ndi kamar itu tanpa mengamuk.
Dialogue: 0,0:16:27.55,0:16:31.05,Default,,0000,0000,0000,,Kalau kau keluar sekarang,\Nnanti cuma jadi samsak pahlawan.
Dialogue: 0,0:16:31.05,0:16:33.05,Default,,0000,0000,0000,,Kau butuh tempat bernaung.
Dialogue: 0,0:16:33.05,0:16:35.06,Default,,0000,0000,0000,,Kami juga siapkan pakaian untukmu.
Dialogue: 0,0:16:35.06,0:16:36.43,Default,,0000,0000,0000,,Silakan dipakai.
Dialogue: 0,0:16:38.02,0:16:40.90,Default,,0000,0000,0000,,Aduh. Sakit sekali.
Dialogue: 0,0:16:40.90,0:16:42.23,Default,,0000,0000,0000,,Sekujur tubuhku...
Dialogue: 0,0:16:42.56,0:16:45.73,Default,,0000,0000,0000,,Aku haus. Aku harus makan juga.
Dialogue: 0,0:16:45.73,0:16:48.19,Default,,0000,0000,0000,,Aku butuh sesuatu\Nuntuk dijadikan nutrisi.
Dialogue: 0,0:16:50.61,0:16:53.07,Default,,0000,0000,0000,,Aku bertarung melawan Pak Tua.
Dialogue: 0,0:16:53.07,0:16:55.70,Default,,0000,0000,0000,,Lalu, ada burung yang muncul.
Dialogue: 0,0:16:55.70,0:16:58.41,Default,,0000,0000,0000,,Asosiasi Monster... menyebalkan.
Dialogue: 0,0:16:58.86,0:17:02.50,Default,,0000,0000,0000,,Apa yang terjadi ke Pak Tua\Nsetelah melawan lipan itu?
Dialogue: 0,0:17:03.07,0:17:04.63,Default,,0000,0000,0000,,Masa bodoh, lah.
Dialogue: 0,0:17:05.00,0:17:08.38,Default,,0000,0000,0000,,Aku mencium aroma darah\Ndi udara yang mengendap ini.
Dialogue: 0,0:17:08.38,0:17:09.70,Default,,0000,0000,0000,,Bikin mual.
Dialogue: 0,0:17:09.70,0:17:12.59,Default,,0000,0000,0000,,Dan saking sunyinya,\Ntelingaku jadi berdenging.
Dialogue: 0,0:17:12.59,0:17:14.38,Default,,0000,0000,0000,,Ini di bawah tanah yang dalam?
Dialogue: 0,0:17:14.38,0:17:15.85,Default,,0000,0000,0000,,Masa bodoh, lah.
Dialogue: 0,0:17:18.81,0:17:19.97,Default,,0000,0000,0000,,Lepaskan kami!
Dialogue: 0,0:17:19.97,0:17:23.90,Default,,0000,0000,0000,,Kami yang salah!\NKami tidak akan melawan lagi!
Dialogue: 0,0:17:23.90,0:17:26.11,Default,,0000,0000,0000,,Aku tidak mau mati!
Dialogue: 0,0:17:26.11,0:17:30.61,Default,,0000,0000,0000,,Meski begitu, kalian sudah\Nmenghabisi dua tentara kami.
Dialogue: 0,0:17:30.61,0:17:33.36,Default,,0000,0000,0000,,Kami tidak bisa membebaskan\Nkalian begitu saja.
Dialogue: 0,0:17:33.36,0:17:37.28,Default,,0000,0000,0000,,Mumpung bos kalian\Nmempersiapkan alat yang kuat,
Dialogue: 0,0:17:37.28,0:17:39.50,Default,,0000,0000,0000,,cobalah berjuang sampai akhir.
Dialogue: 0,0:17:39.50,0:17:44.50,Default,,0000,0000,0000,,Monster di sini senang mempermainkan\Norang yang melawan.
Dialogue: 0,0:17:45.82,0:17:47.59,Default,,0000,0000,0000,,Ini gara-gara dia!
Dialogue: 0,0:17:47.59,0:17:49.13,Default,,0000,0000,0000,,Sialan!
Dialogue: 0,0:17:49.13,0:17:52.34,Default,,0000,0000,0000,,Jika robot aneh itu tidak muncul,\Nharusnya kita bisa kembali ke daratan!
Dialogue: 0,0:17:52.59,0:17:56.55,Default,,0000,0000,0000,,Tampaknya iklannya berpengaruh.\NTerima kasih oleh-olehnya.
Dialogue: 0,0:17:56.55,0:18:01.52,Default,,0000,0000,0000,,Aku senang ada kandidat yang berbakat,\Nkau lulus tanpa keberatan apa pun.
Dialogue: 0,0:18:01.52,0:18:04.10,Default,,0000,0000,0000,,Anak baru, siapa namamu?
Dialogue: 0,0:18:04.10,0:18:06.52,Default,,0000,0000,0000,,Aku Dewa Mesin G5.
Dialogue: 0,0:18:04.52,0:18:10.82,Default,,0000,0000,0000,,{\an8}(Level Bencana: Iblis\NDewa Mesin G5)
Dialogue: 0,0:18:06.52,0:18:10.82,Default,,0000,0000,0000,,Aku dikirim oleh organisasi\Nuntuk bergabung Asosiasi Monster.
Dialogue: 0,0:18:10.82,0:18:12.24,Default,,0000,0000,0000,,Organisasi?
Dialogue: 0,0:18:12.24,0:18:15.16,Default,,0000,0000,0000,,Bagaimana caramu masuk\Nsarang ini tanpa tersesat?
Dialogue: 0,0:18:15.16,0:18:17.11,Default,,0000,0000,0000,,Bisa bicara dengan pembuatmu?
Dialogue: 0,0:18:17.78,0:18:19.78,Default,,0000,0000,0000,,Yah, lupakan. Selamat datang.
Dialogue: 0,0:18:19.78,0:18:21.66,Default,,0000,0000,0000,,Ada lagi yang akan datang.
Dialogue: 0,0:18:21.66,0:18:25.58,Default,,0000,0000,0000,,Silakan saja kalau mau sembunyi,\Ntapi tunggu sebentar lagi, ya, Garou.
Dialogue: 0,0:18:25.58,0:18:27.83,Default,,0000,0000,0000,,Suaranya masuk ke kepalaku langsung.
Dialogue: 0,0:18:27.83,0:18:29.09,Default,,0000,0000,0000,,Telepati?
Dialogue: 0,0:18:29.09,0:18:32.76,Default,,0000,0000,0000,,Berdasarkan sudut pandangku\Nyang pernah melawan mereka,
Dialogue: 0,0:18:32.76,0:18:36.21,Default,,0000,0000,0000,,kemampuan tempur baju tempur\Nyang mereka miliki sangat tinggi.
Dialogue: 0,0:18:36.21,0:18:37.76,Default,,0000,0000,0000,,Layak untuk digunakan.
Dialogue: 0,0:18:38.22,0:18:41.47,Default,,0000,0000,0000,,Tapi sudah dikustomisasi\Nuntuk mereka sendiri
Dialogue: 0,0:18:41.47,0:18:45.65,Default,,0000,0000,0000,,sehingga tidak bisa digunakan\Norang lain apalagi monster.
Dialogue: 0,0:18:45.65,0:18:49.61,Default,,0000,0000,0000,,Berarti lebih baik biarkan mereka\Nhidup untuk dijadikan bidak?
Dialogue: 0,0:18:51.10,0:18:55.27,Default,,0000,0000,0000,,Kalau begitu, mereka milikku.\NAkan kulatih dengan baik.
Dialogue: 0,0:18:56.39,0:18:57.82,Default,,0000,0000,0000,,Latih? Apa itu?
Dialogue: 0,0:18:57.82,0:18:59.58,Default,,0000,0000,0000,,Aku mohon, bebaskan kami!
Dialogue: 0,0:18:59.95,0:19:01.32,Default,,0000,0000,0000,,Diam!
Dialogue: 0,0:19:07.08,0:19:08.96,Default,,0000,0000,0000,,Bagus.
Dialogue: 0,0:19:08.96,0:19:13.54,Default,,0000,0000,0000,,Beruntungnya aku bisa dapat\Nbudak yang berguna.
Dialogue: 0,0:19:23.43,0:19:26.19,Default,,0000,0000,0000,,Halo, Garou.\NBangunmu cepat sekali.
Dialogue: 0,0:19:26.19,0:19:28.10,Default,,0000,0000,0000,,Jadi itu Pemburu Pahlawan?
Dialogue: 0,0:19:26.84,0:19:29.77,Default,,0000,0000,0000,,{\an8}Bagus, aku mendukungmu.
Dialogue: 0,0:19:28.10,0:19:29.77,Default,,0000,0000,0000,,Kita membawanya yang terluka\Nlalu merawatnya...
Dialogue: 0,0:19:29.77,0:19:31.27,Default,,0000,0000,0000,,{\an8}Perlakuan istimewa!
Dialogue: 0,0:19:29.77,0:19:33.90,Default,,0000,0000,0000,,Apa alasan Tuan Gyoro Gyoro\Nmengincar manusia sepertinya?
Dialogue: 0,0:19:31.27,0:19:32.44,Default,,0000,0000,0000,,{\an8}Kenapa?
Dialogue: 0,0:19:32.44,0:19:33.90,Default,,0000,0000,0000,,{\an8}- Manusia?\N- Sudah sekarat.
Dialogue: 0,0:19:33.90,0:19:35.15,Default,,0000,0000,0000,,{\an8}- Monster?\N- Ayo serang dan makan dia.
Dialogue: 0,0:19:33.90,0:19:35.15,Default,,0000,0000,0000,,Diam.
Dialogue: 0,0:19:35.15,0:19:37.78,Default,,0000,0000,0000,,Aku mau membicarakan\Nhal penting dengannya.
Dialogue: 0,0:19:37.78,0:19:40.69,Default,,0000,0000,0000,,Makhluk besar apa\Nyang ada di pojok sana?
Dialogue: 0,0:19:41.19,0:19:42.91,Default,,0000,0000,0000,,Kau mau aku melakukan apa?
Dialogue: 0,0:19:42.91,0:19:45.91,Default,,0000,0000,0000,,Level Bencana Iblis atau lebih tinggi
Dialogue: 0,0:19:45.91,0:19:49.83,Default,,0000,0000,0000,,berkurang akibat pertempuran kemarin\Ndan tersisa kurang dari 80 monster.
Dialogue: 0,0:19:50.10,0:19:53.34,Default,,0000,0000,0000,,Kekuatan tempur itu\Nsudah cukup untuk menang,
Dialogue: 0,0:19:53.34,0:19:56.34,Default,,0000,0000,0000,,tapi yang kurang dari kami\Nsaat ini adalah persatuan.
Dialogue: 0,0:19:56.34,0:19:57.97,Default,,0000,0000,0000,,Dan pemimpin.
Dialogue: 0,0:19:58.37,0:20:02.68,Default,,0000,0000,0000,,Aku ingin kau jadi petinggi\Ndan membantuku.
Dialogue: 0,0:20:02.68,0:20:05.80,Default,,0000,0000,0000,,Tiba-tiba jadi petinggi, ya.\NPilih kasih sekali.
Dialogue: 0,0:20:05.80,0:20:09.94,Default,,0000,0000,0000,,Orang yang punya prinsip\Nantipahlawan seperti dia
Dialogue: 0,0:20:09.94,0:20:12.52,Default,,0000,0000,0000,,adalah sosok yang kuinginkan.
Dialogue: 0,0:20:12.52,0:20:18.65,Default,,0000,0000,0000,,Bergerak seorang diri mengejar\Npahlawan Kelas S sampai babak belur
Dialogue: 0,0:20:18.65,0:20:20.07,Default,,0000,0000,0000,,adalah yang terbaik!
Dialogue: 0,0:20:21.28,0:20:25.25,Default,,0000,0000,0000,,Namun ada satu syarat dari Bos Orochi.
Dialogue: 0,0:20:25.25,0:20:29.17,Default,,0000,0000,0000,,Buktikan bahwa kau\Nadalah monster sungguhan.
Dialogue: 0,0:20:29.17,0:20:30.79,Default,,0000,0000,0000,,Kau menyuruhku menumbuhkan tanduk?
Dialogue: 0,0:20:30.79,0:20:32.37,Default,,0000,0000,0000,,Lakukan dalam sehari.
Dialogue: 0,0:20:32.37,0:20:36.05,Default,,0000,0000,0000,,Siapa saja boleh,\Nbawakan kepala pahlawan.
Dialogue: 0,0:20:36.38,0:20:37.92,Default,,0000,0000,0000,,Kalau nyawa pahlawan...
Dialogue: 0,0:20:37.92,0:20:39.63,Default,,0000,0000,0000,,Ada kabar buruk untukmu.
Dialogue: 0,0:20:39.63,0:20:42.17,Default,,0000,0000,0000,,Silver Fang dan kawan-kawan masih hidup.
Dialogue: 0,0:20:42.17,0:20:44.18,Default,,0000,0000,0000,,Lipan Tetua telah dikalahkan.
Dialogue: 0,0:20:48.55,0:20:50.98,Default,,0000,0000,0000,,Halo, maaf memanggil kalian.
Dialogue: 0,0:20:50.98,0:20:52.40,Default,,0000,0000,0000,,Aku ada permintaan.
Dialogue: 0,0:20:52.93,0:20:54.65,Default,,0000,0000,0000,,Permintaan apa?
Dialogue: 0,0:20:52.94,0:20:54.65,Default,,0000,0000,0000,,{\an8}(Level Bencana: Iblis\NDewa Serangga)
Dialogue: 0,0:20:54.65,0:20:56.90,Default,,0000,0000,0000,,Aku sudah tidak sabar\Nmendengar jeritan manusia,
Dialogue: 0,0:20:55.15,0:21:00.53,Default,,0000,0000,0000,,{\an8}(Level Bencana: Iblis\NRaja Pemotong)
Dialogue: 0,0:20:56.90,0:20:59.02,Default,,0000,0000,0000,,aku hampir gila.
Dialogue: 0,0:20:59.02,0:21:00.53,Default,,0000,0000,0000,,Cepat beri tahu aku.
Dialogue: 0,0:21:00.53,0:21:02.62,Default,,0000,0000,0000,,Garou keluar.
Dialogue: 0,0:21:03.35,0:21:04.99,Default,,0000,0000,0000,,Buntuti dia.
Dialogue: 0,0:21:26.13,0:21:36.19,Default,,0000,0000,0000,,Mengapung di tepi kebenaran bersamaan♪
Dialogue: 0,0:21:36.19,0:21:45.91,Default,,0000,0000,0000,,Bila perasaanmu berkelana sendiri♪
Dialogue: 0,0:21:45.91,0:21:53.16,Default,,0000,0000,0000,,Akan kusambut dengan\Nekspresiku yang biasanya♪
Dialogue: 0,0:21:53.78,0:22:01.38,Default,,0000,0000,0000,,Jika cahaya di situ masih sama♪
Dialogue: 0,0:22:01.38,0:22:06.39,Default,,0000,0000,0000,,dan menyinari kita semua♪
Dialogue: 0,0:22:06.39,0:22:11.27,Default,,0000,0000,0000,,Mari terima apa adanya♪
Dialogue: 0,0:22:11.27,0:22:16.15,Default,,0000,0000,0000,,rasa sakit dan sepi yang datang♪
Dialogue: 0,0:22:16.15,0:22:24.53,Default,,0000,0000,0000,,Dekap harapan dalam hati\Ndan terus melaju♪
Dialogue: 0,0:22:36.86,0:22:38.58,Default,,0000,0000,0000,,Kemarin, Gouketsu.
Dialogue: 0,0:22:38.58,0:22:41.21,Default,,0000,0000,0000,,Dan hari ini, Lipan Tetua itu kalah.
Dialogue: 0,0:22:41.21,0:22:44.46,Default,,0000,0000,0000,,Sebelum pertarungan penentuan,\Ndua petinggi kita dikalahkan.
Dialogue: 0,0:22:44.46,0:22:46.55,Default,,0000,0000,0000,,Gyoro Gyoro pasti tak menduganya.
Dialogue: 0,0:22:46.55,0:22:50.77,Default,,0000,0000,0000,,Makanya dia mengundang\NPemburu Pahlawan sebagai anggota?
Dialogue: 0,0:22:50.77,0:22:53.05,Default,,0000,0000,0000,,Pemikiran Gyoro Gyoro\Ntak bisa dibaca.
Dialogue: 0,0:22:53.05,0:22:55.52,Default,,0000,0000,0000,,Yah, aku juga tidak tertarik, sih.
Dialogue: 0,0:22:55.52,0:22:58.61,Default,,0000,0000,0000,,Yang penting aku bisa menghancurkan\NAsosiasi Pahlawan dan Flash.
Dialogue: 0,0:22:59.06,0:23:02.57,Default,,0000,0000,0000,,Omong-omong, bagaimana dengan Sonic\NSang Kecepatan Suara yang bergabung?
Dialogue: 0,0:23:02.57,0:23:04.15,Default,,0000,0000,0000,,Dia tidak datang, ya.
Dialogue: 0,0:23:04.15,0:23:06.53,Default,,0000,0000,0000,,Dia tidak bisa beradaptasi\Ndengan sel monster, ya.
Dialogue: 0,0:23:10.49,0:23:14.99,Default,,0000,0000,0000,,Aku dibuat menderita seharian,\Ntapi tampaknya berhasil kulewati.
Dialogue: 0,0:23:14.99,0:23:16.95,Default,,0000,0000,0000,,Aku benci orang-orang\Ndari Asosiasi Monster.
Dialogue: 0,0:23:16.95,0:23:19.62,Default,,0000,0000,0000,,Aku tidak tahu perutku\Nsampai sesakit ini.
Dialogue: 0,0:23:19.62,0:23:21.17,Default,,0000,0000,0000,,Aku pasti akan membalasnya.
Dialogue: 0,0:23:23.17,0:23:24.13,Default,,0000,0000,0000,,Biarlah.
Dialogue: 0,0:23:24.46,0:23:27.46,Default,,0000,0000,0000,,Sejak awal, aku tidak berniat\Nbekerja sama dengan para monster.
Dialogue: 0,0:23:27.46,0:23:30.05,Default,,0000,0000,0000,,Aku cuma akan memanfaatkan mereka.
Dialogue: 0,0:23:30.05,0:23:33.05,Default,,0000,0000,0000,,Targetku cuma Saitama.
Dialogue: 0,0:23:33.05,0:23:37.39,Default,,0000,0000,0000,,Selain itu, aku mulai merasakan\Nkekuatan yang baru.
Dialogue: 0,0:23:37.39,0:23:40.27,Default,,0000,0000,0000,,Jelas sekali ada perubahan\Ndalam tubuhku.
Dialogue: 0,0:23:40.27,0:23:42.44,Default,,0000,0000,0000,,Sensasi tubuh ringan ini...
Dialogue: 0,0:23:42.44,0:23:45.15,Default,,0000,0000,0000,,Sepertinya butuh waktu\Nsampai aku terbiasa.
Dialogue: 0,0:23:45.44,0:23:47.19,Default,,0000,0000,0000,,Jadi ini rasanya\Nberubah jadi monster.
Dialogue: 0,0:23:47.19,0:23:50.45,Default,,0000,0000,0000,,Ternyata biasa saja setelah berubah.
Dialogue: 0,0:23:50.91,0:23:55.91,Default,,0000,0000,0000,,{\an8}(Sonic kurusan 2 kg)
Dialogue: 0,0:23:55.91,0:24:00.92,Default,,0000,0000,0000,,{\an8}(Syarat Monster)

