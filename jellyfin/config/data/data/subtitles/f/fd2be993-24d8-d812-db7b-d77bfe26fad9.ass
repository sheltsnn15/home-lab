Dialogue: 0,0:00:00.00,0:00:02.98,Ep_Title,Screen,0,0,0,,‫الحلقة 48\N{\fs36}‫إعدام
Dialogue: 0,0:03:38.09,0:03:41.95,Show_Title,Screen,0,0,0,,{\c&H0200E9&\3c&H010007&}‫جوجيتسو كايسن
Dialogue: 0,0:03:41.95,0:03:43.99,Show_Title,Screen,0,0,0,,{\c&H0200E9&\3c&H010007&}‫لعبة الإعدام
Dialogue: 0,0:03:54.51,0:03:55.22,Show_Title,Screen,0,0,0,,{\c&H0200E9&\3c&H000000&}‫جوجيتسو كايسن
Dialogue: 0,0:04:18.48,0:04:22.65,Show_Title,Screen,0,0,0,,{\fad(0,650)\c&H2E2C2C&}‫جوجيتسو كايسن\N{\fs16\c&HF3F3F3&\bord0\alpha&HFF&\t(237,736,1 \alpha&H00&)}‫لعبة الإعدام الجزء 1
Dialogue: 0,0:05:15.82,0:05:19.66,Main,Naoya,0,0,0,,‫إذًا، هل ماي-تشان ميتة؟
Dialogue: 0,0:05:20.96,0:05:23.34,Main,MakiMother,0,0,0,,‫ما يجب أن تقلق بشأنه هو \N‫رئيس العشيرة.
Dialogue: 0,0:05:23.34,0:05:25.81,Main,MakiMother,0,0,0,,‫كما أنّ الشخص الذي أوشك على الموت هو ماكي.
Dialogue: 0,0:05:25.81,0:05:28.78,Main,Naoya,0,0,0,,‫حقًا؟ هذا جيد.
Dialogue: 0,0:05:28.78,0:05:31.58,Main,Naoya,0,0,0,,‫ماكي-تشان جميلة حقًا، لكنها ليست جيّدة.
Dialogue: 0,0:05:31.58,0:05:33.77,Main,Naoya,0,0,0,,‫لا يمكنها دعم رجل.
Dialogue: 0,0:05:33.77,0:05:35.76,Main,Naoya,0,0,0,,‫أي امرأة لا تستطيع السير \N‫بتواضع خلف رجلها
Dialogue: 0,0:05:35.76,0:05:38.02,Main,Naoya,0,0,0,,‫تستحق أن تُطعن في ظهرها وتُقتل.
Dialogue: 0,0:05:38.83,0:05:41.67,Main,Naoya,0,0,0,,{\an8}‫ماي-تشان امرأة رائعة من تلك الناحية.
Dialogue: 0,0:05:41.19,0:05:43.82,Sign_Basic,Screen,0,0,0,,{\pos(320,310)\fs18\b1\bord0\shad0\c&HCECDD1&}‫مستعمل جوجيتسو من الدرجة الأولى الخاصة   ناويا زينين
Dialogue: 0,0:05:44.29,0:05:47.65,Main,Naoya,0,0,0,,‫لديها نفس وجه وصدر ماكي-تشان.
Dialogue: 0,0:05:47.65,0:05:49.47,Main,Naoya,0,0,0,,‫قد تتظاهر بالشجاعة،
Dialogue: 0,0:05:49.47,0:05:51.70,Main,Naoya,0,0,0,,‫لكنها تفهم مكانها كامرأة.
Dialogue: 0,0:05:52.65,0:05:53.84,Main,Ogi,0,0,0,,‫لقد تأخرت.
Dialogue: 0,0:05:54.30,0:05:55.97,Main,Ogi,0,0,0,,‫ماذا كنت تفعل؟
Dialogue: 0,0:05:55.97,0:05:59.50,Main,Ogi,0,0,0,,‫والدك في حالة حرجة!
Dialogue: 0,0:05:59.50,0:06:01.06,Main,Naoya,0,0,0,,‫أنا آسف.
Dialogue: 0,0:06:01.06,0:06:04.11,Main,Naoya,0,0,0,,‫لكن ما الفرق سواء كنت هنا أم لا؟
Dialogue: 0,0:06:04.68,0:06:07.76,Main,Naoya,0,0,0,,‫سأصبح رئيس عشيرة زينين التالي على أيّ حال.
Dialogue: 0,0:06:08.79,0:06:12.14,Main,Naoya,0,0,0,,‫كل إخوتي الأكبر حمقى.
Dialogue: 0,0:06:12.63,0:06:13.47,Main,Naoya,0,0,0,,‫ويا عمّي،
Dialogue: 0,0:06:13.84,0:06:16.11,Main,Naoya,0,0,0,,‫أنت شقيقه الأصغر، لكنّك بلا تأثير.
Dialogue: 0,0:06:16.11,0:06:18.48,Main,Naoya,0,0,0,,‫بناتك بعيدات عن الحسبان.
Dialogue: 0,0:06:18.70,0:06:20.48,Main,Naoya,0,0,0,,‫وجينيتشي-كن...
Dialogue: 0,0:06:22.91,0:06:24.93,Main,Naoya,0,0,0,,‫مظهرك سيئ.
Dialogue: 0,0:06:24.93,0:06:27.82,Main,Naoya,0,0,0,,‫لكان أفضل لو حصلت على مظهر توجي-كن.
Dialogue: 0,0:06:31.11,0:06:33.87,Sign_Basic,Screen,0,0,0,,{\pos(320,315)\fs18\b1\bord0\shad0\c&HCECDD1&}‫مستعمل جوجيتسو من الدرجة الأولى الخاصة   أوغي زنين
Dialogue: 0,0:06:33.87,0:06:38.08,Sign_Basic,Screen,0,0,0,,{\pos(320,315)\fs18\b1\bord0\shad0\c&HCECDD1&}‫مستعمل جوجيتسو من الدرجة الأولى الخاصة   جينيتشي زينين
Dialogue: 0,0:06:35.37,0:06:38.12,Main,Naoya,0,0,0,,{\an8}‫أبي في حالة حرجة كما تعلمان.
Dialogue: 0,0:06:38.28,0:06:39.91,Main,Naoya,0,0,0,,‫أفسحا لي مجالًا.
Dialogue: 0,0:06:41.02,0:06:42.96,Main,Furudate,0,0,0,,‫أرى أن الجميع هنا.
Dialogue: 0,0:06:45.34,0:06:48.06,Main,Furudate,0,0,0,,‫منذ قليل، تُوفيّ رئيس عشيرة زينين،
Dialogue: 0,0:06:48.06,0:06:51.57,Main,Furudate,0,0,0,,‫ناوبيتو زينين-ساما.
Dialogue: 0,0:06:55.75,0:07:00.15,Main,Furudate,0,0,0,,‫أنا، فوروداتي، سأقرأ الآن\N‫وصيته التي ائتمنني عليها.
Dialogue: 0,0:07:00.15,0:07:03.85,Main,Furudate,0,0,0,,‫كانت رغبة ناوبيتو-ساما أن تُقرأ\N‫هذه الوصية من طرفي عندما
Dialogue: 0,0:07:04.28,0:07:06.06,Main,Furudate,0,0,0,,‫يكون أوغي زينين-ساما
Dialogue: 0,0:07:06.45,0:07:08.69,Main,Furudate,0,0,0,,‫وجينيتشي زينين-ساما
Dialogue: 0,0:07:08.98,0:07:11.03,Main,Furudate,0,0,0,,‫وناويا زينين-ساما
Dialogue: 0,0:07:11.59,0:07:16.63,Main,Furudate,0,0,0,,‫مجتمعين جميعًا معًا.
Dialogue: 0,0:07:18.01,0:07:22.04,Main,Furudate,0,0,0,,‫إن لم تكن هناك اعتراضات، فسأبدأ قراءة وصيته.
Dialogue: 0,0:07:28.47,0:07:34.55,Main,Furudate,0,0,0,,‫أولًا، ناويا زينين سيصبح الرئيس\N‫السابع وعشرين لعشيرة زينين.
Dialogue: 0,0:07:35.12,0:07:40.38,Main,Furudate,0,0,0,,‫ثانيًا، سيرث ناويا جميع الأصول\N‫والأدوات الملعونة المحفوظة
Dialogue: 0,0:07:40.38,0:07:44.56,Main,Furudate,0,0,0,,‫في كل من ثانوية جوجيتسو\N‫وخزائن عشيرة زينين المحظورة،
Dialogue: 0,0:07:45.39,0:07:50.73,Main,Furudate,0,0,0,,‫ويجب على ناويا الحصول على موافقة\N‫إما أوغي زينين أو جينيتشي زينين
Dialogue: 0,0:07:51.45,0:07:54.39,Main,Furudate,0,0,0,,‫لاستخدام محتوياتها.
Dialogue: 0,0:07:56.02,0:07:57.64,Main,Naoya,0,0,0,,‫حسنًا، لا بأس.
Dialogue: 0,0:07:57.64,0:07:58.71,Main,Furudate,0,0,0,,‫ولكن،
Dialogue: 0,0:07:59.32,0:08:02.74,Main,Furudate,0,0,0,,‫في حال موت ساتورو غوجو،
Dialogue: 0,0:08:02.74,0:08:06.46,Main,Furudate,0,0,0,,‫أو فقدانه القدرة على استخدام\N‫قواه العقلية لأي سبب،
Dialogue: 0,0:08:06.46,0:08:10.16,Main,Furudate,0,0,0,,‫فعندها يجب تنفيذ العهد مع توجي فوشيغورو.
Dialogue: 0,0:08:10.16,0:08:13.31,Main,Furudate,0,0,0,,‫سيُرَحَّب بميغومي فوشيغورو في عشيرة زينين،
Dialogue: 0,0:08:13.31,0:08:16.47,Main,Furudate,0,0,0,,‫وسيصبح هو نفسه رئيس عشيرة زينين،
Dialogue: 0,0:08:16.70,0:08:19.73,Main,Furudate,0,0,0,,‫ويرث كلّ أصولها.
Dialogue: 0,0:08:21.86,0:08:22.60,Main,Naoya,0,0,0,,‫ماذا؟!
Dialogue: 0,0:08:22.60,0:08:24.51,Main,Naoya,0,0,0,,‫هذا سيّئ.
Dialogue: 0,0:08:24.51,0:08:26.51,Main,Naoya,0,0,0,,‫ذلكما الاثنان جبانان.
Dialogue: 0,0:08:26.51,0:08:28.80,Main,Naoya,0,0,0,,‫يظنان أنّ جعل شقي مجهول رئيسًا
Dialogue: 0,0:08:28.80,0:08:30.98,Main,Naoya,0,0,0,,‫سيكون أفضل مني، لذا لن يفعلا شيئًا.
Dialogue: 0,0:08:32.67,0:08:35.36,Main,Naoya,0,0,0,,‫أين ميغومي-كن؟ وماذا يفعل الآن؟
Dialogue: 0,0:08:35.55,0:08:37.03,Main,MakiMother,0,0,0,,‫لا أعرف الكثير...
Dialogue: 0,0:08:37.03,0:08:40.87,Main,MakiMother,0,0,0,,‫فقط أنه في مهمة \N‫للعثور على يوجي إيتادوري في طوكيو.
Dialogue: 0,0:08:41.03,0:08:42.08,Main,Naoya,0,0,0,,‫ومن ذاك؟
Dialogue: 0,0:08:42.45,0:08:44.63,Main,MakiMother,0,0,0,,‫وعاء سوكونا.
Dialogue: 0,0:08:44.63,0:08:46.96,Main,Naoya,0,0,0,,‫إذًا اذهبي وأخبر الكبار
Dialogue: 0,0:08:46.96,0:08:49.99,Main,Naoya,0,0,0,,‫أن ناويا زينين سيقتل وعاء سوكونا.
Dialogue: 0,0:08:50.37,0:08:53.30,Main,Naoya,0,0,0,,‫ميغومي-كن مع وعاء سوكونا، صحيح؟
Dialogue: 0,0:08:53.80,0:08:55.63,Main,Naoya,0,0,0,,‫سأقتلهما معًا.
Dialogue: 0,0:08:56.68,0:08:58.51,Main,Naoya,0,0,0,,‫طوكيو جحيم الآن.
Dialogue: 0,0:08:59.15,0:09:01.89,Main,Naoya,0,0,0,,‫يمكن أن يموت النّاس هناك في أي وقت ولأيّ سبب.
Dialogue: 0,0:09:02.79,0:09:06.04,Main,Naoya,0,0,0,,‫سيُحَّلّ كلّ شيء بمجرد أن أقتله.
Dialogue: 0,0:09:09.39,0:09:11.57,Main,Naoya,0,0,0,,‫أنا رئيس عشيرة زينين!
Dialogue: 0,0:09:21.41,0:09:22.69,Flashback,Yuji,0,0,0,,‫مت!
Dialogue: 0,0:09:23.21,0:09:24.46,Flashback,Yuji,0,0,0,,‫كوغيساكي!
Dialogue: 0,0:09:23.21,0:09:24.46,Flashback,Yuji,0,0,0,,{\an8}‫أنا فقط!
Dialogue: 0,0:09:24.46,0:09:25.89,Flashback,Nanami,0,0,0,,‫تولّ الأمر من هنا.
Dialogue: 0,0:09:24.46,0:09:25.89,Flashback,Nanami,0,0,0,,‫مت!
Dialogue: 0,0:09:25.20,0:09:26.15,Flashback,Kugisaki,0,0,0,,{\an8}‫إيتادوري
Dialogue: 0,0:09:26.15,0:09:27.50,Flashback,Nanami,0,0,0,,‫إيتادوري-كن.
Dialogue: 0,0:09:27.50,0:09:28.54,Flashback,Tsukumo,0,0,0,,‫ماذا ستفعل؟
Dialogue: 0,0:09:53.66,0:09:54.61,Main,Choso,0,0,0,,‫يوجي.
Dialogue: 0,0:09:56.17,0:09:57.95,Main,Choso,0,0,0,,‫كيف حال إصاباتك؟
Dialogue: 0,0:09:59.10,0:10:02.64,Main,Yuji,0,0,0,,‫بخير، باستثناء المكان الذي تلقيت\N‫فيه ذلك الوميض الأسود.
Dialogue: 0,0:10:04.29,0:10:06.29,Main,Yuji,0,0,0,,‫على الأرجح أنّ ذلك بسبب سوكونا.
Dialogue: 0,0:10:06.84,0:10:09.48,Main,Yuji,0,0,0,,‫أشعر أن قوته ازدادت.
Dialogue: 0,0:10:10.87,0:10:12.07,Main,Choso,0,0,0,,‫يوجي.
Dialogue: 0,0:10:12.07,0:10:13.97,Main,Choso,0,0,0,,‫لا تقلق بشأني.
Dialogue: 0,0:10:13.97,0:10:15.95,Main,Choso,0,0,0,,‫يمكنك العودة إلى ثانوية جوجيتسو.
Dialogue: 0,0:10:16.60,0:10:19.84,Main,Choso,0,0,0,,‫أود استعادة بقايا شوسو والآخرين أيضًا.
Dialogue: 0,0:10:21.33,0:10:22.75,Main,Yuji,0,0,0,,‫لستُ قلقًا.
Dialogue: 0,0:10:23.29,0:10:25.88,Main,Yuji,0,0,0,,‫المسألة ليست مسألة رغبتي\N‫في العودة من عدمها أصلًا.
Dialogue: 0,0:10:26.96,0:10:29.77,Main,Yuji,0,0,0,,‫سوكونا يخطط لشيء يستعمل فوشيغورو.
Dialogue: 0,0:10:30.50,0:10:34.30,Main,Yuji,0,0,0,,‫كما أني قتلت الكثير من النّاس.
Dialogue: 0,0:10:34.73,0:10:38.85,Flashback_Italics,Fushiguro,0,0,0,,‫ماذا ستفعل عندما يَقتل شخص\N‫أنقذتَه شخصًا آخر في المستقبل؟
Dialogue: 0,0:10:40.08,0:10:43.14,Main,Yuji,0,0,0,,‫لا يمكنني البقاء مع الآخرين بعد الآن.
Dialogue: 0,0:10:44.05,0:10:46.16,Main,Yuji,0,0,0,,‫وهل تتقبّل هذا يا تشوسو؟
Dialogue: 0,0:10:45.70,0:10:48.10,Main,Yuji,0,0,0,,‫لقد قتلت أخويك الصغيرين أيضًا.
Dialogue: 0,0:10:48.10,0:10:49.06,Main,Choso,0,0,0,,‫لا بأس.
Dialogue: 0,0:10:49.06,0:10:50.63,Main,Choso,0,0,0,,‫كان ذلك حادثًا.
Dialogue: 0,0:10:50.63,0:10:54.74,Main,Choso,0,0,0,,‫إيسو وكيتشيزو كانا سيفعلان\N‫الشيء نفسه لو كانا مكاني.
Dialogue: 0,0:10:55.21,0:10:57.23,Main,Choso,0,0,0,,‫مسامحتك من عدمها لا تهم.
Dialogue: 0,0:10:57.70,0:10:59.79,Main,Choso,0,0,0,,‫هذا هو معنى الإخوة.
Dialogue: 0,0:11:03.21,0:11:04.20,Main,Yuji,0,0,0,,‫لنذهب.
Dialogue: 0,0:11:04.72,0:11:07.01,Main,Yuji,0,0,0,,‫علينا الآن تقليل عدد الأرواح الملعونة.
Dialogue: 0,0:12:59.37,0:13:00.62,Main,Yuji,0,0,0,,‫تشوسو!
Dialogue: 0,0:13:07.76,0:13:08.89,Main,Choso,0,0,0,,‫يوجي.
Dialogue: 0,0:13:21.11,0:13:22.91,Italics,Choso,0,0,0,,‫كم هذا مخيف.
Dialogue: 0,0:13:23.29,0:13:26.57,Italics,Choso,0,0,0,,‫شعرتُ بالفعل أنّه قويّ عندما تقاتلنا.
Dialogue: 0,0:13:26.57,0:13:29.44,Italics,Choso,0,0,0,,‫والآن أضاف الدقة إلى ذلك.
Dialogue: 0,0:13:29.44,0:13:31.35,Italics,Choso,0,0,0,,‫لديه تحكّم ثابت بطاقته الملعونة
Dialogue: 0,0:13:31.35,0:13:33.40,Italics,Choso,0,0,0,,‫وقوة بدنية استثنائية.
Dialogue: 0,0:13:36.04,0:13:37.96,Italics,Choso,0,0,0,,‫إنه حقًا أشبه بإله حرب!
Dialogue: 0,0:13:37.96,0:13:40.95,Italics,Choso,0,0,0,,‫هذا يعني أنه لم يكن \N‫في أفضل حالاته حتى الآن.
Dialogue: 0,0:13:42.51,0:13:45.17,Main,Choso,0,0,0,,‫أنت مذهل يا أخي الصغير.
Dialogue: 0,0:13:45.35,0:13:47.01,Main,Yuji,0,0,0,,‫ما زلت تقول ذلك؟
Dialogue: 0,0:13:47.80,0:13:49.89,Main,Choso,0,0,0,,‫سأقول ذلك بقدر ما يلزم.
Dialogue: 0,0:13:49.89,0:13:51.01,Main,Choso,0,0,0,,‫تذكّر.
Dialogue: 0,0:13:51.01,0:13:52.67,Main,Choso,0,0,0,,‫كان من المفترض أن يكونوا هناك.
Dialogue: 0,0:13:55.98,0:13:59.43,Main,Choso,0,0,0,,‫يفترض أن يكون لوالدك غرز في جبهته أيضًا.
Dialogue: 0,0:14:01.82,0:14:03.67,Main,Naoya,0,0,0,,‫ميغومي-كن ليس هنا؟
Dialogue: 0,0:14:04.03,0:14:05.56,Main,Naoya,0,0,0,,‫هل أنا أول الواصلين؟
Dialogue: 0,0:14:05.56,0:14:06.74,Main,Naoya,0,0,0,,‫هل هذا ممكن فعلًا؟
Dialogue: 0,0:14:06.74,0:14:07.78,Main,Naoya,0,0,0,,‫إنه بطيء للغاية.
Dialogue: 0,0:14:08.74,0:14:10.19,Italics,Yuji,0,0,0,,‫من هذا الرجل؟
Dialogue: 0,0:14:10.50,0:14:12.53,Italics,Yuji,0,0,0,,‫هل كان يتحدث عن فوشيغورو للتو؟
Dialogue: 0,0:14:12.79,0:14:14.56,Main,Naoya,0,0,0,,‫ماذا تفعلان على أيّ حال؟
Dialogue: 0,0:14:14.56,0:14:16.05,Main,Naoya,0,0,0,,‫أنتما بارزان أكثر من اللازم.
Dialogue: 0,0:14:16.05,0:14:17.43,Main,Naoya,0,0,0,,‫ألن تحاولا الهرب؟
Dialogue: 0,0:14:17.99,0:14:19.21,Main,Yuji,0,0,0,,‫الهرب؟
Dialogue: 0,0:14:19.21,0:14:20.90,Main,Naoya,0,0,0,,‫ألا تعلم؟
Dialogue: 0,0:14:21.31,0:14:23.07,Main,Naoya,0,0,0,,‫لقد حُكم عليك بالإعدام.
Dialogue: 0,0:14:23.53,0:14:26.42,Main,Naoya,0,0,0,,‫فقد فقدت حماية ساتورو-كن.
Dialogue: 0,0:14:26.42,0:14:27.42,Main,Choso,0,0,0,,‫ماذا؟!
Dialogue: 0,0:14:29.17,0:14:31.71,Flashback_Italics,Ino,0,0,0,,‫هناك العديد من مستعملي الجوجيتسو الذين نجوا
Dialogue: 0,0:14:31.71,0:14:34.51,Flashback_Italics,Ino,0,0,0,,‫بسبب تأثير غوجو-سان وكبريائه ونزواته.
Dialogue: 0,0:14:34.51,0:14:37.07,Main,Naoya,0,0,0,,‫أنا أريد ميغومي-كن،
Dialogue: 0,0:14:37.07,0:14:40.19,Main,Naoya,0,0,0,,‫لذا بصراحة، لا يهمّني سواء عشت أو متّ.
Dialogue: 0,0:14:40.19,0:14:42.39,Main,Naoya,0,0,0,,‫لكني لا أريدك أن تركض هنا وهنا كما تشاء،
Dialogue: 0,0:14:42.39,0:14:45.11,Main,Naoya,0,0,0,,‫لذا سأكسر ساقيك الآن.
Dialogue: 0,0:14:45.44,0:14:47.55,Main,Yuji,0,0,0,,‫ماذا تريد من فوشيغورو؟
Dialogue: 0,0:14:47.55,0:14:49.05,Main,Naoya,0,0,0,,‫أريده أن يموت.
Dialogue: 0,0:14:49.85,0:14:53.48,Main,Naoya,0,0,0,,‫مع أنه سيكون رائعًا بالنسبة لي\N‫لو كتب بضع كلمات قبل رحيله.
Dialogue: 0,0:14:53.48,0:14:56.41,Main,Naoya,0,0,0,,‫سمعت أن ميغومي-كن كان يبحث عنك.
Dialogue: 0,0:15:16.64,0:15:19.68,Main,Yuji,0,0,0,,‫إنه سريع بالتأكيد، لكن هناك شيء غير طبيعي.
Dialogue: 0,0:15:19.98,0:15:21.69,Main,Choso,0,0,0,,‫ربما هي تقنيته.
Dialogue: 0,0:15:21.69,0:15:24.06,Main,Naoya,0,0,0,,‫أنتما تبليان أفضل مما توقعت.
Dialogue: 0,0:15:24.26,0:15:26.38,Main,Naoya,0,0,0,,‫لقد استخففت بكما بصراحة.
Dialogue: 0,0:15:26.81,0:15:29.02,Italics,Naoya,0,0,0,,‫أعلم أنّ الوعاء لديه الإمكانيات،
Dialogue: 0,0:15:29.02,0:15:31.02,Italics,Naoya,0,0,0,,‫لكن ما ذاك الشيء الذي بجانبه؟
Dialogue: 0,0:15:31.02,0:15:33.40,Italics,Naoya,0,0,0,,‫أظنني سأرفع السرعة أكثر بقليل.
Dialogue: 0,0:15:39.55,0:15:42.12,Italics,Yuji,0,0,0,,‫غوجو-سينسي؟! لا!
Dialogue: 0,0:15:42.12,0:15:44.03,Italics,Yuji,0,0,0,,‫هذا مخيف أكثر!
Dialogue: 0,0:15:51.06,0:15:53.97,Main,Okkotsu,0,0,0,,‫ماذا؟ لستَ وحدك.
Dialogue: 0,0:15:59.97,0:16:00.59,Main,Yuji,0,0,0,,‫من أنت؟
Dialogue: 0,0:16:00.96,0:16:02.85,Italics,Choso,0,0,0,,‫أيًّا كان، هدفه هو...
Dialogue: 0,0:16:03.21,0:16:05.23,Main,Okkotsu,0,0,0,,‫ما علاقتكما
Dialogue: 0,0:16:05.23,0:16:06.34,Main,Okkotsu,0,0,0,,‫بإيتادوري-كن؟
Dialogue: 0,0:16:06.82,0:16:09.60,Main,Choso,0,0,0,,‫إذًا أنت هنا لإعدام يوجي حقًّا.
Dialogue: 0,0:16:18.03,0:16:20.24,Main,Naoya,0,0,0,,‫مهلًا. أنا في صفّك.
Dialogue: 0,0:16:20.95,0:16:22.62,Main,Naoya,0,0,0,,‫أنت أوكّوتسو-كن، صحيح؟
Dialogue: 0,0:16:22.84,0:16:24.18,Italics,Yuji,0,0,0,,‫أوكّوتسو!
Dialogue: 0,0:16:24.18,0:16:26.34,Italics,Yuji,0,0,0,,‫تلميذ السنة الثانية الذي ذكره فوشيغورو!
Dialogue: 0,0:16:26.34,0:16:29.62,Italics,Yuji,0,0,0,,‫مستعمل جوجيتسو من الدرجة\N‫الخاصة مثل غوجو-سينسي!
Dialogue: 0,0:16:29.62,0:16:30.87,Main,Okkotsu,0,0,0,,‫ومن أنت؟
Dialogue: 0,0:16:30.87,0:16:32.38,Main,Naoya,0,0,0,,‫أنا ناويا زينين.
Dialogue: 0,0:16:32.38,0:16:34.34,Main,Naoya,0,0,0,,‫ابن عم ماكي-تشان،
Dialogue: 0,0:16:34.34,0:16:37.20,Main,Naoya,0,0,0,,‫وقد طُلب مني قتل إيتادوري-كن مثلك تمامًا.
Dialogue: 0,0:16:37.20,0:16:38.17,Main,Choso,0,0,0,,‫سنهرب يا يوجي.
Dialogue: 0,0:16:38.17,0:16:39.73,Main,Naoya,0,0,0,,‫لذا اطمئن.
Dialogue: 0,0:16:39.73,0:16:41.26,Main,Naoya,0,0,0,,‫لن أعيقك.
Dialogue: 0,0:16:41.26,0:16:43.98,Main,Choso,0,0,0,,‫الأشقر من النوع السريع \N‫ولديه خدعة ما.
Dialogue: 0,0:16:43.98,0:16:46.14,Main,Choso,0,0,0,,‫علينا تجنب المطاردة.
Dialogue: 0,0:16:46.50,0:16:48.02,Main,Choso,0,0,0,,‫سأبطئه.
Dialogue: 0,0:16:48.02,0:16:49.39,Main,Yuji,0,0,0,,‫هل ستكون بخير؟
Dialogue: 0,0:16:49.39,0:16:52.21,Main,Naoya,0,0,0,,‫في المقابل، بعد أن تقتل إيتادوري-كن،
Dialogue: 0,0:16:52.21,0:16:55.18,Main,Naoya,0,0,0,,‫هل يمكنك تأجيل إبلاغهم قليلًا؟
Dialogue: 0,0:16:55.18,0:16:57.72,Main,Naoya,0,0,0,,‫أريد استخدامه كطُعم لألتقي شخصًا ما.
Dialogue: 0,0:16:57.72,0:16:59.10,Main,Choso,0,0,0,,‫سأكون بخير.
Dialogue: 0,0:16:59.10,0:17:01.69,Main,Choso,0,0,0,,‫أنت هدفهما يا يوجي.
Dialogue: 0,0:17:01.69,0:17:03.50,Main,Choso,0,0,0,,‫ذو الشعر الأسود ذاك...
Dialogue: 0,0:17:03.50,0:17:05.84,Main,Choso,0,0,0,,‫أوكّوتسو. ركّز فقط على الهرب منه.
Dialogue: 0,0:17:06.37,0:17:08.76,Main,Choso,0,0,0,,‫يبدو من نفس نوع ساتورو غوجو.
Dialogue: 0,0:17:08.76,0:17:10.54,Main,Choso,0,0,0,,‫ستُقتل إن قاتلته.
Dialogue: 0,0:17:10.54,0:17:13.47,Italics,Naoya,0,0,0,,‫لم يكن عليّ ذكر ميغومي-كن.
Dialogue: 0,0:17:13.47,0:17:14.79,Italics,Naoya,0,0,0,,‫لقد جعلني أرتجف.
Dialogue: 0,0:17:14.79,0:17:17.30,Italics,Choso,0,0,0,,‫إنه مخطط يمنع يوجي \N‫من قتال إنسان آخر
Dialogue: 0,0:17:17.30,0:17:20.24,Italics,Choso,0,0,0,,‫ويمنعه من الشعور بالذنب تجاهي.
Dialogue: 0,0:17:21.39,0:17:23.35,Italics,Choso,0,0,0,,‫إنه حقًا مشكلة.
Dialogue: 0,0:17:23.35,0:17:25.43,Main,Choso,0,0,0,,‫سنلتقي في موقع الأمس!
Dialogue: 0,0:17:25.43,0:17:26.71,Main,Okkotsu,0,0,0,,‫موافق.
Dialogue: 0,0:17:26.71,0:17:28.56,Main,Okkotsu,0,0,0,,‫سأترك ذاك لك إذًا.
Dialogue: 0,0:17:28.56,0:17:29.37,Main,Yuji,0,0,0,,‫نعم!
Dialogue: 0,0:17:31.93,0:17:32.83,Italics,Yuji,0,0,0,,‫إنه سريع!
Dialogue: 0,0:17:32.83,0:17:34.85,Italics,Yuji,0,0,0,,‫هل هو بهذه السرعة وسيفه مسحوب؟!
Dialogue: 0,0:17:36.44,0:17:37.80,Italics,Okkotsu,0,0,0,,‫إنه سريع.
Dialogue: 0,0:17:37.80,0:17:40.07,Italics,Okkotsu,0,0,0,,‫خطّطت أن أسحقه عندما يبدأ بالجري.
Dialogue: 0,0:17:41.05,0:17:44.66,Italics,Choso,0,0,0,,‫كنت أحاول سد طريق أوكّوتسو، لكنّه فهم نواياي!
Dialogue: 0,0:17:44.66,0:17:46.81,Main,Naoya,0,0,0,,‫كنت أشاهد سابقًا.
Dialogue: 0,0:17:46.81,0:17:49.12,Main,Naoya,0,0,0,,‫هذا تلاعب بالدّم، أليس كذلك؟
Dialogue: 0,0:17:49.12,0:17:52.31,Main,Naoya,0,0,0,,‫لكني لا أعلم لمَ تملكه.
Dialogue: 0,0:17:52.31,0:17:55.07,Main,Naoya,0,0,0,,‫ومع ذلك فهو ليس مخيفًا باستثناء الدّم الثاقب.
Dialogue: 0,0:17:55.07,0:17:57.91,Main,Naoya,0,0,0,,‫وإطلاق الدّم الثاقب يتطّلب التّقارب.
Dialogue: 0,0:17:57.91,0:17:59.63,Main,Naoya,0,0,0,,‫له وقت تجهيز طويل.
Dialogue: 0,0:17:59.63,0:18:01.60,Main,Naoya,0,0,0,,‫لا أحتاج أن أقول المزيد، أليس كذلك؟
Dialogue: 0,0:18:01.60,0:18:02.66,Main,Naoya,0,0,0,,‫مات الشّاه.
Dialogue: 0,0:18:02.66,0:18:04.13,Main,Naoya,0,0,0,,‫ستموت.
Dialogue: 0,0:18:04.33,0:18:06.08,Main,Choso,0,0,0,,‫بل أنت من سيموت.
Dialogue: 0,0:18:06.08,0:18:08.30,Main,Choso,0,0,0,,‫أتظنّ أنّ بإمكانك استهداف أخي الصغير
Dialogue: 0,0:18:08.30,0:18:11.12,Main,Choso,0,0,0,,‫والمغادرة حيًّا؟
Dialogue: 0,0:18:32.54,0:18:35.08,Italics,Okkotsu,0,0,0,,‫أنا متأكد أنني قطعته أيضًا.
Dialogue: 0,0:18:35.08,0:18:36.65,Italics,Okkotsu,0,0,0,,‫إنه مثل ماكي-سان.
Dialogue: 0,0:18:58.27,0:18:59.67,Main,Okkotsu,0,0,0,,‫هل تفاجأت؟
Dialogue: 0,0:19:00.02,0:19:02.32,Main,Okkotsu,0,0,0,,‫لا أبدو من النوع القوي، أليس كذلك؟
Dialogue: 0,0:19:02.32,0:19:04.32,Italics,Yuji,0,0,0,,‫حتى بدون قوة جسدية،
Dialogue: 0,0:19:04.66,0:19:06.79,Italics,Yuji,0,0,0,,‫لديه كمية هائلة من الطاقة الملعونة!
Dialogue: 0,0:19:06.79,0:19:08.95,Main,Okkotsu,0,0,0,,‫أنا في الحقيقة من النوع الأضعف جسديًا.
Dialogue: 0,0:19:08.95,0:19:12.11,Italics,Yuji,0,0,0,,‫إنه يعوّض نقص قوته الجسدية\N‫بتعزيز نفسه بالطاقة الملعونة.
Dialogue: 0,0:19:12.11,0:19:15.29,Italics,Yuji,0,0,0,,‫يفعل الجميع ذلك إلى حدّ ما، لكن عندما يفعل ذلك هو...
Dialogue: 0,0:19:15.29,0:19:17.23,Main,Yuji,0,0,0,,‫عكسي تمامًا إذًا.
Dialogue: 0,0:19:19.67,0:19:21.21,Main,Okkotsu,0,0,0,,‫هل لاحظت؟
Dialogue: 0,0:19:21.21,0:19:24.23,Main,Okkotsu,0,0,0,,‫لدي طاقة ملعونة \N‫أكثر حتى من غوجو-سينسي.
Dialogue: 0,0:19:25.59,0:19:28.24,Main,Okkotsu,0,0,0,,‫لكن سينسي يمتلك عيونه الست،
Dialogue: 0,0:19:28.24,0:19:30.93,Main,Okkotsu,0,0,0,,‫لذا هو لا يهدر أي طاقة تقريبًا
Dialogue: 0,0:19:30.93,0:19:32.83,Main,Okkotsu,0,0,0,,‫عند تفعيل تقنيته.
Dialogue: 0,0:19:33.55,0:19:36.81,Main,Okkotsu,0,0,0,,‫إنه الأفضل فيما يتعلّق بالأداء.
Dialogue: 0,0:19:37.02,0:19:39.16,Main,Okkotsu,0,0,0,,‫يمكن أن تنفد الطاقة الملعونة مني،
Dialogue: 0,0:19:39.16,0:19:40.75,Main,Okkotsu,0,0,0,,‫لكن سينسي لا.
Dialogue: 0,0:19:41.89,0:19:43.79,Main,Okkotsu,0,0,0,,‫كفى حديثًا.
Dialogue: 0,0:19:49.36,0:19:50.23,Italics,Yuji,0,0,0,,‫اللعنة!
Dialogue: 0,0:19:50.23,0:19:51.84,Flashback_Italics,Todo,0,0,0,,‫كلما كان مستعمل الجوجيتسو أفضل،
Dialogue: 0,0:19:51.84,0:19:54.22,Flashback_Italics,Todo,0,0,0,,‫زادت صعوبة قراءة تدفق طاقته الملعونة.
Dialogue: 0,0:19:54.22,0:19:56.20,Flashback_Italics,Todo,0,0,0,,{\an8}‫ولسبب مختلف عنك.
Dialogue: 0,0:19:56.16,0:19:59.66,Sign_Basic,Text,0,0,0,,{\fs16\b1\bord2\shad0\pos(332,158)\c&H5D3842&\3c&HF7C6E6&}‫درجة ثالثة
Dialogue: 0,0:19:56.17,0:19:59.67,Sign_Basic,Text,0,0,0,,{\pos(320,315)\fs20\bord0\shad0}‫عندما يكون مستعمل جوجيتسو غرًّا في التلاعب بالطاقة الملعونة، هناك انحراف\N‫في الطاقة الملعونة خلال تحركاته الأولية ما يسمح بتوقع حركته التالية
Dialogue: 0,0:19:56.20,0:19:57.80,Italics,Yuji,0,0,0,,{\an8}‫هذا لأنّ كلّما كان مستعمل جوجيتسو أفضل،
Dialogue: 0,0:19:57.80,0:19:59.85,Italics,Yuji,0,0,0,,{\an8}‫زادت دقّة تلاعبه بالطاقة الملعونة.
Dialogue: 0,0:19:59.67,0:20:02.92,Sign_Basic,Text,0,0,0,,{\pos(320,315)\fs20\bord0\shad0}‫عندما يتقن التلاعب بالطاقة الملعونة، لا يكون هناك ذلك الانحراف\N‫في الطاقة الملعونة ما يصعّب توقع حركته حتى اللحظة الأخيرة
Dialogue: 0,0:19:59.67,0:20:02.92,Sign_Basic,Text,0,0,0,,{\fs16\b1\bord2\shad0\c&H160F10&\3c&HE6AF21&\pos(313.333,171.333)}‫درجة أولى
Dialogue: 0,0:19:59.85,0:20:03.17,Italics,Yuji,0,0,0,,{\an8}‫هذا يعني أنّك لا تستطيع التنبؤ\N‫بهجومه إلّا في اللّحظة الأخيرة.
Dialogue: 0,0:20:04.80,0:20:06.21,Italics,Yuji,0,0,0,,‫لكن مع هذا الرجل...
Dialogue: 0,0:20:06.21,0:20:10.47,Italics,Yuji,0,0,0,,‫هناك طاقة ملعونة تتصاعد باستمرار\N‫من كل جسده، حتى سيفه!
Dialogue: 0,0:20:10.47,0:20:13.12,Italics,Yuji,0,0,0,,‫ليس الأمر مسألة قراءة حركاته!
Dialogue: 0,0:20:13.51,0:20:16.22,Italics,Yuji,0,0,0,,‫كل هجماته يمكن أن تكون \N‫ضربات حاسمة،
Dialogue: 0,0:20:16.22,0:20:19.48,Italics,Yuji,0,0,0,,‫ويمكنه تقليل كل الضرر لأدنى حد!
Dialogue: 0,0:20:19.77,0:20:21.23,Flashback,Nanami,0,0,0,,‫تولى الأمر الآن.
Dialogue: 0,0:20:21.93,0:20:25.73,Main,Yuji,0,0,0,,‫آسف، لكن لا يمكنني الموت بعد!
Dialogue: 0,0:20:33.26,0:20:34.78,Flashback,Gojo,0,0,0,,‫هناك بعض الأشخاص
Dialogue: 0,0:20:34.78,0:20:37.58,Flashback,Gojo,0,0,0,,‫الذين يركزون تدريبهم على استخدام السلاح،
Dialogue: 0,0:20:38.91,0:20:41.57,Flashback,Gojo,0,0,0,,‫لكن لا يجب أن تعتمد على أداة ملعونة
Dialogue: 0,0:20:41.57,0:20:43.42,Flashback,Gojo,0,0,0,,‫وتهمل مهارتك في التلاعب بالطاقة الملعونة.
Dialogue: 0,0:20:43.42,0:20:45.92,Flashback,Gojo,0,0,0,,‫لكن لا يزال ذلك بعيدًا عن مستواك.
Dialogue: 0,0:20:47.00,0:20:49.30,Flashback,Gojo,0,0,0,,‫إذًا شيطان الذّبح مجرد إجراء طوارئ.
Dialogue: 0,0:20:50.05,0:20:51.80,Italics,Yuji,0,0,0,,‫لم تعلمني ذلك قطّ!
Dialogue: 0,0:20:53.71,0:20:56.14,Main,Okkotsu,0,0,0,,‫أنت تضع تركيزًا كبيرًا على النصل.
Dialogue: 0,0:21:03.98,0:21:04.98,Italics,Okkotsu,0,0,0,,‫انكسر؟
Dialogue: 0,0:21:05.57,0:21:06.94,Italics,Okkotsu,0,0,0,,‫بالطبع سينكسر.
Dialogue: 0,0:21:06.94,0:21:08.90,Italics,Okkotsu,0,0,0,,‫إنه أحد تلاميذ غوجو-سينسي.
Dialogue: 0,0:21:08.90,0:21:11.15,Main,Okkotsu,0,0,0,,‫يبدو أنّك لن تسقط بسهولة.
Dialogue: 0,0:21:11.66,0:21:12.78,Italics,Yuji,0,0,0,,‫الجرح عميق!
Dialogue: 0,0:21:12.78,0:21:14.47,Italics,Yuji,0,0,0,,‫لكن أعضائي لا تتساقط!
Dialogue: 0,0:21:14.47,0:21:16.22,Italics,Yuji,0,0,0,,‫والآن كلانا بلا سلاح!
Dialogue: 0,0:21:16.22,0:21:17.14,Italics,Yuji,0,0,0,,‫يمكنني الفوز!
Dialogue: 0,0:21:22.58,0:21:25.78,Main,Rika,0,0,0,,‫ماذا تفعل؟
Dialogue: 0,0:21:28.88,0:21:31.70,Main,Okkotsu,0,0,0,,‫نحن نلعب فقط يا ريكا-تشان.
Dialogue: 0,0:21:32.68,0:21:34.87,Italics,Yuji,0,0,0,,‫"ريكا"؟! ما هذا الشيء؟!
Dialogue: 0,0:21:34.87,0:21:36.01,Italics,Yuji,0,0,0,,‫شيكيغامي؟!
Dialogue: 0,0:21:36.01,0:21:37.68,Italics,Yuji,0,0,0,,‫من أين جاء؟!
Dialogue: 0,0:21:39.14,0:21:40.56,Main,Okkotsu,0,0,0,,‫أمسكيه جيدًا.
Dialogue: 0,0:21:41.27,0:21:42.31,Italics,Yuji,0,0,0,,‫لا أستطيع الحركة!
Dialogue: 0,0:21:44.77,0:21:46.56,Italics,Yuji,0,0,0,,‫يا لها من قوة!
Dialogue: 0,0:21:53.90,0:21:55.10,Main,Okkotsu,0,0,0,,‫أنا آسف
Dialogue: 0,0:22:01.95,0:22:03.50,Main,Okkotsu,0,0,0,,‫يا إيتادوري-كن.
Dialogue: 0,0:23:40.28,0:23:42.95,Main,Naoya,0,0,0,,‫الإخوة الكبار الأقل كفاءة من أخ أصغر لا قيمة لهم.
Dialogue: 0,0:23:42.95,0:23:45.61,Main,Choso,0,0,0,,‫...لا أفهم كيف لا يمكن أن تحب إخوتك أبدًا
Dialogue: 0,0:23:45.61,0:23:46.74,Main,Okkotsu,0,0,0,,‫...أبلغ بموت إيتادوري-كن رجاءً...
Dialogue: 0,0:23:46.74,0:23:49.44,Main,Tsukumo,0,0,0,,‫...قد تكون كل التشوهات\N‫بدأت منذ ذلك الحين.
Dialogue: 0,0:23:49.44,0:23:50.45,Main,Naoya,0,0,0,,‫لا تنظر إليّ باستخفاف!
Dialogue: 0,0:23:50.45,0:23:51.41,Main,Fushiguro,0,0,0,,‫لذا ابدأ بإنقاذي...
Dialogue: 0,0:23:51.41,0:23:52.07,Main,Choso,0,0,0,,‫مات الشّاه.
Dialogue: 0,0:23:52.07,0:23:54.58,Main,Fushiguro,0,0,0,,‫جُرّت تسوميكي إلى هذه اللعبة أيضًا.
Dialogue: 0,0:23:51.99,0:23:55.02,Next_Ep_Title,Screen,0,0,0,,{\c&HFFFFFF&}‫الحلقة القادمة\N{\fs36}‫مرة أخرى

